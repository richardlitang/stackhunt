---
/**
 * DynamicSpecs - Display category-specific and VIP tool-specific data
 *
 * Renders fields dynamically based on what's available:
 * - categorySpecificData: Fields based on tool category (e.g., CI/CD minutes)
 * - specifics: VIP tool-specific fields (e.g., Copilot integration for GitHub)
 *
 * Automatically hides sections with no data.
 */

interface Props {
  categorySpecificData?: Record<string, unknown>;
  specifics?: Record<string, unknown>;
  toolName: string;
  categoryName?: string;
}

const { categorySpecificData, specifics, toolName, categoryName } = Astro.props;

// Helper to format field keys nicely
function formatLabel(key: string): string {
  return key
    .replace(/_/g, ' ')
    .replace(/([a-z])([A-Z])/g, '$1 $2')
    .replace(/\b\w/g, (c) => c.toUpperCase());
}

// Helper to format values based on type
function formatValue(value: unknown): string {
  if (value === null || value === undefined) return '-';
  if (typeof value === 'boolean') return value ? 'Yes' : 'No';
  if (typeof value === 'number') return value.toLocaleString();
  if (Array.isArray(value)) return value.join(', ') || '-';
  if (typeof value === 'string') return value || '-';
  if (typeof value === 'object') return JSON.stringify(value);
  return String(value);
}

// Helper to get icon based on value type/content
function getIcon(key: string, value: unknown): string | null {
  // Boolean checks
  if (typeof value === 'boolean') {
    return value ? 'check' : 'x';
  }
  // Common field patterns
  if (key.includes('api') || key.includes('sdk')) return 'code';
  if (key.includes('limit') || key.includes('quota')) return 'meter';
  if (key.includes('storage') || key.includes('backup')) return 'database';
  if (key.includes('security') || key.includes('encryption')) return 'shield';
  if (key.includes('integration') || key.includes('connect')) return 'plug';
  if (key.includes('support') || key.includes('sla')) return 'headset';
  if (key.includes('price') || key.includes('cost') || key.includes('fee')) return 'dollar';
  if (key.includes('time') || key.includes('speed') || key.includes('minutes')) return 'clock';
  if (key.includes('user') || key.includes('member') || key.includes('seat')) return 'users';
  return null;
}

// Filter out null/undefined values and internal fields
function filterFields(data: Record<string, unknown> | undefined): [string, unknown][] {
  if (!data) return [];
  return Object.entries(data).filter(([key, value]) => {
    // Skip null/undefined
    if (value === null || value === undefined) return false;
    // Skip internal fields
    if (key.startsWith('_')) return false;
    // Skip empty arrays
    if (Array.isArray(value) && value.length === 0) return false;
    // Skip empty strings
    if (typeof value === 'string' && !value.trim()) return false;
    return true;
  });
}

const categoryFields = filterFields(categorySpecificData);
const vipFields = filterFields(specifics);

const hasData = categoryFields.length > 0 || vipFields.length > 0;
---

{
  hasData && (
    <details
      class="group rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
      open
    >
      <summary class="flex items-center justify-between cursor-pointer md:pointer-events-none">
        <div>
          <h2 class="text-lg font-semibold text-zinc-100">Technical Specs</h2>
          <p class="mt-1 text-sm text-zinc-400">
            {categoryName
              ? `${categoryName}-specific details`
              : `Detailed specifications for ${toolName}`}
          </p>
        </div>
        <svg
          class="h-5 w-5 text-zinc-400 transition-transform group-open:rotate-90 md:hidden shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </summary>

      <div class="mt-6 space-y-6">
        {/* Category-Specific Fields */}
        {categoryFields.length > 0 && (
          <div>
            {categoryName && (
              <h3 class="text-sm font-medium text-zinc-400 mb-3 flex items-center gap-2">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
                  />
                </svg>
                {categoryName} Details
              </h3>
            )}
            <dl class="grid gap-3 sm:grid-cols-2">
              {categoryFields.map(([key, value]) => {
                const icon = getIcon(key, value);
                const isBool = typeof value === 'boolean';
                return (
                  <div
                    class:list={[
                      'flex items-start gap-3 rounded-lg border border-zinc-800 bg-zinc-800/50 p-3',
                      isBool && value && 'border-green-800/50 bg-green-900/20',
                      isBool && !value && 'border-zinc-800 bg-zinc-800/30',
                    ]}
                  >
                    {icon === 'check' && (
                      <svg
                        class="h-5 w-5 text-green-500 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                    )}
                    {icon === 'x' && (
                      <svg
                        class="h-5 w-5 text-zinc-500 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M6 18L18 6M6 6l12 12"
                        />
                      </svg>
                    )}
                    {icon === 'code' && (
                      <svg
                        class="h-5 w-5 text-blue-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"
                        />
                      </svg>
                    )}
                    {icon === 'meter' && (
                      <svg
                        class="h-5 w-5 text-amber-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
                        />
                      </svg>
                    )}
                    {icon === 'database' && (
                      <svg
                        class="h-5 w-5 text-purple-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"
                        />
                      </svg>
                    )}
                    {icon === 'shield' && (
                      <svg
                        class="h-5 w-5 text-green-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
                        />
                      </svg>
                    )}
                    {icon === 'plug' && (
                      <svg
                        class="h-5 w-5 text-cyan-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
                        />
                      </svg>
                    )}
                    {icon === 'clock' && (
                      <svg
                        class="h-5 w-5 text-sky-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                    )}
                    {icon === 'users' && (
                      <svg
                        class="h-5 w-5 text-indigo-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"
                        />
                      </svg>
                    )}
                    {icon === 'dollar' && (
                      <svg
                        class="h-5 w-5 text-emerald-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                    )}
                    {!icon && (
                      <svg
                        class="h-5 w-5 text-zinc-500 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                        />
                      </svg>
                    )}
                    <div class="min-w-0 flex-1">
                      <dt class="text-xs text-zinc-400">{formatLabel(key)}</dt>
                      <dd
                        class:list={[
                          'text-sm font-medium mt-0.5',
                          isBool && value && 'text-green-400',
                          isBool && !value && 'text-zinc-500',
                          !isBool && 'text-zinc-200',
                        ]}
                      >
                        {formatValue(value)}
                      </dd>
                    </div>
                  </div>
                );
              })}
            </dl>
          </div>
        )}

        {/* VIP Tool-Specific Fields */}
        {vipFields.length > 0 && (
          <div>
            <h3 class="text-sm font-medium text-zinc-400 mb-3 flex items-center gap-2">
              <svg
                class="h-4 w-4 text-amber-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"
                />
              </svg>
              {toolName} Specifics
            </h3>
            <dl class="grid gap-3 sm:grid-cols-2">
              {vipFields.map(([key, value]) => {
                const icon = getIcon(key, value);
                const isBool = typeof value === 'boolean';
                return (
                  <div
                    class:list={[
                      'flex items-start gap-3 rounded-lg border border-amber-800/30 bg-amber-900/10 p-3',
                      isBool && value && 'border-green-800/50 bg-green-900/20',
                      isBool && !value && 'border-zinc-800 bg-zinc-800/30',
                    ]}
                  >
                    {icon === 'check' && (
                      <svg
                        class="h-5 w-5 text-green-500 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                    )}
                    {icon === 'x' && (
                      <svg
                        class="h-5 w-5 text-zinc-500 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M6 18L18 6M6 6l12 12"
                        />
                      </svg>
                    )}
                    {!icon && (
                      <svg
                        class="h-5 w-5 text-amber-400 shrink-0 mt-0.5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M13 10V3L4 14h7v7l9-11h-7z"
                        />
                      </svg>
                    )}
                    <div class="min-w-0 flex-1">
                      <dt class="text-xs text-zinc-400">{formatLabel(key)}</dt>
                      <dd
                        class:list={[
                          'text-sm font-medium mt-0.5',
                          isBool && value && 'text-green-400',
                          isBool && !value && 'text-zinc-500',
                          !isBool && 'text-amber-200',
                        ]}
                      >
                        {formatValue(value)}
                      </dd>
                    </div>
                  </div>
                );
              })}
            </dl>
          </div>
        )}
      </div>
    </details>
  )
}
