---
import InfoCardsGrid from '@/components/InfoCardsGrid.astro';

interface Props {
  decisionText: string;
  bestFor: string;
  tradeoff: string;
  isCurated: boolean;
  checkedLabel?: string | null;
}

const { decisionText, bestFor, tradeoff, isCurated, checkedLabel = null } = Astro.props as Props;
---

<section id="verdict" class="mb-10 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">Decision</p>
  <h2 class="mt-2 text-lg font-semibold text-zinc-100">{decisionText}</h2>
  <InfoCardsGrid
    className="mt-4 grid gap-3 md:grid-cols-2"
    cards={[
      { title: 'Best for', body: bestFor },
      { title: 'Tradeoff', body: tradeoff },
    ]}
    titleClassName="text-xs font-semibold uppercase tracking-wide text-zinc-400"
    bodyClassName="mt-2 text-sm text-zinc-200"
  />
  <p class="mt-3 text-xs text-zinc-500">
    {isCurated ? 'Curated editorial comparison' : 'Editorial comparison'} • Last checked{' '}
    {checkedLabel || 'unknown'}
  </p>
</section>
