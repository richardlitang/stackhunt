---
import type { ToolPageFitMatrix } from '@/types/tool-page-blueprint';

interface Props {
  fitMatrix: ToolPageFitMatrix;
}

const { fitMatrix } = Astro.props;

const rows: Array<{ label: string; row: ToolPageFitMatrix['solo'] }> = [
  { label: 'Solo', row: fitMatrix.solo },
  { label: 'Startup', row: fitMatrix.startup },
  { label: 'Mid-market', row: fitMatrix.midMarket },
  { label: 'Enterprise', row: fitMatrix.enterprise },
];

function fitToneClass(fit: 'weak' | 'mixed' | 'strong'): string {
  if (fit === 'strong') return 'text-emerald-300 border-emerald-700/60 bg-emerald-950/20';
  if (fit === 'mixed') return 'text-amber-200 border-amber-700/60 bg-amber-950/20';
  return 'text-rose-200 border-rose-700/60 bg-rose-950/20';
}
---

<section id="fit-matrix" class="mb-8 rounded-2xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
  <h2 class="text-lg font-semibold text-zinc-100">Fit matrix by buyer type</h2>
  <p class="mt-1 text-sm text-zinc-400">
    Use this to pressure-test fit before deeper rollout and procurement work.
  </p>
  <div class="mt-4 space-y-3">
    {
      rows.map((entry) =>
        entry.row ? (
          <article class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-3">
            <div class="flex flex-wrap items-center gap-2">
              <h3 class="text-sm font-semibold text-zinc-100">{entry.label}</h3>
              <span
                class={`rounded-full border px-2 py-0.5 text-[11px] uppercase tracking-wide ${fitToneClass(entry.row.fit)}`}
              >
                {entry.row.fit}
              </span>
            </div>
            {entry.row.reason && <p class="mt-2 text-sm text-zinc-300">{entry.row.reason}</p>}
            {entry.row.caveat && (
              <p class="mt-1 text-xs text-zinc-500">Caveat: {entry.row.caveat}</p>
            )}
          </article>
        ) : null
      )
    }
  </div>
</section>
