---
import type { ToolPageFitMatrix } from '@/types/tool-page-blueprint';

interface Props {
  fitMatrix: ToolPageFitMatrix;
}

const { fitMatrix } = Astro.props;

const rows: Array<{ label: string; row: ToolPageFitMatrix['solo'] }> = [
  { label: 'Solo', row: fitMatrix.solo },
  { label: 'Startup', row: fitMatrix.startup },
  { label: 'Mid-market', row: fitMatrix.midMarket },
  { label: 'Enterprise', row: fitMatrix.enterprise },
];
const visibleRows = rows.filter(
  (entry): entry is { label: string; row: NonNullable<ToolPageFitMatrix['solo']> } =>
    Boolean(entry.row)
);

function fitToneClass(fit: 'weak' | 'mixed' | 'strong'): string {
  if (fit === 'strong') return 'text-emerald-200 border-emerald-700/50 bg-emerald-950/30';
  if (fit === 'mixed') return 'text-amber-200 border-amber-700/50 bg-amber-950/30';
  return 'text-rose-200 border-rose-700/50 bg-rose-950/30';
}

function fitLabel(fit: 'weak' | 'mixed' | 'strong'): string {
  if (fit === 'strong') return 'Strong fit';
  if (fit === 'mixed') return 'Conditional fit';
  return 'Weak fit';
}
---

{
  visibleRows.length > 0 && (
    <section id="fit-matrix" class="mb-10">
      <h2 class="tool-review-section-title text-3xl">Market fit matrix</h2>
      <p class="mt-2 max-w-2xl text-sm text-zinc-400">
        Segment-level fit signal. Strong fit means low rollout friction, conditional fit means
        specific caveats matter, weak fit means likely blocker risk.
      </p>
      <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
        {visibleRows.map((entry) => (
          <article class="tool-review-panel-muted rounded-[1.35rem] p-5 transition duration-200 hover:-translate-y-0.5 hover:border-zinc-700">
            <div class="flex flex-wrap items-start justify-between gap-3">
              <h3 class="font-headline text-lg font-bold tracking-tight text-zinc-50">
                {entry.label}
              </h3>
              <span
                class={`rounded-md border px-2 py-1 text-[10px] font-bold uppercase tracking-[0.18em] ${fitToneClass(entry.row.fit)}`}
              >
                {fitLabel(entry.row.fit)}
              </span>
            </div>
            {entry.row.reason && (
              <p class="mt-4 text-sm leading-6 text-zinc-300">{entry.row.reason}</p>
            )}
            {entry.row.caveat && (
              <p class="mt-4 border-t border-zinc-800 pt-4 text-xs leading-5 text-zinc-500">
                {entry.label} caveat: {entry.row.caveat}
              </p>
            )}
          </article>
        ))}
      </div>
    </section>
  )
}
