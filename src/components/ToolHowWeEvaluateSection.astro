---
import TwoColumnChecklistCards from '@/components/TwoColumnChecklistCards.astro';

interface Props {
  hasCollectedSources: boolean;
  testedItems: string[];
  notTestedItems: string[];
}

const { hasCollectedSources, testedItems, notTestedItems } = Astro.props as Props;
---

<details
  id="how-we-evaluate"
  class="group tool-review-panel mt-12 rounded-[1.8rem] p-6 shadow-sm"
  data-focus-target
  data-focus-groups="all trust"
>
  <summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-3">
    <h2 class="tool-review-section-title text-3xl">How We Evaluated</h2>
  </summary>
  <div class="mt-3">
    <p class="text-sm text-zinc-400">
      {
        hasCollectedSources
          ? 'Claims are linked to the sources used for this review.'
          : 'The review scope and test coverage are documented below.'
      }
    </p>
    <TwoColumnChecklistCards
      left={{ title: 'What we tested for this review', items: testedItems }}
      right={{ title: 'Not tested', items: notTestedItems }}
    />
    <p class="mt-4 text-xs text-zinc-500">
      Source policy: high confidence requires official docs/pricing plus corroborating evidence for
      key claims.
    </p>
    <p class="mt-2 text-xs text-zinc-500">
      See{' '}
      <a href="/methodology" class="text-hunt-500 hover:text-hunt-400"> methodology </a>{' '}
      and{' '}
      <a href="/disclosure" class="text-hunt-500 hover:text-hunt-400"> disclosures </a>
      .
    </p>
  </div>
</details>
