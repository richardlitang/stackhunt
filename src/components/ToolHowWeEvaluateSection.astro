---
import TwoColumnChecklistCards from '@/components/TwoColumnChecklistCards.astro';

interface Props {
  evaluationDepth: string;
  hasCollectedSources: boolean;
  testedItems: string[];
  notTestedItems: string[];
}

const { evaluationDepth, hasCollectedSources, testedItems, notTestedItems } = Astro.props as Props;
---

<details
  id="how-we-evaluate"
  class="group mt-12 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm"
  data-focus-target
  data-focus-groups="all trust"
>
  <summary class="flex cursor-pointer list-none flex-wrap items-center justify-between gap-3">
    <h2 class="text-lg font-semibold text-zinc-100">How We Evaluated</h2>
    <span
      class="rounded-full border border-zinc-700 bg-zinc-800/90 px-2.5 py-1 text-xs text-zinc-300"
    >
      Evaluation depth: {evaluationDepth}
    </span>
  </summary>
  <div class="mt-3">
    <p class="text-sm text-zinc-400">
      {
        hasCollectedSources
          ? 'Verified against linked sources means each claim appears in a linked source on the date checked. Vendors can update details after that date.'
          : 'No qualifying sources collected yet. Some claims remain in verification mode until section-level sources are attached.'
      }
    </p>
    <TwoColumnChecklistCards
      left={{ title: 'What we tested for this review', items: testedItems }}
      right={{ title: 'Not tested', items: notTestedItems }}
    />
    <p class="mt-4 text-xs text-zinc-500">
      Source policy: high confidence requires official docs/pricing plus corroborating evidence for
      key claims.
    </p>
    <p class="mt-2 text-xs text-zinc-500">
      See{' '}
      <a href="/methodology" class="text-hunt-500 hover:text-hunt-400"> methodology </a>{' '}
      and{' '}
      <a href="/disclosure" class="text-hunt-500 hover:text-hunt-400"> disclosures </a>
      .
    </p>
  </div>
</details>
