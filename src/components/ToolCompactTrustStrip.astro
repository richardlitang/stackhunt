---
interface Props {
  status: 'Source-backed' | 'Needs confirmation' | 'Needs recheck';
  confidence: 'High' | 'Medium' | 'Low';
  lastChecked?: string | null;
}

const { status, confidence, lastChecked = null } = Astro.props;
---

<div class="tool-review-panel-muted rounded-2xl px-4 py-3 text-xs text-zinc-300">
  <div class="group relative inline-flex max-w-full flex-col">
    <button
      type="button"
      class="inline-flex items-center gap-2 rounded-full border border-amber-700/40 bg-amber-950/20 px-3 py-1.5 text-xs font-medium text-amber-200 transition hover:border-amber-600/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-amber-400/60"
      aria-describedby="review-status-tooltip"
    >
      <span>{status}</span>
      <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path
          d="M10 18a8 8 0 1 1 0-16 8 8 0 0 1 0 16Zm0-11a1 1 0 0 0-1 1v4a1 1 0 1 0 2 0V8a1 1 0 0 0-1-1Zm0-3a1.25 1.25 0 1 0 0 2.5A1.25 1.25 0 0 0 10 4Z"
        ></path>
      </svg>
    </button>
    <div
      id="review-status-tooltip"
      role="tooltip"
      class="pointer-events-none absolute left-0 top-[calc(100%+0.5rem)] z-20 hidden w-72 rounded-xl border border-zinc-700 bg-zinc-950 p-3 text-xs text-zinc-300 shadow-lg group-hover:block group-focus-within:block"
    >
      <p>
        <span class="text-zinc-500">Confidence:</span>
        {confidence}
      </p>
      <p>
        <span class="text-zinc-500">Last checked:</span>
        {lastChecked || 'unknown'}
      </p>
      {
        status !== 'Source-backed' && (
          <p class="mt-2 text-zinc-400">
            Early snapshot, validate plan-gated claims in a live demo before switching.
          </p>
        )
      }
    </div>
  </div>
</div>
