---
interface Props {
  status: 'Source-backed' | 'Needs confirmation' | 'Needs recheck';
  confidence: 'High' | 'Medium' | 'Low';
  lastChecked?: string | null;
}

const { status, confidence, lastChecked = null } = Astro.props;
---

<div class="tool-review-panel-muted rounded-2xl px-4 py-3 text-xs text-zinc-300">
  <div class="flex flex-wrap items-center gap-2">
    <span class="tool-review-chip border-emerald-700/50 bg-emerald-950/30 text-emerald-200">
      {status}
    </span>
    <span class="tool-review-chip">Confidence {confidence}</span>
    <span class="tool-review-chip">Last checked {lastChecked || 'unknown'}</span>
  </div>
</div>
