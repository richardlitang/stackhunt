---
import SmartComparisonTable from '@/components/compare/SmartComparisonTable';

interface TableToolInput {
  name: string;
  slug: string;
  logo_url?: string | null;
  metadata?: Record<string, unknown> | null;
}

interface Props {
  toolA: TableToolInput;
  toolB: TableToolInput;
}

const { toolA, toolB } = Astro.props as Props;
---

<section class="mt-12">
  <h2 class="mb-6 text-xl font-semibold text-zinc-100">Detailed Feature Comparison</h2>
  <SmartComparisonTable client:load toolA={toolA} toolB={toolB} />
</section>
