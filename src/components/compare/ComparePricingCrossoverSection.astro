---
import PricingCrossoverChart from '@/components/pricing/PricingCrossoverChart';
import type { SMPPricingData } from '@/types/database';

interface ToolPricingInput {
  name: string;
  slug: string;
  pricingData: SMPPricingData | null;
}

interface Props {
  tools: [ToolPricingInput, ToolPricingInput];
}

const { tools } = Astro.props as Props;
---

<section class="mt-12">
  <p class="mb-3 text-xs text-zinc-500">
    Pricing can change frequently; confirm current plans on vendor pricing pages.
  </p>
  <PricingCrossoverChart client:load tools={tools} />
</section>
