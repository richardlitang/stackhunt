---
import Logo from '@/components/Logo.astro';

interface ChoiceColumn {
  name: string;
  logoUrl?: string | null;
  reasons: string[];
  tone: 'emerald' | 'sky';
}

interface Props {
  columns: ChoiceColumn[];
}

const { columns } = Astro.props as Props;
const validColumns = (Array.isArray(columns) ? columns : []).filter(
  (column) => column && Array.isArray(column.reasons) && column.reasons.length > 0
);

if (validColumns.length === 0) {
  return null;
}

const styles = {
  emerald: {
    wrapper: 'rounded-xl border border-emerald-500/40 bg-emerald-900/20 p-5',
    title: 'mb-3 flex items-center gap-2 font-semibold text-emerald-300',
    icon: 'h-4 w-4 mt-0.5 text-green-500 shrink-0',
  },
  sky: {
    wrapper: 'rounded-xl border border-sky-500/40 bg-sky-900/20 p-5',
    title: 'mb-3 flex items-center gap-2 font-semibold text-sky-300',
    icon: 'h-4 w-4 mt-0.5 text-blue-500 shrink-0',
  },
} as const;
---

<div class="grid gap-6 lg:grid-cols-2">
  {
    validColumns.map((column) => {
      const palette = styles[column.tone];
      return (
        <div class={palette.wrapper}>
          <h3 class={palette.title}>
            <Logo domain={column.logoUrl} name={column.name} size="sm" class="rounded-lg" />
            Choose {column.name} if...
          </h3>
          <ul class="space-y-2">
            {column.reasons.map((reason) => (
              <li class="flex items-start gap-2 text-sm text-zinc-200">
                <svg class={palette.icon} fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                    clip-rule="evenodd"
                  />
                </svg>
                {reason}
              </li>
            ))}
          </ul>
        </div>
      );
    })
  }
</div>
