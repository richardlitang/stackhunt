---
interface Props {
  status: 'Source-backed' | 'Needs confirmation' | 'Needs recheck';
  pendingCount?: number;
  evaluationDepth: 'Docs-only' | 'Light hands-on' | 'Deep hands-on';
  lastChecked?: string | null;
  confidence: 'High' | 'Medium' | 'Low';
  sourcesCount?: number;
  sourcesHref?: string;
}

const {
  status,
  pendingCount = 0,
  evaluationDepth,
  lastChecked = null,
  confidence,
  sourcesCount = 0,
  sourcesHref = '#sources',
} = Astro.props;

const statusClasses =
  status === 'Source-backed'
    ? 'border-emerald-700/40 bg-emerald-950/30 text-emerald-200'
    : status === 'Needs recheck'
      ? 'border-amber-700/40 bg-amber-950/30 text-amber-200'
      : 'border-amber-700/40 bg-amber-950/30 text-amber-200';
---

<section class="mb-8 rounded-xl border border-zinc-700 bg-zinc-900 p-4 shadow-sm">
  <div class="flex flex-wrap items-center gap-2 text-xs">
    <span class:list={['rounded-full border px-2.5 py-1 font-medium', statusClasses]}>
      Sourcing: {status}
      {pendingCount > 0 ? ` (${pendingCount} pending)` : ''}
    </span>
    <span class="rounded-full border border-zinc-700 bg-zinc-800/90 px-2.5 py-1 text-zinc-300">
      Evaluation: {evaluationDepth}
    </span>
    <span class="rounded-full border border-zinc-700 bg-zinc-800/90 px-2.5 py-1 text-zinc-300">
      Confidence: {confidence}
    </span>
    <span class="rounded-full border border-zinc-700 bg-zinc-800/90 px-2.5 py-1 text-zinc-300">
      Last checked: {lastChecked || 'Unknown'}
    </span>
    <span class="rounded-full border border-zinc-700 bg-zinc-800/90 px-2.5 py-1 text-zinc-300">
      Sources: {sourcesCount}
    </span>
  </div>
  <div class="mt-3 flex flex-wrap gap-2">
    <a
      href={sourcesHref}
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Sources
    </a>
    <a
      href="/methodology"
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Methodology
    </a>
    <a
      href="/disclosure"
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Disclosure
    </a>
  </div>
</section>
