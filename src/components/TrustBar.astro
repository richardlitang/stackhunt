---
import { resolveFreshnessLine } from '@/lib/tool-page/freshness-line';

interface Props {
  status: 'Source-backed' | 'Needs confirmation' | 'Needs recheck';
  pendingCount?: number;
  evaluationDepth: 'Docs-only' | 'Light hands-on' | 'Deep hands-on';
  lastChecked?: string | null;
  confidence: 'High' | 'Medium' | 'Low';
  sourcesCount?: number;
  sourcesHref?: string;
}

const { status, lastChecked = null, sourcesCount = 0, sourcesHref = '#sources' } = Astro.props;
const freshnessLine = resolveFreshnessLine({ lastCheckedISO: lastChecked, status });
---

<section class="mb-8 rounded-xl border border-zinc-700 bg-zinc-900 p-4 shadow-sm">
  <div class="flex flex-wrap items-center gap-3 text-xs text-zinc-300">
    {freshnessLine && <span>{freshnessLine}</span>}
    <span>{sourcesCount} sources</span>
  </div>
  <div class="mt-3 flex flex-wrap gap-2">
    <a
      href={sourcesHref}
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Sources
    </a>
    <a
      href="/methodology"
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Methodology
    </a>
    <a
      href="/disclosure"
      class="inline-flex items-center rounded-md border border-zinc-700 px-2.5 py-1.5 text-xs text-zinc-300 hover:border-hunt-500 hover:text-hunt-400 transition"
    >
      Disclosure
    </a>
  </div>
</section>
