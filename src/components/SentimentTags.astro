---
interface Props {
  tags: string[];
  limit?: number;
}

const { tags, limit = 5 } = Astro.props;
const displayTags = tags.slice(0, limit);

// Map common tags to colors
const tagColors: Record<string, string> = {
  'easy-to-use': 'bg-green-100 text-green-700',
  'feature-rich': 'bg-blue-100 text-blue-700',
  'expensive': 'bg-red-100 text-red-700',
  'affordable': 'bg-green-100 text-green-700',
  'steep-learning-curve': 'bg-yellow-100 text-yellow-700',
  'great-support': 'bg-emerald-100 text-emerald-700',
  'poor-support': 'bg-red-100 text-red-700',
  'scalable': 'bg-purple-100 text-purple-700',
  'fast': 'bg-teal-100 text-teal-700',
  'slow': 'bg-orange-100 text-orange-700',
  'secure': 'bg-indigo-100 text-indigo-700',
  'modern-ui': 'bg-cyan-100 text-cyan-700',
  'outdated-ui': 'bg-gray-100 text-gray-700',
  'good-integrations': 'bg-violet-100 text-violet-700',
  'limited-integrations': 'bg-amber-100 text-amber-700',
};

function getTagColor(tag: string): string {
  return tagColors[tag] || 'bg-slate-100 text-slate-600';
}

function formatTag(tag: string): string {
  return tag
    .split('-')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}
---

{displayTags.length > 0 && (
  <div class="flex flex-wrap gap-2">
    {displayTags.map((tag) => (
      <span
        class:list={[
          'inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium',
          getTagColor(tag),
        ]}
      >
        {formatTag(tag)}
      </span>
    ))}
  </div>
)}
