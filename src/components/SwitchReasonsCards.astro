---
interface SwitchReasonsDirection {
  fromLabel: string;
  toLabel: string;
  reasons: string[];
}

interface Props {
  directions: SwitchReasonsDirection[];
}

const { directions } = Astro.props as Props;
const validDirections = (Array.isArray(directions) ? directions : []).filter(
  (direction) =>
    direction &&
    typeof direction.fromLabel === 'string' &&
    typeof direction.toLabel === 'string' &&
    Array.isArray(direction.reasons) &&
    direction.reasons.length > 0
);

if (validDirections.length === 0) {
  return null;
}
---

<div class="grid gap-6 lg:grid-cols-2">
  {
    validDirections.map((direction) => (
      <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
        <h3 class="mb-3 text-sm font-medium text-zinc-300">
          {direction.fromLabel} → {direction.toLabel}
        </h3>
        <ul class="space-y-2">
          {direction.reasons.map((reason) => (
            <li class="flex items-start gap-2 text-sm text-zinc-300">
              <svg
                class="mt-0.5 h-4 w-4 shrink-0 text-zinc-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
              {reason}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
