---
/**
 * PricingInsights Component (Budget Analyst)
 *
 * Displays cost mechanics and TCO factors without judgment.
 * Shows the "how the bill works" information from Budget Analyst persona.
 *
 * @module components/PricingInsights
 */

interface Props {
  budgetAnalyst?: {
    costDrivers: string[];
    oneTimeFees: string[];
    commitmentTerms?: string | null;
    roiThreshold?: string | null;
  };
}

const { budgetAnalyst } = Astro.props;

// Don't render if no budget analyst data
if (!budgetAnalyst) return null;

const {
  costDrivers = [],
  oneTimeFees = [],
  commitmentTerms,
  roiThreshold,
} = budgetAnalyst;

// Don't render if all fields are empty
if (
  costDrivers.length === 0 &&
  oneTimeFees.length === 0 &&
  !commitmentTerms &&
  !roiThreshold
) {
  return null;
}
---

<div class="rounded-lg border border-zinc-800 bg-zinc-900/50 p-6">
  <div class="mb-4 flex items-start gap-3">
    <div class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-blue-500/10">
      <svg class="h-5 w-5 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1"
        />
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="text-lg font-semibold text-zinc-100">Price Mechanics</h3>
      <p class="mt-1 text-sm text-zinc-400">
        Understanding the total cost of ownership
      </p>
    </div>
  </div>

  <div class="space-y-4">
    <!-- Cost Drivers -->
    {costDrivers.length > 0 && (
      <div>
        <h4 class="mb-2 text-sm font-medium text-zinc-300">Cost Drivers</h4>
        <ul class="space-y-1.5">
          {costDrivers.map((driver) => (
            <li class="flex items-start gap-2 text-sm text-zinc-400">
              <svg
                class="h-4 w-4 flex-shrink-0 mt-0.5 text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 7l5 5m0 0l-5 5m5-5H6"
                />
              </svg>
              <span>{driver}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- One-Time Fees -->
    {oneTimeFees.length > 0 && (
      <div class="rounded-lg border border-amber-500/20 bg-amber-500/5 p-3">
        <h4 class="mb-2 flex items-center gap-2 text-sm font-medium text-amber-400">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
            />
          </svg>
          Setup Costs
        </h4>
        <ul class="space-y-1">
          {oneTimeFees.map((fee) => (
            <li class="text-sm text-amber-400/90">{fee}</li>
          ))}
        </ul>
      </div>
    )}

    <!-- Bottom row: Commitment Terms & ROI Threshold -->
    <div class="grid gap-3 md:grid-cols-2">
      {commitmentTerms && (
        <div class="rounded-lg border border-zinc-700 bg-zinc-800/50 p-3">
          <div class="mb-1 flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-zinc-500">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
              />
            </svg>
            Contract
          </div>
          <p class="text-sm text-zinc-300">{commitmentTerms}</p>
        </div>
      )}

      {roiThreshold && (
        <div class="rounded-lg border border-zinc-700 bg-zinc-800/50 p-3">
          <div class="mb-1 flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-zinc-500">
            <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"
              />
            </svg>
            Worth It When
          </div>
          <p class="text-sm text-zinc-300">{roiThreshold}</p>
        </div>
      )}
    </div>
  </div>
</div>
