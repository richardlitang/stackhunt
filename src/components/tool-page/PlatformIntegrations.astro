---
/**
 * PlatformIntegrations Component
 * Displays platform availability and integrations
 * Only renders if platform or integration data exists
 */

import type { PlatformAvailability, KnowledgeCard } from '@/lib/knowledge-card';
import { rankIntegrationsForLens } from '@/lib/tool-page/presentation/integrations-lens';
import type { ReviewLens } from '@/lib/tool-page/presentation/view-model';
import CheckIcon from '@/components/icons/Check.astro';

interface Props {
  platforms: PlatformAvailability[];
  integrations: KnowledgeCard['integrations'];
  toolName: string;
  sectionId?: string;
  activeReviewLens?: ReviewLens;
}

const { platforms, integrations, toolName, sectionId, activeReviewLens = 'general' } = Astro.props;
const notableIntegrations = Array.isArray(integrations?.notable)
  ? rankIntegrationsForLens(integrations.notable, activeReviewLens)
  : [];

// Check if we have any data to display
const hasData =
  (platforms && platforms.length > 0) ||
  (integrations && (integrations.total_count || integrations.notable?.length > 0));

if (!hasData) return null;

// Platform labels and icons
const platformInfo = {
  web: { label: 'Web', icon: '🌐' },
  mac: { label: 'Mac', icon: '🍎' },
  windows: { label: 'Windows', icon: '🪟' },
  linux: { label: 'Linux', icon: '🐧' },
  ios: { label: 'iOS', icon: '📱' },
  android: { label: 'Android', icon: '🤖' },
  cli: { label: 'CLI', icon: '⌨️' },
  api: { label: 'API', icon: '🔌' },
  selfhosted: { label: 'Self-Hosted', icon: '🏠' },
};

// Integration type badges
const integrationTypeColors = {
  native: 'bg-green-900/30 text-green-400 border-green-700',
  api: 'bg-blue-900/30 text-blue-400 border-blue-700',
  zapier: 'bg-amber-900/30 text-amber-400 border-amber-700',
  webhook: 'bg-amber-900/30 text-amber-400 border-amber-700',
  plugin: 'bg-zinc-800 text-zinc-300 border-zinc-700',
};

// Integration direction icons
const directionIcons = {
  importDir: '⬇️',
  exportDir: '⬆️',
  bidirectional: '↔️',
};
---

<section
  id={sectionId}
  class="tool-review-panel rounded-[1.8rem] p-6 shadow-sm transition-shadow hover:shadow-md"
>
  <h2 class="tool-review-section-title mb-4 text-3xl">
    {toolName} integrations and platform support
  </h2>

  {/* Platform Availability */}
  {
    platforms && platforms.length > 0 && (
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-medium text-zinc-300">Available Platforms</h3>
        <div class="flex flex-wrap gap-2">
          {platforms.map(({ platform, available, notes }) => {
            const platformKey = platform === 'self-hosted' ? 'selfhosted' : platform;
            const info = platformInfo[platformKey];
            if (!info) return null;

            return (
              <span
                class={`inline-flex items-center gap-1.5 rounded-full px-3 py-1.5 text-sm font-medium border ${
                  available
                    ? 'bg-green-900/30 text-green-400 border-green-700'
                    : 'bg-zinc-800 text-zinc-500 border-zinc-700'
                }`}
                title={notes || undefined}
              >
                <span>{info.icon}</span>
                <span>{info.label}</span>
                {notes && <span class="text-xs opacity-75">({notes})</span>}
              </span>
            );
          })}
        </div>
      </div>
    )
  }

  {/* Integrations */}
  {
    integrations && (integrations.total_count || integrations.notable?.length > 0) && (
      <div>
        <h3 class="mb-3 text-sm font-medium text-zinc-300">Integrations</h3>

        {/* Total count headline */}
        {integrations.total_count && (
          <p class="mb-3 text-sm text-zinc-400">
            <span class="font-semibold text-zinc-100">{integrations.total_count}+</span>{' '}
            integrations available
          </p>
        )}

        {/* Notable integrations */}
        {notableIntegrations.length > 0 && (
          <div class="mb-4 grid grid-cols-2 gap-2 sm:grid-cols-3">
            {notableIntegrations.map(({ name, type, direction }) => {
              // Generate slug from integration name (lowercase, replace spaces with dashes)
              const slug = name
                .toLowerCase()
                .replace(/\s+/g, '-')
                .replace(/[^a-z0-9-]/g, '');
              const internalLink = `/tool/${slug}`;

              return (
                <div class="tool-review-panel-muted group flex cursor-pointer items-center gap-2 rounded-lg p-2.5 transition hover:border-zinc-700">
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-1.5">
                      <a
                        href={internalLink}
                        class="text-sm font-medium text-zinc-200 hover:text-hunt-400 transition truncate"
                        title={`View ${name} details`}
                      >
                        {name}
                      </a>
                      {direction && (
                        <span class="text-xs shrink-0" title={direction}>
                          {direction === 'import'
                            ? directionIcons.importDir
                            : direction === 'export'
                              ? directionIcons.exportDir
                              : directionIcons.bidirectional}
                        </span>
                      )}
                    </div>
                    <span
                      class={`inline-flex items-center rounded-full px-1.5 py-0.5 text-[10px] font-medium border ${integrationTypeColors[type]}`}
                    >
                      {type}
                    </span>
                  </div>
                </div>
              );
            })}
          </div>
        )}

        {/* Developer features */}
        {(integrations.has_api || integrations.has_webhooks || integrations.has_zapier) && (
          <div class="mt-4 border-t border-zinc-800 pt-4">
            <h4 class="mb-2 text-sm font-medium text-zinc-300">Developer Features</h4>
            <div class="flex flex-wrap gap-2">
              {integrations.has_api && (
                <span class="inline-flex items-center gap-1 rounded-full bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300 border border-zinc-700">
                  <CheckIcon class="h-3 w-3 text-green-500" />
                  REST API
                </span>
              )}
              {integrations.has_webhooks && (
                <span class="inline-flex items-center gap-1 rounded-full bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300 border border-zinc-700">
                  <CheckIcon class="h-3 w-3 text-green-500" />
                  Webhooks
                </span>
              )}
              {integrations.has_zapier && (
                <span class="inline-flex items-center gap-1 rounded-full bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300 border border-zinc-700">
                  <CheckIcon class="h-3 w-3 text-green-500" />
                  Zapier
                </span>
              )}
            </div>
          </div>
        )}
      </div>
    )
  }
</section>
