---
interface Props {
  bestFor?: string | null;
  notFor?: string | null;
  mainRisk?: string | null;
  upgradeTrigger?: string | null;
  implementationFriction?: string | null;
}

const {
  bestFor = null,
  notFor = null,
  mainRisk = null,
  upgradeTrigger = null,
  implementationFriction = null,
} = Astro.props;
---

<section class="rounded-2xl border border-zinc-700 bg-zinc-950/50 p-4">
  <h2 class="text-sm font-semibold uppercase tracking-wide text-zinc-400">Immediate verdict</h2>
  <div class="mt-3 space-y-3 text-sm">
    <article>
      <p class="text-xs uppercase tracking-wide text-zinc-500">Best for</p>
      <p class="mt-1 text-zinc-100">{bestFor || 'Not confirmed yet'}</p>
    </article>
    <article>
      <p class="text-xs uppercase tracking-wide text-zinc-500">Not for</p>
      <p class="mt-1 text-zinc-200">{notFor || 'Not confirmed yet'}</p>
    </article>
    <article>
      <p class="text-xs uppercase tracking-wide text-zinc-500">Main risk</p>
      <p class="mt-1 text-zinc-200">{mainRisk || 'Not confirmed yet'}</p>
    </article>
    <article>
      <p class="text-xs uppercase tracking-wide text-zinc-500">Upgrade trigger</p>
      <p class="mt-1 text-zinc-200">{upgradeTrigger || 'Not confirmed yet'}</p>
    </article>
    <article>
      <p class="text-xs uppercase tracking-wide text-zinc-500">Implementation friction</p>
      <p class="mt-1 text-zinc-200">{implementationFriction || 'Needs more evidence'}</p>
    </article>
  </div>
</section>

