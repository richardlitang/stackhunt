---
interface Props {
  sectionId?: string | null;
  bestFor?: string | null;
  notFor?: string | null;
  mainRisk?: string | null;
  upgradeTrigger?: string | null;
  implementationFriction?: string | null;
  implementationDrivers?: string[];
  implementationStakeholders?: string[];
}

const {
  sectionId = null,
  bestFor = null,
  notFor = null,
  mainRisk = null,
  upgradeTrigger = null,
  implementationFriction = null,
  implementationDrivers = [],
  implementationStakeholders = [],
} = Astro.props;

const hasImplementationDetails = Boolean(
  implementationFriction || implementationDrivers.length > 0
);
---

<section
  id={sectionId || undefined}
  class="tool-review-panel rounded-[1.6rem] border-l-4 border-l-amber-400 p-6"
  data-focus-target={sectionId ? true : undefined}
  data-focus-groups={sectionId ? 'all verdict' : undefined}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <p class="tool-review-micro-label">Immediate verdict</p>
      <h2 class="mt-2 font-headline text-xl font-extrabold tracking-tight text-zinc-50">
        Decision snapshot
      </h2>
    </div>
    <span
      class="rounded-full border border-amber-500/30 bg-amber-500/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-amber-200"
    >
      Review
    </span>
  </div>

  <div class="mt-6 space-y-5 text-sm">
    {
      bestFor && (
        <article>
          <p class="tool-review-micro-label">Best for</p>
          <p class="mt-1.5 text-sm font-semibold text-zinc-50">{bestFor}</p>
        </article>
      )
    }
    {
      notFor && (
        <article>
          <p class="tool-review-micro-label">Not for</p>
          <p class="mt-1.5 text-sm font-medium text-zinc-300">{notFor}</p>
        </article>
      )
    }
    {
      mainRisk && (
        <article class="border-t border-zinc-800 pt-4">
          <p class="tool-review-micro-label text-rose-300">Main risk</p>
          <p class="mt-1.5 text-sm text-zinc-100">{mainRisk}</p>
        </article>
      )
    }
    {
      upgradeTrigger && (
        <article>
          <p class="tool-review-micro-label text-amber-300">Upgrade trigger</p>
          <p class="mt-1.5 text-sm text-zinc-100">{upgradeTrigger}</p>
        </article>
      )
    }
    {
      hasImplementationDetails && (
        <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
          <div class="flex items-center justify-between gap-3">
            <p class="tool-review-micro-label">Implementation</p>
            {implementationFriction && (
              <span class="text-xs font-semibold text-zinc-100">{implementationFriction}</span>
            )}
          </div>
          {implementationDrivers.length > 0 && (
            <p class="mt-2 text-xs leading-6 text-zinc-400">
              Drivers: {implementationDrivers.slice(0, 2).join(' | ')}
            </p>
          )}
          {implementationStakeholders.length > 0 && (
            <p class="mt-1 text-xs leading-6 text-zinc-500">
              Stakeholders: {implementationStakeholders.slice(0, 3).join(' | ')}
            </p>
          )}
        </article>
      )
    }
  </div>
</section>
