---
import ScoreBadge from './ScoreBadge.astro';
import PricingBadge from './PricingBadge.astro';
import Logo from './Logo.astro';
import type { Tool } from '@/types/database';

interface Props {
  tool: Pick<Tool, 'name' | 'slug' | 'logo_url' | 'short_description' | 'avg_score' | 'pricing_type'>;
  category?: { name: string; slug: string } | null;
  score?: number; // Override score (for contextual display)
  rank?: number;
}

const { tool, category, score, rank } = Astro.props;
const displayScore = score ?? tool.avg_score;
---

<a
  href={`/tools/${tool.slug}`}
  class="group relative flex flex-col rounded-xl border border-slate-200 bg-white p-5 transition hover:border-hunt-200 hover:shadow-lg hover:shadow-hunt-500/5"
>
  {rank && (
    <div class="absolute -left-2 -top-2 flex h-6 w-6 items-center justify-center rounded-full bg-hunt-500 text-xs font-bold text-white">
      {rank}
    </div>
  )}

  <div class="flex items-start justify-between gap-4">
    <!-- Logo & Info -->
    <div class="flex items-center gap-4">
      <Logo domain={tool.logo_url} name={tool.name} size="md" />

      <div class="min-w-0">
        <h3 class="font-semibold text-slate-900 group-hover:text-hunt-600 transition truncate">
          {tool.name}
        </h3>
        {category && (
          <span class="text-xs text-slate-500">{category.name}</span>
        )}
      </div>
    </div>

    <!-- Score -->
    {displayScore > 0 && <ScoreBadge score={displayScore} size="sm" />}
  </div>

  <!-- Description -->
  {tool.short_description && (
    <p class="mt-3 line-clamp-2 text-sm text-slate-600">
      {tool.short_description}
    </p>
  )}

  <!-- Footer -->
  <div class="mt-4 flex items-center justify-between">
    <PricingBadge type={tool.pricing_type} size="sm" />

    <span class="text-xs text-slate-400 group-hover:text-hunt-500 transition">
      View details &rarr;
    </span>
  </div>
</a>
