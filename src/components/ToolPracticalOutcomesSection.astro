---
interface PracticalOutcome {
  outcome: string;
  verifyInDemo: string;
  planDependency: string;
  planDependencyStatus: 'Source-backed' | 'Needs confirmation';
}

interface Props {
  title: string;
  outcomes: PracticalOutcome[];
}

const { title, outcomes } = Astro.props as Props;
---

{
  outcomes.length > 0 && (
    <section
      id="practical-outcomes"
      class="rounded-[1.8rem] border border-zinc-700 bg-zinc-900/80 p-6 shadow-sm"
      data-focus-target
      data-focus-groups="all capabilities setup pricing"
    >
      <h2 class="tool-review-section-title text-3xl">{title}</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        {outcomes.map((item) => (
          <article class="tool-review-panel-muted rounded-[1.35rem] p-5">
            <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-indigo-500/12 text-sm font-bold text-indigo-200">
              +
            </div>
            <p class="font-headline text-xl font-bold tracking-tight text-zinc-50">
              {item.outcome}
            </p>
            <p class="mt-3 text-sm leading-6 text-zinc-300">
              <span class="text-zinc-400">What to verify in a demo:</span> {item.verifyInDemo}
            </p>
            <p class="mt-4 text-xs leading-6 text-zinc-400">
              <span class="text-zinc-500">Plan dependency:</span> {item.planDependency}
              <span
                class={`ml-2 inline-flex items-center rounded-full border px-2 py-0.5 text-[10px] font-semibold uppercase tracking-[0.14em] ${
                  item.planDependencyStatus === 'Source-backed'
                    ? 'border-emerald-700/70 bg-emerald-950/40 text-emerald-300'
                    : 'border-amber-700/70 bg-amber-950/40 text-amber-200'
                }`}
              >
                {item.planDependencyStatus}
              </span>
            </p>
          </article>
        ))}
      </div>
    </section>
  )
}
