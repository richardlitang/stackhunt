---
/**
 * ProsCons Component
 * Displays pros and cons with full source attribution for legal protection
 *
 * Supports multiple formats:
 * - Legacy: string[] - ["pro1", "pro2"]
 * - Basic: Array<{text: string, source_url?: string}>
 * - Full: Array<{text: string, source_url: string, source_type: string, claim_type: string}>
 *
 * For community sources and opinions, applies hedging language automatically.
 */

type SourceType = 'official' | 'editorial' | 'community';
type ClaimType = 'fact' | 'opinion';

interface ClaimWithSource {
  text: string;
  source_url?: string;
  source_type?: SourceType;
  claim_type?: ClaimType;
  retrieved_at?: string; // ISO 8601 timestamp for time-bound defense
}

type ClaimItem = string | ClaimWithSource;

interface Props {
  pros: ClaimItem[];
  cons: ClaimItem[];
  title?: string;
  showSources?: boolean;
  sourceDisplay?: 'inline' | 'toggle' | 'hidden';
}

const { pros, cons, title, showSources = true, sourceDisplay } = Astro.props;
const resolvedSourceDisplay = sourceDisplay || (showSources ? 'inline' : 'hidden');

// Hedging prefixes for different source types
const HEDGING_PREFIXES: Record<SourceType, string[]> = {
  community: ['Users report that', 'According to community feedback,', 'Based on user discussions,'],
  editorial: ['According to reviews,', 'Reviewers note that'],
  official: [],
};

// Normalize items to consistent format
function normalizeClaim(item: ClaimItem, index: number): ClaimWithSource & { displayText: string; formattedDate: string | null } {
  if (typeof item === 'string') {
    return { text: item, displayText: item, formattedDate: null };
  }

  // Determine if we need hedging
  const needsHedging =
    item.source_type === 'community' ||
    (item.claim_type === 'opinion' && item.source_type !== 'official');

  let displayText = item.text;
  if (needsHedging && item.source_type) {
    const prefixes = HEDGING_PREFIXES[item.source_type];
    if (prefixes.length > 0) {
      const prefix = prefixes[index % prefixes.length];
      // Lowercase first letter of claim text when adding prefix
      displayText = `${prefix} ${item.text.charAt(0).toLowerCase()}${item.text.slice(1)}`;
    }
  }

  return { ...item, displayText, formattedDate: formatTimestamp(item.retrieved_at) };
}

const normalizedPros = pros.map((item, i) => normalizeClaim(item, i));
const normalizedCons = cons.map((item, i) => normalizeClaim(item, i));

// Extract domain from URL for display
function getDomain(url: string): string {
  try {
    const domain = new URL(url).hostname.replace(/^www\./, '');
    return domain;
  } catch {
    return url;
  }
}

// Get source type badge styles
function getSourceBadgeClass(sourceType?: SourceType): string {
  switch (sourceType) {
    case 'official':
      return 'bg-blue-900/30 text-blue-400 border-blue-700';
    case 'editorial':
      return 'bg-purple-900/30 text-purple-400 border-purple-700';
    case 'community':
      return 'bg-amber-900/30 text-amber-400 border-amber-700';
    default:
      return 'bg-zinc-800 text-zinc-400 border-zinc-700';
  }
}

// Get source type label
function getSourceLabel(sourceType?: SourceType): string {
  switch (sourceType) {
    case 'official': return 'Official';
    case 'editorial': return 'Review';
    case 'community': return 'Community';
    default: return 'Source';
  }
}

// Format timestamp for display (e.g., "Jan 2026")
function formatTimestamp(isoDate?: string): string | null {
  if (!isoDate) return null;
  try {
    const date = new Date(isoDate);
    return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
  } catch {
    return null;
  }
}

/**
 * Get appropriate rel attribute for source links based on source type
 *
 * SEO Strategy (per Gemini's E-E-A-T analysis):
 * - Official sources: dofollow (links to authoritative sites help SEO)
 * - Editorial sources: nofollow (don't pass juice to review aggregators)
 * - Community sources: nofollow ugc (UGC = User Generated Content per Google guidelines)
 */
function getSourceRelAttribute(sourceType?: SourceType): string {
  switch (sourceType) {
    case 'official':
      // Dofollow for official sources - linking to high-authority sites helps our SEO
      return 'noopener noreferrer';
    case 'editorial':
      // Nofollow for review sites - cite but don't pass authority
      return 'nofollow noopener noreferrer';
    case 'community':
      // Nofollow + UGC for user-generated content (Reddit, forums)
      return 'nofollow ugc noopener noreferrer';
    default:
      // Default to nofollow for safety
      return 'nofollow noopener noreferrer';
  }
}

// Get source icon based on domain
function getSourceIcon(url?: string): string | null {
  if (!url) return null;
  try {
    const hostname = new URL(url).hostname.replace(/^www\./, '').toLowerCase();
    // Return emoji icons for known sources (lightweight, no external requests)
    if (hostname.includes('reddit.com')) return '🗣️';
    if (hostname.includes('g2.com')) return '⭐';
    if (hostname.includes('capterra.com')) return '📊';
    if (hostname.includes('producthunt.com')) return '🚀';
    if (hostname.includes('ycombinator.com')) return '🟧';
    return null;
  } catch {
    return null;
  }
}

import CheckIcon from '@/components/icons/Check.astro';
import MinusIcon from '@/components/icons/Minus.astro';
import ExternalLinkIcon from '@/components/icons/ExternalLink.astro';
---

<div class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow">
  {title && (
    <h2 class="mb-4 text-lg font-semibold text-zinc-100">{title}</h2>
  )}

  <div class="space-y-8">
    <!-- Pros -->
    <div>
      <div class="flex items-center gap-2 mb-4">
        <div class="flex h-6 w-6 items-center justify-center rounded-full bg-green-900/30">
          <CheckIcon class="h-4 w-4 text-green-400" />
        </div>
        <span class="font-semibold text-green-400">Pros</span>
      </div>

      <ul class="space-y-3">
        {normalizedPros.map((pro) => (
          <li class="text-sm text-zinc-300">
            <div class="flex items-start gap-3">
              <CheckIcon class="mt-0.5 h-4 w-4 shrink-0 text-green-400" />
              <div class="flex-1">
                <span>{pro.displayText}</span>
                {resolvedSourceDisplay !== 'hidden' && pro.source_url && (
                  <span class="inline-flex items-center gap-1 ml-2">
                    {resolvedSourceDisplay === 'inline' ? (
                      <>
                        {pro.source_type && (
                          <span class={`inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded border ${getSourceBadgeClass(pro.source_type)}`}>
                            {getSourceIcon(pro.source_url) && <span class="mr-0.5">{getSourceIcon(pro.source_url)}</span>}
                            {getSourceLabel(pro.source_type)}{pro.formattedDate && `, ${pro.formattedDate}`}
                          </span>
                        )}
                        <a
                          href={pro.source_url}
                          target="_blank"
                          rel={getSourceRelAttribute(pro.source_type)}
                          class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-hunt-400 transition"
                          title={`View source: ${getDomain(pro.source_url)}${pro.formattedDate ? ` (retrieved ${pro.formattedDate})` : ''}`}
                        >
                          <ExternalLinkIcon class="h-3 w-3" />
                        </a>
                      </>
                    ) : (
                      <details class="inline-block">
                        <summary class="cursor-pointer text-xs text-zinc-500 hover:text-hunt-400">Source</summary>
                        <div class="mt-1 inline-flex items-center gap-1">
                          {pro.source_type && (
                            <span class={`inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded border ${getSourceBadgeClass(pro.source_type)}`}>
                              {getSourceIcon(pro.source_url) && <span class="mr-0.5">{getSourceIcon(pro.source_url)}</span>}
                              {getSourceLabel(pro.source_type)}{pro.formattedDate && `, ${pro.formattedDate}`}
                            </span>
                          )}
                          <a
                            href={pro.source_url}
                            target="_blank"
                            rel={getSourceRelAttribute(pro.source_type)}
                            class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-hunt-400 transition"
                            title={`View source: ${getDomain(pro.source_url)}${pro.formattedDate ? ` (retrieved ${pro.formattedDate})` : ''}`}
                          >
                            <ExternalLinkIcon class="h-3 w-3" />
                          </a>
                        </div>
                      </details>
                    )}
                  </span>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <!-- Cons -->
    <div>
      <div class="flex items-center gap-2 mb-4">
        <div class="flex h-6 w-6 items-center justify-center rounded-full bg-red-900/30">
          <MinusIcon class="h-4 w-4 text-red-400" />
        </div>
        <span class="font-semibold text-red-400">Cons</span>
      </div>

      <ul class="space-y-3">
        {normalizedCons.map((con) => (
          <li class="text-sm text-zinc-300">
            <div class="flex items-start gap-3">
              <MinusIcon class="mt-0.5 h-4 w-4 shrink-0 text-red-400" />
              <div class="flex-1">
                <span>{con.displayText}</span>
                {resolvedSourceDisplay !== 'hidden' && con.source_url && (
                  <span class="inline-flex items-center gap-1 ml-2">
                    {resolvedSourceDisplay === 'inline' ? (
                      <>
                        {con.source_type && (
                          <span class={`inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded border ${getSourceBadgeClass(con.source_type)}`}>
                            {getSourceIcon(con.source_url) && <span class="mr-0.5">{getSourceIcon(con.source_url)}</span>}
                            {getSourceLabel(con.source_type)}{con.formattedDate && `, ${con.formattedDate}`}
                          </span>
                        )}
                        <a
                          href={con.source_url}
                          target="_blank"
                          rel={getSourceRelAttribute(con.source_type)}
                          class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-hunt-400 transition"
                          title={`View source: ${getDomain(con.source_url)}${con.formattedDate ? ` (retrieved ${con.formattedDate})` : ''}`}
                        >
                          <ExternalLinkIcon class="h-3 w-3" />
                        </a>
                      </>
                    ) : (
                      <details class="inline-block">
                        <summary class="cursor-pointer text-xs text-zinc-500 hover:text-hunt-400">Source</summary>
                        <div class="mt-1 inline-flex items-center gap-1">
                          {con.source_type && (
                            <span class={`inline-flex items-center px-1.5 py-0.5 text-[10px] font-medium rounded border ${getSourceBadgeClass(con.source_type)}`}>
                              {getSourceIcon(con.source_url) && <span class="mr-0.5">{getSourceIcon(con.source_url)}</span>}
                              {getSourceLabel(con.source_type)}{con.formattedDate && `, ${con.formattedDate}`}
                            </span>
                          )}
                          <a
                            href={con.source_url}
                            target="_blank"
                            rel={getSourceRelAttribute(con.source_type)}
                            class="inline-flex items-center gap-1 text-xs text-zinc-500 hover:text-hunt-400 transition"
                            title={`View source: ${getDomain(con.source_url)}${con.formattedDate ? ` (retrieved ${con.formattedDate})` : ''}`}
                          >
                            <ExternalLinkIcon class="h-3 w-3" />
                          </a>
                        </div>
                      </details>
                    )}
                  </span>
                )}
              </div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</div>

<!-- Source links now open in new tab instead of copy-to-clipboard -->
