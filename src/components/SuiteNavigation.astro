---
/**
 * SuiteNavigation Component
 *
 * Displays sibling tools in the same suite (e.g., "Also in Google Workspace").
 * Shows when a tool has a parent_id (is part of a bundle/suite).
 *
 * @module components/SuiteNavigation
 */

import { supabase } from '@/lib/supabase';
import Logo from '@/components/Logo.astro';

interface Props {
  currentToolId: string;
  parentId: string;
  parentName: string;
}

const { currentToolId, parentId, parentName } = Astro.props;

// Fetch all tools in this suite (same parent_id)
const { data: siblingTools } = await supabase
  .from('items')
  .select('id, slug, name, logo_url, short_description, pricing_type')
  .eq('parent_id', parentId)
  .neq('id', currentToolId) // Exclude current tool
  .order('name');

// Fetch parent tool info
const { data: parentTool } = await supabase
  .from('items')
  .select('id, slug, name, logo_url, short_description, pricing_type')
  .eq('id', parentId)
  .single();

if (!siblingTools || siblingTools.length === 0) return null;
---

<div class="rounded-xl border border-indigo-500/20 bg-indigo-500/5 p-6">
  <div class="mb-4 flex items-start gap-3">
    <div
      class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-lg bg-indigo-500/10"
    >
      <svg class="h-5 w-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
        ></path>
      </svg>
    </div>
    <div class="flex-1">
      <h3 class="text-lg font-semibold text-indigo-400">Also in {parentName}</h3>
      <p class="mt-1 text-sm text-zinc-400">
        This tool is part of {parentName}. Here are other tools in the suite:
      </p>
    </div>
  </div>

  <!-- Parent Suite Link -->
  {
    parentTool && (
      <a
        href={`/tool/${parentTool.slug}`}
        class="mb-4 flex items-center gap-3 rounded-lg border border-zinc-700 bg-zinc-800/50 p-3 transition hover:border-indigo-500/50 hover:bg-zinc-800"
      >
        <Logo domain={parentTool.logo_url} name={parentTool.name} size="sm" />
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2">
            <span class="font-medium text-zinc-100">{parentTool.name}</span>
            <span class="rounded-full bg-indigo-500/10 px-2 py-0.5 text-xs font-medium text-indigo-400">
              Suite
            </span>
          </div>
          {parentTool.short_description && (
            <p class="mt-1 text-xs text-zinc-400 truncate">{parentTool.short_description}</p>
          )}
        </div>
        <svg
          class="h-4 w-4 flex-shrink-0 text-zinc-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )
  }

  <!-- Sibling Tools -->
  <div class="space-y-2">
    {
      siblingTools.map((tool) => (
        <a
          href={`/tool/${tool.slug}`}
          class="flex items-center gap-3 rounded-lg border border-zinc-700 bg-zinc-900/50 p-3 transition hover:border-zinc-600 hover:bg-zinc-800/50"
        >
          <Logo domain={tool.logo_url} name={tool.name} size="sm" />
          <div class="flex-1 min-w-0">
            <div class="font-medium text-zinc-200">{tool.name}</div>
            {tool.short_description && (
              <p class="mt-0.5 text-xs text-zinc-400 truncate">{tool.short_description}</p>
            )}
          </div>
          <svg
            class="h-4 w-4 flex-shrink-0 text-zinc-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 5l7 7-7 7"
            />
          </svg>
        </a>
      ))
    }
  </div>

  <div class="mt-4 rounded-lg bg-indigo-500/10 p-3">
    <p class="text-xs text-indigo-400">
      💡 Already have {parentName}? These tools are included in your subscription.
    </p>
  </div>
</div>
