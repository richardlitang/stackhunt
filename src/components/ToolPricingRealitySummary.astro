---
interface Props {
  freeWorksIf?: string | null;
  paidNeededWhen?: string | null;
  hiddenCostTriggers?: string[];
}

const { freeWorksIf = null, paidNeededWhen = null, hiddenCostTriggers = [] } = Astro.props;
const hasPricingRealitySignals = Boolean(
  freeWorksIf || paidNeededWhen || hiddenCostTriggers.length
);
---

{
  hasPricingRealitySignals && (
    <section class="mb-6 rounded-[1.6rem] border border-indigo-500/15 bg-indigo-500/5 p-6">
      <h3 class="font-headline text-2xl font-bold tracking-tight text-zinc-50">Pricing reality</h3>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        <article class="tool-review-panel-muted rounded-2xl p-4">
          <p class="tool-review-micro-label">Free works if</p>
          <p class="mt-2 text-sm leading-6 text-zinc-300">{freeWorksIf || 'Not confirmed yet'}</p>
        </article>
        <article class="tool-review-panel-muted rounded-2xl p-4">
          <p class="tool-review-micro-label">Paid needed when</p>
          <p class="mt-2 text-sm leading-6 text-zinc-300">
            {paidNeededWhen || 'Not confirmed yet'}
          </p>
        </article>
      </div>
      <article class="tool-review-panel-muted mt-4 rounded-2xl p-4">
        <p class="tool-review-micro-label">Hidden cost triggers</p>
        {hiddenCostTriggers.length > 0 ? (
          <ul class="mt-3 space-y-2 text-sm text-zinc-300">
            {hiddenCostTriggers.slice(0, 3).map((item) => (
              <li class="flex gap-3">
                <span class="mt-1 h-1.5 w-1.5 rounded-full bg-indigo-300" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        ) : (
          <p class="mt-2 text-sm text-zinc-300">No source-backed hidden triggers confirmed yet.</p>
        )}
      </article>
    </section>
  )
}
