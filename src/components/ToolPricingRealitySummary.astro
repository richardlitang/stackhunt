---
interface Props {
  freeWorksIf?: string | null;
  paidNeededWhen?: string | null;
  hiddenCostTriggers?: string[];
}

const { freeWorksIf = null, paidNeededWhen = null, hiddenCostTriggers = [] } = Astro.props;
---

<section class="mb-4 rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
  <h3 class="text-sm font-semibold text-zinc-100">Pricing reality</h3>
  <div class="mt-3 grid gap-3 md:grid-cols-2">
    <article class="rounded border border-zinc-800 bg-zinc-950/50 p-3">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Free works if</p>
      <p class="mt-1 text-sm text-zinc-300">{freeWorksIf || 'Not confirmed yet'}</p>
    </article>
    <article class="rounded border border-zinc-800 bg-zinc-950/50 p-3">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Paid needed when</p>
      <p class="mt-1 text-sm text-zinc-300">{paidNeededWhen || 'Not confirmed yet'}</p>
    </article>
  </div>
  <article class="mt-3 rounded border border-zinc-800 bg-zinc-950/50 p-3">
    <p class="text-xs uppercase tracking-wide text-zinc-500">Hidden cost triggers</p>
    {
      hiddenCostTriggers.length > 0 ? (
        <ul class="mt-1 space-y-1 text-sm text-zinc-300">
          {hiddenCostTriggers.slice(0, 3).map((item) => (
            <li>- {item}</li>
          ))}
        </ul>
      ) : (
        <p class="mt-1 text-sm text-zinc-300">No source-backed hidden triggers confirmed yet.</p>
      )
    }
  </article>
</section>
