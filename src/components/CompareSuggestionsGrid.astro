---
import Logo from '@/components/Logo.astro';

interface SuggestionTool {
  slug: string;
  name: string;
  logo_url?: string | null;
}

interface Suggestion {
  toolA: SuggestionTool;
  toolB: SuggestionTool;
  reason: 'switching' | 'category' | string;
}

interface Props {
  suggestions: Suggestion[];
}

const { suggestions } = Astro.props as Props;
const validSuggestions = (Array.isArray(suggestions) ? suggestions : []).filter(
  (suggestion) =>
    suggestion &&
    suggestion.toolA &&
    suggestion.toolB &&
    typeof suggestion.toolA.slug === 'string' &&
    typeof suggestion.toolB.slug === 'string'
);

if (validSuggestions.length === 0) {
  return null;
}
---

<div class="grid gap-4 sm:grid-cols-2">
  {
    validSuggestions.map((suggestion) => {
      const [first, second] =
        suggestion.toolA.slug < suggestion.toolB.slug
          ? [suggestion.toolA, suggestion.toolB]
          : [suggestion.toolB, suggestion.toolA];

      return (
        <a
          href={`/compare/${first.slug}-vs-${second.slug}`}
          class="group relative overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 transition hover:border-indigo-500/50 hover:bg-zinc-900/80"
        >
          <div class="absolute right-3 top-3">
            {suggestion.reason === 'switching' ? (
              <span class="inline-flex items-center gap-1 rounded-full border border-purple-700 bg-purple-900/30 px-2 py-0.5 text-xs text-purple-400">
                <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                </svg>
                Often switched
              </span>
            ) : (
              <span class="inline-flex items-center gap-1 rounded-full border border-zinc-700 bg-zinc-800 px-2 py-0.5 text-xs text-zinc-500">
                Similar category
              </span>
            )}
          </div>

          <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
              <Logo domain={suggestion.toolA.logo_url} name={suggestion.toolA.name} size="md" />
              <span class="text-sm font-medium text-zinc-200">{suggestion.toolA.name}</span>
            </div>

            <svg
              class="h-4 w-4 shrink-0 text-zinc-600 transition group-hover:text-indigo-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>

            <div class="flex items-center gap-2">
              <Logo domain={suggestion.toolB.logo_url} name={suggestion.toolB.name} size="md" />
              <span class="text-sm font-medium text-zinc-200">{suggestion.toolB.name}</span>
            </div>
          </div>

          <div class="absolute bottom-3 right-3 opacity-0 transition group-hover:opacity-100">
            <svg class="h-4 w-4 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </div>
        </a>
      );
    })
  }
</div>
