---
/**
 * Source-backed Badge Component
 *
 * Displays verification status for tools with:
 * - Source-backed status badge
 * - Last verification date
 * - Source count
 *
 * Critical for EEAT (Expertise, Authoritativeness, Trustworthiness)
 *
 * @module components/VerifiedBadge
 */

interface Props {
  isVerified?: boolean;
  lastVerifiedAt?: string | null;
  sourceCount?: number;
  size?: 'sm' | 'md' | 'lg';
  showDetails?: boolean;
}

const {
  isVerified = false,
  lastVerifiedAt,
  sourceCount = 0,
  size = 'md',
  showDetails = true,
} = Astro.props;

// Format the verification date
const formatDate = (date: string) => {
  const d = new Date(date);
  const now = new Date();
  const diffDays = Math.floor((now.getTime() - d.getTime()) / (1000 * 60 * 60 * 24));

  if (diffDays === 0) return 'today';
  if (diffDays === 1) return 'yesterday';
  if (diffDays < 7) return `${diffDays} days ago`;
  if (diffDays < 30) return `${Math.floor(diffDays / 7)} weeks ago`;
  if (diffDays < 60) return 'last month';

  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};

// Determine if data is stale (>60 days)
const isStale = lastVerifiedAt
  ? (new Date().getTime() - new Date(lastVerifiedAt).getTime()) / (1000 * 60 * 60 * 24) > 60
  : false;

const sizeClasses = {
  sm: {
    badge: 'px-2 py-1 text-xs gap-1',
    icon: 'h-3 w-3',
    details: 'text-xs',
  },
  md: {
    badge: 'px-3 py-1.5 text-sm gap-1.5',
    icon: 'h-4 w-4',
    details: 'text-sm',
  },
  lg: {
    badge: 'px-4 py-2 text-base gap-2',
    icon: 'h-5 w-5',
    details: 'text-base',
  },
};

const classes = sizeClasses[size];
if (!isVerified) return null;
---

<div class="flex flex-col gap-2">
  <!-- Main Badge -->
  <div
    class:list={[
      'inline-flex items-center rounded-full font-medium',
      classes.badge,
      isStale
        ? 'bg-amber-500/10 text-amber-400 border border-amber-500/20'
        : 'bg-green-500/10 text-green-400 border border-green-500/20',
    ]}
  >
    <!-- Check Icon -->
    <svg
      class:list={[classes.icon, 'flex-shrink-0']}
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      {
        isStale ? (
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
          />
        ) : (
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        )
      }
    </svg>

    <span class="font-semibold">
      {isStale ? 'Needs Recheck' : 'Source-backed'}
    </span>
  </div>

  <!-- Details (optional) -->
  {
    showDetails && (
      <div
        class:list={[
          'flex flex-wrap items-center gap-x-4 gap-y-1',
          classes.details,
          'text-zinc-500',
        ]}
      >
        {lastVerifiedAt && (
          <span class="flex items-center gap-1.5">
            <svg
              class:list={[classes.icon, 'flex-shrink-0']}
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span>
              Last checked{' '}
              <span class={isStale ? 'text-amber-400' : 'text-zinc-400'}>
                {formatDate(lastVerifiedAt)}
              </span>
            </span>
          </span>
        )}

        {sourceCount > 0 && (
          <span class="flex items-center gap-1.5">
            <svg
              class:list={[classes.icon, 'flex-shrink-0']}
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"
              />
            </svg>
            <span>
              <span class="text-zinc-400">{sourceCount}</span>{' '}
              {sourceCount === 1 ? 'source' : 'sources'}
            </span>
          </span>
        )}
      </div>
    )
  }

  <!-- Stale Warning -->
  {
    isStale && lastVerifiedAt && (
      <div class="rounded-lg border border-amber-500/20 bg-amber-500/5 px-3 py-2">
        <p class:list={[classes.details, 'text-amber-400/90']}>
          This information was last checked over 60 days ago. Pricing and features may have
          changed.
          <a
            href="/corrections"
            class="ml-1 font-medium text-amber-400 hover:text-amber-300 underline"
          >
            Report updates
          </a>
        </p>
      </div>
    )
  }
</div>
