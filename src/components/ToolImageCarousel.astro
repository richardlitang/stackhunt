---
/**
 * Tool Image Carousel
 *
 * Shows actual product screenshots - the killer feature that differentiates
 * from scraper sites. Users need to SEE the product, not just read about it.
 *
 * Images should show:
 * 1. Main Interface (the primary view)
 * 2. Killer Feature (what makes it unique)
 * 3. Settings/Pricing (proof of hard limits)
 */

interface Screenshot {
  url: string;
  caption: string;
  alt: string;
}

interface Props {
  toolName: string;
  screenshots?: Screenshot[];
  fallbackMessage?: string;
}

const {
  toolName,
  screenshots = [],
  fallbackMessage = 'Product screenshots coming soon',
} = Astro.props;

// Don't render if no screenshots
if (!screenshots || screenshots.length === 0) {
  return null;
}
---

<div class="not-prose overflow-hidden rounded-xl border border-zinc-700 bg-zinc-900">
  <!-- Header -->
  <div class="border-b border-zinc-800 px-4 py-3">
    <h3 class="flex items-center gap-2 text-sm font-semibold text-zinc-100">
      <svg class="h-4 w-4 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"
        ></path>
      </svg>
      {toolName} Interface
    </h3>
  </div>

  <!-- Carousel -->
  <div class="relative">
    <div class="carousel-container overflow-x-auto scroll-smooth">
      <div class="flex snap-x snap-mandatory">
        {
          screenshots.map((screenshot, index) => (
            <div class="min-w-full snap-center p-4">
              <img
                src={screenshot.url}
                alt={screenshot.alt}
                class="mx-auto rounded-lg border border-zinc-800 shadow-lg"
                loading={index === 0 ? 'eager' : 'lazy'}
              />
              {screenshot.caption && (
                <p class="mt-3 text-center text-sm text-zinc-400">{screenshot.caption}</p>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- Navigation Arrows (only show if multiple images) -->
    {
      screenshots.length > 1 && (
        <>
          <button
            class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 rounded-full bg-zinc-800/90 p-2 text-zinc-300 shadow-lg hover:bg-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
            aria-label="Previous image"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 19l-7-7 7-7"
              />
            </svg>
          </button>
          <button
            class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 rounded-full bg-zinc-800/90 p-2 text-zinc-300 shadow-lg hover:bg-zinc-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
            aria-label="Next image"
          >
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </button>
        </>
      )
    }

    <!-- Dots Indicator -->
    {
      screenshots.length > 1 && (
        <div class="flex justify-center gap-2 pb-4">
          {screenshots.map((_, index) => (
            <button
              class={`carousel-dot h-2 w-2 rounded-full transition-all ${
                index === 0 ? 'bg-blue-500 w-6' : 'bg-zinc-600 hover:bg-zinc-500'
              }`}
              data-index={index}
              aria-label={`Go to image ${index + 1}`}
            />
          ))}
        </div>
      )
    }
  </div>
</div>

<script>
  // Client-side carousel logic
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('.carousel-container');
    const prevBtn = document.querySelector('.carousel-prev');
    const nextBtn = document.querySelector('.carousel-next');
    const dots = document.querySelectorAll('.carousel-dot');

    if (!container || !prevBtn || !nextBtn) return;

    let currentIndex = 0;
    const itemWidth = container.clientWidth;

    const updateCarousel = (index: number) => {
      currentIndex = index;
      container.scrollTo({
        left: itemWidth * index,
        behavior: 'smooth',
      });

      // Update dots
      dots.forEach((dot, i) => {
        if (i === index) {
          dot.classList.add('bg-blue-500', 'w-6');
          dot.classList.remove('bg-zinc-600', 'w-2');
        } else {
          dot.classList.remove('bg-blue-500', 'w-6');
          dot.classList.add('bg-zinc-600', 'w-2');
        }
      });
    };

    prevBtn?.addEventListener('click', () => {
      const newIndex = currentIndex > 0 ? currentIndex - 1 : dots.length - 1;
      updateCarousel(newIndex);
    });

    nextBtn?.addEventListener('click', () => {
      const newIndex = currentIndex < dots.length - 1 ? currentIndex + 1 : 0;
      updateCarousel(newIndex);
    });

    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => updateCarousel(index));
    });
  });
</script>
