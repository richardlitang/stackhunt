---
/**
 * FeaturesShowcase Component
 * Displays core features and unique differentiators
 * Only renders if feature data exists
 */

import type { KnowledgeCard } from '@/lib/knowledge-card';
import CheckIcon from '@/components/icons/Check.astro';

interface Props {
  features: KnowledgeCard['features'];
  toolName: string;
  sectionId?: string;
  peerCount?: number;
}

const { features, toolName: _toolName, sectionId, peerCount = 0 } = Astro.props;

// Check if we have any data to display
const hasData =
  features &&
  ((features.core && features.core.length > 0) ||
    (features.unique && features.unique.length > 0) ||
    (features.capabilities && features.capabilities.length > 0));

if (!hasData) return null;

// Status badge colors
const statusColors = {
  full: 'bg-green-900/30 text-green-400 border-green-700',
  partial: 'bg-blue-900/30 text-blue-400 border-blue-700',
  beta: 'bg-purple-900/30 text-purple-400 border-purple-700',
  planned: 'bg-amber-900/30 text-amber-400 border-amber-700',
  none: 'bg-zinc-800 text-zinc-500 border-zinc-700',
};

const statusLabels = {
  full: 'Full Support',
  partial: 'Partial',
  beta: 'Beta',
  planned: 'Planned',
  none: 'Not Available',
};
---

<section
  id={sectionId}
  class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
>
  <h2 class="mb-2 text-lg font-semibold text-zinc-100">Capabilities and feature depth</h2>
  <p class="mb-6 text-sm text-zinc-400">
    {
      peerCount > 0
        ? `Source-backed capabilities compared with ${peerCount} similar tools.`
        : 'Source-backed capability summary focused on practical team impact.'
    }
  </p>

  {/* Core Features */}
  {
    features.core && features.core.length > 0 && (
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-medium text-zinc-300">Core workflows</h3>
        <div class="grid gap-3 sm:grid-cols-2">
          {features.core.map((feature) => (
            <div class="flex items-start gap-2">
              <CheckIcon class="mt-0.5 h-4 w-4 shrink-0 text-green-500" />
              <span class="text-sm text-zinc-200">{feature}</span>
            </div>
          ))}
        </div>
      </div>
    )
  }

  {/* Unique Features */}
  {
    features.unique && features.unique.length > 0 && (
      <div class="mb-6">
        <h3 class="mb-3 text-sm font-medium text-zinc-300">Why teams choose it</h3>
        <div class="grid gap-3">
          {features.unique.map((feature) => (
            <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-3">
              <div class="flex items-center gap-2">
                <span class="text-lg shrink-0" role="img" aria-label="star">
                  ⭐
                </span>
                <span class="text-sm font-medium text-zinc-100">{feature}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )
  }

  {/* Feature Capabilities Table */}
  {
    features.capabilities && features.capabilities.length > 0 && (
      <details class="group rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
        <summary class="flex cursor-pointer list-none items-center justify-between">
          <div>
            <h3 class="text-sm font-medium text-zinc-300">Feature depth and limits</h3>
            <p class="mt-1 text-xs text-zinc-500">Detailed implementation status by capability</p>
          </div>
          <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
            <span class="group-open:hidden">Expand</span>
            <span class="hidden group-open:inline">Collapse</span>
          </span>
        </summary>
        <div class="mt-3 space-y-2">
          {features.capabilities.map(({ name, status, notes }) => (
            <div class="flex items-start justify-between rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2">
              <div class="min-w-0 flex-1 pr-3">
                <div class="text-sm text-zinc-200">{name}</div>
                {notes && <div class="mt-0.5 text-xs text-zinc-400">{notes}</div>}
              </div>
              <span
                class={`inline-flex shrink-0 whitespace-nowrap rounded-full border px-2.5 py-0.5 text-xs font-medium ${statusColors[status]}`}
              >
                {statusLabels[status]}
              </span>
            </div>
          ))}
        </div>
      </details>
    )
  }
</section>
