---
/**
 * FTC Affiliate Disclosure Component
 *
 * Required for FTC compliance when pages contain affiliate links.
 * Must be placed ABOVE THE FOLD (visible without scrolling) per FTC guidelines.
 *
 * Key requirements met:
 * - Clear and conspicuous disclosure
 * - Placed before any affiliate content
 * - Uses plain language
 * - Links to full disclosure policy
 *
 * @see https://www.ftc.gov/business-guidance/resources/disclosures-101-social-media-influencers
 * @module components/AffiliateDisclosure
 */

interface Props {
  variant?: 'banner' | 'inline' | 'compact';
  hasAffiliateLinks?: boolean;
}

const { variant = 'banner', hasAffiliateLinks = true } = Astro.props;
---

{
  hasAffiliateLinks && variant === 'banner' && (
    <div class="bg-zinc-900/50 border-b border-zinc-800 px-4 py-2 text-center text-xs text-zinc-500">
      <div class="container mx-auto max-w-7xl">
        <span>
          StackHunt is reader-supported. When you buy through links on our site, we may earn an
          affiliate commission.
          <a
            href="/disclosure"
            class="text-zinc-400 hover:text-zinc-300 underline underline-offset-2 ml-1"
          >
            Learn More
          </a>
        </span>
      </div>
    </div>
  )
}

{
  hasAffiliateLinks && variant === 'inline' && (
    <div class="rounded-lg bg-slate-50 border border-slate-200 px-4 py-3 text-sm text-slate-600 mb-6">
      <div class="flex items-start gap-3">
        <svg
          class="h-5 w-5 shrink-0 text-slate-400 mt-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          />
        </svg>
        <div>
          <p class="font-medium text-slate-700 mb-1">Affiliate Disclosure</p>
          <p>
            This page contains affiliate links. If you click through and make a purchase, we may
            receive a small commission at no additional cost to you. This helps support our
            independent research.
            <a href="/disclosure" class="text-hunt-600 hover:text-hunt-700 underline ml-1">
              Full disclosure policy
            </a>
          </p>
        </div>
      </div>
    </div>
  )
}

{
  hasAffiliateLinks && variant === 'compact' && (
    <p class="text-xs text-slate-500 mb-4">
      <svg
        class="inline h-3 w-3 mr-1"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
        />
      </svg>
      Some links are affiliate links.
      <a href="/disclosure" class="underline hover:text-slate-600">
        Disclosure
      </a>
    </p>
  )
}
