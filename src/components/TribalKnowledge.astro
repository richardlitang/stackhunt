---
import {
  filterGenericFrustrations,
  filterGenericStrengths,
  normalizeTextContent,
} from '../lib/utils/content-sanitizer';
import TwoColumnChecklistCards from './TwoColumnChecklistCards.astro';

interface Props {
  userAdvocate?: {
    vibe?: string | null;
    originStory?: string | null;
    idealFor: string[];
    avoidIf: string[];
    powerTip?: string | null;
    delighters: string[];
    frustrations: string[];
  };
  humanVerdict?: string | null;
}

const { userAdvocate, humanVerdict } = Astro.props;
if (!userAdvocate) return null;

const cleanList = (items: string[] | undefined, minLength = 10, limit = 4): string[] => {
  if (!Array.isArray(items)) return [];
  const seen = new Set<string>();
  const cleaned: string[] = [];

  for (const item of items) {
    if (typeof item !== 'string') continue;
    const normalized = normalizeTextContent(item);
    if (!normalized || normalized.length < minLength) continue;
    const key = normalized.toLowerCase();
    if (seen.has(key)) continue;
    seen.add(key);
    cleaned.push(normalized);
    if (cleaned.length >= limit) break;
  }

  return cleaned;
};

const strengths = cleanList(filterGenericStrengths(userAdvocate.delighters || []), 16, 4);
const concerns = cleanList(filterGenericFrustrations(userAdvocate.frustrations || []), 16, 4);
const practicalTip =
  typeof userAdvocate.powerTip === 'string' ? normalizeTextContent(userAdvocate.powerTip) : '';
const vibe = typeof userAdvocate.vibe === 'string' ? normalizeTextContent(userAdvocate.vibe) : '';
const originStory =
  typeof userAdvocate.originStory === 'string'
    ? normalizeTextContent(userAdvocate.originStory)
    : '';
const editorialTake =
  typeof humanVerdict === 'string' && humanVerdict.trim().length > 0
    ? normalizeTextContent(humanVerdict).replace(/\s+/g, ' ').slice(0, 260)
    : '';

if (
  strengths.length === 0 &&
  concerns.length === 0 &&
  practicalTip.length === 0 &&
  editorialTake.length === 0
) {
  return null;
}
---

<section class="tool-review-panel rounded-[1.8rem] p-6 shadow-sm transition-shadow hover:shadow-md">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-2">
    <h2 class="tool-review-section-title text-3xl">Field Notes</h2>
    {
      vibe && (
        <span class="rounded-full border border-zinc-700 bg-zinc-800 px-2.5 py-1 text-xs text-zinc-300">
          {vibe}
        </span>
      )
    }
  </div>

  {
    editorialTake && (
      <p class="tool-review-panel-muted mb-4 rounded-xl p-4 text-sm leading-relaxed text-zinc-300">
        {editorialTake}
      </p>
    )
  }

  {originStory && <p class="mb-4 text-sm text-zinc-400">{originStory}</p>}

  {
    (strengths.length > 0 || concerns.length > 0) && (
      <TwoColumnChecklistCards
        className=""
        headingClassName="text-sm font-semibold text-zinc-100"
        listClassName="mt-2 space-y-1.5 text-sm text-zinc-300"
        left={strengths.length > 0 ? { title: 'What Users Praise', items: strengths } : undefined}
        right={concerns.length > 0 ? { title: 'Common Friction', items: concerns } : undefined}
      />
    )
  }

  {
    practicalTip && (
      <div class="mt-4 rounded-lg border border-cyan-700/40 bg-cyan-950/20 p-4">
        <h3 class="text-sm font-semibold text-cyan-300">Practical Tip</h3>
        <p class="mt-2 text-sm text-zinc-200">{practicalTip}</p>
      </div>
    )
  }
</section>
