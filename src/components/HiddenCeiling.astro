---
/**
 * Hidden Ceiling Component
 *
 * Displays hard limits and hidden costs extracted from pricing pages.
 * Groups by severity (critical/high/medium/low) for visual hierarchy.
 */

import type { ToolConstraints } from '@/lib/knowledge-card';
import {
  evaluateConstraintSeverity,
  getSeverityColors,
  getConsequenceLabel,
  getConstraintTypeLabel,
  formatConstraintValue,
  groupConstraintsBySeverity,
} from '@/lib/pricing/constraints';

interface Props {
  constraints?: ToolConstraints | null;
  toolName: string;
}

const { constraints, toolName } = Astro.props;

if (!constraints || ((!constraints.hard_limits?.length) && (!constraints.hidden_costs?.length))) {
  return null;
}

const hardLimits = constraints.hard_limits || [];
const hiddenCosts = constraints.hidden_costs || [];
const groupedLimits = groupConstraintsBySeverity(hardLimits);
const severityOrder: Array<'critical' | 'high' | 'medium' | 'low'> = ['critical', 'high', 'medium', 'low'];
---

<div class="space-y-4">
  {hardLimits.length > 0 && (
    <div>
      <h3 class="mb-3 flex items-center gap-2 text-lg font-semibold text-zinc-100">
        <svg class="h-5 w-5 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        Hard Limits
      </h3>

      <div class="space-y-2">
        {severityOrder.map(severity => {
          const limits = groupedLimits.get(severity);
          if (!limits?.length) return null;
          const colors = getSeverityColors(severity);

          return limits.map(limit => (
            <div class:list={['rounded-lg border p-4', colors.bg, colors.border]}>
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1">
                  <div class="mb-1 flex items-center gap-2">
                    <span class:list={['text-sm font-semibold', colors.text]}>
                      {getConstraintTypeLabel(limit.type)}: {formatConstraintValue(limit.type, limit.value)}
                    </span>
                    <span class="rounded-full bg-zinc-800 px-2 py-0.5 text-xs text-zinc-400">
                      {getConsequenceLabel(limit.consequence)}
                    </span>
                  </div>
                  <p class="text-sm text-zinc-300">{limit.description}</p>
                  {limit.overage && (
                    <p class="mt-1 text-xs text-amber-400">
                      Overage: ${limit.overage.cost} {limit.overage.unit}
                    </p>
                  )}
                  {limit.plan_id && (
                    <p class="mt-1 text-xs text-zinc-500">
                      Plan: {limit.plan_id.split('-').slice(1).join(' ')}
                    </p>
                  )}
                </div>
                <a href={limit.source_url} target="_blank" rel="noopener" class:list={['text-xs hover:underline', colors.text]}>
                  Source →
                </a>
              </div>
            </div>
          ));
        })}
      </div>
    </div>
  )}

  {hiddenCosts.length > 0 && (
    <div>
      <h3 class="mb-3 flex items-center gap-2 text-lg font-semibold text-zinc-100">
        <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Hidden Costs
      </h3>

      <div class="space-y-2">
        {hiddenCosts.map(cost => (
          <div class="rounded-lg border border-zinc-700 bg-zinc-800/50 p-4">
            <div class="flex items-start justify-between gap-3">
              <div class="flex-1">
                <div class="mb-1 flex items-center gap-2">
                  <span class="text-sm font-semibold text-zinc-100">{cost.description}</span>
                  {cost.cost && (
                    <span class="rounded-full bg-zinc-700 px-2 py-0.5 text-xs text-zinc-300">
                      ${cost.cost}
                    </span>
                  )}
                </div>
                <p class="text-sm text-zinc-400">Trigger: {cost.trigger}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <div class="rounded-lg border border-zinc-700 bg-zinc-800/30 p-3">
    <p class="text-xs text-zinc-500">
      Constraints extracted from {toolName}'s pricing page. Verify current limits before purchasing.
    </p>
  </div>
</div>
