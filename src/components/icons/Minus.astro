---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class={className}
  fill="none"
  viewBox="0 0 24 24"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
>
  <line x1="5" y1="12" x2="19" y2="12"></line>
</svg>
