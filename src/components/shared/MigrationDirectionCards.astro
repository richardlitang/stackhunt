---
interface MigrationDirection {
  fromLabel: string;
  toLabel: string;
  canImport: boolean;
  difficultyLeaving?: number | null;
}

interface Props {
  directions: MigrationDirection[];
}

const { directions } = Astro.props as Props;
const validDirections = (Array.isArray(directions) ? directions : []).filter(
  (direction) =>
    direction &&
    typeof direction.fromLabel === 'string' &&
    typeof direction.toLabel === 'string' &&
    typeof direction.canImport === 'boolean'
);

if (validDirections.length === 0) {
  return null;
}
---

<div class="grid gap-6 lg:grid-cols-2">
  {
    validDirections.map((direction) => (
      <div
        class={`rounded-xl border p-5 ${direction.canImport ? 'border-green-700 bg-green-900/20' : 'border-zinc-700 bg-zinc-900'}`}
      >
        <h3 class="mb-3 text-sm font-medium text-zinc-300">
          {direction.fromLabel} → {direction.toLabel}
        </h3>
        {direction.canImport ? (
          <div class="flex items-center gap-2 text-green-400">
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"
              />
            </svg>
            <span class="text-sm">
              {direction.toLabel} can import from {direction.fromLabel}
            </span>
          </div>
        ) : (
          <div class="flex items-center gap-2 text-zinc-500">
            <svg
              class="h-5 w-5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span class="text-sm">Manual migration may be required</span>
          </div>
        )}
        {typeof direction.difficultyLeaving === 'number' && (
          <p class="mt-2 text-xs text-zinc-500">
            Difficulty leaving {direction.fromLabel}: {direction.difficultyLeaving}/5
          </p>
        )}
      </div>
    ))
  }
</div>
