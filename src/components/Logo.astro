---
/**
 * Logo Component - Brandfetch Hotlinking (TOS Compliant)
 *
 * Uses domain-based hotlinking to Brandfetch CDN.
 * Also handles direct image URLs from Supabase storage.
 *
 * Fallback chain:
 * 1. Direct URL (if Supabase storage) OR Brandfetch CDN (high-quality)
 * 2. Google Favicons (reliable fallback)
 * 3. DuckDuckGo (last resort)
 * 4. Initials (if all fail)
 *
 * @see src/lib/hunter/services/logo.ts for the data storage strategy
 */

interface Props {
  domain: string | null;
  name: string;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  class?: string;
  priority?: boolean; // For fetchpriority="high" on LCP images
}

const { domain, name, size = 'md', class: className = '', priority = false } = Astro.props;

const sizeClasses = {
  sm: 'h-8 w-8',
  md: 'h-12 w-12',
  lg: 'h-16 w-16',
  xl: 'h-20 w-20',
};

const sizePx = {
  sm: 32,
  md: 48,
  lg: 64,
  xl: 80,
};

const sizeClass = sizeClasses[size];

// Calculate initials for fallback (always needed)
const initials = name.charAt(0).toUpperCase();

// Check if domain is actually a full URL to an image (e.g., Supabase storage URL)
const isDirectImageUrl = domain?.includes('/storage/') || domain?.includes('.png') || domain?.includes('.jpg') || domain?.includes('.svg');

// Extract clean domain from input (handles both "notion.so" and "https://notion.so")
function cleanDomain(input: string | null): string | null {
  if (!input) return null;
  try {
    // If it looks like a URL, extract hostname
    if (input.includes('://')) {
      return new URL(input).hostname;
    }
    // Otherwise use as-is (already a domain)
    return input;
  } catch {
    return input;
  }
}

const cleanedDomain = isDirectImageUrl ? null : cleanDomain(domain);

// Brandfetch Client ID (from env - free tier, no attribution required)
const brandfetchId = import.meta.env.PUBLIC_BRANDFETCH_CLIENT_ID || '';

// Construct URLs dynamically
const directUrl = isDirectImageUrl ? domain : null;

const brandfetchUrl = cleanedDomain && brandfetchId
  ? `https://cdn.brandfetch.io/${cleanedDomain}?c=${brandfetchId}`
  : null;

const googleUrl = cleanedDomain
  ? `https://www.google.com/s2/favicons?domain=${cleanedDomain}&sz=128`
  : null;

const duckduckgoUrl = cleanedDomain
  ? `https://icons.duckduckgo.com/ip3/${cleanedDomain}.ico`
  : null;

// Primary: Direct URL (if available) OR Brandfetch if client ID available, else Google
const primarySrc = directUrl || brandfetchUrl || googleUrl;
---

{!domain ? (
  <div class={`${sizeClass} ${className} flex items-center justify-center rounded-lg bg-zinc-800 border border-zinc-700`}>
    <span class="text-xl font-bold text-zinc-400">{initials}</span>
  </div>
) : (
  <div class={`${sizeClass} ${className} flex items-center justify-center overflow-hidden rounded-lg bg-white border border-zinc-700/50`}>
    <img
      src={primarySrc}
      alt={`${name} logo`}
      width={sizePx[size]}
      height={sizePx[size]}
      class="h-full w-full object-contain p-2"
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : undefined}
      onerror={`
        if (this.src.includes('supabase') || this.src.includes('brandfetch')) {
          this.src = '${googleUrl}';
        } else if (this.src.includes('google')) {
          this.src = '${duckduckgoUrl}';
        } else {
          this.style.display = 'none';
          this.nextElementSibling.style.display = 'flex';
        }
      `}
    />
    <span class="hidden text-xl font-bold text-zinc-500">{initials}</span>
  </div>
)}

<style>
  img {
    transition: opacity 0.2s ease-in-out;
  }
  img[src=""] {
    opacity: 0;
  }
</style>
