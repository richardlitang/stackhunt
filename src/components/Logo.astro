---
/**
 * Logo Component - Compliant Hotlinking
 *
 * Uses Brandfetch CDN with proper hotlinking (TOS compliant)
 * Fallback chain: Brandfetch → Google Favicons → DuckDuckGo → Initials
 */

interface Props {
  domain: string | null;
  name: string;
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { domain, name, size = 'md', class: className = '' } = Astro.props;

const sizeClasses = {
  sm: 'h-8 w-8',
  md: 'h-12 w-12',
  lg: 'h-16 w-16',
};

const sizeClass = sizeClasses[size];

// Calculate initials for fallback (always needed)
const initials = name.charAt(0).toUpperCase();

// Check if domain is actually a full URL (e.g., Supabase storage URL)
const isFullUrl = domain?.startsWith('http://') || domain?.startsWith('https://');

// If it's a full URL, use it directly as primary source
const directUrl = isFullUrl ? domain : null;

// Extract domain from URL for fallback services (if full URL provided)
const extractedDomain = isFullUrl && domain
  ? new URL(domain).hostname
  : domain;

// Brandfetch Client ID (from env - free tier, no attribution required)
const brandfetchId = import.meta.env.PUBLIC_BRANDFETCH_CLIENT_ID || '';

// Primary: Direct URL (if provided) OR Brandfetch CDN (hotlink compliant)
const primaryUrl = directUrl || (extractedDomain && brandfetchId
  ? `https://cdn.brandfetch.io/${extractedDomain}?c=${brandfetchId}`
  : null);

// Fallback 1: Google Favicons
const googleUrl = extractedDomain ? `https://www.google.com/s2/favicons?domain=${extractedDomain}&sz=128` : null;

// Fallback 2: DuckDuckGo
const duckduckgoUrl = extractedDomain ? `https://icons.duckduckgo.com/ip3/${extractedDomain}.ico` : null;
---

{!domain ? (
  <div class={`${sizeClass} ${className} flex items-center justify-center rounded-lg bg-zinc-900`}>
    <span class="text-xl font-bold text-zinc-500">{initials}</span>
  </div>
) : (
  <div class={`${sizeClass} ${className} flex items-center justify-center overflow-hidden rounded-lg bg-zinc-900`}>
    <img
      src={primaryUrl}
      alt={`${name} logo`}
      class="h-full w-full object-contain p-1"
      loading="lazy"
      onerror={`
        if (this.src.includes('supabase') || this.src.includes('brandfetch')) {
          this.src = '${googleUrl}';
        } else if (this.src.includes('google')) {
          this.src = '${duckduckgoUrl}';
        } else {
          this.style.display = 'none';
          this.nextElementSibling.style.display = 'flex';
        }
      `}
    />
    <span class="hidden text-xl font-bold text-zinc-500">{initials}</span>
  </div>
)}

<style>
  img {
    transition: opacity 0.2s ease-in-out;
  }
  img[src=""] {
    opacity: 0;
  }
</style>
