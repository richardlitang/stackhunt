---
import { formatPricingType, getPricingColor } from '@/lib/utils';

interface Props {
  type: string;
  size?: 'sm' | 'md';
}

const { type, size = 'md' } = Astro.props;
const colorClass = getPricingColor(type);

const sizeClasses = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
};
---

<span
  class:list={[
    'inline-flex items-center rounded-full font-medium',
    sizeClasses[size],
    colorClass,
  ]}
>
  {formatPricingType(type)}
</span>
