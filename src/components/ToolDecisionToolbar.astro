---
import ReviewLensSwitch from '@/components/ReviewLensSwitch.astro';

type ReviewLens = 'general' | 'personal' | 'startup' | 'enterprise';

interface Props {
  activeLens: ReviewLens;
  lensHrefs: Record<ReviewLens, string>;
  jumpLinks: Array<{ href: string; label: string }>;
}

const { activeLens, lensHrefs, jumpLinks } = Astro.props;
---

<section class="tool-review-panel-muted rounded-2xl p-4">
  <p class="tool-review-micro-label mb-3">Navigation</p>
  <ReviewLensSwitch activeLens={activeLens} hrefs={lensHrefs} compact showNote={false} />
  {
    jumpLinks.length > 0 && (
      <nav class="mt-3 border-t border-zinc-800 pt-3" aria-label="Decision section links">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Jump to</p>
        <div class="flex flex-wrap gap-2">
          {jumpLinks.map((link) => (
            <a
              href={link.href}
              class="rounded-full border border-zinc-700 bg-zinc-950/80 px-3 py-1 text-xs font-medium text-zinc-300 transition hover:border-amber-400/60 hover:text-amber-200"
            >
              {link.label}
            </a>
          ))}
        </div>
      </nav>
    )
  }
</section>
