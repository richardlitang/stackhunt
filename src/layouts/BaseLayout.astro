---
import type { MetaProps } from '@/lib/seo';
import { generateOrganizationSchema, generateWebSiteSchema } from '@/lib/seo';
import MyStackWidget from '@/components/MyStackWidget';
import '@/styles/globals.css';

interface Props {
  meta: MetaProps;
  schemas?: Record<string, unknown>[];
}

const { meta, schemas = [] } = Astro.props;

const allSchemas = [
  generateOrganizationSchema(),
  generateWebSiteSchema(),
  ...schemas,
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{meta.title}</title>
    <meta name="title" content={meta.title} />
    <meta name="description" content={meta.description} />
    {meta.noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Canonical -->
    <link rel="canonical" href={meta.canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={meta.ogType || 'website'} />
    <meta property="og:url" content={meta.canonical} />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    {meta.ogImage && <meta property="og:image" content={meta.ogImage} />}

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={meta.canonical} />
    <meta property="twitter:title" content={meta.title} />
    <meta property="twitter:description" content={meta.description} />
    {meta.ogImage && <meta property="twitter:image" content={meta.ogImage} />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <!-- Umami Analytics -->
    <script defer src="https://analytics.stackhunt.io/script.js" data-website-id="9836274c-fc2c-4279-854a-1f50c05faf3c"></script>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Preload critical font for LCP optimization -->
    <link
      rel="preload"
      href="https://fonts.gstatic.com/s/inter/v13/UcCO3FwrK3iLTeHuS_fvQtMwCp50KnMw2boKoduKmMEVuLyfAZ9hiA.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- JSON-LD Schemas -->
    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <!-- Header -->
    <header class="sticky top-0 z-50 border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-lg">
      <nav class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2">
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-500">
            <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
          </div>
          <span class="text-lg font-semibold text-zinc-100">Stack<span class="text-indigo-400">Hunt</span></span>
        </a>

        <!-- Nav Links -->
        <div class="flex items-center gap-4">
          <a href="/categories" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
            Categories
          </a>
          <a href="/best" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
            Lists
          </a>
          <a href="/tools" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
            Tools
          </a>
        </div>
      </nav>
    </header>

    <!-- Main Content -->
    <main>
      <slot />
    </main>

    <!-- My Stack Widget (floating) -->
    <MyStackWidget client:load />

    <!-- Footer -->
    <footer class="border-t border-zinc-800 bg-zinc-900">
      <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <!-- Brand -->
        <div class="mb-8">
          <a href="/" class="flex items-center gap-2">
            <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-500">
              <svg class="h-4 w-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
            </div>
            <span class="text-lg font-semibold text-zinc-100">Stack<span class="text-indigo-400">Hunt</span></span>
          </a>
          <p class="mt-2 max-w-md text-sm text-zinc-500">
            AI-powered software research platform. Find the right tools for your stack.
          </p>
        </div>

        <!-- 4-Column Links -->
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <!-- Product -->
          <div>
            <h3 class="text-sm font-semibold text-zinc-100 mb-3">Product</h3>
            <ul class="space-y-2">
              <li><a href="/categories" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Browse Categories</a></li>
              <li><a href="/compare" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Compare Tools</a></li>
              <li><a href="/tools" class="text-sm text-zinc-500 hover:text-indigo-400 transition">All Tools</a></li>
              <li><a href="/best" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Best Lists</a></li>
            </ul>
          </div>

          <!-- Company -->
          <div>
            <h3 class="text-sm font-semibold text-zinc-100 mb-3">Company</h3>
            <ul class="space-y-2">
              <li><a href="/about" class="text-sm text-zinc-500 hover:text-indigo-400 transition">About StackHunt</a></li>
              <li><a href="/methodology" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Methodology</a></li>
              <li><a href="/contact" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Contact</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="text-sm font-semibold text-zinc-100 mb-3">Legal</h3>
            <ul class="space-y-2">
              <li><a href="/privacy" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Privacy Policy</a></li>
              <li><a href="/terms" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Terms of Service</a></li>
              <li><a href="/disclosure" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Affiliate Disclosure</a></li>
            </ul>
          </div>

          <!-- Top Categories (SEO) -->
          <div>
            <h3 class="text-sm font-semibold text-zinc-100 mb-3">Popular</h3>
            <ul class="space-y-2">
              <li><a href="/best/crm-for-startups" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Best CRM for Startups</a></li>
              <li><a href="/best/project-management" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Best PM Software</a></li>
              <li><a href="/categories/developers" class="text-sm text-zinc-500 hover:text-indigo-400 transition">Tools for Developers</a></li>
            </ul>
          </div>
        </div>

        <!-- Legal Disclaimer -->
        <div class="mt-10 border-t border-zinc-800 pt-8 bg-zinc-900/50 -mx-4 px-4 sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
          <div class="mx-auto max-w-7xl">
            <p class="text-xs text-zinc-600 leading-relaxed mb-4">
              <strong class="text-zinc-500">Disclaimer:</strong> StackHunt is an independent research platform. Pricing, features, and verdicts are synthesized by AI from public data. While we refresh data every 30-60 days, software terms change rapidly. Always verify final costs on the vendor's official website.
            </p>
            <p class="text-xs text-zinc-600 leading-relaxed mb-4">
              <strong class="text-zinc-500">Content Attribution:</strong> We reference and cite third-party reviews under fair use for purposes of comparison and commentary. All claims are synthesized from multiple sources and attributed with proper links. We do not copy review text verbatim.
            </p>
            <p class="text-xs text-zinc-600 leading-relaxed mb-4">
              <strong class="text-zinc-500">Affiliate Notice:</strong> We may earn a commission when you click our links. This does not impact our data-driven rankings or Fit Scores. <a href="/disclosure" class="text-zinc-500 hover:text-zinc-400 underline">View our full Disclosure Policy</a>.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3 pt-4 border-t border-zinc-800">
              <p class="text-xs text-zinc-600">
                &copy; {new Date().getFullYear()} StackHunt Research. Built for Founders, by Founders.
              </p>
              <p class="text-xs text-zinc-600">
                Global Data • AI-Powered Research
              </p>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* Custom scrollbar */
  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }
  ::-webkit-scrollbar-track {
    background: #18181b;
  }
  ::-webkit-scrollbar-thumb {
    background: #3f3f46;
    border-radius: 3px;
  }
  ::-webkit-scrollbar-thumb:hover {
    background: #52525b;
  }
</style>
