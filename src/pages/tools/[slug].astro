---
/**
 * Tool Detail Page - /tools/[slug]
 * The "Hub" in our Hub & Spoke model
 *
 * Features:
 * - ProductHunt-style layout
 * - SEO: SoftwareApplication JSON-LD
 * - Spiderweb internal linking to all contexts
 * - Affiliate CTA with proper disclosure
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ScoreBadge from '@/components/ScoreBadge.astro';
import PricingBadge from '@/components/PricingBadge.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import SpiderwebGrid from '@/components/SpiderwebGrid.astro';
import SentimentTags from '@/components/SentimentTags.astro';
import VoteWidget from '@/components/VoteWidget';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import {
  getToolBySlug,
  getToolContexts,
  getToolTags,
  getAllToolSlugs,
} from '@/lib/supabase';
import {
  generateToolMeta,
  generateToolSchema,
  generateBreadcrumbSchema,
} from '@/lib/seo';
import { simpleMarkdown } from '@/lib/utils';

// Prerender for sitemap inclusion and performance
export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getAllToolSlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Fetch tool data
const tool = await getToolBySlug(slug);

if (!tool) {
  return Astro.redirect('/404');
}

// Fetch all contexts this tool appears in (the "Spiderweb")
const contextLinks = await getToolContexts(tool.id);

// Fetch Knowledge Graph tags
const tags = await getToolTags(tool.id);

// Get primary affiliate offer
const primaryOffer = tool.affiliate_offers?.find((o) => o.is_primary) || tool.affiliate_offers?.[0];

// Get the first review for pros/cons (or aggregate later)
const firstReview = tool.reviews?.[0];

// Extract unique source domains for display (text-only, no links)
const sourceDomains = firstReview?.sources
  ? [...new Set((firstReview.sources as Array<{domain: string}>).map(s => {
      const domain = s.domain.replace(/\.(com|org|net|io|co)$/, '');
      return domain.charAt(0).toUpperCase() + domain.slice(1);
    }))].slice(0, 5)
  : [];

// Generate SEO
const meta = generateToolMeta(tool, tool.review_count);
const schemas = [
  generateToolSchema(tool, primaryOffer, tool.review_count),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools' },
    ...(tool.category ? [{ name: tool.category.name, url: `/categories/${tool.category.slug}` }] : []),
    { name: tool.name, url: `/tools/${tool.slug}` },
  ]),
];

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<BaseLayout meta={meta} schemas={schemas}>
  {/* FTC Affiliate Disclosure - Above the fold */}
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={primaryOffer?.is_affiliate || false} />

  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-slate-500">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/tools" class="hover:text-hunt-500">Tools</a>
      {tool.category && (
        <>
          <span>/</span>
          <a href={`/categories/${tool.category.slug}`} class="hover:text-hunt-500">
            {tool.category.name}
          </a>
        </>
      )}
      <span>/</span>
      <span class="text-slate-700">{tool.name}</span>
    </nav>

    <!-- Hero Section -->
    <header class="mb-8 rounded-2xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-6 sm:p-8">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <!-- Left: Logo & Info -->
        <div class="flex items-start gap-5">
          <div class="flex h-20 w-20 shrink-0 items-center justify-center overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
            {tool.logo_url ? (
              <img
                src={tool.logo_url}
                alt={`${tool.name} logo`}
                class="h-full w-full object-contain p-2"
              />
            ) : (
              <span class="text-3xl font-bold text-slate-300">
                {tool.name.charAt(0)}
              </span>
            )}
          </div>

          <div>
            <div class="flex items-center gap-3">
              <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">
                {tool.name}
              </h1>
              {tool.is_verified && (
                <span class="flex items-center gap-1 rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
                  <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Verified
                </span>
              )}
            </div>

            {tool.short_description && (
              <p class="mt-2 text-slate-600">{tool.short_description}</p>
            )}

            <div class="mt-3 flex flex-wrap items-center gap-3">
              <PricingBadge type={tool.pricing_type} />

              {tool.category && (
                <a
                  href={`/categories/${tool.category.slug}`}
                  class="text-sm text-slate-500 hover:text-hunt-500"
                >
                  {tool.category.name}
                </a>
              )}

              {tool.website && (
                <a
                  href={tool.website}
                  target="_blank"
                  rel="noopener"
                  class="flex items-center gap-1 text-sm text-slate-500 hover:text-hunt-500"
                >
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  Website
                </a>
              )}
            </div>

            {/* Knowledge Graph Tags */}
            {(tags.functions.length > 0 || tags.audiences.length > 0 || tags.platforms.length > 0) && (
              <div class="mt-4 flex flex-wrap gap-2">
                {tags.functions.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800">
                    {tag.name}
                  </span>
                ))}
                {tags.audiences.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                    {tag.name}
                  </span>
                ))}
                {tags.platforms.map((tag) => (
                  <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800">
                    {tag.name}
                  </span>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- Right: Score & CTA -->
        <div class="flex flex-col items-center gap-4 sm:items-end">
          {tool.avg_score > 0 && (
            <ScoreBadge score={Math.round(tool.avg_score)} size="lg" showLabel />
          )}

          {primaryOffer && (
            <AffiliateButton offer={primaryOffer} toolName={tool.name} size="md" />
          )}

          <div class="flex gap-2">
            <CompareButton
              client:load
              toolSlug={tool.slug}
              toolName={tool.name}
              toolLogo={tool.logo_url}
            />
            <AddToStackButton
              client:load
              toolSlug={tool.slug}
              toolName={tool.name}
              toolLogo={tool.logo_url}
              pricing={{
                starting_price: (tool.metadata as Record<string, unknown>)?.pricing?.starting_price ?? null,
                model: (tool.metadata as Record<string, unknown>)?.pricing?.model ?? tool.pricing_type,
              }}
            />
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Grid -->
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Left Column (2/3) -->
      <div class="space-y-8 lg:col-span-2">
        <!-- Pros & Cons -->
        {firstReview && (firstReview.pros?.length > 0 || firstReview.cons?.length > 0) && (
          <ProsCons
            pros={firstReview.pros || []}
            cons={firstReview.cons || []}
            title="Pros & Cons"
          />
        )}

        <!-- Review Summary -->
        {firstReview?.summary_markdown && (
          <section class="rounded-xl border border-slate-200 bg-white p-6">
            <h2 class="mb-4 text-lg font-semibold text-slate-900">Our Analysis</h2>
            <div
              class="prose prose-slate prose-sm max-w-none"
              set:html={simpleMarkdown(firstReview.summary_markdown)}
            />

            {firstReview.sentiment_tags?.length > 0 && (
              <div class="mt-6 border-t border-slate-100 pt-4">
                <SentimentTags tags={firstReview.sentiment_tags} />
              </div>
            )}

            {/* Vote Widget for this review */}
            <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-4">
              <span class="text-sm text-slate-500">Was this helpful?</span>
              <VoteWidget
                client:visible
                reviewId={firstReview.id}
                initialUpvotes={firstReview.upvotes}
                initialDownvotes={firstReview.downvotes}
                turnstileSiteKey={turnstileSiteKey}
              />
            </div>

            {/* Sources & Suggest Edit */}
            <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
              {/* Sources - text only, no links to competitors */}
              {sourceDomains.length > 0 && (
                <div class="flex items-center gap-2 text-xs text-slate-400">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>Sources: {sourceDomains.join(', ')}</span>
                </div>
              )}

              {/* Suggest Edit link */}
              <button
                type="button"
                data-suggest-edit
                data-tool-id={tool.id}
                data-tool-name={tool.name}
                class="text-xs text-slate-400 hover:text-hunt-600 transition"
              >
                See something wrong? Suggest an edit
              </button>
            </div>
          </section>
        )}

        <!-- Detailed Description -->
        {tool.long_description && (
          <section class="rounded-xl border border-slate-200 bg-white p-6">
            <h2 class="mb-4 text-lg font-semibold text-slate-900">About {tool.name}</h2>
            <div
              class="prose prose-slate prose-sm max-w-none"
              set:html={simpleMarkdown(tool.long_description)}
            />
          </section>
        )}
      </div>

      <!-- Right Column (1/3) - Sidebar -->
      <div class="space-y-6">
        <!-- Quick Stats -->
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="mb-4 font-semibold text-slate-900">Quick Stats</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Overall Score</dt>
              <dd class="text-sm font-medium text-slate-900">
                {tool.avg_score > 0 ? `${Math.round(tool.avg_score)}/100` : 'N/A'}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Pricing</dt>
              <dd class="text-sm font-medium text-slate-900 capitalize">
                {tool.pricing_type.replace('_', ' ')}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Reviews</dt>
              <dd class="text-sm font-medium text-slate-900">{tool.review_count}</dd>
            </div>
            {tool.category && (
              <div class="flex justify-between">
                <dt class="text-sm text-slate-500">Category</dt>
                <dd class="text-sm font-medium text-slate-900">{tool.category.name}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Alternative Offers -->
        {tool.affiliate_offers && tool.affiliate_offers.length > 1 && (
          <div class="rounded-xl border border-slate-200 bg-white p-5">
            <h3 class="mb-4 font-semibold text-slate-900">Get {tool.name}</h3>
            <div class="space-y-3">
              {tool.affiliate_offers.map((offer) => (
                <a
                  href={offer.url}
                  target="_blank"
                  rel={offer.is_affiliate ? 'nofollow sponsored noopener' : 'noopener'}
                  class="flex items-center justify-between rounded-lg border border-slate-100 p-3 transition hover:border-hunt-200 hover:bg-hunt-50"
                >
                  <span class="text-sm font-medium text-slate-700">{offer.cta_text}</span>
                  <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    <!-- Spiderweb Section: All contexts this tool appears in -->
    {contextLinks && contextLinks.length > 0 && (
      <div class="mt-10">
        <SpiderwebGrid
          contexts={contextLinks.map((cl) => ({
            id: cl.context.id,
            title: cl.context.title,
            slug: cl.context.slug,
            score: cl.score,
            tool_count: cl.context.tool_count,
          }))}
          currentToolName={tool.name}
          limit={9}
        />
      </div>
    )}
  </div>

  <!-- Suggest Edit Modal -->
  <div id="suggest-edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-slate-900">Suggest an Edit</h3>
        <button type="button" data-close-modal class="text-slate-400 hover:text-slate-600">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="suggest-edit-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={tool.id} />

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">What needs correcting?</label>
          <select name="field_name" class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20">
            <option value="pricing">Pricing information</option>
            <option value="pros">Pros</option>
            <option value="cons">Cons</option>
            <option value="summary">Summary/description</option>
            <option value="score">Score seems off</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">What's the correct information?</label>
          <textarea
            name="correction_text"
            rows="3"
            required
            placeholder="e.g., The pricing has changed to $15/month..."
            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          ></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Your email (optional)</label>
          <input
            type="email"
            name="reporter_email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          />
          <p class="mt-1 text-xs text-slate-400">We'll notify you when the correction is reviewed</p>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 rounded-lg bg-hunt-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-hunt-700 transition"
          >
            Submit Suggestion
          </button>
          <button
            type="button"
            data-close-modal
            class="rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition"
          >
            Cancel
          </button>
        </div>
      </form>

      <div id="suggest-edit-success" class="hidden text-center py-4">
        <svg class="mx-auto h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-3 text-sm text-slate-600">Thanks! We'll review your suggestion.</p>
        <button type="button" data-close-modal class="mt-4 text-sm text-hunt-600 hover:text-hunt-700">Close</button>
      </div>
    </div>
  </div>

  <script is:inline>
    // Suggest Edit Modal Logic
    const modal = document.getElementById('suggest-edit-modal');
    const form = document.getElementById('suggest-edit-form');
    const success = document.getElementById('suggest-edit-success');

    // Open modal
    document.querySelectorAll('[data-suggest-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        form?.classList.remove('hidden');
        success?.classList.add('hidden');
      });
    });

    // Close modal
    document.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      });
    });

    // Close on backdrop click
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });

    // Form submission
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      try {
        const res = await fetch('/api/corrections', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          form.reset();
        } else {
          alert('Failed to submit. Please try again.');
        }
      } catch (err) {
        alert('Network error. Please try again.');
      }
    });
  </script>
</BaseLayout>
