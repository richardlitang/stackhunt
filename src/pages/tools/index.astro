---
/**
 * Tools Index - /tools
 * Browse all tools with pagination
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import { supabase, getCategories } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Cache for 5 minutes (SSR)
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=300, s-maxage=300, stale-while-revalidate=600'
);

// Pagination settings
const ITEMS_PER_PAGE = 24;
const MIN_SEARCH_QUERY_LENGTH = 2;
const MAX_SEARCH_QUERY_LENGTH = 64;

// Get filter from URL
const url = new URL(Astro.request.url);
const categoryFilter = url.searchParams.get('category');
const sortBy = url.searchParams.get('sort') || 'score';
const rawPage = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const rawSearchQuery = (url.searchParams.get('q') || '').trim();
const searchQuery = rawSearchQuery.slice(0, MAX_SEARCH_QUERY_LENGTH).replace(/\s+/g, ' ').trim();
const hasSearchQuery = searchQuery.length >= MIN_SEARCH_QUERY_LENGTH;
const activeCategoryFilter = hasSearchQuery ? null : categoryFilter;
const page = hasSearchQuery ? 1 : rawPage;

// Calculate offset
const offset = (page - 1) * ITEMS_PER_PAGE;

// First get total count (software tools only)
let totalCount = 0;
let categoryRecord: { id: string; name: string; slug: string } | null = null;

if (!hasSearchQuery && activeCategoryFilter) {
  const { data: category } = await supabase
    .from('categories')
    .select('id, name, slug')
    .eq('slug', activeCategoryFilter)
    .maybeSingle();
  categoryRecord = category || null;

  if (categoryRecord) {
    const { count } = await supabase
      .from('item_category_links')
      .select('id, item:items!inner(type)', { count: 'exact', head: true })
      .eq('category_id', categoryRecord.id)
      .eq('item.type', 'tool');
    totalCount = count || 0;
  }
} else if (!hasSearchQuery) {
  const { count } = await supabase
    .from('tools')
    .select('id', { count: 'exact', head: true })
    .eq('type', 'tool');
  totalCount = count || 0;
}
const totalPages = Math.ceil((totalCount || 0) / ITEMS_PER_PAGE);

// Fetch tools with pagination (software tools only)
let tools: any[] = [];

if (hasSearchQuery) {
  let query = supabase
    .from('tools')
    .select(
      `
      id, name, slug, logo_url, short_description, avg_score, pricing_type, type,
      item_category_links(
        relevance_score,
        category:categories(name, slug)
      )
    `
    )
    .eq('type', 'tool')
    .ilike('name', `%${searchQuery}%`)
    .order('relevance_score', { foreignTable: 'item_category_links', ascending: false })
    .limit(1, { foreignTable: 'item_category_links' })
    .limit(ITEMS_PER_PAGE);

  if (sortBy === 'score') {
    query = query.order('avg_score', { ascending: false, nullsFirst: false });
  } else if (sortBy === 'name') {
    query = query.order('name', { ascending: true });
  } else if (sortBy === 'newest') {
    query = query.order('created_at', { ascending: false });
  }

  const { data } = await query;
  tools = (data || []).map((tool: any) => ({
    ...tool,
    category: tool.item_category_links?.[0]?.category || null,
  }));
  totalCount = tools.length;
} else if (activeCategoryFilter && categoryRecord) {
  let query = supabase
    .from('item_category_links')
    .select(
      `
      relevance_score,
      item:items(
        id, name, slug, logo_url, short_description, avg_score, pricing_type, type
      )
    `
    )
    .eq('category_id', categoryRecord.id)
    .eq('item.type', 'tool');

  if (sortBy === 'score') {
    query = query.order('avg_score', { ascending: false, nullsFirst: false, foreignTable: 'item' });
  } else if (sortBy === 'name') {
    query = query.order('name', { ascending: true, foreignTable: 'item' });
  } else if (sortBy === 'newest') {
    query = query.order('created_at', { ascending: false, foreignTable: 'item' });
  }

  const { data } = await query.range(offset, offset + ITEMS_PER_PAGE - 1);
  tools = (data || [])
    .map((link: any) => link.item)
    .filter(Boolean)
    .map((tool: any) => ({
      ...tool,
      category: categoryRecord,
    }));
} else {
  let query = supabase
    .from('tools')
    .select(
      `
      id, name, slug, logo_url, short_description, avg_score, pricing_type, type,
      item_category_links(
        relevance_score,
        category:categories(name, slug)
      )
    `
    )
    .eq('type', 'tool')
    .order('relevance_score', { foreignTable: 'item_category_links', ascending: false })
    .limit(1, { foreignTable: 'item_category_links' });

  if (sortBy === 'score') {
    query = query.order('avg_score', { ascending: false, nullsFirst: false });
  } else if (sortBy === 'name') {
    query = query.order('name', { ascending: true });
  } else if (sortBy === 'newest') {
    query = query.order('created_at', { ascending: false });
  }

  const { data } = await query.range(offset, offset + ITEMS_PER_PAGE - 1);
  tools = (data || []).map((tool: any) => ({
    ...tool,
    category: tool.item_category_links?.[0]?.category || null,
  }));
}
const categories = await getCategories();

// Build page URL helper
function buildPageUrl(pageNum: number) {
  const params = new URLSearchParams();
  if (hasSearchQuery) params.set('q', searchQuery);
  if (activeCategoryFilter) params.set('category', activeCategoryFilter);
  if (sortBy !== 'score') params.set('sort', sortBy);
  if (!hasSearchQuery && pageNum > 1) params.set('page', pageNum.toString());
  const queryString = params.toString();
  return queryString ? `/tools?${queryString}` : '/tools';
}

const meta = {
  title:
    hasSearchQuery
      ? `Search: ${searchQuery} | StackHunt`
      : page > 1
      ? `All Software Tools - Page ${page} | StackHunt`
      : 'All Software Tools - Browse Our Directory | StackHunt',
  description:
    hasSearchQuery
      ? `Search results for "${searchQuery}".`
      : 'Browse our complete directory of software tools. Filter by category, compare features, and find the best tools for your stack.',
  canonical: getCanonicalUrl(buildPageUrl(page)),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-3xl font-semibold text-zinc-100">All Tools</h1>
      <p class="mt-2 text-zinc-400">
        {
          hasSearchQuery
            ? `Search results for "${searchQuery}" (showing up to ${ITEMS_PER_PAGE} matches)`
            : `Browse ${totalCount || 0} tools in our directory`
        }
      </p>
    </header>

    <!-- Search -->
    <form action="/tools" method="get" class="mb-6">
      <input type="hidden" name="sort" value={sortBy} />
      <label for="tools-search" class="sr-only">Search tools by name</label>
      <div class="relative max-w-xl">
        <input
          id="tools-search"
          name="q"
          value={searchQuery}
          minlength={MIN_SEARCH_QUERY_LENGTH}
          maxlength={MAX_SEARCH_QUERY_LENGTH}
          placeholder="Search tools by name..."
          class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 placeholder-zinc-500 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/50"
        />
      </div>
      <p class="mt-2 text-xs text-zinc-500">
        Search is capped to {ITEMS_PER_PAGE} results per request to control query cost.
      </p>
    </form>

    <!-- Filters -->
    <div class="mb-8 flex flex-wrap items-center gap-4">
      <!-- Category Filter -->
      <div class="flex items-center gap-2">
        <label class="text-sm font-medium text-zinc-400">Category:</label>
        <select
          id="category-filter"
          disabled={hasSearchQuery}
          class:list={[
            'rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/50',
            hasSearchQuery && 'cursor-not-allowed opacity-60',
          ]}
          onchange="const params=new URLSearchParams(window.location.search); if (this.value) params.set('category', this.value); else params.delete('category'); params.delete('page'); window.location.search=params.toString();"
        >
          <option value="">All Categories</option>
          {
            categories.map((cat) => (
              <option value={cat.slug} selected={activeCategoryFilter === cat.slug}>
                {cat.name}
              </option>
            ))
          }
        </select>
      </div>

      <!-- Sort -->
      <div class="flex items-center gap-2">
        <label class="text-sm font-medium text-zinc-400">Sort by:</label>
        <select
          id="sort-filter"
          class="rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-sm text-zinc-100 focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500/50"
          onchange="const params=new URLSearchParams(window.location.search); params.set('sort', this.value); params.delete('page'); window.location.search=params.toString();"
        >
          <option value="score" selected={sortBy === 'score'}>Highest Score</option>
          <option value="name" selected={sortBy === 'name'}>Name (A-Z)</option>
          <option value="newest" selected={sortBy === 'newest'}>Newest</option>
        </select>
      </div>
    </div>

    <!-- Tools Grid -->
    {
      tools && tools.length > 0 ? (
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {tools.map((tool) => (
            <ToolCard tool={tool} category={tool.category} />
          ))}
        </div>
      ) : (
        <div class="rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-12 text-center">
          <svg
            class="mx-auto h-12 w-12 text-zinc-600"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
            />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-zinc-100">No tools found</h3>
          <p class="mt-2 text-sm text-zinc-500">
            {hasSearchQuery
              ? 'No name matches found. Try a different tool name.'
              : activeCategoryFilter
              ? 'No tools in this category. Try another filter.'
              : 'Check back soon for more tools!'}
          </p>
        </div>
      )
    }

    <!-- Pagination -->
    {
      !hasSearchQuery && totalPages > 1 && (
        <nav class="mt-10 flex items-center justify-center gap-2" aria-label="Pagination">
          {/* Previous */}
          {page > 1 ? (
            <a
              href={buildPageUrl(page - 1)}
              class="rounded-lg border border-zinc-700 bg-zinc-900/50 px-3 py-2 text-sm text-zinc-400 transition hover:border-zinc-600 hover:bg-zinc-800/50 hover:text-zinc-100"
            >
              ← Previous
            </a>
          ) : (
            <span class="rounded-lg border border-zinc-800 bg-zinc-900/30 px-3 py-2 text-sm text-zinc-600 cursor-not-allowed">
              ← Previous
            </span>
          )}

          {/* Page numbers */}
          <div class="flex items-center gap-1">
            {Array.from({ length: totalPages }, (_, i) => i + 1)
              .filter((p) => p === 1 || p === totalPages || (p >= page - 1 && p <= page + 1))
              .map((p, idx, arr) => (
                <>
                  {idx > 0 && arr[idx - 1] !== p - 1 && <span class="px-2 text-zinc-600">...</span>}
                  {p === page ? (
                    <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-indigo-500 text-sm font-medium text-white">
                      {p}
                    </span>
                  ) : (
                    <a
                      href={buildPageUrl(p)}
                      class="flex h-9 w-9 items-center justify-center rounded-lg border border-zinc-700 bg-zinc-900/50 text-sm text-zinc-400 transition hover:border-zinc-600 hover:bg-zinc-800/50 hover:text-zinc-100"
                    >
                      {p}
                    </a>
                  )}
                </>
              ))}
          </div>

          {/* Next */}
          {page < totalPages ? (
            <a
              href={buildPageUrl(page + 1)}
              class="rounded-lg border border-zinc-700 bg-zinc-900/50 px-3 py-2 text-sm text-zinc-400 transition hover:border-zinc-600 hover:bg-zinc-800/50 hover:text-zinc-100"
            >
              Next →
            </a>
          ) : (
            <span class="rounded-lg border border-zinc-800 bg-zinc-900/30 px-3 py-2 text-sm text-zinc-600 cursor-not-allowed">
              Next →
            </span>
          )}
        </nav>
      )
    }
  </div>
</BaseLayout>
