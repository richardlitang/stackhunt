---
/**
 * Gear Detail Page - /gear/[slug]
 * Hardware items only (type='gear')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ScoreBadge from '@/components/ScoreBadge.astro';
import PricingBadge from '@/components/PricingBadge.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import SpiderwebGrid from '@/components/SpiderwebGrid.astro';
import SentimentTags from '@/components/SentimentTags.astro';
import VoteWidget from '@/components/VoteWidget';
import VideoEmbed from '@/components/VideoEmbed';
import {
  getToolBySlugAndType,
  getToolContexts,
  getToolTags,
  getToolSlugsByType,
} from '@/lib/supabase';
import { generateToolMeta, generateToolSchema, generateBreadcrumbSchema } from '@/lib/seo';
import { simpleMarkdown } from '@/lib/utils';

export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getToolSlugsByType('gear');
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const gear = await getToolBySlugAndType(slug, 'gear');

if (!gear) {
  return Astro.redirect('/404');
}

const contextLinks = await getToolContexts(gear.id);
const tags = await getToolTags(gear.id);
const primaryOffer = gear.affiliate_offers?.find((o) => o.is_primary) || gear.affiliate_offers?.[0];
const firstReview = gear.reviews?.[0];

const sourceDomains = firstReview?.sources
  ? [
      ...new Set(
        (firstReview.sources as Array<{ domain?: string; url?: string }>)
          .map((s) => {
            const rawDomain =
              s.domain ||
              (() => {
                if (!s.url) return '';
                try {
                  return new URL(s.url).hostname.replace(/^www\./, '');
                } catch {
                  return '';
                }
              })();
            if (!rawDomain) return '';
            const domain = rawDomain.replace(/\.(com|org|net|io|co)$/, '');
            return domain.charAt(0).toUpperCase() + domain.slice(1);
          })
          .filter(Boolean)
      ),
    ].slice(0, 5)
  : [];

const meta = generateToolMeta(gear, gear.review_count);
const schemas = [
  generateToolSchema(gear, primaryOffer, gear.review_count),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Gear', url: '/gear' },
    ...(gear.category
      ? [{ name: gear.category.name, url: `/categories/${gear.category.slug}` }]
      : []),
    { name: gear.name, url: `/gear/${gear.slug}` },
  ]),
];

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<BaseLayout meta={meta} schemas={schemas}>
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={primaryOffer?.is_affiliate || false} />

  <div class="mx-auto max-w-5xl px-4 py-8 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-slate-500">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/gear" class="hover:text-hunt-500">Gear</a>
      {
        gear.category && (
          <>
            <span>/</span>
            <a href={`/categories/${gear.category.slug}`} class="hover:text-hunt-500">
              {gear.category.name}
            </a>
          </>
        )
      }
      <span>/</span>
      <span class="text-slate-700">{gear.name}</span>
    </nav>

    <!-- Hero Section -->
    <header
      class="mb-8 rounded-2xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-6 sm:p-8"
    >
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-5">
          <Logo
            domain={gear.logo_url}
            name={gear.name}
            size="xl"
            class="shrink-0 rounded-2xl border border-slate-200 shadow-sm"
          />
          <div>
            <div class="flex items-center gap-3">
              <h1 class="text-2xl font-bold text-slate-900 sm:text-3xl">{gear.name}</h1>
              <span
                class="flex items-center gap-1 rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700"
              >
                <svg
                  class="h-3 w-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"
                  ></path>
                </svg>
                Hardware
              </span>
              {
                gear.is_verified && (
                  <span class="flex items-center gap-1 rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
                    <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                      <path
                        fill-rule="evenodd"
                        d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                        clip-rule="evenodd"
                      />
                    </svg>
                    Verified
                  </span>
                )
              }
            </div>
            {gear.short_description && <p class="mt-2 text-slate-600">{gear.short_description}</p>}
            <div class="mt-3 flex flex-wrap items-center gap-3">
              <PricingBadge type={gear.pricing_type} />
              {
                gear.category && (
                  <a
                    href={`/categories/${gear.category.slug}`}
                    class="text-sm text-slate-500 hover:text-hunt-500"
                  >
                    {gear.category.name}
                  </a>
                )
              }
              {
                gear.website && (
                  <a
                    href={gear.website}
                    target="_blank"
                    rel="noopener"
                    class="flex items-center gap-1 text-sm text-slate-500 hover:text-hunt-500"
                  >
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"
                      />
                    </svg>
                    Website
                  </a>
                )
              }
            </div>
            {
              (tags.functions.length > 0 ||
                tags.audiences.length > 0 ||
                tags.platforms.length > 0) && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {tags.functions.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800">
                      {tag.name}
                    </span>
                  ))}
                  {tags.audiences.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                      {tag.name}
                    </span>
                  ))}
                  {tags.platforms.map((tag) => (
                    <span class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800">
                      {tag.name}
                    </span>
                  ))}
                </div>
              )
            }
          </div>
        </div>
        <div class="flex flex-col items-center gap-4 sm:items-end">
          {
            gear.avg_score > 0 && (
              <ScoreBadge score={Math.round(gear.avg_score)} size="lg" showLabel />
            )
          }
          {primaryOffer && <AffiliateButton offer={primaryOffer} toolName={gear.name} size="md" />}
        </div>
      </div>
    </header>

    <!-- Main Content Grid -->
    <div class="grid gap-8 lg:grid-cols-3">
      <div class="space-y-8 lg:col-span-2">
        {/* Video Embed */}
        {
          gear.video_id && (
            <section>
              <VideoEmbed
                client:visible
                id={gear.video_id}
                title={gear.video_title || `${gear.name} Review`}
              />
            </section>
          )
        }

        {/* Pros & Cons */}
        {
          firstReview && (firstReview.pros?.length > 0 || firstReview.cons?.length > 0) ? (
            <ProsCons
              pros={firstReview.pros || []}
              cons={firstReview.cons || []}
              title="Pros & Cons"
            />
          ) : (
            <section class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="mb-4 text-lg font-semibold text-slate-900">Pros & Cons</h2>
              <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-6 text-center">
                <svg
                  class="mx-auto h-10 w-10 text-slate-300 mb-3"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                  />
                </svg>
                <p class="text-sm text-slate-500 mb-2">No detailed pros and cons available yet.</p>
                <p class="text-xs text-slate-400">
                  We're working on reviewing this gear. Check back soon!
                </p>
              </div>
            </section>
          )
        }

        {/* Review Summary */}
        {
          firstReview?.summary_markdown && (
            <section class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="mb-4 text-lg font-semibold text-slate-900">Our Review</h2>
              <div
                class="prose prose-slate prose-sm max-w-none"
                set:html={simpleMarkdown(firstReview.summary_markdown)}
              />
              {firstReview.sentiment_tags?.length > 0 && (
                <div class="mt-6 border-t border-slate-100 pt-4">
                  <SentimentTags tags={firstReview.sentiment_tags} />
                </div>
              )}
              <div class="mt-6 flex items-center justify-between border-t border-slate-100 pt-4">
                <span class="text-sm text-slate-500">Was this helpful?</span>
                <VoteWidget
                  client:visible
                  reviewId={firstReview.id}
                  initialUpvotes={firstReview.upvotes}
                  initialDownvotes={firstReview.downvotes}
                  turnstileSiteKey={turnstileSiteKey}
                />
              </div>
              <div class="mt-4 flex items-center justify-between border-t border-slate-100 pt-4">
                {sourceDomains.length > 0 && (
                  <div class="flex items-center gap-2 text-xs text-slate-400">
                    <svg
                      class="h-3.5 w-3.5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    <span>Sources: {sourceDomains.join(', ')}</span>
                  </div>
                )}
                <button
                  type="button"
                  data-suggest-edit
                  data-tool-id={gear.id}
                  data-tool-name={gear.name}
                  class="text-xs text-slate-400 hover:text-hunt-600 transition"
                >
                  See something wrong? Suggest an edit
                </button>
              </div>
            </section>
          )
        }

        {/* About */}
        {
          gear.long_description && (
            <section class="rounded-xl border border-slate-200 bg-white p-6">
              <h2 class="mb-4 text-lg font-semibold text-slate-900">About {gear.name}</h2>
              <div
                class="prose prose-slate max-w-none text-slate-700 leading-relaxed"
                set:html={simpleMarkdown(gear.long_description)}
              />
            </section>
          )
        }
      </div>

      <!-- Sidebar -->
      <div class="space-y-6">
        <div class="rounded-xl border border-slate-200 bg-white p-5">
          <h3 class="mb-4 font-semibold text-slate-900">Quick Stats</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Overall Score</dt>
              <dd class="text-sm font-medium text-slate-900">
                {gear.avg_score > 0 ? `${Math.round(gear.avg_score)}/100` : 'N/A'}
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Type</dt>
              <dd class="text-sm font-medium text-slate-900">Hardware</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-slate-500">Reviews</dt>
              <dd class="text-sm font-medium text-slate-900">{gear.review_count}</dd>
            </div>
            {
              gear.category && (
                <div class="flex justify-between">
                  <dt class="text-sm text-slate-500">Category</dt>
                  <dd class="text-sm font-medium text-slate-900">{gear.category.name}</dd>
                </div>
              )
            }
          </dl>
        </div>
        {
          gear.affiliate_offers && gear.affiliate_offers.length > 1 && (
            <div class="rounded-xl border border-slate-200 bg-white p-5">
              <h3 class="mb-4 font-semibold text-slate-900">Buy {gear.name}</h3>
              <div class="space-y-3">
                {gear.affiliate_offers.map((offer) => (
                  <a
                    href={offer.url}
                    target="_blank"
                    rel={offer.is_affiliate ? 'nofollow sponsored noopener' : 'noopener'}
                    class="flex items-center justify-between rounded-lg border border-slate-100 p-3 transition hover:border-hunt-200 hover:bg-hunt-50"
                  >
                    <span class="text-sm font-medium text-slate-700">{offer.cta_text}</span>
                    <svg
                      class="h-4 w-4 text-slate-400"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>

    {/* Spiderweb */}
    {
      contextLinks && contextLinks.length > 0 && (
        <div class="mt-10">
          <SpiderwebGrid
            contexts={contextLinks.map((cl) => ({
              id: cl.context.id,
              title: cl.context.title,
              slug: cl.context.slug,
              score: cl.score,
              tool_count: cl.context.tool_count,
            }))}
            currentToolName={gear.name}
            limit={9}
          />
        </div>
      )
    }
  </div>

  <!-- Suggest Edit Modal -->
  <div
    id="suggest-edit-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
  >
    <div class="w-full max-w-md rounded-xl bg-white p-6 shadow-xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-slate-900">Suggest an Edit</h3>
        <button type="button" data-close-modal class="text-slate-400 hover:text-slate-600">
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <form id="suggest-edit-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={gear.id} />
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">What needs correcting?</label
          >
          <select
            name="field_name"
            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          >
            <option value="pricing">Price information</option>
            <option value="pros">Pros</option>
            <option value="cons">Cons</option>
            <option value="summary">Review/description</option>
            <option value="score">Score seems off</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1"
            >What's the correct information?</label
          >
          <textarea
            name="correction_text"
            rows="3"
            required
            placeholder="e.g., The price has changed to $199..."
            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 mb-1">Your email (optional)</label>
          <input
            type="email"
            name="reporter_email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          />
          <p class="mt-1 text-xs text-slate-400">
            We'll notify you when the correction is reviewed
          </p>
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 rounded-lg bg-hunt-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-hunt-700 transition"
            >Submit Suggestion</button
          >
          <button
            type="button"
            data-close-modal
            class="rounded-lg border border-slate-200 px-4 py-2.5 text-sm font-medium text-slate-600 hover:bg-slate-50 transition"
            >Cancel</button
          >
        </div>
      </form>
      <div id="suggest-edit-success" class="hidden text-center py-4">
        <svg
          class="mx-auto h-12 w-12 text-green-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-3 text-sm text-slate-600">Thanks! We'll review your suggestion.</p>
        <button
          type="button"
          data-close-modal
          class="mt-4 text-sm text-hunt-600 hover:text-hunt-700">Close</button
        >
      </div>
    </div>
  </div>

  <script is:inline>
    const modal = document.getElementById('suggest-edit-modal');
    const form = document.getElementById('suggest-edit-form');
    const success = document.getElementById('suggest-edit-success');
    document.querySelectorAll('[data-suggest-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        form?.classList.remove('hidden');
        success?.classList.add('hidden');
      });
    });
    document.querySelectorAll('[data-close-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      });
    });
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      try {
        const res = await fetch('/api/corrections', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          form.reset();
        } else {
          alert('Failed to submit. Please try again.');
        }
      } catch {
        alert('Network error. Please try again.');
      }
    });
  </script>
</BaseLayout>
