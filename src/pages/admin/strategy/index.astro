---
/**
 * Admin: Content Ideas Management
 * Import CSV from Gemini and manage content pipeline
 */

export const prerender = false;

// Check authentication
const sessionToken = Astro.cookies.get('stackhunt_admin_session')?.value;

if (!sessionToken) {
  return Astro.redirect('/admin/login?redirect=/admin/content-ideas');
}

// Validate session (you could add validateSession here if needed)
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Content Strategy - StackHunt Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-slate-50">
  <div class="mx-auto max-w-6xl p-8">
    <!-- Header -->
    <div class="mb-8 flex items-center justify-between">
      <div>
        <h1 class="text-3xl font-bold text-slate-900">Content Strategy</h1>
        <p class="mt-1 text-slate-600">Import and manage content ideas from LLM brainstorming</p>
      </div>
      <a href="/admin" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
        ← Back to Admin
      </a>
    </div>

    <!-- Import Form -->
    <div class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">Import Content Ideas</h2>

      <form id="import-form" class="space-y-4">
        <div>
          <label class="mb-2 block text-sm font-medium text-slate-700">
            Paste CSV from Gemini
          </label>
          <textarea
            id="csv-content"
            name="csv_content"
            rows="12"
            required
            placeholder='keyword,tool_name,context_query,content_type,pillar,target_audience,priority,notes
"supabase vs firebase","Supabase","Supabase vs Firebase",comparison,builder,developers,98,"Core wedge"
"best headless cms",,"Best Headless CMS",listicle,builder,developers,95,"Sanity, Strapi"'
            class="w-full rounded-lg border border-slate-300 px-3 py-2 font-mono text-sm focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
          ></textarea>
          <p class="mt-1 text-xs text-slate-500">
            Just paste directly from Gemini - it will auto-detect CSV or JSON format.
          </p>
        </div>

        <div class="flex items-center gap-3">
          <button
            type="submit"
            class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-medium text-white hover:bg-indigo-700 disabled:opacity-50"
          >
            Import Content Ideas
          </button>
          <button
            type="button"
            id="clear-btn"
            class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
          >
            Clear
          </button>
        </div>
      </form>

      <!-- Progress -->
      <div id="progress" class="mt-6 hidden">
        <div class="mb-2 flex items-center gap-2 text-sm text-slate-600">
          <svg class="h-5 w-5 animate-spin text-indigo-600" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span id="progress-text">Processing...</span>
        </div>
        <div class="h-2 w-full overflow-hidden rounded-full bg-slate-200">
          <div id="progress-bar" class="h-full bg-indigo-600 transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <!-- Results -->
      <div id="results" class="mt-6 hidden">
        <h3 class="mb-3 font-semibold text-slate-900">Import Results</h3>
        <div class="space-y-2">
          <div class="flex items-center gap-2 text-sm">
            <span class="font-medium text-green-700">Inserted:</span>
            <span id="inserted-count" class="text-slate-900">0</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span class="font-medium text-yellow-700">Skipped (duplicates):</span>
            <span id="skipped-count" class="text-slate-900">0</span>
          </div>
          <div class="flex items-center gap-2 text-sm">
            <span class="font-medium text-red-700">Failed:</span>
            <span id="failed-count" class="text-slate-900">0</span>
          </div>
        </div>
        <div id="error-messages" class="mt-4 hidden space-y-1"></div>
      </div>
    </div>

    <!-- Recent Ideas -->
    <div class="mt-8 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-slate-900">Recent Content Ideas</h2>
      <div id="recent-ideas" class="space-y-2">
        <p class="text-sm text-slate-500">Loading...</p>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('import-form');
    const csvContent = document.getElementById('csv-content');
    const clearBtn = document.getElementById('clear-btn');
    const progress = document.getElementById('progress');
    const progressText = document.getElementById('progress-text');
    const progressBar = document.getElementById('progress-bar');
    const results = document.getElementById('results');
    const insertedCount = document.getElementById('inserted-count');
    const skippedCount = document.getElementById('skipped-count');
    const failedCount = document.getElementById('failed-count');
    const errorMessages = document.getElementById('error-messages');

    clearBtn?.addEventListener('click', () => {
      csvContent.value = '';
      results?.classList.add('hidden');
    });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      const content = csvContent.value.trim();
      if (!content) {
        alert('Please paste CSV content');
        return;
      }

      // Show progress
      progress?.classList.remove('hidden');
      results?.classList.add('hidden');
      progressBar.style.width = '0%';
      progressText.textContent = 'Processing...';

      try {
        const response = await fetch('/api/admin/content-ideas/import', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ csv_content: content }),
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || 'Import failed');
        }

        // Show results
        progressBar.style.width = '100%';
        progressText.textContent = 'Complete!';

        setTimeout(() => {
          progress?.classList.add('hidden');
          results?.classList.remove('hidden');
          insertedCount.textContent = data.inserted;
          skippedCount.textContent = data.skipped;
          failedCount.textContent = data.failed;

          if (data.errors && data.errors.length > 0) {
            errorMessages.classList.remove('hidden');
            errorMessages.innerHTML = data.errors.map(err =>
              `<div class="text-xs text-red-600">• ${err}</div>`
            ).join('');
          }

          // Refresh recent ideas
          loadRecentIdeas();
        }, 500);

      } catch (error) {
        progress?.classList.add('hidden');
        alert(error.message);
      }
    });

    async function loadRecentIdeas() {
      const container = document.getElementById('recent-ideas');

      try {
        const response = await fetch('/api/admin/content-ideas?limit=10');
        const data = await response.json();

        if (data.ideas && data.ideas.length > 0) {
          container.innerHTML = data.ideas.map(idea => `
            <div class="flex items-center justify-between border-b border-slate-100 py-2 last:border-0">
              <div class="min-w-0 flex-1">
                <p class="text-sm font-medium text-slate-900">${idea.context_query}</p>
                <p class="text-xs text-slate-500">
                  ${idea.content_type} • ${idea.pillar} • Priority: ${idea.priority}
                </p>
              </div>
              <span class="ml-2 rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600">
                ${idea.status}
              </span>
            </div>
          `).join('');
        } else {
          container.innerHTML = '<p class="text-sm text-slate-500">No content ideas yet.</p>';
        }
      } catch (error) {
        container.innerHTML = '<p class="text-sm text-red-600">Failed to load ideas</p>';
      }
    }

    // Load on page load
    loadRecentIdeas();
  </script>
</body>
</html>
