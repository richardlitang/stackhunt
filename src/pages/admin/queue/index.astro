---
/**
 * Admin Queue Management - /admin/queue
 * View and manage the content generation queue
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { getAdminClient } from '@/lib/supabase';

const admin = getAdminClient();

// Fetch queue items grouped by status
const { data: queueItems } = await admin
  .from('hunt_queue')
  .select('*')
  .order('status', { ascending: true })
  .order('priority', { ascending: false })
  .order('created_at', { ascending: true });

const pending = queueItems?.filter((i) => i.status === 'pending') || [];
const processing = queueItems?.filter((i) => i.status === 'processing' || i.status === 'claimed') || [];
const completed = queueItems?.filter((i) => i.status === 'completed') || [];
const failed = queueItems?.filter((i) => i.status === 'failed') || [];
---

<AdminLayout title="Content Queue">
  <div class="space-y-8">
    <!-- Stats -->
    <div class="grid gap-4 sm:grid-cols-4">
      <div class="rounded-xl border border-blue-200 bg-blue-50 p-4">
        <div class="text-2xl font-bold text-blue-700">{pending.length}</div>
        <div class="text-sm text-blue-600">Pending</div>
      </div>
      <div class="rounded-xl border border-amber-200 bg-amber-50 p-4">
        <div class="text-2xl font-bold text-amber-700">{processing.length}</div>
        <div class="text-sm text-amber-600">Processing</div>
      </div>
      <div class="rounded-xl border border-green-200 bg-green-50 p-4">
        <div class="text-2xl font-bold text-green-700">{completed.length}</div>
        <div class="text-sm text-green-600">Completed</div>
      </div>
      <div class="rounded-xl border border-red-200 bg-red-50 p-4">
        <div class="text-2xl font-bold text-red-700">{failed.length}</div>
        <div class="text-sm text-red-600">Failed</div>
      </div>
    </div>

    <!-- Add to Queue -->
    <div class="rounded-xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-semibold text-slate-900">Add to Queue</h2>
      <form method="POST" action="/api/admin/queue/add" class="mt-4 flex flex-wrap gap-3">
        <input
          type="text"
          name="tool_name"
          placeholder="Tool name (e.g., Salesforce)"
          required
          class="flex-1 min-w-[200px] rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
        />
        <input
          type="text"
          name="context_title"
          placeholder="Context (optional)"
          class="flex-1 min-w-[200px] rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
        />
        <input
          type="number"
          name="priority"
          placeholder="Priority"
          value="0"
          min="0"
          max="100"
          class="w-24 rounded-lg border border-slate-200 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
        />
        <button
          type="submit"
          class="rounded-lg bg-hunt-500 px-4 py-2 text-sm font-medium text-white hover:bg-hunt-600"
        >
          Add to Queue
        </button>
      </form>
    </div>

    <!-- Pending Items -->
    <section>
      <h2 class="mb-4 text-lg font-semibold text-slate-900">
        Pending ({pending.length})
      </h2>
      {pending.length > 0 ? (
        <div class="overflow-hidden rounded-xl border border-slate-200">
          <table class="w-full">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Tool</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Context</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Priority</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Source</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Added</th>
                <th class="px-4 py-3 text-right text-sm font-medium text-slate-700">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {pending.map((item) => (
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 text-sm font-medium text-slate-900">{item.tool_name}</td>
                  <td class="px-4 py-3 text-sm text-slate-600">{item.context_title || '-'}</td>
                  <td class="px-4 py-3">
                    <span class="rounded-full bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-700">
                      {item.priority}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-sm text-slate-500">{item.source}</td>
                  <td class="px-4 py-3 text-sm text-slate-500">
                    {new Date(item.created_at).toLocaleDateString()}
                  </td>
                  <td class="px-4 py-3 text-right">
                    <form method="POST" action={`/api/admin/queue/${item.id}/delete`} class="inline">
                      <button type="submit" class="text-sm text-red-600 hover:text-red-700">
                        Remove
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center text-slate-500">
          Queue is empty
        </div>
      )}
    </section>

    <!-- Failed Items -->
    {failed.length > 0 && (
      <section>
        <h2 class="mb-4 text-lg font-semibold text-slate-900">
          Failed ({failed.length})
        </h2>
        <div class="overflow-hidden rounded-xl border border-red-200">
          <table class="w-full">
            <thead class="bg-red-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-medium text-red-700">Tool</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-red-700">Error</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-red-700">Attempts</th>
                <th class="px-4 py-3 text-right text-sm font-medium text-red-700">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-red-100 bg-white">
              {failed.map((item) => (
                <tr class="hover:bg-red-50">
                  <td class="px-4 py-3 text-sm font-medium text-slate-900">{item.tool_name}</td>
                  <td class="px-4 py-3 text-sm text-red-600">{item.error_message || 'Unknown error'}</td>
                  <td class="px-4 py-3 text-sm text-slate-500">{item.attempts}</td>
                  <td class="px-4 py-3 text-right space-x-2">
                    <form method="POST" action={`/api/admin/queue/${item.id}/retry`} class="inline">
                      <button type="submit" class="text-sm text-hunt-600 hover:text-hunt-700">
                        Retry
                      </button>
                    </form>
                    <form method="POST" action={`/api/admin/queue/${item.id}/delete`} class="inline">
                      <button type="submit" class="text-sm text-red-600 hover:text-red-700">
                        Remove
                      </button>
                    </form>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Recent Completed -->
    {completed.length > 0 && (
      <section>
        <h2 class="mb-4 text-lg font-semibold text-slate-900">
          Recently Completed ({completed.length})
        </h2>
        <div class="overflow-hidden rounded-xl border border-slate-200">
          <table class="w-full">
            <thead class="bg-slate-50">
              <tr>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Tool</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Context</th>
                <th class="px-4 py-3 text-left text-sm font-medium text-slate-700">Processed</th>
                <th class="px-4 py-3 text-right text-sm font-medium text-slate-700">Review</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200">
              {completed.slice(0, 10).map((item) => (
                <tr class="hover:bg-slate-50">
                  <td class="px-4 py-3 text-sm font-medium text-slate-900">{item.tool_name}</td>
                  <td class="px-4 py-3 text-sm text-slate-600">{item.context_title || '-'}</td>
                  <td class="px-4 py-3 text-sm text-slate-500">
                    {item.completed_at ? new Date(item.completed_at).toLocaleDateString() : '-'}
                  </td>
                  <td class="px-4 py-3 text-right">
                    {item.review_id && (
                      <a
                        href={`/admin/review/${item.review_id}`}
                        class="text-sm text-hunt-600 hover:text-hunt-700"
                      >
                        View Draft →
                      </a>
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}
  </div>
</AdminLayout>
