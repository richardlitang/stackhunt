---
/**
 * Admin Review Detail - /admin/review/[id]
 * View, edit, and publish/reject a draft review
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { getAdminClient } from '@/lib/supabase';

const { id } = Astro.params;
const admin = getAdminClient();

// Fetch the review with full details
const { data: review, error } = await admin
  .from('reviews')
  .select(`
    *,
    tool:tools(*),
    context:contexts(*)
  `)
  .eq('id', id)
  .single();

if (error || !review) {
  return Astro.redirect('/admin/review');
}

const tool = review.tool as Record<string, unknown>;
const context = review.context as Record<string, unknown> | null;
---

<AdminLayout title={`Review: ${tool?.name || 'Unknown'}`}>
  <!-- Breadcrumb -->
  <nav class="mb-6 flex items-center gap-2 text-sm">
    <a href="/admin/review" class="text-slate-500 hover:text-slate-700">Review Queue</a>
    <svg class="h-4 w-4 text-slate-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
    <span class="text-slate-900 font-medium">{tool?.name}</span>
  </nav>

  <div class="grid gap-8 lg:grid-cols-3">
    <!-- Main Editor (2/3) -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Tool Header -->
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <div class="flex items-start gap-4">
          <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-xl border border-slate-200 bg-slate-50">
            {tool?.logo_url ? (
              <img src={tool.logo_url as string} alt="" class="h-full w-full object-contain p-2" />
            ) : (
              <span class="text-2xl font-bold text-slate-300">
                {(tool?.name as string)?.charAt(0) || '?'}
              </span>
            )}
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-3">
              <h1 class="text-xl font-bold text-slate-900">{tool?.name}</h1>
              <span class={`rounded-full px-2.5 py-0.5 text-sm font-medium ${
                review.status === 'draft' ? 'bg-amber-100 text-amber-700' :
                review.status === 'published' ? 'bg-green-100 text-green-700' :
                'bg-red-100 text-red-700'
              }`}>
                {review.status}
              </span>
            </div>
            {context && (
              <p class="mt-1 text-slate-500">{context.title}</p>
            )}
            <div class="mt-3 flex items-center gap-4 text-sm">
              {tool?.website && (
                <a
                  href={tool.website as string}
                  target="_blank"
                  class="text-hunt-600 hover:text-hunt-700"
                >
                  Visit website →
                </a>
              )}
              <a
                href={`/tools/${tool?.slug}`}
                target="_blank"
                class="text-slate-500 hover:text-slate-700"
              >
                Preview on site →
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Edit Form -->
      <form id="review-form" method="POST" action={`/api/admin/review/${id}/update`} class="space-y-6">
        <!-- Score -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <label class="block text-sm font-medium text-slate-700 mb-2">Score</label>
          <div class="flex items-center gap-4">
            <input
              type="number"
              name="score"
              min="0"
              max="100"
              value={review.score}
              class="w-24 rounded-lg border border-slate-200 px-4 py-2 text-2xl font-bold text-center focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
            />
            <div class="flex-1">
              <div class="h-2 rounded-full bg-slate-100 overflow-hidden">
                <div
                  class={`h-full rounded-full transition-all ${
                    (review.score || 0) >= 70 ? 'bg-green-500' :
                    (review.score || 0) >= 50 ? 'bg-amber-500' :
                    'bg-red-500'
                  }`}
                  style={`width: ${review.score || 0}%`}
                ></div>
              </div>
              <p class="mt-1 text-xs text-slate-500">
                0-30 poor • 31-50 below average • 51-70 average • 71-85 good • 86-100 excellent
              </p>
            </div>
          </div>
        </div>

        <!-- Summary -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <label class="block text-sm font-medium text-slate-700 mb-2">Summary (Markdown)</label>
          <textarea
            name="summary_markdown"
            rows="10"
            class="w-full rounded-lg border border-slate-200 px-4 py-3 font-mono text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          >{review.summary_markdown}</textarea>
        </div>

        <!-- Pros & Cons -->
        <div class="grid gap-6 lg:grid-cols-2">
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <label class="block text-sm font-medium text-slate-700 mb-2">
              Pros <span class="text-slate-400 font-normal">(one per line)</span>
            </label>
            <textarea
              name="pros"
              rows="5"
              class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
            >{(review.pros as string[] || []).join('\n')}</textarea>
          </div>

          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <label class="block text-sm font-medium text-slate-700 mb-2">
              Cons <span class="text-slate-400 font-normal">(one per line)</span>
            </label>
            <textarea
              name="cons"
              rows="5"
              class="w-full rounded-lg border border-slate-200 px-4 py-3 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
            >{(review.cons as string[] || []).join('\n')}</textarea>
          </div>
        </div>

        <!-- Sentiment Tags -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Sentiment Tags <span class="text-slate-400 font-normal">(comma-separated)</span>
          </label>
          <input
            type="text"
            name="sentiment_tags"
            value={(review.sentiment_tags as string[] || []).join(', ')}
            placeholder="e.g., easy-to-use, expensive, feature-rich"
            class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          />
        </div>

        <!-- Reviewer Notes -->
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <label class="block text-sm font-medium text-slate-700 mb-2">
            Reviewer Notes <span class="text-slate-400 font-normal">(internal)</span>
          </label>
          <textarea
            name="reviewer_notes"
            rows="2"
            placeholder="Any notes about this review..."
            class="w-full rounded-lg border border-slate-200 px-4 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          >{review.reviewer_notes}</textarea>
        </div>

        <!-- Actions -->
        <div class="flex flex-wrap items-center gap-3 sticky bottom-4 bg-slate-50 rounded-xl p-4 border border-slate-200 shadow-lg">
          <button
            type="submit"
            name="action"
            value="save"
            data-shortcut="save"
            class="rounded-lg bg-slate-900 px-5 py-2.5 text-sm font-medium text-white hover:bg-slate-800"
          >
            Save Changes
          </button>
          <button
            type="submit"
            name="action"
            value="publish"
            class="rounded-lg bg-green-600 px-5 py-2.5 text-sm font-medium text-white hover:bg-green-700"
          >
            Save & Publish
          </button>
          <button
            type="submit"
            name="action"
            value="reject"
            class="rounded-lg border border-red-200 bg-white px-5 py-2.5 text-sm font-medium text-red-700 hover:bg-red-50"
          >
            Reject
          </button>
          <a
            href="/admin/review"
            class="ml-auto text-sm text-slate-500 hover:text-slate-700"
          >
            Cancel
          </a>
        </div>
      </form>
    </div>

    <!-- Sidebar (1/3) -->
    <div class="space-y-6">
      <!-- Tool Info -->
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h3 class="font-semibold text-slate-900 mb-4">Tool Info</h3>
        <dl class="space-y-4 text-sm">
          <div>
            <dt class="text-slate-500">Website</dt>
            <dd class="mt-1">
              {tool?.website ? (
                <a href={tool.website as string} target="_blank" class="text-hunt-600 hover:underline break-all">
                  {(tool.website as string).replace(/^https?:\/\//, '')}
                </a>
              ) : (
                <span class="text-slate-400">Not set</span>
              )}
            </dd>
          </div>
          <div>
            <dt class="text-slate-500">Pricing</dt>
            <dd class="mt-1 capitalize">{(tool?.pricing_type as string)?.replace('_', ' ') || 'Unknown'}</dd>
          </div>
          <div>
            <dt class="text-slate-500">Short Description</dt>
            <dd class="mt-1 text-slate-700">{tool?.short_description || <span class="text-slate-400">Not set</span>}</dd>
          </div>
        </dl>
      </div>

      <!-- Preview Links -->
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h3 class="font-semibold text-slate-900 mb-4">Preview</h3>
        <div class="space-y-2">
          <a
            href={`/tools/${tool?.slug}`}
            target="_blank"
            class="flex items-center justify-between rounded-lg border border-slate-200 p-3 text-sm hover:bg-slate-50 transition"
          >
            <span>Tool Page</span>
            <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
          {context && (
            <a
              href={`/best/${context.slug}`}
              target="_blank"
              class="flex items-center justify-between rounded-lg border border-slate-200 p-3 text-sm hover:bg-slate-50 transition"
            >
              <span>Context List</span>
              <svg class="h-4 w-4 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
              </svg>
            </a>
          )}
        </div>
      </div>

      <!-- History -->
      <div class="rounded-xl border border-slate-200 bg-white p-6">
        <h3 class="font-semibold text-slate-900 mb-4">History</h3>
        <ul class="space-y-3 text-sm">
          <li class="flex items-center gap-3">
            <span class="flex h-2 w-2 rounded-full bg-slate-300"></span>
            <span class="text-slate-600">
              Created {new Date(review.created_at).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              })}
            </span>
          </li>
          {review.updated_at && review.updated_at !== review.created_at && (
            <li class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-blue-500"></span>
              <span class="text-slate-600">
                Updated {new Date(review.updated_at).toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </span>
            </li>
          )}
          {review.published_at && (
            <li class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-green-500"></span>
              <span class="text-green-700">
                Published {new Date(review.published_at).toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </span>
            </li>
          )}
          {review.rejected_at && (
            <li class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-red-500"></span>
              <span class="text-red-700">
                Rejected {new Date(review.rejected_at).toLocaleDateString('en-US', {
                  month: 'short',
                  day: 'numeric',
                  year: 'numeric',
                })}
              </span>
            </li>
          )}
        </ul>
      </div>

      <!-- Keyboard Shortcuts -->
      <div class="rounded-xl border border-slate-200 bg-slate-50 p-4">
        <div class="flex items-center gap-2 text-xs text-slate-500">
          <kbd class="rounded bg-white border border-slate-200 px-1.5 py-0.5 font-mono">Cmd+S</kbd>
          <span>to save</span>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    // Intercept form submission for better UX
    const form = document.getElementById('review-form');

    form?.addEventListener('submit', async (e) => {
      // Only intercept save action for instant feedback
      const submitter = e.submitter;
      if (submitter?.value === 'reject') {
        e.preventDefault();
        window.confirm2(
          'Reject Review',
          'Are you sure you want to reject this review?',
          () => {
            form.submit();
          }
        );
      }
    });
  </script>
</AdminLayout>
