---
/**
 * Editorial Brain Dashboard - /admin/editorial
 * Autonomous content discovery and topic management
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { getAdminClient } from '@/lib/supabase';

const admin = getAdminClient();

// Fetch editorial stats and data
const [
  dashboardStats,
  { data: proposedTopics },
  { data: approvedTopics },
  { data: recentlyCompleted },
  { data: guidelines },
] = await Promise.all([
  admin.from('editorial_dashboard').select('*'),
  admin
    .from('editorial_topics')
    .select('*')
    .eq('status', 'proposed')
    .order('priority_score', { ascending: false })
    .limit(10),
  admin
    .from('editorial_topics')
    .select('*')
    .in('status', ['approved', 'queued'])
    .order('priority_score', { ascending: false })
    .limit(5),
  admin
    .from('editorial_topics')
    .select('*, context:contexts(title, slug)')
    .eq('status', 'completed')
    .order('completed_at', { ascending: false })
    .limit(5),
  admin
    .from('editorial_guidelines')
    .select('*')
    .eq('is_active', true)
    .order('key'),
]);

// Parse dashboard stats
const stats = (dashboardStats.data || []).reduce((acc, row) => {
  acc[row.status] = row;
  return acc;
}, {} as Record<string, { count: number; avg_priority: number; new_this_week: number }>);

const totalProposed = stats.proposed?.count || 0;
const totalApproved = stats.approved?.count || 0;
const totalQueued = stats.queued?.count || 0;
const totalCompleted = stats.completed?.count || 0;

// Type helpers
type TopicType = 'best_list' | 'comparison' | 'tool_review' | 'roundup' | 'guide';
type RevenueType = 'high' | 'medium' | 'low' | 'unknown';

const topicTypeLabels: Record<TopicType, string> = {
  best_list: 'Best List',
  comparison: 'Comparison',
  tool_review: 'Tool Review',
  roundup: 'Roundup',
  guide: 'Guide',
};

const revenueColors: Record<RevenueType, string> = {
  high: 'bg-green-100 text-green-700',
  medium: 'bg-amber-100 text-amber-700',
  low: 'bg-slate-100 text-slate-600',
  unknown: 'bg-slate-100 text-slate-500',
};
---

<AdminLayout title="Editorial Brain">
  <div class="space-y-8">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">Editorial Brain</h1>
        <p class="mt-1 text-sm text-slate-500">
          AI-powered content discovery and editorial planning
        </p>
      </div>
      <div class="flex items-center gap-3">
        <button
          id="trigger-discovery"
          class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
          </svg>
          Run Discovery
        </button>
        <a
          href="/admin/editorial/guidelines"
          class="inline-flex items-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 transition"
        >
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Guidelines
        </a>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="rounded-xl border border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100/50 p-5">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-3xl font-bold text-purple-700">{totalProposed}</div>
            <div class="mt-1 text-sm font-medium text-purple-600">Proposed</div>
          </div>
          <div class="rounded-lg bg-purple-200/50 p-2 text-purple-600">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
        </div>
        {stats.proposed?.new_this_week > 0 && (
          <div class="mt-2 text-xs text-purple-600">
            +{stats.proposed.new_this_week} this week
          </div>
        )}
      </div>

      <div class="rounded-xl border border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100/50 p-5">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-3xl font-bold text-blue-700">{totalApproved + totalQueued}</div>
            <div class="mt-1 text-sm font-medium text-blue-600">In Pipeline</div>
          </div>
          <div class="rounded-lg bg-blue-200/50 p-2 text-blue-600">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-green-200 bg-gradient-to-br from-green-50 to-green-100/50 p-5">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-3xl font-bold text-green-700">{totalCompleted}</div>
            <div class="mt-1 text-sm font-medium text-green-600">Completed</div>
          </div>
          <div class="rounded-lg bg-green-200/50 p-2 text-green-600">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>
      </div>

      <div class="rounded-xl border border-slate-200 bg-gradient-to-br from-slate-50 to-slate-100/50 p-5">
        <div class="flex items-start justify-between">
          <div>
            <div class="text-3xl font-bold text-slate-700">{guidelines?.length || 0}</div>
            <div class="mt-1 text-sm font-medium text-slate-600">Active Guidelines</div>
          </div>
          <div class="rounded-lg bg-slate-200/50 p-2 text-slate-500">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
          </div>
        </div>
      </div>
    </div>

    <!-- Proposed Topics Section -->
    <section>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-slate-900">Proposed Topics</h2>
        <span class="text-sm text-slate-500">Awaiting your review</span>
      </div>

      {proposedTopics && proposedTopics.length > 0 ? (
        <div class="rounded-xl border border-slate-200 bg-white overflow-hidden">
          <table class="w-full">
            <thead class="bg-slate-50 border-b border-slate-200">
              <tr>
                <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Topic</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Type</th>
                <th class="text-left px-4 py-3 text-xs font-medium text-slate-500 uppercase">Revenue</th>
                <th class="text-center px-4 py-3 text-xs font-medium text-slate-500 uppercase">Priority</th>
                <th class="text-right px-4 py-3 text-xs font-medium text-slate-500 uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {proposedTopics.map((topic) => (
                <tr class="hover:bg-slate-50 transition topic-row" data-topic-id={topic.id}>
                  <td class="px-4 py-3">
                    <div class="max-w-md">
                      <div class="font-medium text-slate-900 truncate">{topic.topic}</div>
                      {topic.description && (
                        <div class="text-sm text-slate-500 truncate">{topic.description}</div>
                      )}
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <span class="inline-block rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
                      {topicTypeLabels[topic.topic_type as TopicType] || topic.topic_type}
                    </span>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${revenueColors[topic.revenue_potential as RevenueType] || revenueColors.unknown}`}>
                      {topic.revenue_potential}
                    </span>
                  </td>
                  <td class="px-4 py-3 text-center">
                    <div class="flex items-center justify-center gap-1">
                      <div class="h-2 w-16 rounded-full bg-slate-200 overflow-hidden">
                        <div
                          class="h-full rounded-full bg-hunt-500"
                          style={`width: ${topic.priority_score}%`}
                        />
                      </div>
                      <span class="text-xs text-slate-500 w-8">{topic.priority_score}</span>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <button
                        class="approve-btn rounded-lg bg-green-100 px-3 py-1.5 text-xs font-medium text-green-700 hover:bg-green-200 transition"
                        data-topic-id={topic.id}
                      >
                        Approve
                      </button>
                      <button
                        class="queue-btn rounded-lg bg-blue-100 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-200 transition"
                        data-topic-id={topic.id}
                      >
                        Queue
                      </button>
                      <button
                        class="reject-btn rounded-lg bg-red-100 px-3 py-1.5 text-xs font-medium text-red-700 hover:bg-red-200 transition"
                        data-topic-id={topic.id}
                      >
                        Reject
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
          <div class="mx-auto w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mb-3">
            <svg class="h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <p class="text-sm text-slate-500">No proposed topics</p>
          <p class="mt-1 text-xs text-slate-400">Click "Run Discovery" to generate new suggestions</p>
        </div>
      )}
    </section>

    <!-- Two Column Layout -->
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Approved / In Pipeline -->
      <section>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-slate-900">In Pipeline</h2>
        </div>

        {approvedTopics && approvedTopics.length > 0 ? (
          <div class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-100">
            {approvedTopics.map((topic) => (
              <div class="flex items-center gap-4 p-4">
                <div class={`shrink-0 rounded-full px-2.5 py-0.5 text-xs font-medium ${
                  topic.status === 'queued' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'
                }`}>
                  {topic.status}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-slate-900 truncate">{topic.topic}</div>
                  <div class="text-sm text-slate-500">
                    {topicTypeLabels[topic.topic_type as TopicType] || topic.topic_type}
                  </div>
                </div>
                <div class="shrink-0 text-sm text-slate-500">
                  Priority: {topic.priority_score}
                </div>
              </div>
            ))}
          </div>
        ) : (
          <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
            <p class="text-sm text-slate-500">No topics in pipeline</p>
          </div>
        )}
      </section>

      <!-- Recently Completed -->
      <section>
        <div class="mb-4 flex items-center justify-between">
          <h2 class="text-lg font-semibold text-slate-900">Recently Completed</h2>
        </div>

        {recentlyCompleted && recentlyCompleted.length > 0 ? (
          <div class="rounded-xl border border-slate-200 bg-white divide-y divide-slate-100">
            {recentlyCompleted.map((topic) => {
              const context = topic.context as { title: string; slug: string } | null;
              return (
                <div class="flex items-center gap-4 p-4">
                  <div class="shrink-0 rounded-full bg-green-100 p-2 text-green-600">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="font-medium text-slate-900 truncate">{topic.topic}</div>
                    {context && (
                      <a href={`/${context.slug}`} class="text-sm text-hunt-600 hover:text-hunt-700">
                        View: {context.title}
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        ) : (
          <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
            <p class="text-sm text-slate-500">No completed topics yet</p>
          </div>
        )}
      </section>
    </div>

    <!-- Add Topic Form -->
    <section class="rounded-xl border border-slate-200 bg-white p-6">
      <h2 class="text-lg font-semibold text-slate-900 mb-4">Add Manual Topic</h2>
      <form id="add-topic-form" class="grid gap-4 sm:grid-cols-2">
        <div class="sm:col-span-2">
          <label for="topic" class="block text-sm font-medium text-slate-700 mb-1">Topic Title</label>
          <input
            type="text"
            id="topic"
            name="topic"
            placeholder="e.g., Best CRM Software for Real Estate Agents"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-hunt-500 focus:ring-2 focus:ring-hunt-500/20 outline-none"
            required
          />
        </div>
        <div>
          <label for="topic_type" class="block text-sm font-medium text-slate-700 mb-1">Type</label>
          <select
            id="topic_type"
            name="topic_type"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-hunt-500 focus:ring-2 focus:ring-hunt-500/20 outline-none"
          >
            <option value="best_list">Best List</option>
            <option value="comparison">Comparison</option>
            <option value="tool_review">Tool Review</option>
            <option value="roundup">Roundup</option>
            <option value="guide">Guide</option>
          </select>
        </div>
        <div>
          <label for="revenue_potential" class="block text-sm font-medium text-slate-700 mb-1">Revenue Potential</label>
          <select
            id="revenue_potential"
            name="revenue_potential"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-hunt-500 focus:ring-2 focus:ring-hunt-500/20 outline-none"
          >
            <option value="high">High</option>
            <option value="medium">Medium</option>
            <option value="low">Low</option>
            <option value="unknown">Unknown</option>
          </select>
        </div>
        <div class="sm:col-span-2">
          <label for="description" class="block text-sm font-medium text-slate-700 mb-1">Description (optional)</label>
          <textarea
            id="description"
            name="description"
            rows="2"
            placeholder="Why this topic matters..."
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-hunt-500 focus:ring-2 focus:ring-hunt-500/20 outline-none resize-none"
          ></textarea>
        </div>
        <div class="sm:col-span-2">
          <label for="suggested_tools" class="block text-sm font-medium text-slate-700 mb-1">Suggested Tools (comma-separated)</label>
          <input
            type="text"
            id="suggested_tools"
            name="suggested_tools"
            placeholder="e.g., Notion, ClickUp, Monday.com"
            class="w-full rounded-lg border border-slate-300 px-4 py-2 text-sm focus:border-hunt-500 focus:ring-2 focus:ring-hunt-500/20 outline-none"
          />
        </div>
        <div class="sm:col-span-2 flex justify-end">
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-lg bg-hunt-500 px-5 py-2.5 text-sm font-medium text-white hover:bg-hunt-600 transition"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
            Add Topic
          </button>
        </div>
      </form>
    </section>
  </div>

  <!-- Toast notification -->
  <div id="toast" class="fixed bottom-4 right-4 hidden">
    <div class="rounded-lg bg-slate-900 px-4 py-3 text-sm text-white shadow-lg">
      <span id="toast-message"></span>
    </div>
  </div>
</AdminLayout>

<script>
  function showToast(message: string) {
    const toast = document.getElementById('toast');
    const toastMessage = document.getElementById('toast-message');
    if (toast && toastMessage) {
      toastMessage.textContent = message;
      toast.classList.remove('hidden');
      setTimeout(() => toast.classList.add('hidden'), 3000);
    }
  }

  // Handle topic actions
  document.querySelectorAll('.approve-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const topicId = (e.target as HTMLElement).dataset.topicId;
      const res = await fetch(`/api/admin/editorial/topics/${topicId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'approve' }),
      });
      if (res.ok) {
        showToast('Topic approved');
        document.querySelector(`[data-topic-id="${topicId}"]`)?.closest('tr')?.remove();
      }
    });
  });

  document.querySelectorAll('.queue-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const topicId = (e.target as HTMLElement).dataset.topicId;
      const res = await fetch(`/api/admin/editorial/topics/${topicId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'approve', auto_queue: true }),
      });
      if (res.ok) {
        showToast('Topic approved and queued');
        document.querySelector(`[data-topic-id="${topicId}"]`)?.closest('tr')?.remove();
      }
    });
  });

  document.querySelectorAll('.reject-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      const topicId = (e.target as HTMLElement).dataset.topicId;
      const reason = prompt('Rejection reason (optional):');
      const res = await fetch(`/api/admin/editorial/topics/${topicId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action: 'reject', reason }),
      });
      if (res.ok) {
        showToast('Topic rejected');
        document.querySelector(`[data-topic-id="${topicId}"]`)?.closest('tr')?.remove();
      }
    });
  });

  // Handle trigger discovery
  document.getElementById('trigger-discovery')?.addEventListener('click', async () => {
    const btn = document.getElementById('trigger-discovery') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Running...';

    try {
      const res = await fetch('/api/cron/discover-topics');
      const data = await res.json();
      if (res.ok) {
        showToast(`Discovered ${data.proposed} new topics`);
        setTimeout(() => window.location.reload(), 1500);
      } else {
        showToast('Discovery failed: ' + data.error);
      }
    } catch (err) {
      showToast('Discovery failed');
    }

    btn.disabled = false;
    btn.textContent = 'Run Discovery';
  });

  // Handle add topic form
  document.getElementById('add-topic-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);

    const suggestedToolsStr = formData.get('suggested_tools') as string;
    const suggestedTools = suggestedToolsStr
      ? suggestedToolsStr.split(',').map((t) => t.trim()).filter(Boolean)
      : [];

    const res = await fetch('/api/admin/editorial/topics', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        topic: formData.get('topic'),
        topic_type: formData.get('topic_type'),
        description: formData.get('description') || undefined,
        revenue_potential: formData.get('revenue_potential'),
        suggested_tools: suggestedTools,
      }),
    });

    if (res.ok) {
      showToast('Topic added successfully');
      form.reset();
      setTimeout(() => window.location.reload(), 1500);
    } else {
      const data = await res.json();
      showToast('Failed: ' + data.error);
    }
  });
</script>
