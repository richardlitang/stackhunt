---
/**
 * Admin: Prompts Management
 * View and edit AI prompts used by the Hunter agent
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabase } from '@/lib/supabase';

// Fetch all prompts
const { data: prompts, error } = await supabase
  .from('prompts')
  .select('*')
  .order('name');

if (error) {
  console.error('Error fetching prompts:', error);
}
---

<AdminLayout title="Prompts">
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900">AI Prompts</h1>
        <p class="mt-1 text-sm text-slate-500">
          Edit prompts used by the Hunter agent. Changes are versioned automatically.
        </p>
      </div>
    </div>

    <!-- Prompts List -->
    <div class="space-y-4">
      {prompts && prompts.length > 0 ? (
        prompts.map((prompt) => (
          <div class="rounded-lg border border-slate-200 bg-white p-5 hover:border-slate-300 transition">
            <div class="flex items-start justify-between">
              <div class="flex-1">
                <div class="flex items-center gap-3">
                  <h3 class="font-semibold text-slate-900">{prompt.name}</h3>
                  <span class="rounded bg-slate-100 px-2 py-0.5 text-xs font-mono text-slate-600">
                    {prompt.key}
                  </span>
                  <span class="rounded bg-blue-100 px-2 py-0.5 text-xs text-blue-700">
                    v{prompt.version}
                  </span>
                  {!prompt.is_active && (
                    <span class="rounded bg-red-100 px-2 py-0.5 text-xs text-red-700">
                      Inactive
                    </span>
                  )}
                </div>

                {prompt.description && (
                  <p class="mt-1 text-sm text-slate-500">{prompt.description}</p>
                )}

                <div class="mt-3 flex items-center gap-4 text-xs text-slate-400">
                  <span>Used {prompt.use_count} times</span>
                  {prompt.last_used_at && (
                    <span>Last used: {new Date(prompt.last_used_at).toLocaleDateString()}</span>
                  )}
                  <span>{prompt.template.length} chars</span>
                </div>
              </div>

              <a
                href={`/admin/prompts/${prompt.key}`}
                class="shrink-0 rounded-lg bg-hunt-500 px-4 py-2 text-sm font-medium text-white hover:bg-hunt-600 transition"
              >
                Edit
              </a>
            </div>

            <!-- Preview -->
            <details class="mt-4 group">
              <summary class="flex cursor-pointer items-center gap-2 text-sm font-medium text-slate-600 hover:text-slate-900">
                <svg class="h-4 w-4 transition group-open:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
                Preview template
              </summary>
              <pre class="mt-3 max-h-48 overflow-auto rounded-lg bg-slate-900 p-4 text-xs text-slate-300 font-mono whitespace-pre-wrap">{prompt.template.slice(0, 500)}{prompt.template.length > 500 ? '...' : ''}</pre>
            </details>
          </div>
        ))
      ) : (
        <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
          <p class="text-slate-500">No prompts found. Run migrations to seed default prompts.</p>
        </div>
      )}
    </div>
  </div>
</AdminLayout>
