---
/**
 * Admin: Edit Prompt
 * Full editor with variable reference and version history
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabase } from '@/lib/supabase';

const { key } = Astro.params;

// Fetch prompt
const { data: prompt, error } = await supabase
  .from('prompts')
  .select('*')
  .eq('key', key)
  .single();

if (error || !prompt) {
  return Astro.redirect('/admin/prompts');
}

// Fetch version history
const { data: versions } = await supabase
  .from('prompt_versions')
  .select('*')
  .eq('prompt_id', prompt.id)
  .order('version', { ascending: false })
  .limit(10);

// Parse variables
const variables = prompt.variables || [];
---

<AdminLayout title={`Edit: ${prompt.name}`}>
  <div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
      <div>
        <div class="flex items-center gap-2 text-sm text-slate-500 mb-2">
          <a href="/admin/prompts" class="hover:text-hunt-500">Prompts</a>
          <span>/</span>
          <span>{prompt.key}</span>
        </div>
        <h1 class="text-2xl font-bold text-slate-900">{prompt.name}</h1>
        <p class="mt-1 text-sm text-slate-500">{prompt.description}</p>
      </div>

      <div class="flex items-center gap-2">
        <span class="rounded bg-blue-100 px-3 py-1 text-sm font-medium text-blue-700">
          Version {prompt.version}
        </span>
      </div>
    </div>

    <!-- Main Editor -->
    <form method="POST" action={`/api/admin/prompts/${key}/update`} class="space-y-6">
      <div class="grid gap-6 lg:grid-cols-3">
        <!-- Editor (2/3) -->
        <div class="lg:col-span-2 space-y-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-2">
              Prompt Template
            </label>
            <textarea
              name="template"
              rows="30"
              class="w-full rounded-lg border border-slate-300 bg-slate-900 p-4 text-sm text-slate-100 font-mono focus:border-hunt-500 focus:ring-hunt-500"
              spellcheck="false"
            >{prompt.template}</textarea>
            <p class="mt-2 text-xs text-slate-500">
              Use <code class="bg-slate-100 px-1 rounded">{'{{variableName}}'}</code> for variables.
              Mustache-style conditionals: <code class="bg-slate-100 px-1 rounded">{'{{#var}}...{{/var}}'}</code>
            </p>
          </div>

          <div class="flex items-center gap-4">
            <button
              type="submit"
              class="rounded-lg bg-hunt-500 px-6 py-2.5 text-sm font-medium text-white hover:bg-hunt-600 transition"
            >
              Save Changes
            </button>
            <a
              href="/admin/prompts"
              class="rounded-lg border border-slate-300 px-6 py-2.5 text-sm font-medium text-slate-700 hover:bg-slate-50 transition"
            >
              Cancel
            </a>
          </div>
        </div>

        <!-- Sidebar (1/3) -->
        <div class="space-y-6">
          <!-- Variables Reference -->
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h3 class="font-semibold text-slate-900 mb-3">Variables</h3>
            {variables.length > 0 ? (
              <ul class="space-y-3">
                {variables.map((v: { name: string; required: boolean; description: string }) => (
                  <li class="text-sm">
                    <div class="flex items-center gap-2">
                      <code class="rounded bg-slate-100 px-1.5 py-0.5 text-xs font-mono text-slate-700">
                        {`{{${v.name}}}`}
                      </code>
                      {v.required && (
                        <span class="text-xs text-red-500">required</span>
                      )}
                    </div>
                    {v.description && (
                      <p class="mt-1 text-xs text-slate-500">{v.description}</p>
                    )}
                  </li>
                ))}
              </ul>
            ) : (
              <p class="text-sm text-slate-500">No variables defined</p>
            )}
          </div>

          <!-- Stats -->
          <div class="rounded-lg border border-slate-200 bg-white p-4">
            <h3 class="font-semibold text-slate-900 mb-3">Stats</h3>
            <dl class="space-y-2 text-sm">
              <div class="flex justify-between">
                <dt class="text-slate-500">Used</dt>
                <dd class="font-medium text-slate-900">{prompt.use_count} times</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-slate-500">Characters</dt>
                <dd class="font-medium text-slate-900">{prompt.template.length}</dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-slate-500">Last used</dt>
                <dd class="font-medium text-slate-900">
                  {prompt.last_used_at ? new Date(prompt.last_used_at).toLocaleDateString() : 'Never'}
                </dd>
              </div>
              <div class="flex justify-between">
                <dt class="text-slate-500">Updated</dt>
                <dd class="font-medium text-slate-900">
                  {new Date(prompt.updated_at).toLocaleDateString()}
                </dd>
              </div>
            </dl>
          </div>

          <!-- Version History -->
          {versions && versions.length > 0 && (
            <div class="rounded-lg border border-slate-200 bg-white p-4">
              <h3 class="font-semibold text-slate-900 mb-3">Version History</h3>
              <ul class="space-y-2">
                {versions.map((v) => (
                  <li class="flex items-center justify-between text-sm">
                    <span class="text-slate-600">v{v.version}</span>
                    <span class="text-xs text-slate-400">
                      {new Date(v.created_at).toLocaleDateString()}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </form>
  </div>
</AdminLayout>
