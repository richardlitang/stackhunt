---
/**
 * Admin: Content Quality Dashboard
 *
 * Lists all tools by quality gate / index readiness status.
 * Allows bulk re-hunting to improve data quality.
 */

import AdminLayout from '@/layouts/AdminLayout.astro';
import { supabase } from '@/lib/supabase';
import { evaluateIndexReadiness } from '@/lib/quality-gate';
import type { Tool, Review } from '@/types/database';

function toStringArray(value: unknown): string[] {
  if (!Array.isArray(value)) return [];
  return value.filter((entry): entry is string => typeof entry === 'string' && entry.length > 0);
}

function toRecord(value: unknown): Record<string, unknown> {
  if (!value || typeof value !== 'object' || Array.isArray(value)) return {};
  return value as Record<string, unknown>;
}

function getToolPageTelemetry(specs: unknown) {
  const specsRecord = toRecord(specs);
  const canonical = toRecord(specsRecord.canonical);
  const quality = toRecord(canonical.quality);
  const omissionReasons = toRecord(quality.tool_page_contract_omission_reasons);

  const qaBlockers = toStringArray(quality.tool_page_qa_blockers);
  const staleFields = toStringArray(quality.tool_page_freshness_stale_fields);
  const noindexReasons = toStringArray(quality.noindex_reasons);
  const omissionEntries = Object.entries(omissionReasons).filter(
    ([, reason]) => typeof reason === 'string' && reason.length > 0
  ) as Array<[string, string]>;

  return {
    qaBlockers,
    staleFields,
    noindexReasons,
    omissionEntries,
  };
}

// Fetch all tools with their first review
const { data: tools, error } = await supabase
  .from('items')
  .select(
    `
    id,
    slug,
    name,
    short_description,
    pricing_type,
    avg_score,
    review_count,
    view_count,
    learning_curve,
    last_verified_at,
    metadata,
    specs,
    reviews:reviews(
      id,
      summary_markdown,
      pros,
      cons,
      sources
    )
  `
  )
  .eq('type', 'tool')
  .order('name');

if (error) {
  console.error('Error fetching tools:', error);
}

// Evaluate index readiness for each tool
const toolsWithQuality = (tools || []).map((tool) => {
  const publishedReviews = (tool.reviews || [])
    .filter((review: any) => review.status === 'published')
    .sort(
      (a: any, b: any) =>
        new Date(b.created_at || 0).getTime() - new Date(a.created_at || 0).getTime()
    );
  const firstReview = publishedReviews[0] as Review | undefined;
  const readiness = evaluateIndexReadiness(tool as Tool, firstReview);
  return {
    ...tool,
    hasPublishedReview: publishedReviews.length > 0,
    readiness,
  };
});

// Separate by status
const noindexed = toolsWithQuality.filter((t) => !t.readiness.shouldIndex);
const lowQuality = toolsWithQuality.filter(
  (t) => t.readiness.shouldIndex && t.readiness.signals.score < 90
);
const highQuality = toolsWithQuality.filter(
  (t) => t.readiness.shouldIndex && t.readiness.signals.score >= 90
);

// Sort by quality score (lowest first)
noindexed.sort((a, b) => a.readiness.signals.score - b.readiness.signals.score);
lowQuality.sort((a, b) => a.readiness.signals.score - b.readiness.signals.score);

// Stats
const totalTools = toolsWithQuality.length;
const noindexedCount = noindexed.length;
const lowQualityCount = lowQuality.length;
const noindexedPercent = ((noindexedCount / totalTools) * 100).toFixed(1);

const requiredSections = [
  { key: 'summary', label: 'Summary' },
  { key: 'pricing', label: 'Pricing' },
  { key: 'models', label: 'Models' },
  { key: 'setup', label: 'Setup' },
  { key: 'faq', label: 'FAQ' },
] as const;

const requiredSectionCoverage = requiredSections.map((section) => {
  const passing = toolsWithQuality.filter(
    (tool) => tool.readiness.signals.section_publishability[section.key]
  ).length;
  const pct = totalTools > 0 ? ((passing / totalTools) * 100).toFixed(1) : '0.0';
  return { ...section, passing, pct };
});

const sectionStatusKeys = [
  { key: 'pricing', label: 'Pricing' },
  { key: 'specs', label: 'Specs' },
  { key: 'faq', label: 'FAQ' },
  { key: 'community', label: 'Community' },
  { key: 'verdict', label: 'Verdict' },
] as const;

const sectionStatusSummary = sectionStatusKeys.map((section) => {
  const scoped = noindexed.length > 0 ? noindexed : toolsWithQuality;
  const show = scoped.filter(
    (tool) => tool.readiness.signals.section_status[section.key] === 'show'
  ).length;
  const procedural = scoped.filter(
    (tool) => tool.readiness.signals.section_status[section.key] === 'procedural'
  ).length;
  const hide = scoped.filter(
    (tool) => tool.readiness.signals.section_status[section.key] === 'hide'
  ).length;
  return { ...section, show, procedural, hide };
});

const noindexReasonCounts = new Map<string, number>();
for (const tool of noindexed) {
  const reasons = tool.readiness.reasons.length > 0 ? tool.readiness.reasons : ['noindex_unknown'];
  for (const reason of reasons) {
    noindexReasonCounts.set(reason, (noindexReasonCounts.get(reason) || 0) + 1);
  }
  if (!tool.hasPublishedReview) {
    noindexReasonCounts.set(
      'no_published_review',
      (noindexReasonCounts.get('no_published_review') || 0) + 1
    );
  }
}

const topNoindexReasons = Array.from(noindexReasonCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 8);

const noindexedTelemetryRows = noindexed.map((tool) => ({
  id: tool.id,
  telemetry: getToolPageTelemetry(tool.specs),
}));
const noindexedWithQaBlockers = noindexedTelemetryRows.filter(
  (row) => row.telemetry.qaBlockers.length > 0
).length;
const noindexedWithStaleFields = noindexedTelemetryRows.filter(
  (row) => row.telemetry.staleFields.length > 0
).length;
const noindexedWithSectionOmissions = noindexedTelemetryRows.filter(
  (row) => row.telemetry.omissionEntries.length > 0
).length;

const qaBlockerCounts = new Map<string, number>();
const staleFieldCounts = new Map<string, number>();
for (const row of noindexedTelemetryRows) {
  for (const blocker of row.telemetry.qaBlockers) {
    qaBlockerCounts.set(blocker, (qaBlockerCounts.get(blocker) || 0) + 1);
  }
  for (const field of row.telemetry.staleFields) {
    staleFieldCounts.set(field, (staleFieldCounts.get(field) || 0) + 1);
  }
}
const topQaBlockers = Array.from(qaBlockerCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
const topStaleFields = Array.from(staleFieldCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 5);
---

<AdminLayout title="Content Quality Dashboard">
  <div class="space-y-8">
    <!-- Header -->
    <div>
      <h1 class="text-3xl font-bold text-zinc-100">Content Quality Dashboard</h1>
      <p class="mt-2 text-zinc-400">
        Monitor and improve tool data quality. Pages failing required-section, freshness, or
        conflict gates are automatically noindexed.
      </p>
    </div>

    <!-- Stats Cards -->
    <div class="grid gap-6 md:grid-cols-4">
      <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-6">
        <div class="text-sm font-medium text-zinc-400">Total Tools</div>
        <div class="mt-2 text-3xl font-bold text-zinc-100">{totalTools}</div>
      </div>

      <div class="rounded-lg border border-red-500/30 bg-red-500/5 p-6">
        <div class="text-sm font-medium text-red-400">Noindexed</div>
        <div class="mt-2 text-3xl font-bold text-red-400">{noindexedCount}</div>
        <div class="mt-1 text-xs text-red-400/70">{noindexedPercent}% of tools</div>
      </div>

      <div class="rounded-lg border border-amber-500/30 bg-amber-500/5 p-6">
        <div class="text-sm font-medium text-amber-400">Low Quality</div>
        <div class="mt-2 text-3xl font-bold text-amber-400">{lowQualityCount}</div>
        <div class="mt-1 text-xs text-amber-400/70">Readiness score &lt; 90/100</div>
      </div>

      <div class="rounded-lg border border-green-500/30 bg-green-500/5 p-6">
        <div class="text-sm font-medium text-green-400">High Quality</div>
        <div class="mt-2 text-3xl font-bold text-green-400">{highQuality.length}</div>
        <div class="mt-1 text-xs text-green-400/70">Readiness score ≥ 90/100</div>
      </div>
    </div>

    <!-- Gate Telemetry -->
    <section class="space-y-4">
      <div>
        <h2 class="text-xl font-semibold text-zinc-100">Gate Telemetry</h2>
        <p class="mt-1 text-sm text-zinc-400">
          Section-by-section coverage and top blockers across current tool pages.
        </p>
      </div>

      <div class="grid gap-6 lg:grid-cols-4">
        <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-5">
          <h3 class="text-sm font-semibold text-zinc-200">Top Noindex Reasons</h3>
          <div class="mt-3 space-y-2">
            {
              topNoindexReasons.length > 0 ? (
                topNoindexReasons.map(([reason, count]) => (
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-zinc-400">{reason}</span>
                    <span class="rounded bg-zinc-800 px-2 py-0.5 text-zinc-200">{count}</span>
                  </div>
                ))
              ) : (
                <p class="text-sm text-zinc-500">No noindex reasons found.</p>
              )
            }
          </div>
        </div>

        <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-5">
          <h3 class="text-sm font-semibold text-zinc-200">Required Section Coverage</h3>
          <div class="mt-3 space-y-2">
            {
              requiredSectionCoverage.map((section) => (
                <div class="flex items-center justify-between text-sm">
                  <span class="text-zinc-400">{section.label}</span>
                  <span class="text-zinc-200">
                    {section.passing}/{totalTools} ({section.pct}%)
                  </span>
                </div>
              ))
            }
          </div>
        </div>

        <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-5">
          <h3 class="text-sm font-semibold text-zinc-200">Section Status (Noindexed)</h3>
          <div class="mt-3 space-y-2">
            {
              sectionStatusSummary.map((section) => (
                <div class="text-sm">
                  <div class="mb-1 flex items-center justify-between">
                    <span class="text-zinc-400">{section.label}</span>
                    <span class="text-zinc-500">show/proc/hide</span>
                  </div>
                  <div class="text-zinc-200">
                    {section.show}/{section.procedural}/{section.hide}
                  </div>
                </div>
              ))
            }
          </div>
        </div>

        <div class="rounded-lg border border-zinc-700 bg-zinc-900 p-5">
          <h3 class="text-sm font-semibold text-zinc-200">Tool-Page QA Telemetry</h3>
          <div class="mt-3 space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="text-zinc-400">Noindexed with QA blockers</span>
              <span class="text-zinc-200">
                {noindexedWithQaBlockers}/{noindexedCount}
              </span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-zinc-400">Noindexed with stale fields</span>
              <span class="text-zinc-200">
                {noindexedWithStaleFields}/{noindexedCount}
              </span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-zinc-400">Noindexed with omissions</span>
              <span class="text-zinc-200">
                {noindexedWithSectionOmissions}/{noindexedCount}
              </span>
            </div>
            {
              topQaBlockers.length > 0 && (
                <div class="pt-2 text-xs text-zinc-500">
                  Top QA blocker: {topQaBlockers[0][0]} ({topQaBlockers[0][1]})
                </div>
              )
            }
            {
              topStaleFields.length > 0 && (
                <div class="text-xs text-zinc-500">
                  Top stale field: {topStaleFields[0][0]} ({topStaleFields[0][1]})
                </div>
              )
            }
          </div>
        </div>
      </div>
    </section>

    <!-- Noindexed Tools -->
    {
      noindexedCount > 0 && (
        <section class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-xl font-semibold text-red-400">
                🚫 Noindexed Pages ({noindexedCount})
              </h2>
              <p class="mt-1 text-sm text-zinc-400">
                These tools are hidden from search engines due to low data quality.
              </p>
            </div>
            <button
              type="button"
              class="rounded-lg bg-red-500 px-4 py-2 text-sm font-medium text-white hover:bg-red-600 transition"
              onclick="queueAllForRehunt('noindexed')"
            >
              Queue All for Re-Hunt
            </button>
          </div>

          <div class="space-y-3">
            {noindexed.map((tool) => (
              <div class="rounded-lg border border-red-500/20 bg-zinc-900 p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-3">
                      <a
                        href={`/tool/${tool.slug}`}
                        class="text-lg font-medium text-zinc-100 hover:text-red-400 transition"
                        target="_blank"
                      >
                        {tool.name}
                      </a>
                      <span class="rounded-full bg-red-500/10 px-2 py-0.5 text-xs font-medium text-red-400">
                        {tool.readiness.signals.score}/100
                      </span>
                    </div>

                    <div class="mt-2 space-y-1">
                      <div class="text-sm text-zinc-400">
                        <span class="font-medium text-red-400">Issues:</span>
                        {!tool.hasPublishedReview && <span> no_published_review</span>}
                        {tool.readiness.reasons.map((reason, idx) => (
                          <span>
                            {(idx > 0 || !tool.hasPublishedReview) && ' • '}
                            {reason}
                          </span>
                        ))}
                      </div>

                      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                        <span>
                          Required: {tool.readiness.signals.required_sections_complete ? '✓' : '✗'}
                        </span>
                        <span>MVUP: {tool.readiness.signals.mvup_complete ? '✓' : '✗'}</span>
                        <span>Fresh: {tool.readiness.signals.volatiles_fresh ? '✓' : '✗'}</span>
                        <span>Conflicts: {tool.readiness.signals.conflicts_count}</span>
                        <span>
                          Risky claims: {tool.readiness.signals.has_risky_claims ? '⚠️' : '✓'}
                        </span>
                      </div>
                      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                        <span>
                          Sections:
                          {tool.readiness.signals.section_publishability.summary ? ' S✓' : ' S✗'}
                          {tool.readiness.signals.section_publishability.pricing ? ' P✓' : ' P✗'}
                          {tool.readiness.signals.section_publishability.models ? ' M✓' : ' M✗'}
                          {tool.readiness.signals.section_publishability.setup ? ' U✓' : ' U✗'}
                          {tool.readiness.signals.section_publishability.faq ? ' F✓' : ' F✗'}
                        </span>
                        <span>
                          Evidence: faq={tool.readiness.signals.evidence_counts.faq}· pricing=
                          {tool.readiness.signals.evidence_counts.pricing}· specs=
                          {tool.readiness.signals.evidence_counts.specs}· community=
                          {tool.readiness.signals.evidence_counts.community_domains}
                        </span>
                      </div>
                      <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                        {(() => {
                          const telemetry = getToolPageTelemetry(tool.specs);
                          const qaText =
                            telemetry.qaBlockers.length > 0
                              ? telemetry.qaBlockers.join(', ')
                              : 'none';
                          const staleText =
                            telemetry.staleFields.length > 0
                              ? telemetry.staleFields.join(', ')
                              : 'none';
                          const omissionText =
                            telemetry.omissionEntries.length > 0
                              ? telemetry.omissionEntries
                                  .map(([section, reason]) => `${section}:${reason}`)
                                  .join(' | ')
                              : 'none';
                          return (
                            <>
                              <span>QA blockers: {qaText}</span>
                              <span>Stale fields: {staleText}</span>
                              <span>Section omissions: {omissionText}</span>
                            </>
                          );
                        })()}
                      </div>
                    </div>
                  </div>

                  <div class="flex gap-2">
                    <a
                      href={`/admin/review/${tool.id}`}
                      class="rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-sm font-medium text-zinc-300 hover:bg-zinc-700 transition"
                    >
                      Review
                    </a>
                    <button
                      type="button"
                      class="rounded-lg bg-red-500 px-3 py-1.5 text-sm font-medium text-white hover:bg-red-600 transition"
                      onclick={`queueForRehunt('${tool.id}', '${tool.name}')`}
                    >
                      Re-Hunt
                    </button>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <!-- Low Quality Tools -->
    {
      lowQualityCount > 0 && (
        <section class="space-y-4">
          <div class="flex items-center justify-between">
            <div>
              <h2 class="text-xl font-semibold text-amber-400">
                ⚠️ Low Quality (Indexed) ({lowQualityCount})
              </h2>
              <p class="mt-1 text-sm text-zinc-400">
                These tools are indexed but could benefit from improved data.
              </p>
            </div>
            <button
              type="button"
              class="rounded-lg border border-amber-500 bg-amber-500/10 px-4 py-2 text-sm font-medium text-amber-400 hover:bg-amber-500/20 transition"
              onclick="queueAllForRehunt('low-quality')"
            >
              Queue All for Re-Hunt
            </button>
          </div>

          <div class="space-y-3">
            {lowQuality.slice(0, 20).map((tool) => (
              <div class="rounded-lg border border-amber-500/20 bg-zinc-900 p-4">
                <div class="flex items-start justify-between gap-4">
                  <div class="flex-1">
                    <div class="flex items-center gap-3">
                      <a
                        href={`/tool/${tool.slug}`}
                        class="text-lg font-medium text-zinc-100 hover:text-amber-400 transition"
                        target="_blank"
                      >
                        {tool.name}
                      </a>
                      <span class="rounded-full bg-amber-500/10 px-2 py-0.5 text-xs font-medium text-amber-400">
                        {tool.readiness.signals.score}/100
                      </span>
                    </div>

                    <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-xs text-zinc-500">
                      <span>
                        Required: {tool.readiness.signals.required_sections_complete ? '✓' : '✗'}
                      </span>
                      <span>MVUP: {tool.readiness.signals.mvup_complete ? '✓' : '✗'}</span>
                      <span>Fresh: {tool.readiness.signals.volatiles_fresh ? '✓' : '✗'}</span>
                      <span>Conflicts: {tool.readiness.signals.conflicts_count}</span>
                    </div>
                  </div>

                  <button
                    type="button"
                    class="rounded-lg border border-amber-500 bg-amber-500/10 px-3 py-1.5 text-sm font-medium text-amber-400 hover:bg-amber-500/20 transition"
                    onclick={`queueForRehunt('${tool.id}', '${tool.name}')`}
                  >
                    Re-Hunt
                  </button>
                </div>
              </div>
            ))}
            {lowQualityCount > 20 && (
              <div class="text-center text-sm text-zinc-500">
                ... and {lowQualityCount - 20} more
              </div>
            )}
          </div>
        </section>
      )
    }

    <!-- High Quality Sample -->
    <section class="space-y-4">
      <div>
        <h2 class="text-xl font-semibold text-green-400">✅ High Quality Sample</h2>
        <p class="mt-1 text-sm text-zinc-400">
          Examples of well-documented tools with strong data quality.
        </p>
      </div>

      <div class="space-y-3">
        {
          highQuality.slice(0, 5).map((tool) => (
            <div class="rounded-lg border border-green-500/20 bg-zinc-900 p-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <a
                    href={`/tool/${tool.slug}`}
                    class="text-lg font-medium text-zinc-100 hover:text-green-400 transition"
                    target="_blank"
                  >
                    {tool.name}
                  </a>
                  <span class="rounded-full bg-green-500/10 px-2 py-0.5 text-xs font-medium text-green-400">
                    {tool.readiness.signals.score}/100
                  </span>
                </div>

                <div class="flex gap-x-4 text-xs text-zinc-500">
                  <span>
                    Required: {tool.readiness.signals.required_sections_complete ? '✓' : '✗'}
                  </span>
                  <span>MVUP: {tool.readiness.signals.mvup_complete ? '✓' : '✗'}</span>
                  <span>Fresh: {tool.readiness.signals.volatiles_fresh ? '✓' : '✗'}</span>
                  <span>Conflicts: {tool.readiness.signals.conflicts_count}</span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</AdminLayout>

<script>
  // Queue single tool for re-hunt
  async function queueForRehunt(toolId: string, toolName: string) {
    if (!confirm(`Queue ${toolName} for re-hunt?`)) return;

    try {
      const response = await fetch('/api/admin/queue-tool', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          toolId,
          toolName,
          priority: 7,
          huntType: 'refresh',
          source: 'quality_improvement',
        }),
      });

      if (!response.ok) throw new Error('Failed to queue tool');

      alert(`✅ ${toolName} queued for re-hunt`);
    } catch (error) {
      console.error('Error queuing tool:', error);
      alert('❌ Failed to queue tool. Check console for details.');
    }
  }

  // Queue all tools in a category
  async function queueAllForRehunt(category: string) {
    const confirmMsg =
      category === 'noindexed'
        ? 'Queue ALL noindexed tools for re-hunt? This may take a while.'
        : 'Queue ALL low-quality tools for re-hunt? This may take a while.';

    if (!confirm(confirmMsg)) return;

    // Get all tool IDs from the current page
    const tools = Array.from(document.querySelectorAll(`[onclick*="queueForRehunt"]`))
      .map((btn) => {
        const match = btn.getAttribute('onclick')?.match(/queueForRehunt\('([^']+)', '([^']+)'/);
        return match ? { id: match[1], name: match[2] } : null;
      })
      .filter(Boolean);

    let queued = 0;
    let failed = 0;

    for (const tool of tools) {
      try {
        const response = await fetch('/api/admin/queue-tool', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            toolId: tool.id,
            toolName: tool.name,
            priority: category === 'noindexed' ? 8 : 6,
            huntType: 'refresh',
            source: 'quality_improvement',
          }),
        });

        if (response.ok) {
          queued++;
        } else {
          failed++;
        }
      } catch {
        failed++;
      }
    }

    alert(`✅ Queued ${queued} tools for re-hunt${failed > 0 ? ` (${failed} failed)` : ''}`);
    location.reload();
  }

  // Make functions global
  (window as any).queueForRehunt = queueForRehunt;
  (window as any).queueAllForRehunt = queueAllForRehunt;
</script>
