---
/**
 * Context/List Page - /best/[slug]
 * The "Spoke" in our Hub & Spoke model
 *
 * Examples:
 * - /best/crm-for-small-teams
 * - /best/slack-alternatives-for-remote-teams
 *
 * Features:
 * - Ranked tool list with contextual scores
 * - SEO: ItemList JSON-LD schema
 * - Internal links to each tool's hub page
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/shared/Logo.astro';
import ProsCons from '@/components/tool-page/ProsCons.astro';
import SentimentTags from '@/components/tool-page/SentimentTags.astro';
import VoteWidget from '@/components/interactive/VoteWidget';
import AffiliateDisclosure from '@/components/shared/AffiliateDisclosure.astro';
import RelatedContent from '@/components/shared/RelatedContent.astro';
import TrustBar from '@/components/tool-page/TrustBar.astro';
import BestShortlistSection from '@/components/shared/BestShortlistSection.astro';
import { getContextBySlug, getProvisionalReviewsForContext, supabase } from '@/lib/supabase';
import { validateAdminAuth } from '@/lib/auth';
import {
  getLatestDraftBestSnapshot,
  getLatestPublishedBestSnapshot,
} from '@/lib/compiler/snapshot-store';
import { generateContextMeta, generateListSchema, generateBreadcrumbSchema } from '@/lib/seo';
import { getDisplayDescription } from '@/lib/display-description';
import { getCanonicalUrl, simpleMarkdown, getScoreColor } from '@/lib/utils';
import { areToolsComparable } from '@/lib/analysis/comparator';

// Server-render for fresh data (switch to prerender = true for production if needed)
export const prerender = false;

// Cache for 5 minutes
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=300, s-maxage=300, stale-while-revalidate=600'
);

const { slug } = Astro.params;

// Preserve the traction winner and fold known duplicate startup CRM intents into it.
const CANONICAL_CRM_STARTUP_SLUG = 'crm-for-startups';
const CRM_STARTUP_ALIAS_SLUGS = new Set([
  'lightweight-crm-for-startup-sales-teams',
  'crm-platform-for-startup-revenue-teams',
]);

if (slug && CRM_STARTUP_ALIAS_SLUGS.has(slug)) {
  return Astro.redirect(`/best/${CANONICAL_CRM_STARTUP_SLUG}`, 301);
}

const AUTHORITATIVE_SOURCE_TYPES = new Set(['official', 'docs', 'support', 'legal']);
const PROVISIONAL_MIN_SCORE = 70;
const PROVISIONAL_MIN_PROS = 2;
const PROVISIONAL_MIN_CONS = 1;
const PROVISIONAL_MIN_SOURCES = 3;
const PROVISIONAL_MIN_AUTHORITATIVE_SOURCES = 1;
const PROVISIONAL_TARGET_PICKS = 5;
const MAX_PROVISIONAL_PICKS = 5;

function countClaimBullets(raw: unknown): number {
  if (!Array.isArray(raw)) return 0;
  return raw.filter((entry) => {
    if (typeof entry === 'string') return entry.trim().length > 0;
    if (entry && typeof entry === 'object') {
      const text = (entry as { text?: string }).text;
      return typeof text === 'string' && text.trim().length > 0;
    }
    return false;
  }).length;
}

function getSourceStats(rawSources: unknown) {
  const sources = Array.isArray(rawSources) ? rawSources : [];
  const authoritativeDomains = new Set<string>();
  let authoritativeSources = 0;

  for (const source of sources) {
    if (!source || typeof source !== 'object') continue;
    const sourceType = String(
      (source as any).source_type || (source as any).type || ''
    ).toLowerCase();
    if (!AUTHORITATIVE_SOURCE_TYPES.has(sourceType)) continue;
    authoritativeSources += 1;

    const rawDomain =
      typeof (source as any).domain === 'string'
        ? (source as any).domain
        : typeof (source as any).url === 'string'
          ? (() => {
              try {
                return new URL((source as any).url).hostname;
              } catch {
                return '';
              }
            })()
          : '';
    const normalizedDomain = rawDomain
      .replace(/^www\./i, '')
      .toLowerCase()
      .trim();
    if (normalizedDomain) authoritativeDomains.add(normalizedDomain);
  }

  return {
    sourceCount: sources.length,
    authoritativeSources,
    authoritativeDomains: authoritativeDomains.size,
  };
}

function getReviewDataQuality(review: any): 'high' | 'medium' | 'low' | 'unknown' {
  const reviewQuality = String(review?.quality || '').toLowerCase();
  if (reviewQuality === 'high' || reviewQuality === 'medium' || reviewQuality === 'low') {
    return reviewQuality;
  }
  const metadataQuality = String(review?.item?.metadata?.meta?.data_quality || '').toLowerCase();
  if (metadataQuality === 'high' || metadataQuality === 'medium' || metadataQuality === 'low') {
    return metadataQuality;
  }
  return 'unknown';
}

function getConfidenceScore(quality: 'high' | 'medium' | 'low' | 'unknown'): number {
  if (quality === 'high') return 100;
  if (quality === 'medium') return 75;
  if (quality === 'low') return 50;
  return 35;
}

function getEvidenceScore(
  sourceCount: number,
  authoritativeSources: number,
  authoritativeDomains: number
) {
  const sourceScore = Math.min(100, sourceCount * 14);
  const authoritativeSourceScore = Math.min(100, authoritativeSources * 35);
  const authoritativeDomainScore = Math.min(100, authoritativeDomains * 50);
  return Math.round(
    sourceScore * 0.4 + authoritativeSourceScore * 0.4 + authoritativeDomainScore * 0.2
  );
}

function getFreshnessScore(review: any): number {
  const referenceDate = review?.updated_at || review?.created_at;
  if (!referenceDate) return 40;
  const ageDays = (Date.now() - new Date(referenceDate).getTime()) / (1000 * 60 * 60 * 24);
  if (ageDays <= 14) return 100;
  if (ageDays <= 30) return 85;
  if (ageDays <= 90) return 70;
  if (ageDays <= 180) return 55;
  return 35;
}

function scoreProvisionalReview(review: any) {
  const score = Number(review?.score || 0);
  if (score < PROVISIONAL_MIN_SCORE) return null;

  const prosCount = countClaimBullets(review?.pros);
  const consCount = countClaimBullets(review?.cons);
  const summaryLength =
    typeof review?.summary_markdown === 'string' ? review.summary_markdown.trim().length : 0;
  const { sourceCount, authoritativeSources, authoritativeDomains } = getSourceStats(
    review?.sources
  );

  if (
    summaryLength < 120 ||
    prosCount < PROVISIONAL_MIN_PROS ||
    consCount < PROVISIONAL_MIN_CONS ||
    sourceCount < PROVISIONAL_MIN_SOURCES ||
    authoritativeSources < PROVISIONAL_MIN_AUTHORITATIVE_SOURCES
  ) {
    return null;
  }

  const quality = getReviewDataQuality(review);
  const confidence = getConfidenceScore(quality);
  const evidence = getEvidenceScore(sourceCount, authoritativeSources, authoritativeDomains);
  const freshness = getFreshnessScore(review);

  let penalty = 0;
  const pricingConfidence = String(review?.item?.pricing_confidence || '').toLowerCase();
  if (!pricingConfidence || pricingConfidence === 'unknown') penalty += 10;
  if (pricingConfidence === 'low') penalty += 14;
  if (quality === 'unknown') penalty += 8;

  const total = Math.max(
    0,
    Math.min(
      100,
      Math.round(0.55 * score + 0.2 * confidence + 0.15 * evidence + 0.1 * freshness - penalty)
    )
  );

  return {
    total,
    sourceCount,
    authoritativeSources,
    quality,
  };
}

// Fetch context with all tools
const context = await getContextBySlug(slug);

if (!context) {
  return Astro.redirect('/404');
}

const publishedReviews = [...(context.reviews || [])].sort(
  (a, b) => (b.score || 0) - (a.score || 0)
);
let provisionalReviews: any[] = [];
const wantsAdminPreview = Astro.url.searchParams.get('preview') === 'admin';
const canUseAdminPreview = wantsAdminPreview ? await validateAdminAuth(Astro.cookies) : false;
const snapshotReadEnabled =
  String(import.meta.env.BEST_SNAPSHOT_READ_ENABLED || 'false').toLowerCase() === 'true';
const snapshotDraftPreviewEnabled =
  String(import.meta.env.BEST_SNAPSHOT_DRAFT_PREVIEW_ENABLED || 'false').toLowerCase() === 'true';

let selectedSnapshot: any = null;

if (snapshotReadEnabled) {
  if (canUseAdminPreview && snapshotDraftPreviewEnabled) {
    try {
      selectedSnapshot = await getLatestDraftBestSnapshot(slug || '');
    } catch (error) {
      console.warn('[best page] Draft snapshot unavailable:', error);
    }
  }
  if (!selectedSnapshot) {
    try {
      selectedSnapshot = await getLatestPublishedBestSnapshot(slug || '');
    } catch (error) {
      console.warn('[best page] Published snapshot unavailable:', error);
    }
  }
}

if (canUseAdminPreview) {
  try {
    provisionalReviews = await getProvisionalReviewsForContext(context.id, 30);
  } catch (error) {
    console.warn('[best page] Provisional reviews unavailable:', error);
  }
}

const publishedItemIds = new Set(
  publishedReviews
    .map((review: any) => review.item_id || review.item?.id)
    .filter((value): value is string => typeof value === 'string' && value.length > 0)
);

const provisionalCandidates = provisionalReviews
  .filter((review) => {
    const itemId = review.item_id || review.item?.id;
    return typeof itemId === 'string' && !publishedItemIds.has(itemId);
  })
  .map((review) => {
    const provisional = scoreProvisionalReview(review);
    if (!provisional) return null;
    return {
      ...review,
      _isProvisional: true,
      _rankScore: provisional.total,
      _provisional: provisional,
    };
  })
  .filter((review): review is any => Boolean(review))
  .sort((a, b) => (b._rankScore || 0) - (a._rankScore || 0));

const provisionalSlots =
  publishedReviews.length < PROVISIONAL_TARGET_PICKS
    ? PROVISIONAL_TARGET_PICKS - publishedReviews.length
    : 0;
const selectedProvisionalReviews =
  canUseAdminPreview && provisionalSlots > 0 && !selectedSnapshot
    ? provisionalCandidates.slice(0, Math.min(MAX_PROVISIONAL_PICKS, provisionalSlots))
    : [];

const runtimeSortedReviews = [
  ...publishedReviews.map((review: any) => ({
    ...review,
    _isProvisional: false,
    _rankScore: Number(review.score || 0),
  })),
  ...selectedProvisionalReviews,
].sort((a, b) => (b._rankScore || 0) - (a._rankScore || 0));

const snapshotRanked = Array.isArray(selectedSnapshot?.snapshot_json?.ranked)
  ? (selectedSnapshot.snapshot_json.ranked as Array<{
      item_id?: string;
      tool_id?: string;
      score?: number;
    }>)
  : [];
const runtimeReviewByItemId = new Map(
  runtimeSortedReviews
    .map((review: any) => {
      const itemId = String(review.item_id || review.item?.id || '').trim();
      return itemId ? [itemId, review] : null;
    })
    .filter((entry): entry is [string, any] => Boolean(entry))
);
const snapshotOrderedReviews = snapshotRanked
  .map((entry) => {
    const itemId = String(entry.item_id || entry.tool_id || '').trim();
    if (!itemId) return null;
    const review = runtimeReviewByItemId.get(itemId);
    if (!review) return null;
    return {
      ...review,
      _isProvisional: false,
      _rankScore: Number(entry.score ?? review.score ?? 0),
      _snapshotRanked: true,
    };
  })
  .filter((review): review is any => Boolean(review));
const snapshotRankedIds = new Set(
  snapshotOrderedReviews
    .map((review: any) => String(review.item_id || review.item?.id || '').trim())
    .filter((value: string) => value.length > 0)
);
const runtimeRemainderReviews = runtimeSortedReviews.filter((review: any) => {
  const itemId = String(review.item_id || review.item?.id || '').trim();
  return itemId ? !snapshotRankedIds.has(itemId) : true;
});
const sortedReviews = selectedSnapshot
  ? [...snapshotOrderedReviews, ...runtimeRemainderReviews]
  : runtimeSortedReviews;

const displayToolCount = Math.max(context.tool_count || 0, sortedReviews.length);
const contextForMeta = {
  ...context,
  tool_count: displayToolCount,
};

// Fetch related contexts (same category, different slug)
const { data: relatedContexts } = context.category_id
  ? await supabase
      .from('contexts')
      .select('id, slug, title, tool_count')
      .eq('category_id', context.category_id)
      .gt('tool_count', 0)
      .neq('id', context.id)
      .limit(5)
  : { data: [] };

// Build deduplicated related content for internal linking (SEO)
// Merged from previous relatedLinks + relatedContentItems to eliminate duplication
const exploreMoreItems: Array<{
  href: string;
  title: string;
  description?: string;
  type: 'list' | 'comparison' | 'category' | 'tool';
  priority: number;
}> = [];

// Priority 1: Comparison between top 2 (unique, high-intent SEO)
// Only add if tools are comparable (same category or comparable functions)
if (sortedReviews.length >= 2) {
  const tool1 = sortedReviews[0].item;
  const tool2 = sortedReviews[1].item;
  const canCompare = areToolsComparable(
    { slug: tool1.slug, category_id: tool1.category?.id || null, metadata: tool1.metadata as any },
    { slug: tool2.slug, category_id: tool2.category?.id || null, metadata: tool2.metadata as any }
  );
  if (canCompare) {
    exploreMoreItems.push({
      href: `/compare/${tool1.slug}-vs-${tool2.slug}`,
      title: `${tool1.name} vs ${tool2.name}`,
      description: 'Head-to-head comparison of top picks',
      type: 'comparison',
      priority: 100,
    });
  }
}

// Priority 2: Category link
if (context.category) {
  exploreMoreItems.push({
    href: `/categories/${context.category.slug}`,
    title: `All ${context.category.name} Tools`,
    description: `Browse the complete ${context.category.name.toLowerCase()} category`,
    type: 'category',
    priority: 90,
  });
}

// Priority 3: Related lists (same category)
for (const ctx of (relatedContexts || []).slice(0, 4)) {
  exploreMoreItems.push({
    href: `/best/${ctx.slug}`,
    title: ctx.title,
    description: `${ctx.tool_count} tools compared`,
    type: 'list',
    priority: 80,
  });
}

// Priority 4: Top tools from this list
for (const review of sortedReviews.slice(0, 2)) {
  exploreMoreItems.push({
    href: `/tool/${review.item.slug}`,
    title: `${review.item.name} Review`,
    description: review.item.short_description || undefined,
    type: 'tool',
    priority: 70,
  });
}

// Generate SEO (base; quality gate applied below after trust metrics are computed)
const contextMeta = generateContextMeta(contextForMeta, context.category?.name);
const schemas = [
  generateListSchema(
    contextForMeta,
    sortedReviews.map((r, i) => ({
      tool: r.item,
      score: r._rankScore || 0,
      position: i + 1,
    }))
  ),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Best Lists', url: '/best' },
    ...(context.category
      ? [{ name: context.category.name, url: `/categories/${context.category.slug}` }]
      : []),
    { name: context.title, url: `/best/${context.slug}` },
  ]),
];

const formatDate = (value?: string | null): string | null => {
  if (!value) return null;
  const parsed = new Date(value);
  if (Number.isNaN(parsed.getTime())) return null;
  return parsed.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
const latestReviewUpdate =
  sortedReviews.length > 0
    ? sortedReviews
        .map((review) => review.updated_at || null)
        .filter((value): value is string => Boolean(value))
        .sort((a, b) => new Date(b).getTime() - new Date(a).getTime())[0] || null
    : null;
const contextCheckedLabel = formatDate(latestReviewUpdate || context.updated_at || null);
const listSourceCount = new Set(
  sortedReviews
    .flatMap((review) =>
      Array.isArray((review as any).sources)
        ? ((review as any).sources as Array<{ url?: string }>)
            .map((entry) => entry.url)
            .filter((url): url is string => Boolean(url))
        : []
    )
    .slice(0, 200)
).size;
const snapshotSourceCount = Number(selectedSnapshot?.snapshot_json?.metrics?.sources_count || 0);
const effectiveSourceCount = snapshotSourceCount > 0 ? snapshotSourceCount : listSourceCount;
const listTrustStatus: 'Source-backed' | 'Needs confirmation' = contextCheckedLabel
  ? 'Source-backed'
  : 'Needs confirmation';
const listConfidence: 'High' | 'Medium' | 'Low' =
  sortedReviews.length >= 5 ? 'High' : sortedReviews.length >= 2 ? 'Medium' : 'Low';

const hasMinimumComparisons = sortedReviews.length >= 2;
const hasSourceCoverage = effectiveSourceCount >= 5;
const hasFreshnessSignal = Boolean(contextCheckedLabel);
const hasReadableSummaryCoverage = sortedReviews.some(
  (review) => !isSparseSummary(review.summary_markdown)
);
const topPickNames = sortedReviews.slice(0, 3).map((review) => review.item.name);
const sourceBackedPickCount = sortedReviews.filter(
  (review) => getReviewDataQuality(review) === 'high' || getReviewDataQuality(review) === 'medium'
).length;
const listStateSummary =
  sortedReviews.length > 0
    ? `This list currently includes ${sortedReviews.length} ranked picks, with ${sourceBackedPickCount} showing medium-to-high data quality signals.`
    : 'No ranked picks are published yet, so this page should be used as a buying checklist until source-backed picks are added.';
const shortlistChecklist = [
  'Confirm your must-have workflow can be completed without paid add-ons.',
  'Validate migration, import/export, and rollback constraints before rollout.',
  'Model price changes at your expected seat or usage volume, not just day-one pricing.',
];
const shortlistSignals = [
  context.category
    ? `Most options in this list compete in the ${context.category.name} workflow family.`
    : 'Most options in this list compete for a similar primary workflow.',
  topPickNames.length > 0
    ? `Current leading picks include ${topPickNames.join(', ')}.`
    : 'The shortlist is still being assembled from verified review evidence.',
  hasFreshnessSignal
    ? `Latest source-backed check: ${contextCheckedLabel}.`
    : 'Freshness checks are still pending before full publication confidence.',
];
const shouldNoindex =
  !selectedSnapshot &&
  (!hasMinimumComparisons ||
    !hasSourceCoverage ||
    !hasFreshnessSignal ||
    !hasReadableSummaryCoverage);

const safeDraftDescription =
  'This list is still in editorial verification and may be incomplete. See finalized software comparisons on StackHunt.';
const meta = {
  ...contextMeta,
  description: shouldNoindex ? safeDraftDescription : contextMeta.description,
  canonical: shouldNoindex ? getCanonicalUrl('/best') : contextMeta.canonical,
  noindex: shouldNoindex,
};
Astro.response.headers.set('X-Robots-Tag', meta.noindex ? 'noindex,follow' : 'index,follow');

// Check if any tools have affiliate links
const hasAffiliateLinks = sortedReviews.some((review) =>
  review.item.affiliate_offers?.some((offer) => offer.is_affiliate)
);

function _extractHighlights(specs: Record<string, unknown> | null | undefined, limit = 2) {
  const pros = Array.isArray((specs as any)?.pros) ? (specs as any).pros : [];
  const cons = Array.isArray((specs as any)?.cons) ? (specs as any).cons : [];
  const pickText = (items: any[]) =>
    items
      .map((item) => (typeof item === 'string' ? item : item?.text))
      .filter(Boolean)
      .slice(0, limit);
  return { pros: pickText(pros), cons: pickText(cons).slice(0, 1) };
}

function getClaimText(claim: unknown): string {
  if (typeof claim === 'string') return claim.trim();
  if (claim && typeof claim === 'object' && typeof (claim as any).text === 'string') {
    return ((claim as any).text as string).trim();
  }
  return '';
}

function isSparseSummary(summary: unknown): boolean {
  if (typeof summary !== 'string') return true;
  const text = summary.trim();
  if (!text) return true;
  const normalized = text.toLowerCase();
  const lines = text
    .split('\n')
    .map((line) => line.trim())
    .filter(Boolean);
  const bulletCount = lines.filter((line) => line.startsWith('-')).length;
  const headingCount = lines.filter((line) => /^(\*\*|#{1,3}\s)/.test(line)).length;
  const chooseAvoidOnly =
    normalized.includes('choose if') &&
    normalized.includes('avoid if') &&
    bulletCount <= 2 &&
    headingCount <= 3;
  return chooseAvoidOnly || text.length < 180;
}
---

<BaseLayout meta={meta} schemas={schemas}>
  {/* FTC Affiliate Disclosure - Above the fold */}
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={hasAffiliateLinks} />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-500">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/best" class="hover:text-hunt-500">Best Lists</a>
      {
        context.category && (
          <>
            <span>/</span>
            <a href={`/categories/${context.category.slug}`} class="hover:text-hunt-500">
              {context.category.name}
            </a>
          </>
        )
      }
      <span>/</span>
      <span class="text-zinc-300 truncate">{context.title}</span>
    </nav>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h1 class="text-3xl font-bold text-zinc-100 sm:text-4xl">
            {context.title}
          </h1>

          {
            context.category && (
              <div class="mt-2">
                <a
                  href={`/categories/${context.category.slug}`}
                  class="inline-flex items-center gap-1 text-sm text-zinc-400 hover:text-hunt-500"
                >
                  <span>{context.category.icon || '📁'}</span>
                  {context.category.name}
                </a>
              </div>
            )
          }
        </div>

        <div class="shrink-0 text-right">
          <div class="text-3xl font-bold text-hunt-500">{displayToolCount}</div>
          <div class="text-sm text-zinc-400">
            {
              selectedProvisionalReviews.length > 0
                ? 'tools compared + early picks'
                : 'tools compared'
            }
          </div>
        </div>
      </div>

      {
        context.intro_text && (
          <div
            class="mt-6 prose prose-slate prose-sm max-w-none rounded-xl border border-zinc-700 bg-zinc-900 p-5"
            set:html={simpleMarkdown(context.intro_text)}
          />
        )
      }

      <!-- If this is an "alternatives to" page, show primary item -->
      {
        context.primary_item && (
          <div class="mt-6 rounded-xl border border-amber-200 bg-amber-50 p-4">
            <div class="flex items-center gap-3">
              <span class="text-sm text-amber-700">Looking for alternatives to</span>
              <a
                href={`/tool/${context.primary_item.slug}`}
                class="inline-flex items-center gap-2 font-medium text-amber-800 hover:text-amber-900"
              >
                {context.primary_item.logo_url && (
                  <img src={context.primary_item.logo_url} alt="" class="h-5 w-5 rounded" />
                )}
                {context.primary_item.name}
                <span class="text-amber-600">→</span>
              </a>
            </div>
          </div>
        )
      }

      <div class="mt-6">
        <TrustBar
          status={listTrustStatus}
          pendingCount={selectedProvisionalReviews.length}
          evaluationDepth="Docs-only"
          lastChecked={contextCheckedLabel || 'Unknown'}
          confidence={listConfidence}
          sourcesCount={effectiveSourceCount}
          sourcesHref="#tool-list"
        />
      </div>
    </header>

    <section class="mb-8 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
      <h2 class="text-lg font-semibold text-zinc-100">Quick checks before you buy</h2>
      <ul class="mt-3 space-y-2 text-sm text-zinc-300">
        <li>- Confirm plan-gated features for your top 2 picks.</li>
        <li>- Verify pricing cadence, seat model, and cancellation terms.</li>
        <li>- Run one real workflow trial before committing.</li>
      </ul>
      <details class="group mt-4 rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
        <summary
          class="flex cursor-pointer list-none items-center justify-between text-sm font-semibold text-zinc-200"
        >
          Team / IT checks
          <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
            <span class="group-open:hidden">Expand</span>
            <span class="hidden group-open:inline">Collapse</span>
          </span>
        </summary>
        <ul class="mt-3 space-y-2 text-sm text-zinc-300">
          <li>- Confirm SSO, SCIM, DPA, and audit log requirements.</li>
          <li>- Validate API limits and integration constraints for rollout.</li>
        </ul>
      </details>
    </section>

    <BestShortlistSection
      summary={listStateSummary}
      checklist={shortlistChecklist}
      signals={shortlistSignals}
    />

    <!-- Ranked Tool List -->
    <section id="tool-list">
      <div class="mb-6 flex items-center justify-between">
        <h2 class="text-xl font-semibold text-zinc-100">
          {
            sortedReviews.length === 1
              ? 'Our Top Pick'
              : sortedReviews.length === 2
                ? 'Our Top 2 Picks'
                : `Top ${Math.min(sortedReviews.length, 10)} Picks`
          }
        </h2>
        <span class="text-sm text-zinc-400">
          {
            selectedSnapshot
              ? 'Sorted by snapshot compiler'
              : selectedProvisionalReviews.length > 0
                ? 'Sorted by contextual + provisional rank'
                : 'Sorted by contextual score'
          }
        </span>
      </div>

      <div class:list={['space-y-8', sortedReviews.length === 1 && 'max-w-2xl mx-auto']}>
        {
          sortedReviews.map((review, index) => {
            const rank = index + 1;
            const isProvisional = Boolean((review as any)._isProvisional);
            const displayScore = Number((review as any)._rankScore || 0);
            const scoreColors = getScoreColor(displayScore);

            return (
              <article
                class="rounded-xl border border-zinc-700 bg-zinc-900 overflow-hidden shadow-sm transition-all hover:shadow-lg hover:border-zinc-600"
                id={`tool-${rank}`}
              >
                {/* Rank Header */}
                <div
                  class={`flex items-center justify-between px-6 py-3 ${rank === 1 ? 'bg-gradient-to-r from-amber-50 to-yellow-50 border-b border-amber-100' : 'bg-zinc-900 border-b border-zinc-800'}`}
                >
                  <div class="flex items-center gap-3">
                    {sortedReviews.length > 1 && (
                      <span
                        class={`flex h-8 w-8 items-center justify-center rounded-full font-bold text-sm ${rank === 1 ? 'bg-amber-500 text-white' : rank === 2 ? 'bg-zinc-600 text-white' : rank === 3 ? 'bg-amber-700 text-white' : 'bg-zinc-700 text-zinc-300'}`}
                      >
                        #{rank}
                      </span>
                    )}
                    {rank === 1 && <span class="text-xs font-medium text-amber-700">Top Pick</span>}
                    {isProvisional && (
                      <span class="rounded-full border border-sky-500/40 bg-sky-500/10 px-2 py-0.5 text-xs font-medium text-sky-200">
                        Early Pick
                      </span>
                    )}
                  </div>

                  <div class="flex items-center gap-3">
                    <span class={`text-sm font-medium ${scoreColors.text}`}>
                      {isProvisional
                        ? `Provisional: ${displayScore}/100`
                        : `Score: ${displayScore}/100`}
                    </span>
                    <div class={`h-2 w-16 rounded-full ${scoreColors.bg}`}>
                      <div
                        class={`h-2 rounded-full ${displayScore >= 70 ? 'bg-green-500' : displayScore >= 50 ? 'bg-yellow-500' : 'bg-red-500'}`}
                        style={`width: ${displayScore}%`}
                      />
                    </div>
                  </div>
                </div>

                {/* Tool Content */}
                <div class="p-6">
                  <div class="flex items-start gap-5">
                    {/* Logo */}
                    <a href={`/tool/${review.item.slug}`} class="shrink-0">
                      <Logo domain={review.item.logo_url} name={review.item.name} size="lg" />
                    </a>

                    {/* Info */}
                    <div class="flex-1 min-w-0">
                      <div class="flex items-start justify-between gap-4">
                        <div>
                          <a
                            href={`/tool/${review.item.slug}`}
                            class="text-xl font-semibold text-zinc-100 hover:text-hunt-600"
                          >
                            {review.item.name}
                          </a>
                          <p class="mt-1 text-sm text-zinc-300 line-clamp-2">
                            {getDisplayDescription({
                              shortDescription: review.item.short_description,
                              summaryMarkdown: review.summary_markdown,
                              categoryName:
                                review.item.category?.name || context.category?.name || null,
                              pricingType: review.item.pricing_type,
                              itemType: review.item.type || 'tool',
                            })}
                          </p>
                        </div>

                        {/* CTA Button */}
                        {review.item.affiliate_offers?.[0] && (
                          <a
                            href={review.item.affiliate_offers[0].url}
                            target="_blank"
                            rel={
                              review.item.affiliate_offers[0].is_affiliate
                                ? 'nofollow sponsored noopener'
                                : 'noopener'
                            }
                            class="shrink-0 rounded-lg bg-hunt-500 px-5 py-2.5 text-sm font-medium text-white shadow-sm transition hover:bg-hunt-600 hover:shadow-md"
                          >
                            {review.item.affiliate_offers[0].cta_text}
                          </a>
                        )}
                      </div>

                      {/* Highlights - Contextual pros/cons for this use case */}
                      {(review.pros?.length > 0 || review.cons?.length > 0) && (
                        <div class="mt-4 grid gap-3 sm:grid-cols-2">
                          {review.pros?.length > 0 && (
                            <div class="space-y-2">
                              {review.pros.slice(0, 2).map((pro: any) => {
                                const text = getClaimText(pro);
                                if (!text) return null;
                                return (
                                  <div class="flex items-start gap-2 text-sm">
                                    <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-emerald-400" />
                                    <div>
                                      <span class="text-zinc-300">{text}</span>
                                    </div>
                                  </div>
                                );
                              })}
                            </div>
                          )}
                          {review.cons?.length > 0 && (
                            <div class="space-y-2">
                              {review.cons.slice(0, 2).map((con: any) => {
                                const text = getClaimText(con);
                                if (!text) return null;
                                return (
                                  <div class="flex items-start gap-2 text-sm">
                                    <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-rose-400" />
                                    <div>
                                      <span class="text-zinc-300">{text}</span>
                                    </div>
                                  </div>
                                );
                              })}
                            </div>
                          )}
                        </div>
                      )}

                      {/* Tags */}
                      {review.sentiment_tags?.length > 0 && (
                        <div class="mt-3">
                          <SentimentTags tags={review.sentiment_tags} limit={4} />
                        </div>
                      )}

                      {isProvisional && (
                        <p class="mt-3 rounded-md border border-sky-500/20 bg-sky-500/5 px-3 py-2 text-xs text-sky-200">
                          Early pick: this entry meets minimum evidence thresholds and is shown
                          before full publication checks are complete.
                        </p>
                      )}
                    </div>
                  </div>

                  {/* Full Pros/Cons - expandable */}
                  {(review.pros?.length > 2 || review.cons?.length > 2) && (
                    <details class="mt-4 group">
                      <summary class="flex cursor-pointer items-center justify-between gap-3 text-sm font-medium text-zinc-300 hover:text-zinc-100">
                        <span class="inline-flex items-center gap-2">
                          <svg
                            class="h-4 w-4 transition group-open:rotate-90"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M9 5l7 7-7 7"
                            />
                          </svg>
                          View all pros & cons
                        </span>
                        <span class="text-xs font-normal text-zinc-500">
                          <span class="group-open:hidden">Expand</span>
                          <span class="hidden group-open:inline">Collapse</span>
                        </span>
                      </summary>

                      <div class="mt-4">
                        <ProsCons
                          pros={review.pros || []}
                          cons={review.cons || []}
                          sourceDisplay="block"
                        />
                      </div>
                    </details>
                  )}

                  {/* Summary */}
                  {review.summary_markdown && !isSparseSummary(review.summary_markdown) && (
                    <details class="mt-3 group">
                      <summary class="flex cursor-pointer items-center justify-between gap-3 text-sm font-medium text-zinc-300 hover:text-zinc-100">
                        <span class="inline-flex items-center gap-2">
                          <svg
                            class="h-4 w-4 transition group-open:rotate-90"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                          >
                            <path
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              stroke-width="2"
                              d="M9 5l7 7-7 7"
                            />
                          </svg>
                          Read full analysis
                        </span>
                        <span class="text-xs font-normal text-zinc-500">
                          <span class="group-open:hidden">Expand</span>
                          <span class="hidden group-open:inline">Collapse</span>
                        </span>
                      </summary>

                      <div
                        class="mt-3 prose prose-slate prose-sm max-w-none rounded-lg bg-zinc-900 p-4"
                        set:html={simpleMarkdown(review.summary_markdown)}
                      />
                    </details>
                  )}

                  {/* Vote & Link */}
                  <div class="mt-4 flex items-center justify-between border-t border-zinc-800 pt-4">
                    <VoteWidget
                      client:visible
                      itemId={review.item.id}
                      storageKey={`review_helpful:${review.id}`}
                    />

                    <a
                      href={`/tool/${review.item.slug}`}
                      class="text-sm font-medium text-hunt-600 hover:text-hunt-700"
                    >
                      Full profile →
                    </a>
                  </div>
                </div>
              </article>
            );
          })
        }
      </div>
    </section>

    <!-- Empty State -->
    {
      sortedReviews.length === 0 && (
        <div class="rounded-xl border border-dashed border-zinc-600 bg-zinc-900 p-12 text-center">
          <svg
            class="mx-auto h-12 w-12 text-zinc-500"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="1.5"
              d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <h3 class="mt-4 text-lg font-medium text-zinc-100">No tools yet</h3>
          <p class="mt-2 text-sm text-zinc-400">
            We're still researching tools for this category. Check back soon!
          </p>
          <ul class="mx-auto mt-4 max-w-xl space-y-1 text-left text-sm text-zinc-400">
            <li>
              - Start with 2-3 incumbents you already know, then compare against this page when
              picks publish.
            </li>
            <li>
              - Prioritize sources that show plan limits, migration constraints, and support
              boundaries.
            </li>
            <li>
              - Revisit after the next source refresh to avoid committing on stale pricing or
              feature assumptions.
            </li>
          </ul>
        </div>
      )
    }

    <!-- Explore More - Merged related content for better UX and SEO -->
    {
      exploreMoreItems.length > 0 && (
        <aside class="mt-12">
          <RelatedContent items={exploreMoreItems} title="Explore More" className="" />
        </aside>
      )
    }
  </div>
</BaseLayout>
