---
/**
 * Category Detail Page - /categories/[slug]
 * Shows all tools and lists in a category
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import {
  getToolsByCategory,
  getContextsByCategory,
  getCategories,
  getAllCategorySlugs,
} from '@/lib/supabase';
import { generateCategoryMeta, generateBreadcrumbSchema } from '@/lib/seo';

// Static generation
export async function getStaticPaths() {
  const slugs = await getAllCategorySlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Fetch data
const [allCategories, tools, contexts] = await Promise.all([
  getCategories(),
  getToolsByCategory(slug),
  getContextsByCategory(slug),
]);

const category = allCategories.find((c) => c.slug === slug);

if (!category) {
  return Astro.redirect('/404');
}

const meta = generateCategoryMeta(category.name, category.slug, category.description || undefined);
const schemas = [
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Categories', url: '/categories' },
    { name: category.name, url: `/categories/${category.slug}` },
  ]),
];
---

<BaseLayout meta={meta} schemas={schemas}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-slate-500">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/categories" class="hover:text-hunt-500">Categories</a>
      <span>/</span>
      <span class="text-slate-700">{category.name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-4">
        <span class="flex h-14 w-14 items-center justify-center rounded-xl bg-hunt-100 text-3xl">
          {category.icon || '📦'}
        </span>
        <div>
          <h1 class="text-3xl font-bold text-slate-900">{category.name}</h1>
          {category.description && (
            <p class="mt-1 text-lg text-slate-600">{category.description}</p>
          )}
        </div>
      </div>

      <!-- Stats -->
      <div class="mt-6 flex gap-8">
        <div>
          <span class="text-2xl font-bold text-slate-900">{tools.length}</span>
          <span class="ml-1 text-slate-500">tools</span>
        </div>
        <div>
          <span class="text-2xl font-bold text-slate-900">{contexts.length}</span>
          <span class="ml-1 text-slate-500">comparison lists</span>
        </div>
      </div>
    </header>

    <!-- Content Grid -->
    <div class="grid gap-12 lg:grid-cols-3">
      <!-- Main: Tools -->
      <div class="lg:col-span-2">
        <section>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-xl font-semibold text-slate-900">
              {category.name} Tools
            </h2>
            <span class="text-sm text-slate-500">
              {tools.length} results
            </span>
          </div>

          {tools.length > 0 ? (
            <div class="grid gap-4 sm:grid-cols-2">
              {tools.map((tool) => (
                <ToolCard tool={tool} />
              ))}
            </div>
          ) : (
            <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-8 text-center">
              <p class="text-slate-500">No tools in this category yet.</p>
            </div>
          )}
        </section>
      </div>

      <!-- Sidebar: Lists -->
      <aside>
        <section>
          <h2 class="mb-4 text-lg font-semibold text-slate-900">
            Popular Lists
          </h2>

          {contexts.length > 0 ? (
            <div class="space-y-3">
              {contexts.map((ctx) => (
                <a
                  href={`/best/${ctx.slug}`}
                  class="group flex items-center justify-between rounded-lg border border-slate-200 bg-white p-4 transition hover:border-hunt-200 hover:bg-hunt-50"
                >
                  <div class="min-w-0 flex-1">
                    <h3 class="font-medium text-slate-900 group-hover:text-hunt-600 truncate">
                      {ctx.title}
                    </h3>
                    <span class="text-sm text-slate-500">{ctx.tool_count} tools</span>
                  </div>
                  <svg class="h-5 w-5 shrink-0 text-slate-300 transition group-hover:text-hunt-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          ) : (
            <div class="rounded-lg border border-dashed border-slate-300 bg-slate-50 p-6 text-center">
              <p class="text-sm text-slate-500">No lists yet.</p>
            </div>
          )}
        </section>

        <!-- Other Categories -->
        <section class="mt-8">
          <h2 class="mb-4 text-lg font-semibold text-slate-900">
            Other Categories
          </h2>
          <div class="flex flex-wrap gap-2">
            {allCategories
              .filter((c) => c.slug !== slug)
              .slice(0, 8)
              .map((cat) => (
                <a
                  href={`/categories/${cat.slug}`}
                  class="inline-flex items-center gap-1 rounded-full border border-slate-200 bg-white px-3 py-1 text-sm text-slate-600 transition hover:border-hunt-200 hover:text-hunt-600"
                >
                  {cat.icon && <span>{cat.icon}</span>}
                  {cat.name}
                </a>
              ))}
          </div>
        </section>
      </aside>
    </div>
  </div>
</BaseLayout>
