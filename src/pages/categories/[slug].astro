---
/**
 * Category Detail Page - /categories/[slug]
 * Shows all tools and lists in a category
 *
 * Design System: Professional Dark Mode
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import Logo from '@/components/Logo.astro';
import { Icon } from 'astro-icon/components';
import {
  getToolsByCategory,
  getContextsByCategory,
  getCategories,
  getAllCategorySlugs,
} from '@/lib/supabase';
import { getDisplayDescription } from '@/lib/display-description';
import { generateCategoryMeta, generateBreadcrumbSchema } from '@/lib/seo';

// Prerender for sitemap inclusion and performance
export const prerender = true;

export async function getStaticPaths() {
  const slugs = await getAllCategorySlugs();
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;

// Fetch data
const [allCategories, tools, contexts] = await Promise.all([
  getCategories(),
  getToolsByCategory(slug),
  getContextsByCategory(slug),
]);

const category = allCategories.find((c) => c.slug === slug);

if (!category) {
  return Astro.redirect('/404');
}

const meta = generateCategoryMeta(category.name, category.slug, category.description || undefined);
const schemas = [
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Categories', url: '/categories' },
    { name: category.name, url: `/categories/${category.slug}` },
  ]),
];

const topTools = tools.slice(0, 6);
const featuredLists = contexts.slice(0, 6);
const sampleToolNames = topTools.slice(0, 3).map((tool) => tool.name);
const hasAnyTools = tools.length > 0;

const pricingLabel = (value: string | null | undefined): string => {
  const key = (value || '').toLowerCase();
  if (key === 'freemium') return 'Freemium';
  if (key === 'free') return 'Free';
  if (key === 'paid') return 'Paid';
  if (key === 'enterprise') return 'Enterprise';
  if (key === 'open_source') return 'Open source';
  return 'Other';
};

const pricingMix = tools.reduce<Record<string, number>>((acc, tool) => {
  const label = pricingLabel(tool.pricing_type);
  acc[label] = (acc[label] || 0) + 1;
  return acc;
}, {});

const pricingMixRows = Object.entries(pricingMix)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 3)
  .map(([label, count]) => `${label}: ${count}`);

const highlightStrengths = Array.from(
  new Set(
    topTools.flatMap((tool) => extractHighlights(tool.specs, 2).pros).filter((value) => value.length > 0)
  )
).slice(0, 3);

const highlightWatchouts = Array.from(
  new Set(
    topTools.flatMap((tool) => extractHighlights(tool.specs, 2).cons).filter((value) => value.length > 0)
  )
).slice(0, 3);

// Build related links for internal linking (SEO)
const relatedLinks: Array<{
  href: string;
  title: string;
  description?: string;
  icon: 'category' | 'list' | 'tool' | 'compare';
}> = [];

// Add featured best-of lists
for (const ctx of featuredLists) {
  relatedLinks.push({
    href: `/best/${ctx.slug}`,
    title: ctx.title,
    description: `Compare ${ctx.tool_count} tools`,
    icon: 'list',
  });
}

// Add top tools
for (const tool of topTools.slice(0, 4)) {
  relatedLinks.push({
    href: `/tool/${tool.slug}`,
    title: tool.name,
    description: tool.short_description || undefined,
    icon: 'tool',
  });
}

function extractHighlights(specs: Record<string, unknown> | null | undefined, limit = 2) {
  const pros = Array.isArray((specs as any)?.pros) ? (specs as any).pros : [];
  const cons = Array.isArray((specs as any)?.cons) ? (specs as any).cons : [];
  const pickText = (items: any[]) =>
    items
      .map((item) => (typeof item === 'string' ? item : item?.text))
      .filter(Boolean)
      .slice(0, limit);
  return { pros: pickText(pros), cons: pickText(cons).slice(0, 1) };
}
---

<BaseLayout meta={meta} schemas={schemas}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-500">
      <a href="/" class="transition hover:text-zinc-100">Home</a>
      <span>/</span>
      <a href="/categories" class="transition hover:text-zinc-100">Categories</a>
      <span>/</span>
      <span class="text-zinc-300">{category.name}</span>
    </nav>

    <!-- Header -->
    <header class="mb-10">
      <div class="flex items-center gap-4">
        <span class="flex h-14 w-14 items-center justify-center rounded-xl bg-zinc-800/50">
          <Icon
            name={category.icon ? `lucide:${category.icon}` : 'lucide:package'}
            class="h-7 w-7 text-zinc-400"
          />
        </span>
        <div>
          <h1 class="text-3xl font-semibold text-zinc-100">{category.name}</h1>
          {
            category.description && (
              <p class="mt-1 text-base text-zinc-400">{category.description}</p>
            )
          }
        </div>
      </div>

      <!-- Stats -->
      <div class="mt-6 flex gap-8">
        <div class="flex items-center gap-2">
          <span class="text-2xl font-semibold text-zinc-100">{tools.length}</span>
          <span class="text-sm text-zinc-500">tools</span>
        </div>
        <div class="flex items-center gap-2">
          <span class="text-2xl font-semibold text-zinc-100">{contexts.length}</span>
          <span class="text-sm text-zinc-500">comparison lists</span>
        </div>
      </div>
    </header>

    <section class="mb-10 rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm">
      <h2 class="text-xl font-semibold text-zinc-100">How to Evaluate {category.name} Tools</h2>
      <p class="mt-2 text-sm text-zinc-300">
        Use this hub as a shortlist builder, not just a directory. Start with your single most frequent
        workflow, then test whether each candidate handles that flow cleanly before comparing edge-case features.
      </p>
      <p class="mt-2 text-sm text-zinc-400">
        {hasAnyTools
          ? sampleToolNames.length > 0
            ? `${sampleToolNames.join(', ')} are current examples in this category, but fit still depends on rollout constraints and plan limits.`
            : 'We track tools in this category with source-backed reviews and list-level context pages.'
          : 'This category is active, but enough source-backed tool profiles have not been published yet.'}
      </p>
      <div class="mt-5 grid gap-4 md:grid-cols-3">
        <div class="rounded-lg border border-zinc-800 bg-zinc-950/50 p-4">
          <h3 class="text-sm font-semibold text-zinc-100">Where Teams Usually See Value</h3>
          <ul class="mt-2 space-y-1 text-sm text-zinc-300">
            {(highlightStrengths.length > 0
              ? highlightStrengths
              : [
                  'Faster execution of a repeated workflow',
                  'Cleaner collaboration handoffs',
                  'Lower operational friction after onboarding',
                ]
            ).map((line) => (
              <li>- {line}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-lg border border-zinc-800 bg-zinc-950/50 p-4">
          <h3 class="text-sm font-semibold text-zinc-100">Where Rollouts Usually Break</h3>
          <ul class="mt-2 space-y-1 text-sm text-zinc-300">
            {(highlightWatchouts.length > 0
              ? highlightWatchouts
              : [
                  'Plan-gated features discovered late in rollout',
                  'Migration work under-scoped during trial',
                  'Integration assumptions not validated early',
                ]
            ).map((line) => (
              <li>- {line}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-lg border border-zinc-800 bg-zinc-950/50 p-4">
          <h3 class="text-sm font-semibold text-zinc-100">Current Category Pricing Shape</h3>
          <ul class="mt-2 space-y-1 text-sm text-zinc-300">
            {(pricingMixRows.length > 0
              ? pricingMixRows
              : ['Pricing data is still being collected for this category.']
            ).map((line) => (
              <li>- {line}</li>
            ))}
          </ul>
          <p class="mt-2 text-xs text-zinc-500">
            Validate cancellation terms, seat mechanics, and usage thresholds before committing.
          </p>
        </div>
      </div>
    </section>

    <!-- Content Grid -->
    <div class="grid gap-8 lg:grid-cols-3">
      <!-- Main: Tools -->
      <div class="lg:col-span-2">
        {/* Best Lists (Context entry points) */}
        <section class="mb-10">
          <div class="mb-4 flex items-center justify-between">
            <h2 class="text-xl font-semibold text-zinc-100">
              Best Lists in {category.name}
            </h2>
            <span class="rounded-full bg-zinc-800/50 px-3 py-1 text-sm text-zinc-400">
              {contexts.length} lists
            </span>
          </div>

          {
            featuredLists.length > 0 ? (
              <div class="grid gap-3 sm:grid-cols-2">
                {featuredLists.map((ctx) => (
                  <a
                    href={`/best/${ctx.slug}`}
                    class="group flex items-center justify-between rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-800/50"
                  >
                    <div class="min-w-0 flex-1">
                      <h3 class="truncate font-medium text-zinc-100 group-hover:text-white">
                        {ctx.title}
                      </h3>
                      <span class="text-sm text-zinc-500">{ctx.tool_count} tools</span>
                    </div>
                    <svg
                      class="h-5 w-5 shrink-0 text-zinc-600 transition group-hover:text-zinc-400"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                    </svg>
                  </a>
                ))}
              </div>
            ) : (
              <div class="rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-6 text-center">
                <p class="text-sm text-zinc-500">No lists yet.</p>
              </div>
            )
          }
        </section>

        {/* Top Tools (decision hub) */}
        {
          topTools.length > 0 && (
            <section class="mb-10">
              <div class="mb-4 flex items-center justify-between">
                <h2 class="text-xl font-semibold text-zinc-100">Top {category.name} Tools</h2>
                <span class="text-sm text-zinc-400">Quick scan</span>
              </div>

              <div class="grid gap-4 sm:grid-cols-2">
                {topTools.map((tool) => {
                  const highlights = extractHighlights(tool.specs);
                  return (
                    <a
                      href={`/tool/${tool.slug}`}
                      class="rounded-xl border border-zinc-800 bg-zinc-900/50 p-4 transition hover:border-zinc-700 hover:bg-zinc-900"
                    >
                      <div class="flex items-start gap-3">
                        <Logo domain={tool.logo_url} name={tool.name} size="sm" class="h-10 w-10" />
                        <div class="min-w-0 flex-1">
                          <div class="flex items-center justify-between gap-2">
                            <h3 class="truncate font-medium text-zinc-100">{tool.name}</h3>
                            {tool.avg_score > 0 && (
                              <span class="text-xs text-zinc-400">
                                {Math.round(tool.avg_score)}/100
                              </span>
                            )}
                          </div>
                          <p class="mt-1 text-sm text-zinc-400 line-clamp-2">
                            {
                              getDisplayDescription({
                                shortDescription: tool.short_description,
                                categoryName: category.name,
                                pricingType: tool.pricing_type,
                                itemType: tool.type || 'tool',
                              })
                            }
                          </p>
                        </div>
                      </div>

                      {(highlights.pros.length > 0 || highlights.cons.length > 0) && (
                        <ul class="mt-3 space-y-1 text-sm text-zinc-300">
                          {highlights.pros.map((text: string) => (
                            <li class="flex items-start gap-2">
                              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-emerald-400" />
                              <span>{text}</span>
                            </li>
                          ))}
                          {highlights.cons.map((text: string) => (
                            <li class="flex items-start gap-2">
                              <span class="mt-1 h-1.5 w-1.5 rounded-full bg-rose-400" />
                              <span>{text}</span>
                            </li>
                          ))}
                        </ul>
                      )}
                    </a>
                  );
                })}
              </div>
            </section>
          )
        }

        <section>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="text-xl font-semibold text-zinc-100">
              {category.name} Tools
            </h2>
            <span class="rounded-full bg-zinc-800/50 px-3 py-1 text-sm text-zinc-400">
              {tools.length} results
            </span>
          </div>

          {
            tools.length > 0 ? (
              <div class="grid gap-4 sm:grid-cols-2">
                {tools.map((tool) => (
                  <ToolCard tool={tool} />
                ))}
              </div>
            ) : (
              <div class="rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-8 text-center">
                <svg
                  class="mx-auto h-12 w-12 text-zinc-600"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"
                  />
                </svg>
                <h3 class="mt-4 text-lg font-medium text-zinc-100">No tools yet</h3>
                <p class="mt-2 text-sm text-zinc-500">
                  No tools in this category yet. Check back soon!
                </p>
              </div>
            )
          }
        </section>
      </div>

      <!-- Sidebar: Lists -->
      <aside class="space-y-8">
        <!-- Other Categories -->
        <section>
          <h2 class="mb-4 text-lg font-semibold text-zinc-100">Other Categories</h2>
          <div class="flex flex-wrap gap-2">
            {
              allCategories
                .filter((c) => c.slug !== slug)
                .slice(0, 8)
                .map((cat) => (
                  <a
                    href={`/categories/${cat.slug}`}
                    class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-800 bg-zinc-900/50 px-3 py-1.5 text-sm text-zinc-400 transition hover:border-zinc-700 hover:bg-zinc-800/50 hover:text-zinc-100"
                  >
                    {cat.icon && <Icon name={`lucide:${cat.icon}`} class="h-4 w-4" />}
                    {cat.name}
                  </a>
                ))
            }
          </div>
        </section>

        <!-- Related Links (SEO) -->
        {
          relatedLinks.length > 0 && (
            <RelatedLinks title="Quick Links" links={relatedLinks} variant="compact" />
          )
        }
      </aside>
    </div>
  </div>
</BaseLayout>
