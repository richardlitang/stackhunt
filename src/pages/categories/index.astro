---
/**
 * Categories Index - /categories
 * Browse all tool categories
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCategories } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Cache for 10 minutes (categories change rarely)
Astro.response.headers.set('Cache-Control', 'public, max-age=600, s-maxage=600, stale-while-revalidate=1200');

const categories = await getCategories();

const meta = {
  title: 'Software Categories - Browse All Tool Types | StackHunt',
  description: 'Browse software by category. Find the best CRM, marketing, productivity, developer tools, and more.',
  canonical: getCanonicalUrl('/categories'),
  ogType: 'website' as const,
};

// Group categories by featured
const featuredCategories = categories.filter(c => c.is_featured);
const otherCategories = categories.filter(c => !c.is_featured);
---

<BaseLayout meta={meta}>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="text-center">
      <h1 class="text-3xl font-semibold text-zinc-100 sm:text-4xl">
        Browse by Category
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-base text-zinc-400">
        Find the perfect tool for your needs. Explore our curated categories with reviews and comparisons.
      </p>
    </header>

    <!-- Featured Categories -->
    {featuredCategories.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-6 text-xl font-semibold text-zinc-100">Popular Categories</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuredCategories.map((category) => (
            <a
              href={`/categories/${category.slug}`}
              class="group relative overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50 p-5 transition-all duration-200 hover:border-zinc-700 hover:bg-gradient-to-b hover:from-zinc-800/50 hover:to-zinc-900/50"
            >
              <div class="flex items-start gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-lg bg-zinc-800/50 text-2xl transition group-hover:bg-zinc-800">
                  {category.icon || '📦'}
                </span>
                <div class="flex-1">
                  <h3 class="font-medium text-zinc-100 group-hover:text-white">
                    {category.name}
                  </h3>
                  {category.description && (
                    <p class="mt-1 text-sm text-zinc-500 line-clamp-2">
                      {category.description}
                    </p>
                  )}
                </div>
              </div>

              <div class="mt-4 flex items-center justify-end text-sm text-zinc-400 opacity-0 transition group-hover:opacity-100">
                Explore tools →
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- All Categories -->
    {otherCategories.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-6 text-xl font-semibold text-zinc-100">All Categories</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {otherCategories.map((category) => (
            <a
              href={`/categories/${category.slug}`}
              class="group flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 transition-all duration-200 hover:border-zinc-700 hover:bg-zinc-800/50"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-800/50 text-lg transition group-hover:bg-zinc-800">
                {category.icon || '📦'}
              </span>
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-zinc-100 group-hover:text-white truncate">
                  {category.name}
                </h3>
              </div>
              <svg class="h-5 w-5 text-zinc-600 transition group-hover:text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Empty State -->
    {categories.length === 0 && (
      <div class="mt-12 rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-zinc-100">No categories yet</h3>
        <p class="mt-2 text-sm text-zinc-500">
          Check back soon for more categories!
        </p>
      </div>
    )}
  </div>
</BaseLayout>
