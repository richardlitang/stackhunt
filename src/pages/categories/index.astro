---
/**
 * Categories Index - /categories
 * Browse all tool categories
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCategories } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

const categories = await getCategories();

const meta = {
  title: 'Software Categories - Browse All Tool Types | StackHunt',
  description: 'Browse software by category. Find the best CRM, marketing, productivity, developer tools, and more with AI-powered analysis.',
  canonical: getCanonicalUrl('/categories'),
  ogType: 'website' as const,
};

// Group categories by featured
const featuredCategories = categories.filter(c => c.is_featured);
const otherCategories = categories.filter(c => !c.is_featured);
---

<BaseLayout meta={meta}>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="text-center">
      <h1 class="text-3xl font-bold text-slate-900 sm:text-4xl">
        Browse by Category
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">
        Find the perfect tool for your needs. Explore our curated categories with AI-powered reviews and comparisons.
      </p>
    </header>

    <!-- Featured Categories -->
    {featuredCategories.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-6 text-xl font-semibold text-slate-900">Popular Categories</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {featuredCategories.map((category) => (
            <a
              href={`/categories/${category.slug}`}
              class="group relative overflow-hidden rounded-xl border border-slate-200 bg-gradient-to-br from-white to-slate-50 p-6 transition hover:border-hunt-200 hover:shadow-lg"
            >
              <div class="flex items-start gap-4">
                <span class="flex h-12 w-12 items-center justify-center rounded-xl bg-hunt-100 text-2xl transition group-hover:bg-hunt-200">
                  {category.icon || '📦'}
                </span>
                <div class="flex-1">
                  <h3 class="font-semibold text-slate-900 group-hover:text-hunt-600">
                    {category.name}
                  </h3>
                  {category.description && (
                    <p class="mt-1 text-sm text-slate-500 line-clamp-2">
                      {category.description}
                    </p>
                  )}
                </div>
              </div>

              <div class="mt-4 flex items-center justify-end text-sm text-hunt-600 opacity-0 transition group-hover:opacity-100">
                Explore tools →
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- All Categories -->
    {otherCategories.length > 0 && (
      <section class="mt-12">
        <h2 class="mb-6 text-xl font-semibold text-slate-900">All Categories</h2>
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {otherCategories.map((category) => (
            <a
              href={`/categories/${category.slug}`}
              class="group flex items-center gap-3 rounded-lg border border-slate-200 bg-white p-4 transition hover:border-hunt-200 hover:bg-hunt-50"
            >
              <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-lg transition group-hover:bg-hunt-100">
                {category.icon || '📦'}
              </span>
              <div class="flex-1 min-w-0">
                <h3 class="font-medium text-slate-900 group-hover:text-hunt-600 truncate">
                  {category.name}
                </h3>
              </div>
              <svg class="h-5 w-5 text-slate-300 transition group-hover:text-hunt-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Empty State -->
    {categories.length === 0 && (
      <div class="mt-12 rounded-xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-slate-900">No categories yet</h3>
        <p class="mt-2 text-sm text-slate-500">
          Categories are seeded automatically. Check your database connection.
        </p>
      </div>
    )}
  </div>
</BaseLayout>
