---
/**
 * Compare Index - /compare
 * Category-based tool selection for comparisons
 * Only allows comparing tools within the same category
 *
 * Design System: Professional Dark Mode (Zinc palette)
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import { supabase } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Fetch tools with categories, grouped by category
const { data: tools } = await supabase
  .from('tools')
  .select(`
    id, name, slug, logo_url, avg_score, pricing_type,
    category:categories(id, name, slug)
  `)
  .gt('avg_score', 0)
  .order('avg_score', { ascending: false })
  .limit(200);

// Group tools by category (only categories with 2+ tools)
interface CategoryGroup {
  name: string;
  slug: string;
  tools: typeof tools;
}

const categoryGroups: CategoryGroup[] = [];
const byCategory: Record<string, typeof tools> = {};

for (const tool of tools || []) {
  if (!tool.category?.slug) continue;
  const catSlug = tool.category.slug;
  if (!byCategory[catSlug]) {
    byCategory[catSlug] = [];
  }
  byCategory[catSlug].push(tool);
}

// Only include categories with 2+ tools for comparison
for (const [slug, categoryTools] of Object.entries(byCategory)) {
  if (categoryTools.length >= 2) {
    categoryGroups.push({
      name: categoryTools[0].category?.name || slug,
      slug,
      tools: categoryTools,
    });
  }
}

// Sort categories by tool count (most tools first)
categoryGroups.sort((a, b) => b.tools.length - a.tools.length);

const meta = {
  title: 'Compare Software Tools Side by Side | StackHunt',
  description: 'Compare popular software tools head-to-head. See features, pricing, pros & cons side by side to make the best choice.',
  canonical: getCanonicalUrl('/compare'),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-zinc-800 bg-zinc-900/50 px-3 py-1 text-sm text-zinc-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        Side-by-Side Comparison
      </div>

      <h1 class="mt-4 text-3xl font-semibold text-zinc-100 sm:text-4xl">
        Compare Tools
      </h1>
      <p class="mx-auto mt-4 max-w-2xl text-base text-zinc-400">
        Select two tools from the same category to see a detailed side-by-side comparison of features, pricing, and performance.
      </p>
    </header>

    <!-- Category-based Tool Lists -->
    <div class="mt-12 space-y-8">
      {categoryGroups.map(({ name, slug, tools: categoryTools }) => (
        <section>
          <h2 class="mb-4 flex items-center gap-2 text-xl font-semibold text-zinc-100">
            <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-800/50 text-sm">
              {categoryTools.length}
            </span>
            {name}
          </h2>

          <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900/50 backdrop-blur-sm transition-all duration-200 hover:border-zinc-700">
            <div class="grid grid-cols-1 divide-y divide-zinc-800 sm:grid-cols-2 sm:divide-x sm:divide-y-0">
              {/* Tool A Selection */}
              <div class="p-5">
                <label class="mb-2 flex items-center gap-2 text-sm font-medium text-zinc-400">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                  </svg>
                  First tool
                </label>
                <select
                  id={`toolA-${slug}`}
                  class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                >
                  <option value="">Select a tool...</option>
                  {categoryTools.map((tool) => (
                    <option value={tool.slug}>{tool.name}</option>
                  ))}
                </select>
              </div>

              {/* Tool B Selection */}
              <div class="p-5">
                <label class="mb-2 flex items-center gap-2 text-sm font-medium text-zinc-400">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
                  </svg>
                  Second tool
                </label>
                <select
                  id={`toolB-${slug}`}
                  class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 transition focus:border-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500/20"
                >
                  <option value="">Select a tool...</option>
                  {categoryTools.map((tool) => (
                    <option value={tool.slug}>{tool.name}</option>
                  ))}
                </select>
              </div>
            </div>

            {/* Compare Button */}
            <div class="border-t border-zinc-800 bg-zinc-900/30 p-4">
              <button
                type="button"
                data-category={slug}
                class="compare-btn group w-full rounded-lg bg-indigo-500 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-indigo-600 disabled:cursor-not-allowed disabled:bg-zinc-700 disabled:text-zinc-500"
              >
                <span class="flex items-center justify-center gap-2">
                  Compare Tools
                  <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </span>
              </button>
            </div>
          </div>
        </section>
      ))}
    </div>

    {categoryGroups.length === 0 && (
      <div class="mt-12 rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-12 text-center">
        <svg class="mx-auto h-12 w-12 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
        </svg>
        <h3 class="mt-4 text-lg font-medium text-zinc-100">No categories yet</h3>
        <p class="mt-2 text-sm text-zinc-500">
          Categories with multiple tools will appear here for comparison.
        </p>
        <a
          href="/tools"
          class="mt-4 inline-flex items-center gap-2 text-sm text-indigo-400 transition hover:text-indigo-300"
        >
          Browse all tools
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  // Handle compare button clicks
  document.querySelectorAll('.compare-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');
      const toolASelect = document.getElementById(`toolA-${category}`) as HTMLSelectElement;
      const toolBSelect = document.getElementById(`toolB-${category}`) as HTMLSelectElement;

      const toolA = toolASelect?.value;
      const toolB = toolBSelect?.value;

      if (!toolA || !toolB) {
        alert('Please select two tools to compare');
        return;
      }

      if (toolA === toolB) {
        alert('Please select two different tools');
        return;
      }

      window.location.href = `/compare/${toolA}-vs-${toolB}`;
    });
  });
</script>
