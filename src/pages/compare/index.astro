---
/**
 * Compare Index - /compare
 * Simplified single-form tool comparison selector
 *
 * Design: Single card with category dropdown that filters tool options
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import { supabase } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Fetch tools with categories
const { data: tools } = await supabase
  .from('tools')
  .select(`
    id, name, slug, logo_url, avg_score,
    category:categories(id, name, slug)
  `)
  .gt('avg_score', 0)
  .order('name', { ascending: true })
  .limit(300);

// Group tools by category (only categories with 2+ tools)
interface CategoryGroup {
  id: string;
  name: string;
  slug: string;
  tools: Array<{ name: string; slug: string; logo_url: string | null; avg_score: number | null }>;
}

const categoryMap = new Map<string, CategoryGroup>();

for (const tool of tools || []) {
  if (!tool.category?.id) continue;
  const catId = tool.category.id;

  if (!categoryMap.has(catId)) {
    categoryMap.set(catId, {
      id: catId,
      name: tool.category.name || '',
      slug: tool.category.slug || '',
      tools: [],
    });
  }

  categoryMap.get(catId)!.tools.push({
    name: tool.name,
    slug: tool.slug,
    logo_url: tool.logo_url,
    avg_score: tool.avg_score,
  });
}

// Filter to categories with 2+ tools and sort by name
const categories = Array.from(categoryMap.values())
  .filter(c => c.tools.length >= 2)
  .sort((a, b) => a.name.localeCompare(b.name));

// Prepare data for client-side
const toolsByCategory = Object.fromEntries(
  categories.map(c => [c.slug, c.tools])
);

const meta = {
  title: 'Compare Software Tools Side by Side | StackHunt',
  description: 'Compare popular software tools head-to-head. See features, pricing, pros & cons side by side to make the best choice.',
  canonical: getCanonicalUrl('/compare'),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <div class="mx-auto max-w-2xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Header -->
    <header class="text-center mb-8">
      <h1 class="text-3xl font-semibold text-zinc-100 sm:text-4xl">
        Compare Tools
      </h1>
      <p class="mx-auto mt-3 max-w-lg text-base text-zinc-400">
        Select a category and two tools to see a detailed side-by-side comparison.
      </p>
    </header>

    <!-- Single Comparison Form -->
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/50 overflow-hidden">
      <!-- Category Selector -->
      <div class="p-5 border-b border-zinc-800">
        <label for="category-select" class="block text-sm font-medium text-zinc-300 mb-2">
          Category
        </label>
        <select
          id="category-select"
          class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 transition focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
        >
          <option value="">Select a category...</option>
          {categories.map((cat) => (
            <option value={cat.slug}>{cat.name} ({cat.tools.length} tools)</option>
          ))}
        </select>
      </div>

      <!-- Tool Selectors -->
      <div class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-zinc-800">
        <div class="p-5">
          <label for="tool-a-select" class="block text-sm font-medium text-zinc-300 mb-2">
            First Tool
          </label>
          <select
            id="tool-a-select"
            disabled
            class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 transition focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <option value="">Select category first...</option>
          </select>
        </div>

        <div class="p-5">
          <label for="tool-b-select" class="block text-sm font-medium text-zinc-300 mb-2">
            Second Tool
          </label>
          <select
            id="tool-b-select"
            disabled
            class="w-full rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-2.5 text-sm text-zinc-100 transition focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <option value="">Select category first...</option>
          </select>
        </div>
      </div>

      <!-- Compare Button -->
      <div class="p-5 border-t border-zinc-800 bg-zinc-900/30">
        <button
          id="compare-btn"
          type="button"
          disabled
          class="w-full rounded-lg bg-hunt-500 px-4 py-3 text-sm font-medium text-white transition hover:bg-hunt-600 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-hunt-500"
        >
          Compare Tools
        </button>
        <p id="error-message" class="mt-2 text-center text-sm text-red-400 hidden"></p>
      </div>
    </div>

    <!-- Popular Comparisons -->
    <div class="mt-12">
      <h2 class="text-lg font-semibold text-zinc-100 mb-4">Popular Comparisons</h2>
      <div class="grid gap-3 sm:grid-cols-2">
        {[
          { a: 'slack', b: 'microsoft-teams', label: 'Slack vs Teams' },
          { a: 'notion', b: 'obsidian', label: 'Notion vs Obsidian' },
          { a: 'figma', b: 'canva', label: 'Figma vs Canva' },
          { a: 'asana', b: 'monday-com', label: 'Asana vs Monday' },
        ].map(({ a, b, label }) => (
          <a
            href={`/compare/${a}-vs-${b}`}
            class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-3 text-sm text-zinc-300 transition hover:border-zinc-700 hover:bg-zinc-900"
          >
            <svg class="h-4 w-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
            </svg>
            {label}
          </a>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ toolsByCategory }}>
  const categorySelect = document.getElementById('category-select');
  const toolASelect = document.getElementById('tool-a-select');
  const toolBSelect = document.getElementById('tool-b-select');
  const compareBtn = document.getElementById('compare-btn');
  const errorMessage = document.getElementById('error-message');

  function updateToolOptions() {
    const category = categorySelect.value;
    const tools = toolsByCategory[category] || [];

    // Clear and populate tool selects
    toolASelect.innerHTML = '<option value="">Select a tool...</option>';
    toolBSelect.innerHTML = '<option value="">Select a tool...</option>';

    tools.forEach((tool) => {
      const optionA = document.createElement('option');
      optionA.value = tool.slug;
      optionA.textContent = tool.name;
      toolASelect.appendChild(optionA);

      const optionB = document.createElement('option');
      optionB.value = tool.slug;
      optionB.textContent = tool.name;
      toolBSelect.appendChild(optionB);
    });

    // Enable/disable selects
    const hasTools = tools.length >= 2;
    toolASelect.disabled = !hasTools;
    toolBSelect.disabled = !hasTools;

    updateCompareButton();
  }

  function updateCompareButton() {
    const toolA = toolASelect.value;
    const toolB = toolBSelect.value;
    const canCompare = toolA && toolB && toolA !== toolB;
    compareBtn.disabled = !canCompare;

    // Hide error when selections change
    errorMessage.classList.add('hidden');
  }

  function handleCompare() {
    const toolA = toolASelect.value;
    const toolB = toolBSelect.value;

    if (!toolA || !toolB) {
      errorMessage.textContent = 'Please select two tools';
      errorMessage.classList.remove('hidden');
      return;
    }

    if (toolA === toolB) {
      errorMessage.textContent = 'Please select two different tools';
      errorMessage.classList.remove('hidden');
      return;
    }

    // Navigate to comparison (alphabetical order for canonical URL)
    const [first, second] = toolA < toolB ? [toolA, toolB] : [toolB, toolA];
    window.location.href = `/compare/${first}-vs-${second}`;
  }

  categorySelect.addEventListener('change', updateToolOptions);
  toolASelect.addEventListener('change', updateCompareButton);
  toolBSelect.addEventListener('change', updateCompareButton);
  compareBtn.addEventListener('click', handleCompare);
</script>
