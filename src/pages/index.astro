---
/**
 * Homepage - /
 *
 * Design System: "Professional" Dark Mode
 * - Zinc palette with 50% opacity surfaces
 * - Indigo for tech, Emerald for money
 * - Subtle hover gradients
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getFeaturedTools, getFeaturedContexts, getCategories } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Cache for 5 minutes (SSR)
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=300, s-maxage=300, stale-while-revalidate=600'
);

// Fetch data
const [featuredTools, featuredContexts, categories] = await Promise.all([
  getFeaturedTools(12),
  getFeaturedContexts(8),
  getCategories(),
]);
const quickContextLinks = featuredContexts.slice(0, 3);

const meta = {
  title: 'StackHunt - Find the Right Tools for Your Stack',
  description:
    'Curated software recommendations for developers, designers, and teams. Compare tools with honest, context-aware reviews.',
  canonical: getCanonicalUrl('/'),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-zinc-950">
    <!-- Subtle grid pattern -->
    <div class="absolute inset-0 opacity-[0.02]">
      <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="32" height="32" patternUnits="userSpaceOnUse">
            <path
              d="M 32 0 L 0 0 0 32"
              fill="none"
              stroke="currentColor"
              stroke-width="1"
              class="text-zinc-100"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <div class="text-center">
        <!-- Headline -->
        <h1 class="text-4xl font-semibold tracking-tight text-zinc-100 sm:text-5xl">
          Find the <span class="text-indigo-400">Right Tools</span>
          <br class="hidden sm:block" />for Your Stack
        </h1>

        <p class="mx-auto mt-5 max-w-xl text-base text-zinc-400">
          Curated recommendations for dev tools, design apps, and productivity software. Honest
          reviews that help you choose what works.
        </p>

        <!-- Search Bar -->
        <div class="mx-auto mt-8 max-w-md">
          <form action="/tools" method="get" class="relative" id="home-search-form">
            <input
              id="home-tools-search"
              type="text"
              name="q"
              autocomplete="off"
              aria-label="Search tools by name"
              aria-autocomplete="list"
              aria-controls="home-tool-suggestions"
              aria-expanded="false"
              minlength="2"
              maxlength="64"
              placeholder="Search tools by name..."
              class="w-full rounded-lg border border-zinc-800 bg-zinc-900/50 py-3 pl-10 pr-4 text-sm text-zinc-100 placeholder-zinc-500 backdrop-blur-sm transition focus:border-indigo-500 focus:bg-zinc-900 focus:outline-none focus:ring-1 focus:ring-indigo-500/50"
            />
            <svg
              class="absolute left-3 top-3 h-5 w-5 text-zinc-500"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <kbd
              class="absolute right-3 top-2.5 hidden rounded border border-zinc-700 bg-zinc-800 px-1.5 py-0.5 text-xs text-zinc-500 sm:inline-block"
            >
              ⌘K
            </kbd>

            <div
              id="home-tool-suggestions"
              role="listbox"
              aria-label="Tool suggestions"
              class="absolute left-0 right-0 top-full z-20 mt-2 hidden overflow-hidden rounded-xl border border-zinc-800 bg-zinc-950/95 shadow-2xl backdrop-blur-sm"
            >
              <div id="home-tool-suggestions-list" class="max-h-80 overflow-y-auto"></div>
              <div
                id="home-tool-suggestions-footer"
                class="border-t border-zinc-800 px-3 py-2 text-xs text-zinc-500"
              >
                Press Enter to search all tools
              </div>
            </div>
          </form>

          <!-- Quick Links -->
          <div class="mt-3 flex flex-wrap justify-center gap-x-3 gap-y-1">
            <span class="text-sm text-zinc-500">Popular:</span>
            {
              quickContextLinks.length > 0 ? (
                quickContextLinks.map((ctx) => (
                  <a
                    href={`/best/${ctx.slug}`}
                    class="text-sm text-zinc-400 hover:text-zinc-100 transition"
                  >
                    {ctx.title}
                  </a>
                ))
              ) : (
                <>
                  <a href="/best" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
                    Best Lists
                  </a>
                  <a href="/compare" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
                    Compare Tools
                  </a>
                  <a href="/tools" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
                    Tool Directory
                  </a>
                </>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="border-b border-zinc-800 bg-zinc-900/50 py-4 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 overflow-x-auto scrollbar-hide">
        <span class="shrink-0 text-sm text-zinc-500">Browse:</span>
        {
          categories.slice(0, 10).map((cat) => (
            <a
              href={`/categories/${cat.slug}`}
              class="shrink-0 rounded-lg border border-zinc-800 bg-zinc-900/50 px-3 py-1.5 text-sm text-zinc-400 transition hover:border-zinc-700 hover:bg-zinc-800/50 hover:text-zinc-100"
            >
              {cat.name}
            </a>
          ))
        }
        <a href="/categories" class="shrink-0 text-sm text-zinc-400 hover:text-zinc-100 transition">
          View all →
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="bg-zinc-950 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-semibold text-zinc-100">Featured Tools</h2>
          <p class="mt-1 text-sm text-zinc-400">Top-rated across all categories</p>
        </div>
        <a href="/tools" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
          View all →
        </a>
      </div>

      <div
        id="featured-tools-grid"
        class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
      >
        {
          featuredTools.map((tool, index) => (
            <div class:list={[index >= 6 && 'hidden-on-mobile']}>
              <ToolCard tool={tool} category={tool.category} />
            </div>
          ))
        }
      </div>

      <div class="mt-6 text-center lg:hidden">
        <button
          id="show-more-tools"
          class="rounded-lg border border-zinc-800 bg-zinc-900/50 px-6 py-2.5 text-sm font-medium text-zinc-300 transition hover:border-zinc-700 hover:bg-zinc-800/50"
        >
          Show more tools
        </button>
      </div>
    </div>
  </section>

  <!-- Comparisons -->
  {
    featuredContexts && featuredContexts.length > 0 && (
      <section class="border-t border-zinc-800 bg-zinc-900/30 py-12">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-semibold text-zinc-100">Comparisons</h2>
              <p class="mt-1 text-sm text-zinc-400">Curated lists to help you choose</p>
            </div>
            <a href="/best" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
              View all →
            </a>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {featuredContexts.map((ctx) => (
              <a
                href={`/best/${ctx.slug}`}
                class="group rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 transition-all duration-200 hover:border-zinc-700 hover:bg-gradient-to-b hover:from-zinc-800/50 hover:to-zinc-900/50"
              >
                <h3 class="text-sm font-medium text-zinc-100 group-hover:text-white">
                  {ctx.title}
                </h3>
                <p class="mt-1 text-sm text-zinc-500">{ctx.tool_count} tools</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Show more functionality */
  @media (max-width: 1023px) {
    .hidden-on-mobile {
      display: none;
    }
    #featured-tools-grid.expanded .hidden-on-mobile {
      display: block;
    }
  }
</style>

<script is:inline>
  // Lightweight client-side suggestions for homepage search
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('home-tools-search');
    const form = document.getElementById('home-search-form');
    const dropdown = document.getElementById('home-tool-suggestions');
    const list = document.getElementById('home-tool-suggestions-list');
    if (
      !(input instanceof HTMLInputElement) ||
      !(form instanceof HTMLFormElement) ||
      !(dropdown instanceof HTMLDivElement) ||
      !(list instanceof HTMLDivElement)
    ) {
      return;
    }

    let toolIndex = null;
    let loadPromise = null;
    let activeIndex = -1;
    let visibleMatches = [];

    const loadToolIndex = async () => {
      if (toolIndex) return toolIndex;
      if (loadPromise) return loadPromise;

      loadPromise = fetch('/api/search/tool-index', { headers: { Accept: 'application/json' } })
        .then((res) => (res.ok ? res.json() : null))
        .then((payload) => {
          toolIndex = Array.isArray(payload?.items) ? payload.items : [];
          return toolIndex;
        })
        .catch(() => {
          toolIndex = [];
          return toolIndex;
        })
        .finally(() => {
          loadPromise = null;
        });

      return loadPromise;
    };

    const closeDropdown = () => {
      dropdown.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
    };

    const openDropdown = () => {
      dropdown.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
    };

    const updateActiveState = () => {
      const buttons = list.querySelectorAll('[data-suggestion-index]');
      buttons.forEach((el, index) => {
        const isActive = index === activeIndex;
        el.classList.toggle('bg-zinc-800/70', isActive);
        el.classList.toggle('border-zinc-700', isActive);
        el.classList.toggle('border-zinc-900/0', !isActive);
        if (isActive) {
          el.scrollIntoView({ block: 'nearest' });
        }
      });
    };

    const renderSuggestions = (query) => {
      if (!Array.isArray(toolIndex) || !query || query.length < 2) {
        visibleMatches = [];
        list.replaceChildren();
        closeDropdown();
        return;
      }

      const q = query.trim().toLowerCase();
      if (q.length < 2) {
        visibleMatches = [];
        list.replaceChildren();
        closeDropdown();
        return;
      }

      const startsWith = [];
      const contains = [];

      for (const tool of toolIndex) {
        const name = String(tool?.name || '');
        const lower = name.toLowerCase();
        if (!lower.includes(q)) continue;
        if (lower.startsWith(q)) startsWith.push(tool);
        else contains.push(tool);
        if (startsWith.length + contains.length >= 12) break;
      }

      const matches = startsWith.concat(contains).slice(0, 8);
      visibleMatches = matches;
      activeIndex = -1;

      if (matches.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'px-3 py-3 text-sm text-zinc-400';
        empty.textContent = 'No quick matches. Press Enter to search all tools.';
        list.replaceChildren(empty);
        openDropdown();
        return;
      }

      const rows = matches.map((tool, index) => {
        const row = document.createElement('a');
        row.href = `/tool/${encodeURIComponent(tool.slug)}`;
        row.className =
          'block border-b border-zinc-900/60 px-3 py-2.5 transition hover:bg-zinc-800/60 focus:bg-zinc-800/60 focus:outline-none';
        row.dataset.suggestionIndex = String(index);

        const top = document.createElement('div');
        top.className = 'flex items-center justify-between gap-3';

        const nameWrap = document.createElement('div');
        nameWrap.className = 'min-w-0';

        const name = document.createElement('div');
        name.className = 'truncate text-sm font-medium text-zinc-100';
        name.textContent = tool.name;

        const path = document.createElement('div');
        path.className = 'truncate text-xs text-zinc-500';
        path.textContent = `/tool/${tool.slug}`;

        nameWrap.append(name, path);

        const badge = document.createElement('div');
        badge.className =
          'shrink-0 rounded border border-zinc-800 bg-zinc-900/80 px-1.5 py-0.5 text-[10px] uppercase tracking-wide text-zinc-400';
        badge.textContent = 'Tool';

        top.append(nameWrap, badge);
        row.append(top);

        const rawDescription = typeof tool.short_description === 'string' ? tool.short_description : '';
        if (rawDescription.trim()) {
          const desc = document.createElement('div');
          desc.className = 'mt-1 line-clamp-2 text-xs text-zinc-400';
          desc.textContent =
            rawDescription.length > 120 ? `${rawDescription.slice(0, 117).trim()}...` : rawDescription;
          row.append(desc);
        }

        row.addEventListener('mouseenter', () => {
          activeIndex = index;
          updateActiveState();
        });

        return row;
      });

      if (rows.length > 0) {
        const last = rows[rows.length - 1];
        last.classList.remove('border-b');
      }

      list.replaceChildren(...rows);
      openDropdown();
    };

    input.addEventListener('focus', () => {
      void loadToolIndex();
      if (input.value.trim().length >= 2) {
        renderSuggestions(input.value);
      }
    });

    input.addEventListener('input', async () => {
      if (!toolIndex) {
        await loadToolIndex();
      }
      renderSuggestions(input.value);
    });

    input.addEventListener('keydown', (event) => {
      if (dropdown.classList.contains('hidden')) return;

      if (event.key === 'ArrowDown') {
        if (visibleMatches.length === 0) return;
        event.preventDefault();
        activeIndex = Math.min(activeIndex + 1, visibleMatches.length - 1);
        updateActiveState();
        return;
      }

      if (event.key === 'ArrowUp') {
        if (visibleMatches.length === 0) return;
        event.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
        updateActiveState();
        return;
      }

      if (event.key === 'Escape') {
        closeDropdown();
        return;
      }

      if (event.key === 'Enter' && activeIndex >= 0 && visibleMatches[activeIndex]) {
        event.preventDefault();
        window.location.href = `/tool/${encodeURIComponent(visibleMatches[activeIndex].slug)}`;
      }
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) return;
      if (!form.contains(event.target)) {
        closeDropdown();
      }
    });
  });

  // Show more tools button
  document.addEventListener('DOMContentLoaded', () => {
    const showMoreBtn = document.getElementById('show-more-tools');
    const grid = document.getElementById('featured-tools-grid');

    if (showMoreBtn && grid) {
      showMoreBtn.addEventListener('click', () => {
        grid.classList.toggle('expanded');
        showMoreBtn.textContent = grid.classList.contains('expanded')
          ? 'Show less'
          : 'Show more tools';
      });
    }
  });
</script>
