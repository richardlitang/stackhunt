---
/**
 * Homepage - /
 *
 * Features:
 * - Hero with search bar (powers up later)
 * - Featured tools grid
 * - Featured lists/contexts
 * - Category navigation
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import {
  getFeaturedTools,
  getFeaturedContexts,
  getCategories,
} from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Fetch data
const [featuredTools, featuredContexts, categories] = await Promise.all([
  getFeaturedTools(12),
  getFeaturedContexts(8),
  getCategories(),
]);

const meta = {
  title: 'StackHunt - Find the Best Software Alternatives',
  description: 'Discover the best software alternatives with AI-powered analysis. Compare tools, read honest reviews, and find the perfect solution for your needs.',
  canonical: getCanonicalUrl('/'),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-20">
      <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="currentColor" stroke-width="0.5" class="text-slate-500" />
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)" />
      </svg>
    </div>

    <div class="relative mx-auto max-w-5xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8">
      <div class="text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 rounded-full border border-hunt-500/30 bg-hunt-500/10 px-4 py-1.5 text-sm text-hunt-400">
          <span class="relative flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-hunt-400 opacity-75"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-hunt-500"></span>
          </span>
          AI-Powered Software Discovery
        </div>

        <!-- Headline -->
        <h1 class="mt-6 text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
          Find the <span class="text-hunt-500">Best Software</span>
          <br />Alternatives
        </h1>

        <p class="mx-auto mt-6 max-w-2xl text-lg text-slate-300">
          Stop wasting hours researching tools. Our AI analyzes reviews, features, and pricing to help you discover the perfect software for your needs.
        </p>

        <!-- Search Bar -->
        <div class="mx-auto mt-10 max-w-xl">
          <div class="relative">
            <input
              type="text"
              placeholder="Search for any tool or category..."
              class="w-full rounded-xl border-2 border-transparent bg-white/10 py-4 pl-12 pr-4 text-white placeholder-slate-400 backdrop-blur transition focus:border-hunt-500 focus:bg-white/20 focus:outline-none"
            />
            <svg class="absolute left-4 top-4 h-6 w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <kbd class="absolute right-4 top-4 hidden rounded border border-slate-600 bg-slate-800 px-2 py-1 text-xs text-slate-400 sm:inline-block">
              ⌘K
            </kbd>
          </div>

          <!-- Quick Links -->
          <div class="mt-4 flex flex-wrap justify-center gap-2">
            <span class="text-sm text-slate-400">Popular:</span>
            <a href="/best/slack-alternatives" class="text-sm text-hunt-400 hover:text-hunt-300">Slack alternatives</a>
            <span class="text-slate-600">•</span>
            <a href="/best/notion-alternatives" class="text-sm text-hunt-400 hover:text-hunt-300">Notion alternatives</a>
            <span class="text-slate-600">•</span>
            <a href="/best/crm-for-startups" class="text-sm text-hunt-400 hover:text-hunt-300">CRM for startups</a>
          </div>
        </div>

        <!-- Stats -->
        <div class="mt-12 flex justify-center gap-12">
          <div>
            <div class="text-3xl font-bold text-white">500+</div>
            <div class="text-sm text-slate-400">Tools Analyzed</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white">50+</div>
            <div class="text-sm text-slate-400">Categories</div>
          </div>
          <div>
            <div class="text-3xl font-bold text-white">10K+</div>
            <div class="text-sm text-slate-400">Reviews Processed</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="border-b border-slate-200 bg-slate-50 py-8">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 overflow-x-auto pb-2 scrollbar-hide">
        <span class="shrink-0 text-sm font-medium text-slate-500">Categories:</span>
        {categories.slice(0, 10).map((cat) => (
          <a
            href={`/categories/${cat.slug}`}
            class="shrink-0 rounded-full border border-slate-200 bg-white px-4 py-1.5 text-sm font-medium text-slate-600 transition hover:border-hunt-200 hover:text-hunt-600"
          >
            {cat.icon && <span class="mr-1">{cat.icon}</span>}
            {cat.name}
          </a>
        ))}
        <a
          href="/categories"
          class="shrink-0 text-sm font-medium text-hunt-600 hover:text-hunt-700"
        >
          View all →
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold text-slate-900">Featured Tools</h2>
          <p class="mt-2 text-slate-600">Top-rated software across all categories</p>
        </div>
        <a href="/tools" class="text-sm font-medium text-hunt-600 hover:text-hunt-700">
          View all tools →
        </a>
      </div>

      <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {featuredTools.map((tool) => (
          <ToolCard tool={tool} category={tool.category} />
        ))}
      </div>

      {featuredTools.length === 0 && (
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 p-12 text-center">
          <p class="text-slate-500">No featured tools yet. Run the Hunter Agent to populate data!</p>
        </div>
      )}
    </div>
  </section>

  <!-- Featured Lists -->
  <section class="border-t border-slate-200 bg-slate-50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold text-slate-900">Popular Comparisons</h2>
          <p class="mt-2 text-slate-600">Curated lists to help you choose the right tool</p>
        </div>
        <a href="/best" class="text-sm font-medium text-hunt-600 hover:text-hunt-700">
          View all lists →
        </a>
      </div>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {featuredContexts.map((ctx) => (
          <a
            href={`/best/${ctx.slug}`}
            class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-hunt-200 hover:shadow-lg"
          >
            <div class="flex items-center gap-3">
              {ctx.category?.icon && (
                <span class="flex h-10 w-10 items-center justify-center rounded-lg bg-slate-100 text-xl group-hover:bg-hunt-100">
                  {ctx.category.icon}
                </span>
              )}
              <div class="min-w-0 flex-1">
                <h3 class="truncate font-semibold text-slate-900 group-hover:text-hunt-600">
                  {ctx.title}
                </h3>
                <p class="text-sm text-slate-500">{ctx.tool_count} tools</p>
              </div>
            </div>
          </a>
        ))}
      </div>

      {featuredContexts.length === 0 && (
        <div class="rounded-xl border border-dashed border-slate-300 bg-white p-12 text-center">
          <p class="text-slate-500">No featured lists yet. Create contexts via the Hunter Agent!</p>
        </div>
      )}
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl bg-gradient-to-br from-hunt-500 to-hunt-600 p-8 text-center sm:p-12">
        <h2 class="text-2xl font-bold text-white sm:text-3xl">
          Can't find what you're looking for?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-hunt-100">
          Submit a tool or request a specific comparison. Our AI will analyze it and add it to the directory.
        </p>
        <div class="mt-8 flex flex-col justify-center gap-4 sm:flex-row">
          <a
            href="/submit"
            class="rounded-lg bg-white px-6 py-3 font-semibold text-hunt-600 transition hover:bg-hunt-50"
          >
            Submit a Tool
          </a>
          <a
            href="/request"
            class="rounded-lg border-2 border-white/30 px-6 py-3 font-semibold text-white transition hover:bg-white/10"
          >
            Request Comparison
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
