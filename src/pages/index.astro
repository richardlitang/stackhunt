---
/**
 * Homepage - /
 *
 * Design System: "Professional" Dark Mode
 * - Zinc palette with 50% opacity surfaces
 * - Indigo for tech, Emerald for money
 * - Subtle hover gradients
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import ToolCard from '@/components/ToolCard.astro';
import { getFeaturedTools, getFeaturedContexts, getCategories } from '@/lib/supabase';
import { getCanonicalUrl } from '@/lib/utils';

// Cache for 5 minutes (SSR)
Astro.response.headers.set(
  'Cache-Control',
  'public, max-age=300, s-maxage=300, stale-while-revalidate=600'
);

// Fetch data
const [featuredTools, featuredContexts, categories] = await Promise.all([
  getFeaturedTools(12),
  getFeaturedContexts(8),
  getCategories(),
]);
const toolCount = featuredTools.length;
const decideCategories = categories.slice(0, 12);
const decideContexts = featuredContexts.slice(0, 12);

const meta = {
  title: 'StackHunt - Find the Right Tools for Your Stack',
  description:
    'Curated software recommendations for developers, designers, and teams. Compare tools with honest, context-aware reviews.',
  canonical: getCanonicalUrl('/'),
  ogType: 'website' as const,
};
---

<BaseLayout meta={meta}>
  <!-- Hero: decision search -->
  <section class="relative overflow-hidden bg-ink-950">
    <div class="relative mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8">
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-paper-muted">
        {toolCount}+ tools scored · updated daily
      </p>

      <h1 class="mt-4 max-w-2xl font-grotesk text-4xl font-semibold leading-[1.05] tracking-tight text-paper sm:text-5xl">
        Stop researching. <span class="text-signal">See the verdict.</span>
      </h1>
      <p class="mt-4 max-w-xl text-base text-paper-muted">
        Search any tool and get the call — score, price, and whether it's worth it — before you open a single tab.
      </p>

      <!-- Primary: decision search -->
      <div class="mt-8 max-w-xl">
        <form action="/tools" method="get" class="relative" id="home-search-form">
          <input
            id="home-tools-search"
            type="text"
            name="q"
            autocomplete="off"
            aria-label="Search tools by name"
            aria-autocomplete="list"
            aria-controls="home-tool-suggestions"
            aria-expanded="false"
            minlength="2"
            maxlength="64"
            placeholder="Search any tool…"
            class="w-full rounded-xl border border-ink-border bg-ink-900 py-3.5 pl-11 pr-4 text-base text-paper placeholder-paper-muted transition focus:border-signal focus:outline-none focus:ring-1 focus:ring-signal/50"
          />
          <svg class="absolute left-3.5 top-4 h-5 w-5 text-paper-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <kbd class="absolute right-3 top-3 hidden rounded border border-ink-border bg-ink-800 px-1.5 py-0.5 font-mono text-xs text-paper-muted sm:inline-block">⌘K</kbd>

          <div
            id="home-tool-suggestions"
            role="listbox"
            aria-label="Tool suggestions"
            class="absolute left-0 right-0 top-full z-20 mt-3 hidden overflow-hidden rounded-2xl border border-ink-border bg-ink-950/95 shadow-2xl backdrop-blur-sm"
          >
            <div id="home-tool-suggestions-list" class="max-h-96 overflow-y-auto p-2"></div>
            <div id="home-tool-suggestions-footer" class="border-t border-ink-border px-4 py-2.5 font-mono text-xs text-paper-muted">
              Press Enter to search all tools
            </div>
          </div>
        </form>
      </div>

      <!-- Secondary: quick-decide -->
      <form id="home-decide-form" class="mt-4 flex flex-wrap items-center gap-2 text-sm text-paper-muted">
        <span>or jump to a decision —</span>
        <span>best</span>
        <select id="decide-category" aria-label="Category" class="rounded-lg border border-ink-border bg-ink-900 px-2.5 py-1.5 text-paper focus:border-signal focus:outline-none">
          {decideCategories.map((cat) => <option value={cat.slug}>{cat.name}</option>)}
        </select>
        <span>for</span>
        <select id="decide-context" aria-label="Use case" class="rounded-lg border border-ink-border bg-ink-900 px-2.5 py-1.5 text-paper focus:border-signal focus:outline-none">
          {decideContexts.map((ctx) => <option value={ctx.slug}>{ctx.title}</option>)}
        </select>
        <button type="submit" class="rounded-lg bg-signal px-3 py-1.5 font-medium text-ink-950 transition hover:brightness-110 focus:outline-none focus:ring-2 focus:ring-signal/50">
          Show me →
        </button>
        <noscript><a href="/best" class="underline">Browse all lists →</a></noscript>
      </form>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="border-b border-zinc-800 bg-zinc-900/50 py-4 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-4 overflow-x-auto scrollbar-hide">
        <span class="shrink-0 text-sm text-zinc-500">Browse:</span>
        {
          categories.slice(0, 10).map((cat) => (
            <a
              href={`/categories/${cat.slug}`}
              class="shrink-0 rounded-lg border border-zinc-800 bg-zinc-900/50 px-3 py-1.5 text-sm text-zinc-400 transition hover:border-zinc-700 hover:bg-zinc-800/50 hover:text-zinc-100"
            >
              {cat.name}
            </a>
          ))
        }
        <a href="/categories" class="shrink-0 text-sm text-zinc-400 hover:text-zinc-100 transition">
          View all →
        </a>
      </div>
    </div>
  </section>

  <!-- Featured Tools -->
  <section class="bg-zinc-950 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-semibold text-zinc-100">Featured Tools</h2>
          <p class="mt-1 text-sm text-zinc-400">Top-rated across all categories</p>
        </div>
        <a href="/tools" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
          View all →
        </a>
      </div>

      <div
        id="featured-tools-grid"
        class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
      >
        {
          featuredTools.map((tool, index) => (
            <div class:list={[index >= 6 && 'hidden-on-mobile']}>
              <ToolCard tool={tool} category={tool.category} />
            </div>
          ))
        }
      </div>

      <div class="mt-6 text-center lg:hidden">
        <button
          id="show-more-tools"
          class="rounded-lg border border-zinc-800 bg-zinc-900/50 px-6 py-2.5 text-sm font-medium text-zinc-300 transition hover:border-zinc-700 hover:bg-zinc-800/50"
        >
          Show more tools
        </button>
      </div>
    </div>
  </section>

  <!-- Comparisons -->
  {
    featuredContexts && featuredContexts.length > 0 && (
      <section class="border-t border-zinc-800 bg-zinc-900/30 py-12">
        <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
          <div class="flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-semibold text-zinc-100">Comparisons</h2>
              <p class="mt-1 text-sm text-zinc-400">Curated lists to help you choose</p>
            </div>
            <a href="/best" class="text-sm text-zinc-400 hover:text-zinc-100 transition">
              View all →
            </a>
          </div>

          <div class="mt-6 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
            {featuredContexts.map((ctx) => (
              <a
                href={`/best/${ctx.slug}`}
                class="group rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 transition-all duration-200 hover:border-zinc-700 hover:bg-gradient-to-b hover:from-zinc-800/50 hover:to-zinc-900/50"
              >
                <h3 class="text-sm font-medium text-zinc-100 group-hover:text-white">
                  {ctx.title}
                </h3>
                <p class="mt-1 text-sm text-zinc-500">{ctx.tool_count} tools</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    )
  }
</BaseLayout>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  /* Show more functionality */
  @media (max-width: 1023px) {
    .hidden-on-mobile {
      display: none;
    }
    #featured-tools-grid.expanded .hidden-on-mobile {
      display: block;
    }
  }
</style>

<script is:inline>
  // Lightweight client-side suggestions for homepage search
  document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('home-tools-search');
    const form = document.getElementById('home-search-form');
    const dropdown = document.getElementById('home-tool-suggestions');
    const list = document.getElementById('home-tool-suggestions-list');
    if (
      !(input instanceof HTMLInputElement) ||
      !(form instanceof HTMLFormElement) ||
      !(dropdown instanceof HTMLDivElement) ||
      !(list instanceof HTMLDivElement)
    ) {
      return;
    }

    let toolIndex = null;
    let loadPromise = null;
    let activeIndex = -1;
    let visibleMatches = [];

    const loadToolIndex = async () => {
      if (toolIndex) return toolIndex;
      if (loadPromise) return loadPromise;

      loadPromise = fetch('/api/search/tool-index', { headers: { Accept: 'application/json' } })
        .then((res) => (res.ok ? res.json() : null))
        .then((payload) => {
          toolIndex = Array.isArray(payload?.items) ? payload.items : [];
          return toolIndex;
        })
        .catch(() => {
          toolIndex = [];
          return toolIndex;
        })
        .finally(() => {
          loadPromise = null;
        });

      return loadPromise;
    };

    const closeDropdown = () => {
      dropdown.classList.add('hidden');
      input.setAttribute('aria-expanded', 'false');
      activeIndex = -1;
    };

    const openDropdown = () => {
      dropdown.classList.remove('hidden');
      input.setAttribute('aria-expanded', 'true');
    };

    const updateActiveState = () => {
      const buttons = list.querySelectorAll('[data-suggestion-index]');
      buttons.forEach((el, index) => {
        const isActive = index === activeIndex;
        el.classList.toggle('bg-ink-800', isActive);
        el.classList.toggle('border-ink-800', isActive);
        el.classList.toggle('border-ink-border', !isActive);
        if (isActive) {
          el.scrollIntoView({ block: 'nearest' });
        }
      });
    };

    const renderSuggestions = (query) => {
      if (!Array.isArray(toolIndex) || !query || query.length < 2) {
        visibleMatches = [];
        list.replaceChildren();
        closeDropdown();
        return;
      }

      const q = query.trim().toLowerCase();
      if (q.length < 2) {
        visibleMatches = [];
        list.replaceChildren();
        closeDropdown();
        return;
      }

      const startsWith = [];
      const contains = [];

      for (const tool of toolIndex) {
        const name = String(tool?.name || '');
        const lower = name.toLowerCase();
        if (!lower.includes(q)) continue;
        if (lower.startsWith(q)) startsWith.push(tool);
        else contains.push(tool);
        if (startsWith.length + contains.length >= 12) break;
      }

      const matches = startsWith.concat(contains).slice(0, 8);
      visibleMatches = matches;
      activeIndex = -1;

      if (matches.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'rounded-xl border border-ink-border bg-ink-900 px-4 py-3.5 text-sm text-paper-muted';
        empty.textContent = 'No quick matches. Press Enter to search all tools.';
        list.replaceChildren(empty);
        openDropdown();
        return;
      }

      const rows = matches.map((tool, index) => {
        const row = document.createElement('a');
        row.href = `/tool/${encodeURIComponent(tool.slug)}`;
        row.className =
          'group block rounded-xl border border-ink-border bg-ink-900 px-4 py-3.5 transition hover:border-ink-800 hover:bg-ink-800 focus:bg-ink-800 focus:outline-none';
        row.dataset.suggestionIndex = String(index);

        const shell = document.createElement('div');
        shell.className = 'flex items-start gap-3';

        const icon = document.createElement('div');
        icon.className =
          'mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-lg border border-ink-border bg-ink-900 text-xs font-semibold text-paper';
        icon.textContent = (tool.name || '?').slice(0, 1).toUpperCase();

        const body = document.createElement('div');
        body.className = 'min-w-0 flex-1';

        const top = document.createElement('div');
        top.className = 'flex items-start justify-between gap-3';

        const nameWrap = document.createElement('div');
        nameWrap.className = 'min-w-0';

        const name = document.createElement('div');
        name.className = 'truncate text-[15px] font-semibold leading-5 text-paper';
        name.textContent = tool.name;

        const path = document.createElement('div');
        path.className = 'mt-1 truncate text-xs leading-4 text-paper-muted';
        path.textContent = `/tool/${tool.slug}`;

        nameWrap.append(name, path);

        const badge = document.createElement('div');
        badge.className =
          'mt-0.5 shrink-0 rounded-md border border-ink-border bg-ink-900 px-2 py-1 font-mono text-xs font-semibold text-paper';
        badge.textContent = tool.score ? tool.score : '—';

        top.append(nameWrap, badge);
        body.append(top);

        const verdictText = typeof tool.verdict === 'string' ? tool.verdict.trim() : '';
        const fallback = typeof tool.short_description === 'string' ? tool.short_description.trim() : '';
        const line = verdictText || fallback;
        if (line) {
          const desc = document.createElement('div');
          desc.className = 'mt-2 line-clamp-2 pr-1 text-sm leading-5 text-paper-muted';
          desc.textContent = line.length > 120 ? `${line.slice(0, 117).trim()}…` : line;
          body.append(desc);
        }

        shell.append(icon, body);
        row.append(shell);

        row.addEventListener('mouseenter', () => {
          activeIndex = index;
          updateActiveState();
        });

        return row;
      });

      list.replaceChildren(...rows);
      openDropdown();
    };

    input.addEventListener('focus', () => {
      void loadToolIndex();
      if (input.value.trim().length >= 2) {
        renderSuggestions(input.value);
      }
    });

    input.addEventListener('input', async () => {
      if (!toolIndex) {
        await loadToolIndex();
      }
      renderSuggestions(input.value);
    });

    input.addEventListener('keydown', (event) => {
      if (dropdown.classList.contains('hidden')) return;

      if (event.key === 'ArrowDown') {
        if (visibleMatches.length === 0) return;
        event.preventDefault();
        activeIndex = Math.min(activeIndex + 1, visibleMatches.length - 1);
        updateActiveState();
        return;
      }

      if (event.key === 'ArrowUp') {
        if (visibleMatches.length === 0) return;
        event.preventDefault();
        activeIndex = Math.max(activeIndex - 1, 0);
        updateActiveState();
        return;
      }

      if (event.key === 'Escape') {
        closeDropdown();
        return;
      }

      if (event.key === 'Enter' && activeIndex >= 0 && visibleMatches[activeIndex]) {
        event.preventDefault();
        window.location.href = `/tool/${encodeURIComponent(visibleMatches[activeIndex].slug)}`;
      }
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) return;
      if (!form.contains(event.target)) {
        closeDropdown();
      }
    });
  });

  document.addEventListener('DOMContentLoaded', () => {
    const decideForm = document.getElementById('home-decide-form');
    const ctxSelect = document.getElementById('decide-context');
    if (decideForm instanceof HTMLFormElement && ctxSelect instanceof HTMLSelectElement) {
      decideForm.addEventListener('submit', (e) => {
        e.preventDefault();
        const slug = ctxSelect.value;
        window.location.href = slug ? `/best/${encodeURIComponent(slug)}` : '/best';
      });
    }
  });

  // Show more tools button
  document.addEventListener('DOMContentLoaded', () => {
    const showMoreBtn = document.getElementById('show-more-tools');
    const grid = document.getElementById('featured-tools-grid');

    if (showMoreBtn && grid) {
      showMoreBtn.addEventListener('click', () => {
        grid.classList.toggle('expanded');
        showMoreBtn.textContent = grid.classList.contains('expanded')
          ? 'Show less'
          : 'Show more tools';
      });
    }
  });
</script>
