          (hasPricing || showProceduralPricing) && (
            <section id="hard-limits" class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm">
              <h2 class="text-lg font-semibold text-zinc-100">Hard limits / dealbreakers</h2>
              {canonicalHardLimits.length > 0 ? (
                <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                  {canonicalHardLimits.map((item) => (
                    <li>
                      - {item.text}{' '}
                      <a
                        href={item.sourceUrl}
                        target="_blank"
                        rel="noopener"
                        data-outbound="source"
                        data-location="hard-limits"
                        data-tool={tool.slug}
                        class="text-xs text-zinc-500 hover:text-hunt-500"
                      >
                        Source
                      </a>
                    </li>
                  ))}
                </ul>
              ) : (
                <p class="mt-2 text-sm text-zinc-300">
                  No source-backed hard limits extracted yet. Use the verification checklist before commitment.
                </p>
              )}
            </section>
          )
        }

        {/* Features Showcase */}
        {
          (knowledgeCard?.features?.core?.length > 0 ||
            knowledgeCard?.features?.unique?.length > 0) && (
            <FeaturesShowcase features={knowledgeCard.features} toolName={tool.name} sectionId="features" />
          )
        }

        {/* Technical Specs - Category-specific and VIP tool details */}
        {
          hasSpecs && (
            <section id="specs">
              {specsVerifiedLabel && (
                <p class="mb-3 text-xs text-zinc-500">Specs verified {specsVerifiedLabel}</p>
              )}
              <DynamicSpecs
                categorySpecificData={displayCategorySpecificData}
                specifics={vipSpecifics}
                toolName={tool.name}
                categoryName={tool.category?.name}
              />
            </section>
          )
        }
        {
          showProceduralSpecs && (
            <section id="specs" class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm">
              <h2 class="text-lg font-semibold text-zinc-100">Technical Validation Steps</h2>
              <ul class="mt-4 space-y-2 text-sm text-zinc-300">
                <li>- Confirm API limits and throttling behavior using your expected peak load.</li>
                <li>- Verify export formats and data portability before onboarding large datasets.</li>
                <li>- Check release cadence and changelog quality for operational predictability.</li>
                <li>- Validate admin controls needed by your security/compliance process.</li>
              </ul>
            </section>
          )
        }
        {
          showOperationalFit && (
            <section
              id="operational-fit"
              class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
            >
              <h2 class="text-lg font-semibold text-zinc-100">Operational Fit</h2>
              <p class="mt-2 text-sm text-zinc-400">
                Evidence-backed constraints and rollout considerations before you scale usage.
              </p>

              <div class="mt-5 grid gap-4 md:grid-cols-2">
                <div class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                  <h3 class="text-sm font-semibold text-zinc-200">Rollout risks</h3>
                  {trialNotesBullets.length > 0 ? (
                    <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                      {trialNotesBullets.map((item) => (
                        <li>
                          - {item.text}{' '}
                          <a
                            href={item.sourceUrl}
                            target="_blank"
                            rel="noopener"
                            class="text-xs text-zinc-500 hover:text-hunt-500"
                          >
                            Source
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                      <li>- Run a week-long pilot with real contributors.</li>
                      <li>- Track failure reasons and manual workarounds daily.</li>
                      <li>- Re-check fit after migration and permissions setup.</li>
                    </ul>
                  )}
                </div>

                <div class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                  <h3 class="text-sm font-semibold text-zinc-200">Adoption blockers</h3>
                  {notIncludedBullets.length > 0 ? (
                    <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                      {notIncludedBullets.map((item) => (
                        <li>
                          - {item.text}{' '}
                          <a
                            href={item.sourceUrl}
                            target="_blank"
                            rel="noopener"
                            class="text-xs text-zinc-500 hover:text-hunt-500"
                          >
                            Source
                          </a>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                      <li>- Verify which required features are plan-gated.</li>
                      <li>- Confirm missing workflows and required integrations.</li>
                      <li>- Validate export/migration paths before commitment.</li>
                    </ul>
                  )}
                </div>
              </div>
            </section>
          )
        }

        {/* Community Insights (Real user insights) */}
        {
          hasCommunity && (userAdvocate || guardedHumanVerdict) && (
            <TribalKnowledge
              userAdvocate={
                userAdvocate
                  ? {
                      vibe,
                      originStory,
                      idealFor,
                      avoidIf: guardedAvoidIf,
                      powerTip,
                      delighters,
                      frustrations,
                    }
                  : undefined
              }
              humanVerdict={guardedHumanVerdict}
            />
          )
        }

        {/* Platform Support & Integrations */}
        {
          (knowledgeCard?.platforms?.length > 0 || knowledgeCard?.integrations) && (
            <PlatformIntegrations
              platforms={knowledgeCard.platforms || []}
              integrations={knowledgeCard.integrations}
              toolName={tool.name}
              sectionId="platform-integrations"
            />
          )
        }

        {/* Video Embed - Bottom of content for better UX */}
        {
          tool.video_id && (
            <section id="video">
              <h2 class="mb-4 text-lg font-semibold text-zinc-100">Watch {tool.name} in Action</h2>
              <VideoEmbed
                client:visible
                id={tool.video_id}
                title={tool.video_title || `${tool.name} Overview`}
              />
            </section>
          )
        }

        {/* Included Tools (if this is a parent suite) */}
        <IncludedTools toolId={tool.id} toolName={tool.name} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-6 lg:sticky lg:top-8 lg:self-start">
        {/* Quick Stats - Moved to top for quick scanning */}
        <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
          <h3 class="mb-4 font-semibold text-zinc-100">Quick Stats</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="group relative text-sm text-zinc-400">
                <span class="cursor-help border-b border-dotted border-zinc-600">
                  StackHunt Index
                </span>
                <div
                  class="pointer-events-none absolute bottom-full left-0 mb-2 hidden w-64 rounded-lg border border-zinc-700 bg-zinc-800 p-3 text-xs text-zinc-300 shadow-xl group-hover:block z-10"
                >
                  <p class="font-medium text-zinc-100 mb-1">What is this?</p>
                  <p>
                    Calculated from feature density, update frequency, and market adoption—not user
                    votes. Community signals appear separately below.
                  </p>
                </div>
              </dt>
              <dd class="text-sm font-medium text-zinc-100">
                {
                  tool.review_count < 10 && tool.avg_score > 0 ? (
                    <span class="inline-flex items-center gap-1.5">
                      {Math.round(tool.avg_score)}/100
                      <span class="text-xs text-zinc-500">(Early)</span>
                    </span>
                  ) : tool.avg_score > 0 ? (
                    `${Math.round(tool.avg_score)}/100`
                  ) : (
                    <span class="rounded-full bg-amber-500/10 px-2 py-0.5 text-xs text-amber-400">
                      Tracking
                    </span>
                  )
                }
              </dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-zinc-400">Published Analyses</dt>
              <dd class="text-sm font-medium text-zinc-100">
                {publishedAnalysesLabel}
              </dd>
            </div>
            {
              tool.category && (
                <div class="flex justify-between">
                  <dt class="text-sm text-zinc-400">Category</dt>
                  <dd class="text-sm font-medium text-zinc-100">{tool.category.name}</dd>
                </div>
              )
            }
          </dl>
          {
            tool.data_confidence && tool.data_confidence < 0.8 && (
              <div class="mt-4 rounded-lg border border-amber-700 bg-amber-900/30 px-3 py-2 text-xs text-amber-400">
                <svg class="inline-block h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                  <path
                    fill-rule="evenodd"
                    d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                    clip-rule="evenodd"
                  />
                </svg>
                Some data may be approximate
              </div>
            )
          }
        </div>

        {/* Company Info */}
        {
          knowledgeCard && (
            <CompanyInfo
              company={knowledgeCard.company}
              audience={knowledgeCard.audience}
              learningCurve={tool.learning_curve}
            />
          )
        }

        {/* Suite Navigation (if part of a bundle) */}
        {
          parentTool && (
            <SuiteNavigation
              currentToolId={tool.id}
              parentId={parentTool.id}
              parentName={parentTool.name}
            />
          )
        }

        {/* Security & Compliance */}
        {knowledgeCard?.security && <SecurityCompliance security={knowledgeCard.security} />}

        {/* Support Options */}
        {knowledgeCard?.support && <SupportOptions support={knowledgeCard.support} />}

        {/* Portability */}
        {
          knowledgeCard?.smp_portability && (
            <PortabilityCard portability={knowledgeCard.smp_portability} toolName={tool.name} />
          )
        }

        {
          tool.affiliate_offers && tool.affiliate_offers.length > 1 && (
            <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
              <h3 class="mb-4 font-semibold text-zinc-100">Get {tool.name}</h3>
              <div class="space-y-3">
                {tool.affiliate_offers.map((offer) => (
                  <a
                    href={offer.url}
                    target="_blank"
                    rel={offer.is_affiliate ? 'nofollow sponsored noopener noreferrer' : 'noopener noreferrer'}
                    data-outbound="vendor"
                    data-location="sidebar-offers"
                    data-tool={tool.slug}
                    class="flex items-center justify-between rounded-lg border border-zinc-800 p-3 transition hover:border-hunt-200 hover:bg-hunt-50"
                  >
                    <span class="text-sm font-medium text-zinc-300">{offer.cta_text}</span>
                    <svg
                      class="h-4 w-4 text-zinc-500"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>

    {/* FAQ - Visible content to match FAQ schema */}
    {
      hasFAQ && (
        <section id="faq" class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
          <h2 class="mb-4 text-lg font-semibold text-zinc-100">FAQ</h2>
          <div class="space-y-4">
            {faqItems.map((item) => (
              <details class="group rounded-lg border border-zinc-800 bg-zinc-900 p-4">
                <summary class="flex items-center justify-between cursor-pointer">
                  <h3 class="text-sm font-semibold text-zinc-100">{item.question}</h3>
                  <svg
                    class="h-4 w-4 text-zinc-400 transition-transform group-open:rotate-90 md:hidden"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </summary>
                <div class="mt-2 space-y-2">
                  <p class="text-sm text-zinc-300">{item.answer}</p>
                  {item.answer_source_url && (
                    <a
                      href={item.answer_source_url}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1 text-xs text-zinc-400 hover:text-hunt-500"
                    >
                      Source
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </details>
            ))}
          </div>
        </section>
      )
    }

    {/* Alternatives Section - Hybrid Search Strategy */}
    {
      orderedAlternatives && orderedAlternatives.length > 0 && (
        <section id="alternatives" class="mt-16">
          <header class="mb-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h2 class="text-2xl font-semibold text-zinc-100">
                  {alternativesLabel} to {tool.name}
                </h2>
                <p class="mt-1 text-sm text-zinc-400">
                  {alternativesResponse.type === 'alternatives'
                    ? `Other ${tool.specs?.taxonomy?.primary_function?.toLowerCase() || tool.category?.name?.toLowerCase() || ''} tools to consider`
                    : 'Similar tools you might find useful'}
                </p>
              </div>
              {tool.category && (
                <a
                  href={`/categories/${tool.category.slug}`}
                  class="text-sm text-hunt-500 hover:text-hunt-400 transition shrink-0"
                >
                  View all →
                </a>
              )}
            </div>
          </header>

          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {orderedAlternatives.map((alt) => {
              const canCompare = areToolsComparable(
                { slug: tool.slug, category_id: getPrimaryCategoryId(tool), metadata: tool.metadata as any },
                { slug: alt.slug, category_id: getPrimaryCategoryId(alt), metadata: alt.metadata as any }
              );
              return (
                <AlternativeCard
                  main={{
                    slug: tool.slug,
                    name: tool.name,
                    pricing_type: tool.pricing_type,
                    learning_curve: tool.learning_curve,
                    base_score: tool.base_score,
                  }}
                  alt={alt}
                  curatedVerdict={curatedVerdicts.get(alt.slug)}
                  computedDiff={microDiffs.get(alt.slug)}
                  showCompareLink={canCompare}
                />
              );
            })}
          </div>
        </section>
      )
    }

    {
      evidenceBasis.length > 0 && (
        <section id="sources" class="mt-12 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
          <h2 class="text-lg font-semibold text-zinc-100">Methodology & Sources</h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {evidenceBasis.map((chip) => (
              <span class="rounded-full border border-zinc-700 bg-zinc-800 px-2.5 py-1 text-xs text-zinc-300">
                {chip.label} ({chip.count})
              </span>
            ))}
          </div>
          <details class="mt-4 rounded-lg border border-zinc-800 bg-zinc-950/60 p-3">
            <summary class="cursor-pointer text-sm text-zinc-300">View sources</summary>
            <ul class="mt-3 space-y-2 text-sm">
              {evidenceLinks.slice(0, 12).map((source) => (
                <li>
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener"
                    data-outbound="source"
                    data-location="methodology-sources"
                    data-tool={tool.slug}
                    class="text-zinc-300 hover:text-hunt-500"
                  >
                    {source.title}
                  </a>
                  <span class="ml-2 text-xs text-zinc-500">
                    {source.domain} · {source.basis} · {source.quality} confidence · {source.inclusionReason}
                  </span>
                </li>
              ))}
            </ul>
            {lowConfidenceEvidenceLinks.length > 0 && (
              <div class="mt-4 rounded-lg border border-amber-700/30 bg-amber-950/20 p-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-amber-300">
                  Low-confidence secondary sources ({lowConfidenceEvidenceLinks.length})
                </p>
                <ul class="mt-2 space-y-1 text-xs text-zinc-400">
                  {lowConfidenceEvidenceLinks.slice(0, 6).map((source) => (
                    <li>
                      {source.domain} · {source.inclusionReason}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </details>
        </section>
      )
    }

    {
      hasVerificationChecklist && (
        <section id="verification-checklist" class="mt-12 rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm">
          <h2 class="text-lg font-semibold text-zinc-100">Verification Checklist</h2>
          <p class="mt-2 text-sm text-zinc-400">
            Canonical pre-procurement checklist. Use this once and reference it across pricing, setup, and rollout.
          </p>
          <div class="mt-5 grid gap-4 md:grid-cols-3">
            <div class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
              <h3 class="text-sm font-semibold text-zinc-200">Pricing verification</h3>
              <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                {checklistPricing.map((item) => (
                  <li>- {item}</li>
                ))}
              </ul>
            </div>
            <div class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
              <h3 class="text-sm font-semibold text-zinc-200">Technical verification</h3>
              <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                {checklistTechnical.map((item) => (
                  <li>- {item}</li>
                ))}
              </ul>
            </div>
            <div class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
              <h3 class="text-sm font-semibold text-zinc-200">Security & migration</h3>
              <ul class="mt-3 space-y-2 text-sm text-zinc-300">
                {checklistSecurity.map((item) => (
                  <li>- {item}</li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      )
    }
  </div>

  {/* Community Feedback - Compact consolidated section */}
  {
    hasCommunity && (
      <section id="community" class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
        {communityVerifiedLabel && (
          <p class="mb-3 text-xs text-zinc-500">Community signals verified {communityVerifiedLabel}</p>
        )}
        <SignalReportWidget client:visible itemId={tool.id} itemName={tool.name} phase={1} />
        <div class="sm:text-right shrink-0">
          <button
            type="button"
            data-suggest-edit
            data-tool-id={tool.id}
            data-tool-name={tool.name}
            class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 hover:border-zinc-600 transition"
          >
            <svg
              class="h-3.5 w-3.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
              ></path>
            </svg>
            Report correction
          </button>
        </div>
      </section>
    )
  }
  {
    showProceduralCommunity && (
      <section id="community" class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 p-5">
        <h2 class="text-lg font-semibold text-zinc-100">Observed Usage Patterns</h2>
        <p class="mt-2 text-sm text-zinc-400">
          Community evidence is currently below publication threshold. Use this lightweight audit:
        </p>
        <ul class="mt-4 space-y-2 text-sm text-zinc-300">
          <li>- Ask references what failed first after rollout and how they mitigated it.</li>
          <li>- Validate support responsiveness during your local business hours.</li>
          <li>- Compare one critical workflow against two alternatives before locking in.</li>
          <li>- Re-check after the next product release cycle for fresher field evidence.</li>
        </ul>
      </section>
    )
  }

  <!-- Suggest Edit Modal -->
  <div
    id="suggest-edit-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="suggest-edit-title"
    aria-hidden="true"
  >
    <div class="w-full max-w-md rounded-xl bg-zinc-900 p-6 shadow-xl" tabindex="-1" data-modal-panel>
      <div class="flex items-center justify-between mb-4">
        <h3 id="suggest-edit-title" class="text-lg font-semibold text-zinc-100">Suggest an Edit</h3>
        <button type="button" data-close-modal aria-label="Close suggest edit dialog" class="text-zinc-500 hover:text-zinc-300">
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <form id="suggest-edit-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={tool.id} />
        <input type="text" name="company_name" tabindex="-1" autocomplete="off" class="hidden" />
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">What needs correcting?</label>
          <select
            name="field_name"
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          >
            <option value="pricing">Pricing information</option>
            <option value="pros">Pros</option>
            <option value="cons">Cons</option>
            <option value="summary">Summary/description</option>
            <option value="score">Score seems off</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1"
            >What's the correct information?</label
          >
          <textarea
            name="correction_text"
            rows="3"
            required
            placeholder="e.g., The pricing has changed to $15/month..."
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">Your email (optional)</label>
          <input
            type="email"
            name="reporter_email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          />
          <p class="mt-1 text-xs text-zinc-500">We'll notify you when the correction is reviewed</p>
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 rounded-lg bg-hunt-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-hunt-700 transition"
            >Submit Suggestion</button
          >
          <button
            type="button"
            data-close-modal
            class="rounded-lg border border-zinc-700 px-4 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-900 transition"
            >Cancel</button
          >
        </div>
      </form>
      <div id="suggest-edit-success" class="hidden text-center py-4">
        <svg
          class="mx-auto h-12 w-12 text-green-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-3 text-sm text-zinc-300">Thanks! We'll review your suggestion.</p>
        <button
          type="button"
          data-close-modal
          class="mt-4 text-sm text-hunt-600 hover:text-hunt-700">Close</button
        >
      </div>
    </div>
  </div>

  <script is:inline>
    // Outbound click tracking (vendor CTA + source links)
    document.addEventListener('click', (event) => {
      const target = event.target as HTMLElement | null;
      const link = target?.closest('a') as HTMLAnchorElement | null;
      if (!link) return;
      const href = link.getAttribute('href') || '';
      const isExternal = /^https?:\/\//i.test(href);
      if (!isExternal) return;

      const location = link.dataset.location || 'unknown';
      const type = link.dataset.outbound || (link.textContent?.trim().toLowerCase() === 'source' ? 'source' : 'vendor');
      const tool = link.dataset.tool || '';
      const sanitizedHref = (() => {
        try {
          const parsed = new URL(href);
          return `${parsed.origin}${parsed.pathname}`;
        } catch {
          return href.split('?')[0];
        }
      })();

      if (typeof (window as any).plausible === 'function') {
        (window as any).plausible('outbound_click', {
          props: { type, location, tool, href: sanitizedHref },
        });
      }
    });

    // Open key sources from decision panel
    document.querySelectorAll('[data-open-key-sources]').forEach((button) => {
      button.addEventListener('click', () => {
        const raw = button.getAttribute('data-open-key-sources');
        if (!raw) return;
        try {
          const urls = JSON.parse(raw) as string[];
          urls.slice(0, 2).forEach((url) => {
            if (url && /^https?:\/\//i.test(url)) window.open(url, '_blank', 'noopener,noreferrer');
          });
        } catch {
          // no-op
        }
      });
    });

    // Copy use-case prompts
    const copyStatus = document.getElementById('prompt-copy-status');
    document.querySelectorAll('[data-copy-prompt]').forEach((button) => {
      button.addEventListener('click', async () => {
        const prompt = button.getAttribute('data-copy-prompt');
        if (!prompt) return;
        try {
          await navigator.clipboard.writeText(prompt);
          button.textContent = 'Copied';
          button.setAttribute('aria-label', 'Prompt copied to clipboard');
          if (copyStatus) copyStatus.textContent = 'Prompt copied to clipboard';
          setTimeout(() => {
            button.textContent = 'Try this prompt';
            button.setAttribute('aria-label', 'Try this prompt');
          }, 1200);
        } catch {
          // no-op
        }
      });
    });

    // Suggest Edit Modal
    const modal = document.getElementById('suggest-edit-modal');
    const modalPanel = modal?.querySelector('[data-modal-panel]') as HTMLElement | null;
    const form = document.getElementById('suggest-edit-form');
    const success = document.getElementById('suggest-edit-success');
    let lastFocusedElement: HTMLElement | null = null;

    const closeModal = () => {
      modal?.classList.add('hidden');
      modal?.classList.remove('flex');
      modal?.setAttribute('aria-hidden', 'true');
      lastFocusedElement?.focus();
    };

    const focusFirstFocusable = () => {
      if (!modal) return;
      const firstFocusable = modal.querySelector<HTMLElement>(
        'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'
      );
      firstFocusable?.focus();
    };

    const trapFocus = (event: KeyboardEvent) => {
      if (event.key !== 'Tab' || !modal || modal.classList.contains('hidden')) return;
      const focusable = Array.from(
        modal.querySelectorAll<HTMLElement>('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])')
      ).filter((el) => !el.hasAttribute('disabled'));
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    };

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
        closeModal();
      }
      trapFocus(event);
    });

    document.querySelectorAll('[data-suggest-edit]').forEach((btn) => {
      btn.addEventListener('click', () => {
        lastFocusedElement = document.activeElement as HTMLElement | null;
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        modal?.setAttribute('aria-hidden', 'false');
        form?.classList.remove('hidden');
        success?.classList.add('hidden');
        setTimeout(() => focusFirstFocusable(), 0);
      });
    });
    document.querySelectorAll('[data-close-modal]').forEach((btn) => {
      btn.addEventListener('click', () => {
        closeModal();
      });
    });
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        closeModal();
      }
    });
    modalPanel?.addEventListener('click', (e) => e.stopPropagation());
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      try {
        const res = await fetch('/api/corrections', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          form.reset();
        } else {
          alert('Failed to submit. Please try again.');
        }
      } catch {
        alert('Network error. Please try again.');
      }
    });
  </script>
</BaseLayout>
