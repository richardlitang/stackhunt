---
/**
 * Tool Detail Page - /tool/[slug] (singular)
 * Software tools only (type='tool')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import VideoEmbed from '@/components/VideoEmbed';
import AlternativeCard from '@/components/AlternativeCard.astro';
import AlternativesCompareGrid from '@/components/AlternativesCompareGrid.astro';
import CompanyInfo from '@/components/CompanyInfo.astro';
import SecurityCompliance from '@/components/SecurityCompliance.astro';
import SupportOptions from '@/components/SupportOptions.astro';
import PortabilityCard from '@/components/PortabilityCard.astro';
import PlatformIntegrations from '@/components/PlatformIntegrations.astro';
import FeaturesShowcase from '@/components/FeaturesShowcase.astro';
import GettingStarted from '@/components/GettingStarted.astro';
import PricingPlansGrid from '@/components/PricingPlansGrid.astro';
import PricingInsights from '@/components/PricingInsights.astro';
import ReviewLensSwitch from '@/components/ReviewLensSwitch.astro';
import TribalKnowledge from '@/components/TribalKnowledge.astro';
import TrustBar from '@/components/TrustBar.astro';
import PriceVerification from '@/components/PriceVerification';
import SuiteNavigation from '@/components/SuiteNavigation.astro';
import DynamicSpecs from '@/components/DynamicSpecs.astro';
import IncludedTools from '@/components/IncludedTools.astro';
import ToolHowWeEvaluateSection from '@/components/ToolHowWeEvaluateSection.astro';
import ToolWeTestedSection from '@/components/ToolWeTestedSection.astro';
import ToolDecisionConditionsSection from '@/components/ToolDecisionConditionsSection.astro';
import ToolDecisionUtilitySection from '@/components/ToolDecisionUtilitySection.astro';
import ToolPracticalOutcomesSection from '@/components/ToolPracticalOutcomesSection.astro';
import SignalReportWidget from '@/components/SignalReportWidget';
import { simpleMarkdown } from '@/lib/utils';
import {
  buildToolPagePricingLinkText,
  getToolPageData,
  isEligibleEvidenceUrl,
  buildToolPageRequestRouteState,
  applyToolPageResponseRouteState,
  buildToolPagePageCompilerRouteStateFromPageContext,
} from '@/lib/tool-page';

// SSR: Compute live, cache at edge (s-maxage=3600, stale-while-revalidate=604800)
export const prerender = false;

const { slug } = Astro.params;
const { activeReviewLens } = buildToolPageRequestRouteState({
  searchParams: Astro.url.searchParams,
  response: Astro.response,
});

const toolPageData = await getToolPageData(slug);
if (!toolPageData || !toolPageData.tool) {
  return Astro.redirect('/404');
}
const { routeDataState, pageAssemblyState } = buildToolPagePageCompilerRouteStateFromPageContext({
  toolPageData,
  isEligibleEvidenceUrl,
  activeReviewLens,
  pathname: Astro.url.pathname,
  searchParams: Astro.url.searchParams,
});

applyToolPageResponseRouteState({
  response: Astro.response,
  robotsTag: pageAssemblyState.indexPolicy.robotsTag,
});
---

<BaseLayout meta={pageAssemblyState.meta} schemas={pageAssemblyState.pageSchemas}>
  <AffiliateDisclosure
    variant="banner"
    hasAffiliateLinks={routeDataState.primaryOffer?.is_affiliate || false}
  />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/tools" class="hover:text-hunt-500">Tools</a>
      {
        pageAssemblyState.categoryBreadcrumb && (
          <>
            <span>/</span>
            <a href={pageAssemblyState.categoryBreadcrumb.href} class="hover:text-hunt-500">
              {pageAssemblyState.categoryBreadcrumb.label}
            </a>
          </>
        )
      }
      <span>/</span>
      <span aria-current="page" class="text-zinc-300">
        {routeDataState.tool.name}
      </span>
    </nav>

    <!-- Hero Section -->
    <header
      class="relative mb-12 overflow-hidden rounded-3xl border border-zinc-700 bg-zinc-900 p-6 shadow-lg sm:p-8"
    >
      {
        routeDataState.showReviewInProgressBanner && (
          <div class="mb-4 rounded-lg border border-sky-500/40 bg-sky-500/10 px-4 py-2 text-sm text-sky-100">
            {pageAssemblyState.reviewInProgressBannerText}
          </div>
        )
      }
      <div
        class="pointer-events-none absolute -right-16 -top-24 h-64 w-64 rounded-full bg-hunt-500/20 blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-20 left-4 h-52 w-52 rounded-full bg-cyan-500/15 blur-3xl"
      >
      </div>

      <div class="relative grid gap-8 xl:grid-cols-[1.6fr_1fr]">
        <div class="space-y-5">
          <div class="flex items-start gap-5">
            <Logo
              domain={routeDataState.tool.logo_url}
              name={routeDataState.tool.name}
              size="xl"
              priority={true}
              class="shrink-0 rounded-2xl border border-zinc-700/80 shadow-md"
            />
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-hunt-400">Review</p>
              <div class="mt-1 flex items-center gap-3">
                <h1 class="text-2xl font-bold text-zinc-100 sm:text-3xl">
                  {pageAssemblyState.toolReviewHeading}
                </h1>
                {
                  routeDataState.tool.is_verified && (
                    <span class="flex items-center gap-1 rounded-full bg-blue-500/15 px-2 py-0.5 text-xs font-medium text-blue-200 ring-1 ring-blue-400/30">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      {pageAssemblyState.verificationBadgeLabel}
                    </span>
                  )
                }
              </div>
              <p class="mt-1 text-sm text-zinc-400">
                {routeDataState.tool.name}: {pageAssemblyState.reviewDek}
              </p>
              {
                routeDataState.qualityState.subjectScopePending &&
                  routeDataState.qualityState.subjectScopeMessage && (
                    <p class="mt-2 rounded-lg border border-orange-700/40 bg-orange-950/20 px-3 py-2 text-sm text-orange-100">
                      {routeDataState.qualityState.subjectScopeMessage}
                    </p>
                  )
              }
              {
                pageAssemblyState.showEarlySnapshotToneBanner && (
                  <p class="mt-2 rounded-lg border border-amber-700/40 bg-amber-950/20 px-3 py-2 text-sm text-amber-100">
                    This is an early, docs-only snapshot. Some claims are pending confirmation. Use
                    this page to shortlist, then verify in a demo.
                  </p>
                )
              }
            </div>
          </div>

          <div
            class="grid gap-2 rounded-xl border border-zinc-700/80 bg-zinc-800/40 p-3 text-sm text-zinc-300 sm:grid-cols-3"
          >
            <div>
              <span class="text-xs uppercase tracking-wide text-zinc-500">Pricing</span>
              <p class="mt-1 font-medium text-zinc-100">{routeDataState.pricingTypeLabel}</p>
            </div>
            {
              routeDataState.tool.category && (
                <div>
                  <span class="text-xs uppercase tracking-wide text-zinc-500">Category</span>
                  <a
                    href={`/categories/${routeDataState.tool.category.slug}`}
                    class="mt-1 block font-medium text-zinc-100 hover:text-hunt-400 transition"
                  >
                    {routeDataState.tool.category.name}
                  </a>
                </div>
              )
            }
            {
              pageAssemblyState.websiteState.hasWebsite && (
                <a
                  href={routeDataState.tool.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-outbound="vendor"
                  data-location="hero-meta"
                  data-tool={routeDataState.tool.slug}
                  class="inline-flex items-end justify-between gap-2 rounded-lg border border-zinc-700/80 bg-zinc-900/40 px-3 py-2 text-zinc-100 hover:border-hunt-500 hover:text-hunt-400 transition"
                >
                  <span>
                    <span class="text-xs uppercase tracking-wide text-zinc-500">Website</span>
                    <span class="mt-1 block font-medium">
                      {pageAssemblyState.websiteDisplayLabel}
                    </span>
                  </span>
                  <svg
                    class="h-3.5 w-3.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 17L17 7M17 7H8M17 7v9"
                    />
                  </svg>
                </a>
              )
            }
          </div>

          <div class="flex flex-wrap gap-3">
            {
              routeDataState.primaryOffer && (
                <AffiliateButton
                  offer={routeDataState.primaryOffer}
                  toolName={routeDataState.tool.name}
                  size="lg"
                />
              )
            }
            <CompareButton
              client:load
              toolSlug={pageAssemblyState.compareButtonProps.toolSlug}
              toolName={pageAssemblyState.compareButtonProps.toolName}
              toolLogo={pageAssemblyState.compareButtonProps.toolLogo}
              categorySlug={pageAssemblyState.compareButtonProps.categorySlug}
              categoryName={pageAssemblyState.compareButtonProps.categoryName}
            />
            <AddToStackButton
              client:load
              toolSlug={pageAssemblyState.addToStackProps.toolSlug}
              toolName={pageAssemblyState.addToStackProps.toolName}
              toolLogo={pageAssemblyState.addToStackProps.toolLogo}
              pricing={pageAssemblyState.addToStackProps.pricing}
              plans={pageAssemblyState.addToStackProps.plans}
            />
          </div>
        </div>

        <aside
          class="rounded-2xl border border-zinc-700 bg-gradient-to-b from-zinc-900/95 via-zinc-900/80 to-zinc-950/95 p-5 shadow-inner"
        >
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">Trust</p>
          <div class="mt-3 rounded-xl border border-zinc-800 bg-zinc-950/50 p-4">
            <p class="text-sm font-medium text-zinc-100">
              {pageAssemblyState.trustBarProps.confidence} confidence,{' '}
              {pageAssemblyState.trustBarProps.sourcesCount} linked sources
            </p>
            <p class="mt-1 text-xs text-zinc-400">
              {pageAssemblyState.researchStatusView.reviewMethodLabel}. Last checked{' '}
              {pageAssemblyState.trustBarProps.lastChecked || 'Unknown'}.
            </p>
            {
              pageAssemblyState.researchStatusView.pendingConfirmationLabel && (
                <p class="mt-2 text-xs text-amber-300">
                  {pageAssemblyState.researchStatusView.pendingConfirmationLabel}
                </p>
              )
            }
            <p class="mt-2 text-xs text-zinc-500">
              Full sourcing and methodology live in{' '}
              <a
                href="#sources"
                class="text-zinc-300 underline underline-offset-2 hover:text-hunt-500"
              >
                Evidence and methodology
              </a>
              .
            </p>
          </div>
          <div class="mt-4">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-400">View</p>
            <div class="mt-2">
              <ReviewLensSwitch
                activeLens={activeReviewLens}
                hrefs={pageAssemblyState.lensHrefs}
                compact
                showNote={false}
              />
            </div>
          </div>
          <div class="mt-4 space-y-2">
            {
              pageAssemblyState.websiteState.hasWebsite && (
                <a
                  href={routeDataState.tool.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-outbound="vendor"
                  data-location="sidebar-cta"
                  data-tool={routeDataState.tool.slug}
                  class="inline-flex w-full items-center justify-center rounded-lg bg-hunt-600 px-3 py-2 text-sm font-semibold text-white hover:bg-hunt-700 transition"
                >
                  Visit {routeDataState.tool.name}
                </a>
              )
            }
            {
              routeDataState.hasAlternatives && (
                <a
                  href="#alternatives"
                  class="inline-flex w-full items-center justify-center rounded-lg border border-zinc-700 bg-zinc-800/70 px-3 py-2 text-sm font-medium text-zinc-200 hover:border-hunt-500 hover:text-hunt-400 transition"
                >
                  Compare alternatives
                </a>
              )
            }
          </div>
        </aside>
      </div>
    </header>

    <section
      class="mb-8 rounded-2xl border border-zinc-700 bg-gradient-to-br from-zinc-900 via-zinc-900 to-zinc-950 p-5 shadow-sm"
      data-focus-target
      data-focus-groups="all verdict"
    >
      <h2 class="text-lg font-semibold text-zinc-100">Best fit, main risk, and upgrade trigger</h2>
      <p class="mt-1 text-sm leading-relaxed text-zinc-300">
        {routeDataState.decisionSnapshotSummary || pageAssemblyState.verdictLabelRationale}
      </p>
      <p class="mt-2 text-xs text-zinc-500">
        Summary of linked sources as of {pageAssemblyState.freshnessLabels.verdictAsOfLabel}.
      </p>
      {
        pageAssemblyState.decisionUtilityState.hasDecisionBullets ? (
          <div class="mt-4 grid gap-3 md:grid-cols-2">
            {pageAssemblyState.decisionUtilityState.decisionUseIf && (
              <article class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Best for</p>
                <p class="mt-2 text-sm text-zinc-200">
                  {pageAssemblyState.decisionUtilityState.decisionUseIf}
                </p>
              </article>
            )}
            {pageAssemblyState.decisionUtilityState.decisionAvoidIf && (
              <article class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">Not for</p>
                <p class="mt-2 text-sm text-zinc-200">
                  {pageAssemblyState.decisionUtilityState.decisionAvoidIf}
                </p>
              </article>
            )}
            {pageAssemblyState.decisionUtilityState.decisionWatchOut && (
              <article class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">
                  Main tradeoff
                </p>
                <p class="mt-2 text-sm text-zinc-200">
                  {pageAssemblyState.decisionUtilityState.decisionWatchOut}
                  {pageAssemblyState.decisionHardLimitEvidence && (
                    <>
                      {' '}
                      <a
                        href={pageAssemblyState.decisionHardLimitEvidence.sourceUrl}
                        target="_blank"
                        rel="noopener"
                        aria-label={pageAssemblyState.sourceAriaLabel(
                          pageAssemblyState.decisionHardLimitEvidence.text
                        )}
                        data-outbound="source"
                        data-location="decision-watchout"
                        data-tool={routeDataState.tool.slug}
                        class="text-xs text-zinc-400 underline underline-offset-2 hover:text-hunt-500"
                        title="Open source"
                      >
                        Source
                      </a>
                    </>
                  )}
                </p>
              </article>
            )}
            {pageAssemblyState.decisionUtilityState.decisionUpgradeTrigger && (
              <article class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-zinc-500">
                  First serious upgrade trigger
                </p>
                <p class="mt-2 text-sm text-zinc-200">
                  {pageAssemblyState.decisionUtilityState.decisionUpgradeTrigger}
                </p>
              </article>
            )}
          </div>
        ) : (
          <p class="mt-3 text-sm text-zinc-400">
            Source-backed fit and tradeoff guidance is still being assembled for this review.
          </p>
        )
      }
      <p class="mt-4 text-xs text-zinc-500">
        Full evidence and methodology live in{' '}
        <a href="#verdict" class="text-hunt-500 hover:text-hunt-400"> Why This Verdict </a>
        {' '}and{' '}
        <a href="#sources" class="text-hunt-500 hover:text-hunt-400"> Evidence and methodology </a>
        .
      </p>
    </section>
    {
      pageAssemblyState.shouldShowDecisionUtilitySection && (
        <ToolDecisionUtilitySection
          checklistTitle={pageAssemblyState.decisionUtilityState.testChecklistTitle}
          checklistItems={pageAssemblyState.decisionUtilityState.testChecklistItems}
          commonSetupsTitle={pageAssemblyState.decisionUtilityState.commonSetupsTitle}
          commonSetups={pageAssemblyState.decisionUtilityState.commonSetups}
        />
      )
    }

    <!-- Main Content Grid -->
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="space-y-8 lg:col-span-2">
        {/* Our Verdict - Quick summary with key points */}
        {
          routeDataState.hasVerdict && (
            <section
              id="verdict"
              class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
              data-focus-target
              data-focus-groups="all verdict"
            >
              <h2 class="mb-2 text-lg font-semibold text-zinc-100">Why This Verdict</h2>
              <p class="text-sm text-zinc-300">
                {pageAssemblyState.decisionUtilityState.verdictLeadOverride}
              </p>
              <p class="text-sm text-zinc-400">
                As of {pageAssemblyState.freshnessLabels.verdictAsOfLabel}.
              </p>
              <div class="mt-4 rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                <div
                  class="prose prose-slate prose-sm max-w-none text-zinc-200 leading-7"
                  set:html={simpleMarkdown(pageAssemblyState.verdictContent.body)}
                />
              </div>
              {routeDataState.lensRankedHardLimits.length > 0 && (
                <div class="mt-4 rounded-lg border border-zinc-800 bg-zinc-950/40 p-4">
                  <h3 class="text-sm font-semibold text-zinc-200">Hard limits / dealbreakers</h3>
                  <ul class="mt-2 space-y-2 text-sm text-zinc-300">
                    {routeDataState.lensRankedHardLimits.slice(0, 4).map((item) => (
                      <li>
                        - {item.text}{' '}
                        <a
                          href={item.sourceUrl}
                          target="_blank"
                          rel="noopener"
                          aria-label={pageAssemblyState.sourceAriaLabel(item.text)}
                          data-outbound="source"
                          data-location="verdict-hard-limits"
                          data-tool={routeDataState.tool.slug}
                          class="text-xs text-zinc-500 underline underline-offset-2 hover:text-hunt-500"
                          title="Open source"
                        >
                          Source
                        </a>
                      </li>
                    ))}
                  </ul>
                </div>
              )}
              {pageAssemblyState.scoreDrivers.length > 0 && (
                <div class="mt-5">
                  <h3 class="text-sm font-semibold text-zinc-200">Recommendation drivers</h3>
                  <ul class="mt-2 space-y-1 text-sm text-zinc-300">
                    {pageAssemblyState.scoreDrivers.map((item) => (
                      <li>- {item}</li>
                    ))}
                  </ul>
                  <p class="mt-2 text-xs text-zinc-500">
                    Source detail is available in{' '}
                    <a
                      href="#sources"
                      class="text-zinc-400 underline underline-offset-2 hover:text-hunt-500"
                    >
                      Methodology and sources
                    </a>
                    .
                  </p>
                </div>
              )}
            </section>
          )
        }
        {routeDataState.showProceduralVerdict && <ToolDecisionConditionsSection />}
        {/* Pricing Plans */}
        {
          routeDataState.showPricingSection && (
            <details
              id="pricing-plans"
              class="group rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
              open={routeDataState.hasPricing}
              data-focus-target
              data-focus-groups="all pricing"
            >
              <summary class="flex items-center justify-between cursor-pointer">
                <div>
                  <h2 class="text-lg font-semibold text-zinc-100">
                    {routeDataState.tool.name} pricing, how seats work
                  </h2>
                  {pageAssemblyState.pricingSectionState.checkedLead && (
                    <p class="mt-1 text-xs text-zinc-500">
                      {pageAssemblyState.pricingSectionState.checkedLead}
                    </p>
                  )}
                  {activeReviewLens !== 'general' &&
                    routeDataState.activeLensPricingPlanCount !== null && (
                      <p class="mt-1 text-xs text-zinc-500">
                        Lens coverage, {pageAssemblyState.lensLabelMap[activeReviewLens]}:{' '}
                        {routeDataState.activeLensPricingPlanCount} plan
                        {routeDataState.activeLensPricingPlanCount === 1 ? '' : 's'} tagged.
                      </p>
                    )}
                  {activeReviewLens !== 'general' &&
                    routeDataState.activeLensConstraintCount !== null && (
                      <p class="mt-1 text-xs text-zinc-500">
                        Constraint coverage, {routeDataState.activeLensConstraintCount} limit
                        {routeDataState.activeLensConstraintCount === 1 ? '' : 's'} tagged for this
                        lens.
                      </p>
                    )}
                </div>
                <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
                  <span class="group-open:hidden">Expand</span>
                  <span class="hidden group-open:inline">Collapse</span>
                  <svg
                    class="h-4 w-4 transition-transform group-open:rotate-90"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </span>
              </summary>
              <div class="mt-4">
                <PricingInsights
                  variant="compact"
                  summaryLead={routeDataState.pricingNarrativeLead}
                  summaryLabel={routeDataState.pricingNarrativeLabel}
                  budgetAnalyst={pageAssemblyState.pricingInsightsBudgetAnalyst}
                  mentalModelItems={pageAssemblyState.decisionUtilityState.pricingMentalModelItems}
                  costModelExamples={pageAssemblyState.pricingScenarioState.examples}
                />
                {routeDataState.topLensHardLimit && (
                  <div class="mb-4 rounded-lg border border-zinc-800 bg-zinc-950/40 p-3">
                    <h3 class="text-xs font-semibold uppercase tracking-wide text-zinc-400">
                      {routeDataState.tool.name} free plan limits and hard constraints
                    </h3>
                    <p class="mt-2 text-xs text-zinc-300">
                      {routeDataState.topLensHardLimit.text}{' '}
                      <a
                        href={routeDataState.topLensHardLimit.sourceUrl}
                        target="_blank"
                        rel="noopener"
                        data-outbound="source"
                        data-location="pricing-hard-limit"
                        data-tool={routeDataState.tool.slug}
                        class="text-zinc-400 underline underline-offset-2 hover:text-hunt-500"
                      >
                        Source
                      </a>
                    </p>
                  </div>
                )}
                <p class="mb-4 text-xs text-zinc-500">{pageAssemblyState.pricingNotice}</p>
                {routeDataState.hasPricing ? (
                  <>
                    <PricingPlansGrid
                      legacy_pricing={routeDataState.knowledgeCard?.pricing}
                      smp_pricing={routeDataState.knowledgeCard?.smp_pricing}
                      toolName={routeDataState.tool.name}
                      activeReviewLens={activeReviewLens}
                    >
                      <PriceVerification
                        slot="verification"
                        client:visible
                        toolId={pageAssemblyState.priceVerificationProps.toolId}
                        toolName={pageAssemblyState.priceVerificationProps.toolName}
                        currentPrice={pageAssemblyState.priceVerificationProps.currentPrice}
                        pricingType={pageAssemblyState.priceVerificationProps.pricingType}
                        verificationCount={
                          pageAssemblyState.priceVerificationProps.verificationCount
                        }
                        variant={pageAssemblyState.priceVerificationProps.variant}
                      />
                    </PricingPlansGrid>
                  </>
                ) : (
                  <div class="space-y-3 rounded-lg border border-zinc-800 bg-zinc-950/40 p-4 text-sm text-zinc-300">
                    <p class="font-medium text-zinc-100">Structured pricing is incomplete.</p>
                    <p>
                      We found pricing references, but not enough source-backed plan detail to
                      publish a reliable numeric table yet.
                    </p>
                    {pageAssemblyState.pricingEvidenceState.hasEvidencePanel && (
                      <details class="rounded-lg border border-zinc-800 bg-zinc-900/70 p-3">
                        <summary class="cursor-pointer text-xs font-semibold uppercase tracking-wide text-zinc-400">
                          Pricing source references
                        </summary>
                        <ul class="mt-2 space-y-1 text-xs text-zinc-300">
                          {routeDataState.officialPricingSource && (
                            <li>
                              -{' '}
                              <a
                                href={routeDataState.officialPricingSource.url}
                                target="_blank"
                                rel="noopener"
