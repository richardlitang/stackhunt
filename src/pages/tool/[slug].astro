---
/**
 * Tool Detail Page - /tool/[slug] (singular)
 * Software tools only (type='tool')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ScoreBadge from '@/components/ScoreBadge.astro';
import PricingBadge from '@/components/PricingBadge.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import SentimentTags from '@/components/SentimentTags.astro';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import VideoEmbed from '@/components/VideoEmbed';
import AlternativeCard from '@/components/AlternativeCard.astro';
import CompanyInfo from '@/components/CompanyInfo.astro';
import SecurityCompliance from '@/components/SecurityCompliance.astro';
import SupportOptions from '@/components/SupportOptions.astro';
import PortabilityCard from '@/components/PortabilityCard.astro';
import PlatformIntegrations from '@/components/PlatformIntegrations.astro';
import FeaturesShowcase from '@/components/FeaturesShowcase.astro';
import GettingStarted from '@/components/GettingStarted.astro';
import PricingPlansGrid from '@/components/PricingPlansGrid.astro';
import VerifiedBadge from '@/components/VerifiedBadge.astro';
import PricingInsights from '@/components/PricingInsights.astro';
import TribalKnowledge from '@/components/TribalKnowledge.astro';
import TrustSignals from '@/components/TrustSignals.astro';
import HiddenCeiling from '@/components/HiddenCeiling.astro';
import PriceVerification from '@/components/PriceVerification';
import SuiteNavigation from '@/components/SuiteNavigation.astro';
import DynamicSpecs from '@/components/DynamicSpecs.astro';
import IncludedTools from '@/components/IncludedTools.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import SignalReportWidget from '@/components/SignalReportWidget';
import type { KnowledgeCard, ToolConstraints } from '@/lib/knowledge-card';
import { computeMicroDiffs } from '@/lib/analysis/micro-diff';
import { areToolsComparable } from '@/lib/analysis/comparator';
import { getToolBySlugAndType, getToolContexts, getToolTags, supabase } from '@/lib/supabase';
import {
  generateToolMeta,
  generateToolSchema,
  generateBreadcrumbSchema,
  generateVideoSchema,
  generateToolFAQSchema,
} from '@/lib/seo';
import { getCanonicalUrl, simpleMarkdown } from '@/lib/utils';
import { getAlternatives } from '@/lib/analysis/alternatives';
import { evaluateContentConfidence, getConfidenceLevel } from '@/lib/confidence';
import { evaluateIndexReadiness } from '@/lib/quality-gate';

// SSR: Compute live, cache at edge (s-maxage=3600, stale-while-revalidate=604800)
export const prerender = false;

const { slug } = Astro.params;
const tool = await getToolBySlugAndType(slug, 'tool');

if (!tool) {
  return Astro.redirect('/404');
}

// Fetch parent tool info if this tool is part of a suite
let parentTool = null;
if (tool.parent_id) {
  const { data } = await supabase
    .from('items')
    .select('id, name, slug')
    .eq('id', tool.parent_id)
    .single();
  parentTool = data;
}

const _contextLinks = await getToolContexts(tool.id);
const tags = await getToolTags(tool.id);

// Build related links for internal linking (SEO)
const relatedLinks: Array<{
  href: string;
  title: string;
  description?: string;
  icon: 'category' | 'list' | 'tool' | 'compare';
}> = [];

// Add category link
if (tool.category) {
  relatedLinks.push({
    href: `/categories/${tool.category.slug}`,
    title: tool.category.name,
    description: `Browse all ${tool.category.name.toLowerCase()} tools`,
    icon: 'category',
  });
}
const primaryOffer = tool.affiliate_offers?.find((o) => o.is_primary) || tool.affiliate_offers?.[0];
const publishedReviews = (tool.reviews || []).filter((review) => review.status === 'published');
const firstReview = publishedReviews[0] || null;

// Extract Knowledge Card data for new components
const knowledgeCard = tool.metadata as KnowledgeCard | null;
const toolSpecs = tool.specs as Record<string, unknown> | null;
const globalPros = Array.isArray(toolSpecs?.pros) ? toolSpecs?.pros : [];
const globalCons = Array.isArray(toolSpecs?.cons) ? toolSpecs?.cons : [];
const constraints = toolSpecs?.constraints as ToolConstraints | null;
const canonicalFacts = toolSpecs?.canonical as Record<string, unknown> | undefined;
const setupTracks = canonicalFacts?.setup_tracks as
  | { dev?: Array<Record<string, unknown>>; non_dev?: Array<Record<string, unknown>> }
  | undefined;
// V4: Smart Schema - Category-specific and VIP tool-specific data
const categorySpecificData = toolSpecs?.categorySpecificData as Record<string, unknown> | undefined;
const canonicalLatestModels = Array.isArray(canonicalFacts?.latest_models_comparison)
  ? canonicalFacts.latest_models_comparison.filter((entry): entry is string => typeof entry === 'string')
  : [];
const displayCategorySpecificData =
  categorySpecificData && canonicalLatestModels.length > 0
    ? { ...categorySpecificData, model_options: canonicalLatestModels }
    : categorySpecificData;
const vipSpecifics = toolSpecs?.specifics as Record<string, unknown> | undefined;
const reviewContext = tool.review_context as Record<string, unknown> | null;
const userAdvocate = (reviewContext?.userAdvocate || reviewContext?.user_advocate) as Record<
  string,
  unknown
> | null;
const budgetAnalyst = (reviewContext?.budgetAnalyst || reviewContext?.budget_analyst) as Record<
  string,
  unknown
> | null;
const humanVerdict = (reviewContext?.humanVerdict || reviewContext?.human_verdict) as string | null;
const delighters = Array.isArray(userAdvocate?.delighters) ? userAdvocate?.delighters : [];
const frustrations = Array.isArray(userAdvocate?.frustrations) ? userAdvocate?.frustrations : [];
const powerTip = (userAdvocate?.powerTip || userAdvocate?.power_tip) as string | null;
const vibe = userAdvocate?.vibe as string | null;
const originStory = (userAdvocate?.originStory || userAdvocate?.origin_story) as string | null;
const idealFor = Array.isArray(userAdvocate?.idealFor || userAdvocate?.ideal_for)
  ? userAdvocate?.idealFor || userAdvocate?.ideal_for
  : [];
const avoidIf = Array.isArray(userAdvocate?.avoidIf || userAdvocate?.avoid_if)
  ? userAdvocate?.avoidIf || userAdvocate?.avoid_if
  : [];

// Fetch alternatives using hybrid search (vector similarity + category guardrails)
// Strategy: Compute live, cache at edge - no DB storage of computed relationships
const alternativesResponse = await getAlternatives(tool, { matchThreshold: 0.4, matchCount: 6 });
const alternativeIds = alternativesResponse.items.map((a) => a.id);

// Fetch full data for alternatives (needed for micro-diffs, display, and comparison validation)
const { data: alternatives } =
  alternativeIds.length > 0
    ? await supabase
        .from('items')
        .select(
          `
          id, name, slug, logo_url, short_description, avg_score, pricing_type, learning_curve,
          base_score, specs, metadata,
          item_category_links(
            relevance_score,
            category:categories(id, slug, name)
          )
        `
        )
        .in('id', alternativeIds)
        .eq('type', 'tool')
    : { data: [] };

// Preserve similarity order from hybrid search
const orderedAlternatives = alternatives
  ? alternativeIds.map((id) => alternatives.find((a) => a.id === id)).filter(Boolean)
  : [];

// Track whether these are true "alternatives" or just "related tools"
const alternativesLabel =
  alternativesResponse.type === 'alternatives' ? 'Alternatives' : 'Related Tools';

// Compute micro-diffs for alternatives (Layer 2 - Computed)
const microDiffs = orderedAlternatives?.length
  ? computeMicroDiffs(
      {
        slug: tool.slug,
        name: tool.name,
        pricing_type: tool.pricing_type,
        learning_curve: tool.learning_curve,
        base_score: tool.base_score,
        specs: tool.specs,
      },
      orderedAlternatives.map((alt) => ({
        slug: alt.slug,
        name: alt.name,
        pricing_type: alt.pricing_type,
        learning_curve: alt.learning_curve,
        base_score: alt.base_score,
        specs: alt.specs,
      }))
    )
  : new Map();

// Fetch curated verdicts for alternatives (Layer 1 - Human Intelligence)
const altSlugs = orderedAlternatives?.map((a) => a.slug) || [];
const curatedVerdicts = new Map<string, string>();

if (altSlugs.length > 0) {
  // Query comparison_insights where either slug is our tool
  const { data: insights } = await supabase
    .from('comparison_insights')
    .select('item_a_slug, item_b_slug, verdict')
    .or(`item_a_slug.eq.${tool.slug},item_b_slug.eq.${tool.slug}`)
    .not('verdict', 'is', null);

  for (const insight of insights || []) {
    // Determine which slug is the alternative
    const altSlug = insight.item_a_slug === tool.slug ? insight.item_b_slug : insight.item_a_slug;
    if (altSlugs.includes(altSlug) && insight.verdict) {
      curatedVerdicts.set(altSlug, insight.verdict);
    }
  }
}

const getPrimaryCategoryId = (item: any) =>
  item?.category?.id || item?.item_category_links?.[0]?.category?.id || null;

const sourceDomains = firstReview?.sources
  ? [
      ...new Set(
        (firstReview.sources as Array<{ domain?: string; url?: string }>)
          .map((s) => {
            const rawDomain =
              s.domain ||
              (() => {
                if (!s.url) return '';
                try {
                  return new URL(s.url).hostname.replace(/^www\./, '');
                } catch {
                  return '';
                }
              })();
            if (!rawDomain) return '';
            const domain = rawDomain.replace(/\.(com|org|net|io|co)$/, '');
            return domain.charAt(0).toUpperCase() + domain.slice(1);
          })
          .filter(Boolean)
      ),
    ].slice(0, 5)
  : [];
const sourceEvidenceDomains = new Set(
  firstReview?.sources
    ? (firstReview.sources as Array<{ domain?: string; url?: string }>)
        .map((source) => {
          if (source.domain) return source.domain.replace(/^www\./, '').toLowerCase();
          if (!source.url) return null;
          try {
            return new URL(source.url).hostname.replace(/^www\./, '').toLowerCase();
          } catch {
            return null;
          }
        })
        .filter((domain): domain is string => Boolean(domain))
    : []
);
const isEligibleEvidenceUrl = (url?: string | null): boolean => {
  if (!url) return false;
  try {
    const hostname = new URL(url).hostname.replace(/^www\./, '').toLowerCase();
    return (
      !hostname.includes('reddit.com') &&
      !hostname.includes('ycombinator.com') &&
      !hostname.includes('g2.com') &&
      !hostname.includes('capterra.com') &&
      !hostname.includes('trustpilot.com') &&
      !hostname.includes('stackexchange.com') &&
      !hostname.includes('stackoverflow.com')
    );
  } catch {
    return false;
  }
};
const getEvidenceDomain = (url: string): string => {
  try {
    return new URL(url).hostname.replace(/^www\./, '').toLowerCase();
  } catch {
    return '';
  }
};
type EvidenceBullet = { text: string; sourceUrl: string };
const toEvidenceBullet = (claim: unknown): EvidenceBullet | null => {
  if (!claim || typeof claim !== 'object') return null;
  const value = claim as Record<string, unknown>;
  const text = typeof value.text === 'string' ? value.text.trim() : '';
  const sourceUrl = typeof value.source_url === 'string' ? value.source_url.trim() : '';
  if (!text || !sourceUrl || !isEligibleEvidenceUrl(sourceUrl)) return null;
  return { text, sourceUrl };
};
const BLOCKED_EVIDENCE_DOMAINS = new Set([
  'g2.com',
  'capterra.com',
  'trustpilot.com',
  'reddit.com',
  'old.reddit.com',
  'm.reddit.com',
]);
const eligibleSignalEvidenceCount = Array.from(sourceEvidenceDomains).filter(
  (domain) =>
    !Array.from(BLOCKED_EVIDENCE_DOMAINS).some(
      (blockedDomain) => domain === blockedDomain || domain.endsWith(`.${blockedDomain}`)
    )
).length;

// SEO: quality/index gate (with confidence retained for trust signal display)
const confidence = evaluateContentConfidence(tool, firstReview);
const contentConfidenceLevel = getConfidenceLevel(confidence.score);
const indexReadiness = evaluateIndexReadiness(tool, firstReview);
const persistedQuality =
  (canonicalFacts?.quality as
    | {
        should_index?: boolean;
        noindex_reasons?: string[];
        section_publishability?: Record<string, boolean>;
        section_status?: Record<string, 'show' | 'hide' | 'procedural'>;
        evidence_counts?: Record<string, number>;
      }
    | undefined) || undefined;
const sectionPublishability = {
  ...indexReadiness.signals.section_publishability,
  ...(persistedQuality?.section_publishability || {}),
};
const sectionStatus = {
  ...indexReadiness.signals.section_status,
  ...(persistedQuality?.section_status || {}),
};
const evidenceCounts = {
  ...indexReadiness.signals.evidence_counts,
  ...(persistedQuality?.evidence_counts || {}),
};
const hasDraftReview = (tool.reviews || []).some((review) => review.status === 'draft');
const isDraftPage = publishedReviews.length === 0 && hasDraftReview;

const VOLATILE_FAQ_TERMS =
  /\b(model|version|pricing|price|plan|quota|limit|token|tokens|rate limit|context window|deprecated|deprecation|gpt|claude|opus|sonnet|haiku|o[1-9])\b/i;
const filteredFaqItems = (Array.isArray(knowledgeCard?.faqs) ? knowledgeCard.faqs : []).filter((item) => {
  if (!item?.question || !item?.answer) return false;
  if (!item.answer_source_url) return false;
  if (VOLATILE_FAQ_TERMS.test(`${item.question} ${item.answer}`) && item.answer_source_type !== 'official') {
    return false;
  }
  return true;
});
const knowledgeCardForSeo =
  knowledgeCard && filteredFaqItems.length !== (knowledgeCard.faqs?.length || 0)
    ? { ...knowledgeCard, faqs: filteredFaqItems }
    : knowledgeCard;
const faqItems = filteredFaqItems;
const hasFAQ = faqItems.length > 0 && sectionPublishability.faq;
const faqSchema = hasFAQ ? generateToolFAQSchema(tool, knowledgeCardForSeo) : null;

const gateShouldIndex =
  typeof persistedQuality?.should_index === 'boolean'
    ? persistedQuality.should_index
    : indexReadiness.shouldIndex;
const gateReasons =
  Array.isArray(persistedQuality?.noindex_reasons) && persistedQuality.noindex_reasons.length > 0
    ? persistedQuality.noindex_reasons
    : indexReadiness.reasons;
const shouldNoindex = !gateShouldIndex || isDraftPage;
const safeDraftDescription = `${tool.name} is currently in editorial verification. This page is not finalized yet.`;
const NEGATIVE_CLAIM_GUARD =
  /\b(no|not|lacks|lack|cannot|can't|won't|avoid|veto|problem|risk|limit|limited|slow|expensive|broken|fails|failure)\b/i;
const hasEligibleNegativeEvidence = eligibleSignalEvidenceCount >= 2;
const guardedVerdict = firstReview?.summary_markdown
  ? !NEGATIVE_CLAIM_GUARD.test(firstReview.summary_markdown) || hasEligibleNegativeEvidence
    ? firstReview.summary_markdown
    : null
  : null;
const guardedHumanVerdict =
  humanVerdict && (!NEGATIVE_CLAIM_GUARD.test(humanVerdict) || hasEligibleNegativeEvidence)
    ? humanVerdict
    : null;
const guardedToolVerdict =
  tool.verdict && (!NEGATIVE_CLAIM_GUARD.test(tool.verdict) || hasEligibleNegativeEvidence)
    ? tool.verdict
    : null;
const renderVerdict = guardedVerdict || guardedToolVerdict || guardedHumanVerdict;
const guardedAvoidIf = hasEligibleNegativeEvidence ? avoidIf : [];

const toolMeta = generateToolMeta(tool, tool.review_count);
const meta = {
  ...toolMeta,
  description: shouldNoindex ? safeDraftDescription : toolMeta.description,
  canonical: shouldNoindex ? getCanonicalUrl('/tools') : toolMeta.canonical,
  noindex: shouldNoindex,
};
Astro.response.headers.set('X-Robots-Tag', meta.noindex ? 'noindex,nofollow' : 'index,follow');
const schemas = [
  generateToolSchema(tool, primaryOffer, tool.review_count),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools' },
    ...(tool.category
      ? [{ name: tool.category.name, url: `/categories/${tool.category.slug}` }]
      : []),
    { name: tool.name, url: `/tool/${tool.slug}` },
  ]),
  // Include VideoObject schema if video exists
  ...(tool.video_id
    ? [generateVideoSchema(tool, tool.video_id, tool.video_title || `${tool.name} Overview`)]
    : []),
  // Include FAQ schema for common questions
  ...(faqSchema ? [faqSchema] : []),
];

const _turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const hasAbout = (() => {
  const longDescription =
    typeof tool.long_description === 'string' ? tool.long_description.trim() : '';
  if (!longDescription) return false;
  const shortDescription =
    typeof tool.short_description === 'string' ? tool.short_description.trim() : '';
  const normalize = (value: string) => value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
  return normalize(longDescription) !== normalize(shortDescription);
})();
const hasVerdict = Boolean(renderVerdict && sectionStatus.verdict === 'show');
const hasStrengths = Boolean(
  globalPros.length > 0 ||
  globalCons.length > 0 ||
  (firstReview && (firstReview.pros?.length > 0 || firstReview.cons?.length > 0))
);
const hasFeatures = Boolean(
  knowledgeCard?.features?.core?.length > 0 || knowledgeCard?.features?.unique?.length > 0
);
const hasGettingStarted = Boolean(
  knowledgeCard?.setup_complexity ||
    (Array.isArray(setupTracks?.non_dev) && setupTracks.non_dev.length > 0) ||
    (Array.isArray(setupTracks?.dev) && setupTracks.dev.length > 0)
);
const hasSpecs = Boolean((categorySpecificData || vipSpecifics) && sectionStatus.specs === 'show');
const hasMeaningfulPricingPlanName = (name?: string): boolean => {
  if (!name || !name.trim()) return false;
  const normalized = name.trim().toLowerCase();
  if (/^plan\s+\d+$/i.test(normalized)) return false;
  if (/^product\s+\d+$/i.test(normalized)) return false;
  return true;
};
const hasRenderableSmpPlans = Boolean(
  knowledgeCard?.smp_pricing?.plans?.some((plan) => hasMeaningfulPricingPlanName((plan as any)?.name))
);
const hasPricing = Boolean(
  ((hasRenderableSmpPlans || knowledgeCard?.pricing?.tiers?.length > 0) && sectionStatus.pricing === 'show')
);
const hasPlatform = Boolean(knowledgeCard?.platforms?.length > 0 || knowledgeCard?.integrations);
const hasVideo = Boolean(tool.video_id);
const hasAlternatives = Boolean(orderedAlternatives && orderedAlternatives.length > 0);
const hasCommunity = Boolean(eligibleSignalEvidenceCount >= 3 && sectionStatus.community === 'show');
const showProceduralVerdict = sectionStatus.verdict === 'procedural' && !hasVerdict;
const showProceduralPricing = sectionStatus.pricing === 'procedural' && !hasPricing;
const showProceduralSpecs = sectionStatus.specs === 'procedural' && !hasSpecs;
const showProceduralCommunity = sectionStatus.community === 'procedural' && !hasCommunity;
const taxonomyPrimary =
  typeof knowledgeCard?.smp_taxonomy?.primary_function === 'string'
    ? knowledgeCard.smp_taxonomy.primary_function.toLowerCase()
    : '';
const categoryHint = `${tool.category?.slug || ''} ${taxonomyPrimary}`.toLowerCase();
const isPaymentsCategory =
  /\b(payment|payments|bank|banking|finance|accounting|treasury|billing)\b/.test(categoryHint);
const extractClaimText = (claim: unknown): string => {
  if (typeof claim === 'string') return claim.trim();
  if (claim && typeof claim === 'object' && typeof (claim as Record<string, unknown>).text === 'string') {
    return ((claim as Record<string, unknown>).text as string).trim();
  }
  return '';
};
const fallbackConsText = (Array.isArray(globalCons) ? globalCons : [])
  .map(extractClaimText)
  .filter((text) => text.length > 0);
const paymentTriggerCons = fallbackConsText.filter((text) =>
  /\b(fee|fees|fx|foreign exchange|gateway|merchant|kyb|kyc|verification|card|transfer|settlement)\b/i.test(
    text
  )
);

const decisionSnapshotWhatItIs =
  tool.short_description || knowledgeCard?.tagline || `Editorial analysis for ${tool.name}.`;
const decisionSnapshotBestFit = (
  idealFor.length > 0
    ? idealFor
    : tags.audiences.length > 0
      ? tags.audiences.map((tag) => tag.name)
      : (firstReview?.pros || [])
).slice(0, 3);
const decisionSnapshotTriggers =
  guardedAvoidIf.length > 0
    ? guardedAvoidIf.slice(0, 2)
    : isPaymentsCategory && paymentTriggerCons.length > 0
      ? paymentTriggerCons.slice(0, 2).map((con) => `Avoid if ${con}`)
      : fallbackConsText.length > 0
        ? fallbackConsText.slice(0, 2).map((con) => `Avoid if ${con}`)
        : (firstReview?.cons || []).slice(0, 2).map((con) => `Avoid if ${con}`);
const implementationSurface =
  knowledgeCard?.setup_complexity?.estimated_setup_time ||
  (tool.learning_curve ? `${tool.learning_curve} learning curve` : null) ||
  'Varies by workflow depth';
const verificationChecklist = [
  'Validate pricing drivers with your expected monthly usage.',
  'Run one production-like workflow and record failure points.',
  'Confirm required integrations, export paths, and API limits.',
  'Check security and compliance docs against your procurement checklist.',
];
const evidenceLinks = (firstReview?.sources || [])
  .map((source) => {
    const url = typeof source?.url === 'string' ? source.url : null;
    if (!url) return null;
    let hostname = '';
    try {
      hostname = new URL(url).hostname.replace(/^www\./, '').toLowerCase();
    } catch {
      return null;
    }
    const path = (() => {
      try {
        return new URL(url).pathname.toLowerCase();
      } catch {
        return '';
      }
    })();
    const blocked =
      hostname.includes('reddit.com') ||
      hostname.includes('ycombinator.com') ||
      hostname.includes('g2.com') ||
      hostname.includes('capterra.com') ||
      hostname.includes('trustpilot.com') ||
      hostname.includes('stackexchange.com') ||
      hostname.includes('stackoverflow.com');
    if (blocked) return null;
    const basis =
      hostname.includes('github.com') && path.includes('/issues')
        ? 'GitHub issues'
        : hostname.startsWith('status.') || path.includes('/status')
          ? 'Status page'
          : path.includes('/changelog') || path.includes('/release') || path.includes('/updates')
            ? 'Changelog'
            : path.includes('/docs') || path.includes('/help') || path.includes('/developer')
              ? 'Docs'
              : 'Independent writeups';
    return {
      url,
      title:
        typeof source?.title === 'string' && source.title.trim().length > 0
          ? source.title
          : hostname,
      domain: hostname,
      basis,
    };
  })
  .filter((entry): entry is { url: string; title: string; domain: string; basis: string } => Boolean(entry));
const evidenceBasis = ['Docs', 'Changelog', 'Status page', 'GitHub issues', 'Independent writeups']
  .map((label) => {
    const domains = new Set(
      evidenceLinks.filter((entry) => entry.basis === label).map((entry) => entry.domain)
    );
    return { label, count: domains.size };
  })
  .filter((entry) => entry.count > 0);
const formatVerifiedDate = (value?: string | null): string | null => {
  if (!value) return null;
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return null;
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
const pricingVerifiedLabel = formatVerifiedDate(tool.pricing_verified_at || tool.last_verified_at);
const specsVerifiedLabel = formatVerifiedDate(
  (knowledgeCard?.meta?.extraction_date as string | undefined) || tool.last_verified_at
);
const communityVerifiedLabel = formatVerifiedDate(
  ((firstReview as any)?.updated_at as string | undefined) ||
    ((firstReview as any)?.created_at as string | undefined) ||
    tool.last_verified_at
);
const contextualEvidenceCons = (Array.isArray(firstReview?.cons) ? firstReview.cons : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const globalEvidenceCons = (Array.isArray(globalCons) ? globalCons : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const effectiveEvidenceCons =
  contextualEvidenceCons.length > 0 ? contextualEvidenceCons : globalEvidenceCons;
const hiddenCostBullets = Array.isArray(constraints?.hidden_costs)
  ? constraints.hidden_costs
      .map((cost: any) => {
        const sourceUrl = typeof cost?.source_url === 'string' ? cost.source_url.trim() : '';
        if (!isEligibleEvidenceUrl(sourceUrl)) return null;
        const name = typeof cost?.name === 'string' ? cost.name.trim() : 'Hidden cost';
        const amount = typeof cost?.amount === 'string' ? ` (${cost.amount})` : '';
        const whenCharged = typeof cost?.when_charged === 'string' ? ` — ${cost.when_charged}` : '';
        return { text: `${name}${amount}${whenCharged}`, sourceUrl } as EvidenceBullet;
      })
      .filter((item): item is EvidenceBullet => Boolean(item))
  : [];
const hardLimitFromConstraints = Array.isArray(constraints?.hard_limits)
  ? constraints.hard_limits
      .map((limit: any) => {
        const sourceUrl = typeof limit?.source_url === 'string' ? limit.source_url : '';
        if (!isEligibleEvidenceUrl(sourceUrl)) return null;
        const metric = typeof limit?.metric === 'string' ? limit.metric.replace(/_/g, ' ') : 'Limit';
        const value =
          typeof limit?.value === 'number' || typeof limit?.value === 'string' ? String(limit.value) : '';
        const unit = typeof limit?.unit === 'string' ? ` ${limit.unit}` : '';
        const plan = typeof limit?.plan_name_match === 'string' ? ` (${limit.plan_name_match})` : '';
        const text = `${metric}: ${value}${unit}${plan}`.trim();
        if (!text || text === 'Limit:') return null;
        return { text, sourceUrl } as EvidenceBullet;
      })
      .filter((item): item is EvidenceBullet => Boolean(item))
  : [];
const withUniqueText = (items: EvidenceBullet[]): EvidenceBullet[] => {
  const seen = new Set<string>();
  return items.filter((item) => {
    const key = item.text.toLowerCase();
    if (seen.has(key)) return false;
    seen.add(key);
    return true;
  });
};
const hardLimitBullets = withUniqueText(
  [
    ...hardLimitFromConstraints,
    ...effectiveEvidenceCons.filter((item) =>
      /\b(limit|limited|quota|cap|hard stop|ceiling|overage|maximum|max)\b/i.test(item.text)
    ),
    ...hiddenCostBullets.filter((item) => /\b(setup fee|one-time|activation)\b/i.test(item.text)),
  ].slice(0, 6)
);
const notIncludedBullets = withUniqueText(
  [...effectiveEvidenceCons, ...hiddenCostBullets]
    .filter((item) =>
      /\b(no\b|not\b|without|lacks|lack|requires integration|not included|missing|merchant gateway|separate fee|one-time fee)\b/i.test(
        item.text
      )
    )
    .slice(0, 6)
);
const trialNotesBullets = withUniqueText(
  [...effectiveEvidenceCons, ...hiddenCostBullets]
    .filter((item) =>
      /\b(users report|teams report|can become|workflow|operational|maintenance|manual|overhead|stale|governance|friction)\b/i.test(
        item.text
      )
    )
    .slice(0, 6)
);
const hasOperationalFit = Boolean(firstReview || constraints);
