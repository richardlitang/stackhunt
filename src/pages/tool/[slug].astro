---
/**
 * Tool Detail Page - /tool/[slug] (singular)
 * Software tools only (type='tool')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import VideoEmbed from '@/components/VideoEmbed';
import AlternativeCard from '@/components/AlternativeCard.astro';
import CompanyInfo from '@/components/CompanyInfo.astro';
import SecurityCompliance from '@/components/SecurityCompliance.astro';
import SupportOptions from '@/components/SupportOptions.astro';
import PortabilityCard from '@/components/PortabilityCard.astro';
import PlatformIntegrations from '@/components/PlatformIntegrations.astro';
import FeaturesShowcase from '@/components/FeaturesShowcase.astro';
import GettingStarted from '@/components/GettingStarted.astro';
import PricingPlansGrid from '@/components/PricingPlansGrid.astro';
import PricingInsights from '@/components/PricingInsights.astro';
import ReviewFocusSwitch from '@/components/ReviewFocusSwitch.astro';
import ReviewLensSwitch from '@/components/ReviewLensSwitch.astro';
import TribalKnowledge from '@/components/TribalKnowledge.astro';
import TrustBar from '@/components/TrustBar.astro';
import PriceVerification from '@/components/PriceVerification';
import SuiteNavigation from '@/components/SuiteNavigation.astro';
import DynamicSpecs from '@/components/DynamicSpecs.astro';
import IncludedTools from '@/components/IncludedTools.astro';
import SignalReportWidget from '@/components/SignalReportWidget';
import type { KnowledgeCard, ToolConstraints } from '@/lib/knowledge-card';
import { computeMicroDiffs } from '@/lib/analysis/micro-diff';
import { getToolBySlugAndType, getToolContexts, getToolTags, supabase } from '@/lib/supabase';
import {
  generateToolMeta,
  generateToolSchema,
  generateBreadcrumbSchema,
  generateVideoSchema,
  generateToolFAQSchema,
} from '@/lib/seo';
import { formatPricingType, getCanonicalUrl, simpleMarkdown } from '@/lib/utils';
import { getAlternatives } from '@/lib/analysis/alternatives';
import { evaluateContentConfidence, getConfidenceLevel } from '@/lib/confidence';
import { evaluateIndexReadiness } from '@/lib/quality-gate';
import { evaluateStrictPublishGate } from '@/lib/review-publish-gate';
import { evaluateToolPageQaGate } from '@/lib/tool-page-qa-gate';
import { evaluateToolPageIndexPolicy } from '@/lib/tool-page-index-policy';
import {
  buildToolPagePricingViewModel,
  deriveToolPagePricingSignals,
} from '@/lib/tool-page-pricing';
import { buildToolPageEvaluationViewModel } from '@/lib/tool-page-evaluation';
import { buildToolPageSourcesViewModel } from '@/lib/tool-page-sources';
import { buildToolPageDecisionSnapshot } from '@/lib/tool-page-decision';
import { deriveToolPageBaseEvidenceGrade } from '@/lib/tool-page-evidence-grade';
import { deriveToolPageCanonicalHardLimits } from '@/lib/tool-page-constraints';
import { buildToolPageEvidenceLinks } from '@/lib/tool-page-evidence-links';
import {
  buildToolPageEvidenceBulletV2,
  toToolPageEvidenceBullet,
  type ToolPageEvidenceBullet as EvidenceBullet,
  type ToolPageEvidenceBulletV2 as EvidenceBulletV2,
} from '@/lib/tool-page-evidence-bullets';
import { evaluateToolPageProvisionalIndexEligibility } from '@/lib/tool-page-provisional-index';
import {
  cleanToolPageDecisionSlotText,
  cleanToolPageNarrativeText,
  extractToolPageClaimText,
  stripToolPageControlChars,
  uniqueToolPageDecisionText,
} from '@/lib/tool-page-text';
import {
  buildToolPageSourceAriaLabel,
} from '@/lib/tool-page-source-labels';
import {
  countEligibleEvidenceDomains,
  isEligibleEvidenceUrl,
} from '@/lib/tool-page-evidence-policy';
import { selectToolPageReview } from '@/lib/reviews/select-review';
import { deriveToolPageSetupSignals } from '@/lib/tool-page-setup';
import { deriveToolPageSectionSignals } from '@/lib/tool-page-section-signals';
import { buildToolPageSectionState } from '@/lib/tool-page-section-state';
import { buildToolPageAlternativesState } from '@/lib/tool-page-alternatives-state';
import { deriveToolPageVerdictPolicy } from '@/lib/tool-page-verdict-policy';
import { buildToolPageLensRuntime } from '@/lib/tool-page-lens-runtime';
import { deriveToolPageReviewSignals } from '@/lib/tool-page-review-signals';
import { buildToolPageTrustRuntime } from '@/lib/tool-page-trust-runtime';

// SSR: Compute live, cache at edge (s-maxage=3600, stale-while-revalidate=604800)
export const prerender = false;

const { slug } = Astro.params;
type ReviewLens = 'general' | 'personal' | 'startup' | 'enterprise';
const REVIEW_LENSES: ReadonlyArray<ReviewLens> = ['general', 'personal', 'startup', 'enterprise'];
const lensParam = (Astro.url.searchParams.get('lens') || '').toLowerCase();
const activeReviewLens: ReviewLens = REVIEW_LENSES.includes(lensParam as ReviewLens)
  ? (lensParam as ReviewLens)
  : 'general';
const hasVersionBypassParam = Astro.url.searchParams.has('v');
if (hasVersionBypassParam) {
  // Cache-bust requests like ?v=34 should always skip CDN/page cache.
  const noStore = 'no-store, max-age=0';
  Astro.response.headers.set('Cache-Control', noStore);
  Astro.response.headers.set('CDN-Cache-Control', noStore);
  Astro.response.headers.set('Vercel-CDN-Cache-Control', noStore);
}

const tool = await getToolBySlugAndType(slug, 'tool');

if (!tool) {
  return Astro.redirect('/404');
}

// Fetch parent tool info if this tool is part of a suite
let parentTool = null;
if (tool.parent_id) {
  const { data } = await supabase
    .from('items')
    .select('id, name, slug')
    .eq('id', tool.parent_id)
    .single();
  parentTool = data;
}

const _contextLinks = await getToolContexts(tool.id);
const tags = await getToolTags(tool.id);

const primaryOffer = tool.affiliate_offers?.find((o) => o.is_primary) || tool.affiliate_offers?.[0];
const reviews = Array.isArray(tool.reviews) ? tool.reviews : [];
const reviewSelection = selectToolPageReview(reviews);
const firstReview = reviewSelection.firstPublished;
const hasNewerUnpublishedReview = reviewSelection.hasNewerUnpublishedThanPublished;

// Extract Knowledge Card data for new components
const knowledgeCard = tool.metadata as KnowledgeCard | null;
const toolSpecs = tool.specs as Record<string, unknown> | null;
const globalPros = Array.isArray(toolSpecs?.pros) ? toolSpecs?.pros : [];
const globalCons = Array.isArray(toolSpecs?.cons) ? toolSpecs?.cons : [];
const constraints = toolSpecs?.constraints as ToolConstraints | null;
const canonicalFacts = toolSpecs?.canonical as Record<string, unknown> | undefined;
const setupTracks = canonicalFacts?.setup_tracks as
  | { dev?: Array<Record<string, unknown>>; non_dev?: Array<Record<string, unknown>> }
  | undefined;
// V4: Smart Schema - Category-specific and VIP tool-specific data
const categorySpecificData = toolSpecs?.categorySpecificData as Record<string, unknown> | undefined;
const canonicalLatestModels = Array.isArray(canonicalFacts?.latest_models_comparison)
  ? canonicalFacts.latest_models_comparison.filter(
      (entry): entry is string => typeof entry === 'string'
    )
  : [];
const displayCategorySpecificData =
  categorySpecificData && canonicalLatestModels.length > 0
    ? {
        ...categorySpecificData,
        latest_model: canonicalLatestModels[0],
        model_options: canonicalLatestModels,
      }
    : categorySpecificData;
const pricingTypeLabel = formatPricingType(tool.pricing_type || 'paid');
const websiteHostLabel = (() => {
  if (!tool.website) return null;
  try {
    return new URL(tool.website).hostname.replace(/^www\./, '');
  } catch {
    return tool.website.replace(/^https?:\/\//i, '').split('/')[0] || tool.website;
  }
})();
const vipSpecifics = toolSpecs?.specifics as Record<string, unknown> | undefined;
const reviewContext = hasNewerUnpublishedReview
  ? null
  : (tool.review_context as Record<string, unknown> | null);
const userAdvocate = (reviewContext?.userAdvocate || reviewContext?.user_advocate) as Record<
  string,
  unknown
> | null;
const budgetAnalyst = (reviewContext?.budgetAnalyst || reviewContext?.budget_analyst) as Record<
  string,
  unknown
> | null;
const humanVerdict = (reviewContext?.humanVerdict || reviewContext?.human_verdict) as string | null;
const decisionSlotsRaw = (reviewContext?.decisionSlots || reviewContext?.decision_slots) as Record<
  string,
  unknown
> | null;
const decisionIntroRaw = (reviewContext?.decisionIntro || reviewContext?.decision_intro) as Record<
  string,
  unknown
> | null;
const delighters = Array.isArray(userAdvocate?.delighters) ? userAdvocate?.delighters : [];
const frustrations = Array.isArray(userAdvocate?.frustrations) ? userAdvocate?.frustrations : [];
const powerTip = (userAdvocate?.powerTip || userAdvocate?.power_tip) as string | null;
const vibe = userAdvocate?.vibe as string | null;
const originStory = (userAdvocate?.originStory || userAdvocate?.origin_story) as string | null;
const idealFor = Array.isArray(userAdvocate?.idealFor || userAdvocate?.ideal_for)
  ? userAdvocate?.idealFor || userAdvocate?.ideal_for
  : [];
const avoidIf = Array.isArray(userAdvocate?.avoidIf || userAdvocate?.avoid_if)
  ? userAdvocate?.avoidIf || userAdvocate?.avoid_if
  : [];
const budgetCostDriversRaw = budgetAnalyst
  ? budgetAnalyst.costDrivers || budgetAnalyst.cost_drivers
  : null;
const budgetCostDrivers = Array.isArray(budgetCostDriversRaw)
  ? budgetCostDriversRaw
      .filter((item): item is string => typeof item === 'string' && item.trim().length > 0)
      .map((item) => item.trim())
  : [];
const budgetOneTimeFeesRaw = budgetAnalyst
  ? budgetAnalyst.oneTimeFees || budgetAnalyst.one_time_fees
  : null;
const budgetOneTimeFees = Array.isArray(budgetOneTimeFeesRaw)
  ? budgetOneTimeFeesRaw
      .filter((item): item is string => typeof item === 'string' && item.trim().length > 0)
      .map((item) => item.trim())
  : [];
const budgetCommitmentTerms = (budgetAnalyst?.commitmentTerms ||
  budgetAnalyst?.commitment_terms) as string | null | undefined;
const budgetRoiThreshold = (budgetAnalyst?.roiThreshold ||
  budgetAnalyst?.roi_threshold) as string | null | undefined;

// Fetch alternatives using hybrid search (vector similarity + category guardrails)
// Strategy: Compute live, cache at edge - no DB storage of computed relationships
const alternativesResponse = await getAlternatives(tool, { matchThreshold: 0.4, matchCount: 6 });
const alternativeIds = alternativesResponse.items.map((a) => a.id);

// Fetch full data for alternatives (needed for micro-diffs, display, and comparison validation)
const { data: alternatives } =
  alternativeIds.length > 0
    ? await supabase
        .from('items')
        .select(
          `
          id, name, slug, logo_url, short_description, avg_score, pricing_type, learning_curve,
          base_score, specs, metadata,
          item_category_links(
            relevance_score,
            category:categories(id, slug, name)
          )
        `
        )
        .in('id', alternativeIds)
        .eq('type', 'tool')
    : { data: [] };

// Preserve similarity order from hybrid search
const orderedAlternatives = (() => {
  if (!alternatives) return [];
  const alternativeById = new Map(alternatives.map((item) => [item.id, item]));
  return alternativeIds
    .map((id) => alternativeById.get(id))
    .filter((item): item is (typeof alternatives)[number] => Boolean(item));
})();

// Track whether these are true "alternatives" or just "related tools"
const alternativesLabel =
  alternativesResponse.type === 'alternatives' ? 'Alternatives' : 'Related Tools';

// Compute micro-diffs for alternatives (Layer 2 - Computed)
const microDiffs = orderedAlternatives?.length
  ? computeMicroDiffs(
      {
        slug: tool.slug,
        name: tool.name,
        pricing_type: tool.pricing_type,
        learning_curve: tool.learning_curve,
        base_score: tool.base_score,
        specs: tool.specs,
      },
      orderedAlternatives.map((alt) => ({
        slug: alt.slug,
        name: alt.name,
        pricing_type: alt.pricing_type,
        learning_curve: alt.learning_curve,
        base_score: alt.base_score,
        specs: alt.specs,
      }))
    )
  : new Map();

// Fetch curated verdicts for alternatives (Layer 1 - Human Intelligence)
const altSlugs = orderedAlternatives?.map((a) => a.slug) || [];
const curatedVerdicts = new Map<string, string>();

if (altSlugs.length > 0) {
  // Query comparison_insights where either slug is our tool
  const { data: insights } = await supabase
    .from('comparison_insights')
    .select('item_a_slug, item_b_slug, verdict')
    .or(`item_a_slug.eq.${tool.slug},item_b_slug.eq.${tool.slug}`)
    .not('verdict', 'is', null);

  for (const insight of insights || []) {
    // Determine which slug is the alternative
    const altSlug = insight.item_a_slug === tool.slug ? insight.item_b_slug : insight.item_a_slug;
    if (altSlugs.includes(altSlug) && insight.verdict) {
      curatedVerdicts.set(altSlug, insight.verdict);
    }
  }
}

const sourceEvidenceDomains = new Set(
  firstReview?.sources
    ? (firstReview.sources as Array<{ domain?: string; url?: string }>)
        .map((source) => {
          if (source.domain) return source.domain.replace(/^www\./, '').toLowerCase();
          if (!source.url) return null;
          try {
            return new URL(source.url).hostname.replace(/^www\./, '').toLowerCase();
          } catch {
            return null;
          }
        })
        .filter((domain): domain is string => Boolean(domain))
    : []
);
const stripControlChars = stripToolPageControlChars;
const extractJsonClaimText = (snippet: string): string | null => {
  try {
    const parsed = JSON.parse(snippet) as Record<string, unknown>;
    if (typeof parsed.text !== 'string') return null;
    const cleaned = stripControlChars(parsed.text);
    return cleaned || null;
  } catch {
    return null;
  }
};
const sanitizeStructuredClaimMarkdown = (value: string | null): string | null => {
  if (!value || typeof value !== 'string') return value;
  const decoded = value.replace(/\{[^{}\n]*"text"[^{}\n]*\}/g, (snippet) => {
    const claimText = extractJsonClaimText(snippet);
    return claimText || snippet;
  });
  const legacyVerdictHeadingPattern = new RegExp(
    String.raw`^\s*(?:#{1,6}\s*)?(?:\*\*)?\s*(?:t(?:l;dr|ldr)|community\s+insights)\s*(?:\*\*)?\s*:?\s*$`,
    'gim'
  );
  return decoded
    .replace(legacyVerdictHeadingPattern, '')
    .replace(/\n{3,}/g, '\n\n')
    .trim();
};
const toEvidenceBullet = (claim: unknown): EvidenceBullet | null =>
  toToolPageEvidenceBullet(claim, isEligibleEvidenceUrl);
const buildEvidenceBulletV2 = ({
  text,
  kind,
  sourceUrl,
  sourceLabel,
  retrievedAt,
  requiredSourcing,
}: {
  text: string;
  kind: EvidenceBulletV2['kind'];
  sourceUrl?: string | null;
  sourceLabel?: string;
  retrievedAt?: string;
  requiredSourcing: boolean;
}): EvidenceBulletV2 | null =>
  buildToolPageEvidenceBulletV2({
    text,
    kind,
    sourceUrl,
    sourceLabel,
    retrievedAt,
    requiredSourcing,
    isEligibleEvidenceUrl,
  });
const eligibleSignalEvidenceCount = countEligibleEvidenceDomains(sourceEvidenceDomains);

// SEO: quality/index gate (with confidence retained for trust signal display)
const confidence = evaluateContentConfidence(tool, firstReview);
const contentConfidenceLevelRaw = getConfidenceLevel(confidence.score);
const indexReadiness = evaluateIndexReadiness(tool, firstReview);
const persistedQuality =
  (canonicalFacts?.quality as
    | {
        should_index?: boolean;
        noindex_reasons?: string[];
        section_publishability?: Record<string, boolean>;
        section_status?: Record<string, 'show' | 'hide' | 'procedural'>;
        evidence_counts?: Record<string, number>;
      }
    | undefined) || undefined;
const sectionPublishability = {
  ...indexReadiness.signals.section_publishability,
  ...(persistedQuality?.section_publishability || {}),
};
const sectionStatus = {
  ...indexReadiness.signals.section_status,
  ...(persistedQuality?.section_status || {}),
};
const hasProceduralSignals =
  sectionStatus.verdict === 'procedural' ||
  sectionStatus.pricing === 'procedural' ||
  sectionStatus.community === 'procedural' ||
  sectionStatus.specs === 'procedural';
const isDraftPage = !reviewSelection.hasPublishedReview && reviewSelection.hasDraftReview;

const VOLATILE_FAQ_TERMS =
  /\b(model|version|pricing|price|plan|quota|limit|token|tokens|rate limit|context window|deprecated|deprecation|gpt|claude|opus|sonnet|haiku|o[1-9])\b/i;
const filteredFaqItems = (Array.isArray(knowledgeCard?.faqs) ? knowledgeCard.faqs : []).filter(
  (item) => {
    if (!item?.question || !item?.answer) return false;
    if (!item.answer_source_url) return false;
    if (
      VOLATILE_FAQ_TERMS.test(`${item.question} ${item.answer}`) &&
      item.answer_source_type !== 'official'
    ) {
      return false;
    }
    if (
      /\b(price|pricing|plan|tier|monthly|annual|enterprise|max plan|models? available|what models?)\b/i.test(
        `${item.question} ${item.answer}`
      )
    ) {
      return false;
    }
    return true;
  }
);
const knowledgeCardForSeo =
  knowledgeCard && filteredFaqItems.length !== (knowledgeCard.faqs?.length || 0)
    ? { ...knowledgeCard, faqs: filteredFaqItems }
    : knowledgeCard;
const faqItems = filteredFaqItems;

const gateShouldIndex =
  typeof persistedQuality?.should_index === 'boolean'
    ? persistedQuality.should_index
    : indexReadiness.shouldIndex;
const gateReasons =
  Array.isArray(persistedQuality?.noindex_reasons) && persistedQuality.noindex_reasons.length > 0
    ? persistedQuality.noindex_reasons
    : indexReadiness.reasons;
const gateBlocksFoundations =
  gateReasons.includes('missing_required_sections') || gateReasons.includes('mvup_incomplete');
const hasProceduralGuidance = hasProceduralSignals && !gateBlocksFoundations;
const contentConfidenceLevel = gateBlocksFoundations ? 'low' : contentConfidenceLevelRaw;
const safeDraftDescription = `${tool.name} is currently in editorial verification. This page is not finalized yet.`;
const strictGateBlockers = firstReview
  ? evaluateStrictPublishGate(tool as any, firstReview as any).blockers
  : [];
const provisionalIndexEligibility = evaluateToolPageProvisionalIndexEligibility({
  firstReview: firstReview as any,
  gateReasons,
  strictBlockers: strictGateBlockers,
});
const showReviewInProgressBanner = provisionalIndexEligibility.allowed;
const hasEligibleNegativeEvidence = eligibleSignalEvidenceCount >= 2;
const renderVerdict = sanitizeStructuredClaimMarkdown(
  firstReview?.summary_markdown || tool.verdict || humanVerdict
);

const _turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';

const hasAbout = (() => {
  const longDescription =
    typeof tool.long_description === 'string' ? tool.long_description.trim() : '';
  if (!longDescription) return false;
  const shortDescription =
    typeof tool.short_description === 'string' ? tool.short_description.trim() : '';
  const normalize = (value: string) =>
    value
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, ' ')
      .trim();
  return normalize(longDescription) !== normalize(shortDescription);
})();
const setupSignals = deriveToolPageSetupSignals({
  knowledgeCard,
  setupTracks: setupTracks || null,
  website: tool.website,
});
const hasGettingStartedRaw = setupSignals.hasGettingStarted;
const comparativeFeaturePeerCount =
  typeof (knowledgeCard?.meta as Record<string, unknown> | undefined)?.comparative_feature_peer_count ===
  'number'
    ? ((knowledgeCard?.meta as Record<string, unknown>)
        .comparative_feature_peer_count as number)
    : 0;
const pricingSignals = deriveToolPagePricingSignals({
  toolPricingType: tool.pricing_type,
  pricingStartingPrice:
    typeof knowledgeCard?.pricing?.starting_price === 'string'
      ? knowledgeCard.pricing.starting_price
      : null,
  smpPlans: knowledgeCard?.smp_pricing?.plans,
  legacyPricingTiers: knowledgeCard?.pricing?.tiers,
  pricingSectionStatus: sectionStatus.pricing,
});
const hasPricing = pricingSignals.hasPricing;
const hasFreePlanSignal = pricingSignals.hasFreePlanSignal;
const verdictPolicy = deriveToolPageVerdictPolicy({
  firstReviewSummaryMarkdown: firstReview?.summary_markdown || null,
  toolVerdict: tool.verdict || null,
  humanVerdict: humanVerdict || null,
  avoidIf: Array.isArray(avoidIf) ? avoidIf : [],
  hasEligibleNegativeEvidence,
  hasFreePlanSignal,
  renderVerdict,
});
const { guardedHumanVerdict, guardedAvoidIf, renderVerdictSafe, isDisallowedConClaim } =
  verdictPolicy;
const hasVerdict = Boolean(renderVerdictSafe && sectionStatus.verdict === 'show');
const sectionSignals = deriveToolPageSectionSignals({
  faqCount: faqItems.length,
  faqPublishable: sectionPublishability.faq,
  featureCoreCount: Array.isArray(knowledgeCard?.features?.core) ? knowledgeCard.features.core.length : 0,
  featureUniqueCount: Array.isArray(knowledgeCard?.features?.unique)
    ? knowledgeCard.features.unique.length
    : 0,
  hasCategorySpecificData: Boolean(categorySpecificData),
  hasVipSpecifics: Boolean(vipSpecifics),
  specsSectionStatus: sectionStatus.specs,
  hasPlatforms: Array.isArray(knowledgeCard?.platforms) && knowledgeCard.platforms.length > 0,
  hasIntegrations: Boolean(knowledgeCard?.integrations),
  alternativesCount: orderedAlternatives?.length || 0,
  communitySectionStatus: sectionStatus.community,
  eligibleSignalEvidenceCount,
  idealFor: Array.isArray(idealFor) ? idealFor.filter((item): item is string => typeof item === 'string') : [],
  avoidIf: Array.isArray(avoidIf) ? avoidIf.filter((item): item is string => typeof item === 'string') : [],
  delighters: Array.isArray(delighters)
    ? delighters.filter((item): item is string => typeof item === 'string')
    : [],
  frustrations: Array.isArray(frustrations)
    ? frustrations.filter((item): item is string => typeof item === 'string')
    : [],
  powerTip: typeof powerTip === 'string' ? powerTip : null,
  humanVerdict: typeof humanVerdict === 'string' ? humanVerdict : null,
});
const hasFAQRaw = sectionSignals.hasFAQRaw;
const hasFeatures = sectionSignals.hasFeatures;
const hasSpecsRaw = sectionSignals.hasSpecsRaw;
const hasPlatformRaw = sectionSignals.hasPlatformRaw;
const hasAlternatives = sectionSignals.hasAlternatives;
const alternativesState = buildToolPageAlternativesState(
  {
    slug: tool.slug,
    category: tool.category as { id?: string | null } | null | undefined,
    item_category_links: (tool as any).item_category_links || null,
    metadata: tool.metadata,
  },
  (orderedAlternatives || []).map((alt) => ({
    slug: alt.slug,
    category: (alt as any).category || null,
    item_category_links: (alt as any).item_category_links || null,
    metadata: alt.metadata,
  }))
);
const comparableAlternatives = alternativesState.comparableAlternatives;
const hasComparableAlternatives = alternativesState.hasComparableAlternatives;
const canCompareByAlternativeSlug = alternativesState.canCompareBySlug;
const hasCommunityRaw = sectionSignals.hasCommunityRaw;
const sectionState = buildToolPageSectionState({
  contentConfidenceLevel,
  hasAlternatives,
  firstReviewUpdatedAt: firstReview?.updated_at || null,
  firstReviewCreatedAt: firstReview?.created_at || null,
  toolLastVerifiedAt: tool.last_verified_at || null,
  toolPricingVerifiedAt: tool.pricing_verified_at || null,
  toolUpdatedAt: tool.updated_at || null,
  sectionStatus: {
    specs: sectionStatus.specs,
    community: sectionStatus.community,
  },
  sectionPublishability: {
    faq: sectionPublishability.faq,
  },
  hasFaqData: hasFAQRaw,
  hasGettingStartedData: hasGettingStartedRaw,
  hasSpecsData: hasSpecsRaw,
  hasCommunityData: hasCommunityRaw,
  hasPlatformData: hasPlatformRaw,
  hasSecurityData: Boolean(knowledgeCard?.security),
  hasPortabilityData: Boolean(knowledgeCard?.smp_portability),
  hasKnowledgeCard: Boolean(knowledgeCard),
  hasParentTool: Boolean(parentTool),
  hasSupportData: Boolean(knowledgeCard?.support),
  now: new Date(),
});
const hasFAQ = sectionState.hasFAQ;
const hasGettingStarted = sectionState.hasGettingStarted;
const hasSpecs = sectionState.hasSpecs;
const hasCommunity = sectionState.hasCommunity;
const hasPlatform = sectionState.hasPlatform;
const hasSecurity = sectionState.hasSecurity;
const hasPortability = sectionState.hasPortability;
const hasOperationalDetails = sectionState.hasOperationalDetails;
const showProceduralVerdict =
  hasProceduralGuidance && sectionStatus.verdict === 'procedural' && !hasVerdict;
const showProceduralSpecs =
  hasProceduralGuidance && sectionStatus.specs === 'procedural' && !hasSpecs;
const faqSchema = hasFAQ ? generateToolFAQSchema(tool, knowledgeCardForSeo) : null;
const taxonomyPrimary =
  typeof knowledgeCard?.smp_taxonomy?.primary_function === 'string'
    ? knowledgeCard.smp_taxonomy.primary_function.toLowerCase()
    : '';
const categoryHint = `${tool.category?.slug || ''} ${taxonomyPrimary}`.toLowerCase();
const isPaymentsCategory =
  /\b(payment|payments|bank|banking|finance|accounting|treasury|billing)\b/.test(categoryHint);
const extractClaimText = extractToolPageClaimText;
const fallbackConsText = (Array.isArray(globalCons) ? globalCons : [])
  .map(extractClaimText)
  .filter((text) => text.length > 0);
const paymentTriggerCons = fallbackConsText.filter((text) =>
  /\b(fee|fees|fx|foreign exchange|gateway|merchant|kyb|kyc|verification|card|transfer|settlement)\b/i.test(
    text
  )
);

const cleanNarrativeText = cleanToolPageNarrativeText;
const cleanDecisionSlotText = cleanToolPageDecisionSlotText;
const uniqueDecisionText = uniqueToolPageDecisionText;
const fallbackDecisionSummary =
  tool.short_description ||
  knowledgeCard?.tagline ||
  `${tool.name} can work well for some teams, but fit depends on your workflow and plan constraints.`;
const decisionSnapshot = buildToolPageDecisionSnapshot({
  decisionSlotsRaw,
  decisionIntroRaw,
  fallbackDecisionSummary,
  idealFor,
  guardedAvoidIf,
  isPaymentsCategory,
  paymentTriggerCons,
  fallbackConsText,
  firstReviewPros: firstReview?.pros || [],
  firstReviewCons: firstReview?.cons || [],
  tagAudienceNames: tags.audiences.map((tag) => tag.name),
  isDisallowedConClaim,
  cleanNarrativeText,
  cleanDecisionSlotText,
  uniqueDecisionText,
});
const {
  decisionSnapshotSummary,
  introLooksSpecSheet,
  decisionSnapshotBestWhen,
  decisionSnapshotWatchOuts,
  decisionTradeoffSummaryInitial,
} = decisionSnapshot;
let decisionTradeoffSummary = decisionTradeoffSummaryInitial;
const toolPageEvaluationViewModel = buildToolPageEvaluationViewModel({
  canonicalFacts: canonicalFacts as Record<string, unknown> | undefined,
});
const {
  handsOnChecks: _handsOnChecks,
  handsOnTestEnvironment,
  handsOnTestSteps,
  handsOnTestFindings,
  handsOnTestedAtLabel,
  hasHandsOnTestNotes: _hasHandsOnTestNotes,
  evaluationDepth,
  testedItems,
  notTestedItems,
  showWeTestedIt,
} = toolPageEvaluationViewModel;
const toolPageEvidenceLinks = buildToolPageEvidenceLinks(
  ((firstReview?.sources as Array<Record<string, unknown> | null | undefined>) || []),
  tool.name
);
const {
  evidenceLinksAll,
  evidenceLinks,
  lowConfidenceEvidenceLinks,
  evidenceBasis,
  officialEvidenceLinks,
} = toolPageEvidenceLinks;
const _independentEvidenceLinks = evidenceLinks.filter(
  (entry) => entry.basis === 'Independent reviews'
);
const _communityEvidenceLinks = evidenceLinks.filter(
  (entry) => entry.basis === 'Community discussions' || entry.basis === 'GitHub issues'
);
const sourceAriaLabel = (context: string): string =>
  buildToolPageSourceAriaLabel(stripControlChars(context));
const reviewSignals = deriveToolPageReviewSignals({
  firstReview,
  toolLastVerifiedAt: tool.last_verified_at || null,
  toolPricingVerifiedAt: tool.pricing_verified_at || null,
  extractionDate: (knowledgeCard?.meta?.extraction_date as string | undefined) || null,
});
const {
  pricingVerifiedLabel,
  specsVerifiedLabel,
  communityVerifiedLabel,
} = reviewSignals;
const contextualEvidenceCons = (Array.isArray(firstReview?.cons) ? firstReview.cons : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const contextualEvidencePros = (Array.isArray(firstReview?.pros) ? firstReview.pros : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const globalEvidencePros = (Array.isArray(globalPros) ? globalPros : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const globalEvidenceCons = (Array.isArray(globalCons) ? globalCons : [])
  .map(toEvidenceBullet)
  .filter((item): item is EvidenceBullet => Boolean(item));
const effectiveEvidencePros =
  contextualEvidencePros.length > 0 ? contextualEvidencePros : globalEvidencePros;
const rawEvidenceCons = contextualEvidenceCons.length > 0 ? contextualEvidenceCons : globalEvidenceCons;
const effectiveEvidenceCons = rawEvidenceCons.filter(
  (item) => !isDisallowedConClaim(item.text)
);
const hasStrengths =
  effectiveEvidencePros.length +
    effectiveEvidenceCons.length >=
  2;
const hiddenCostBullets = Array.isArray(constraints?.hidden_costs)
  ? constraints.hidden_costs
      .map((cost: any) => {
        const sourceUrl = typeof cost?.source_url === 'string' ? cost.source_url.trim() : '';
        if (!isEligibleEvidenceUrl(sourceUrl)) return null;
        const name = typeof cost?.name === 'string' ? cost.name.trim() : 'Hidden cost';
        const amount = typeof cost?.amount === 'string' ? ` (${cost.amount})` : '';
        const whenCharged = typeof cost?.when_charged === 'string' ? ` — ${cost.when_charged}` : '';
        return { text: `${name}${amount}${whenCharged}`, sourceUrl } as EvidenceBullet;
      })
      .filter((item): item is EvidenceBullet => Boolean(item))
  : [];
const hardLimitFromConstraints = Array.isArray(constraints?.hard_limits)
  ? constraints.hard_limits
      .map((limit: any) => {
        const sourceUrl = typeof limit?.source_url === 'string' ? limit.source_url : '';
        if (!isEligibleEvidenceUrl(sourceUrl)) return null;
        const metric =
          typeof limit?.metric === 'string' ? limit.metric.replace(/_/g, ' ') : 'Limit';
        const value =
          typeof limit?.value === 'number' || typeof limit?.value === 'string'
            ? String(limit.value)
            : '';
        const unit = typeof limit?.unit === 'string' ? ` ${limit.unit}` : '';
        const plan =
          typeof limit?.plan_name_match === 'string' ? ` (${limit.plan_name_match})` : '';
        const text = `${metric}: ${value}${unit}${plan}`.trim();
        if (!text || text === 'Limit:') return null;
        if (isDisallowedConClaim(text)) return null;
        return { text, sourceUrl } as EvidenceBullet;
      })
      .filter((item): item is EvidenceBullet => Boolean(item))
  : [];
const toolPageCanonicalHardLimits = deriveToolPageCanonicalHardLimits({
  hardLimitFromConstraints,
  effectiveEvidenceCons,
  hiddenCostBullets,
});
const { hardLimitBullets: _hardLimitBullets, canonicalHardLimits, topHardLimit } =
  toolPageCanonicalHardLimits;
decisionTradeoffSummary =
  decisionTradeoffSummary ||
  cleanNarrativeText(topHardLimit?.text) ||
  cleanNarrativeText(decisionSnapshotWatchOuts[0]) ||
  'Tradeoff not confirmed yet.';
const gettingStartedCtaUrl = setupSignals.gettingStartedCtaUrl;
const baseEvidenceGrade = deriveToolPageBaseEvidenceGrade({
  officialEvidenceLinks,
  canonicalHardLimitCount: canonicalHardLimits.length,
  evidenceLinkCount: evidenceLinks.length,
});
let pendingVerificationCount = 0;
const directPricingPageSource =
  typeof knowledgeCard?.smp_pricing?.pricing_page_url === 'string'
    ? knowledgeCard.smp_pricing.pricing_page_url
    : null;
const officialDocsSource = officialEvidenceLinks.find(
  (entry) =>
    entry.basis === 'Official docs/help center' ||
    entry.basis === 'Official changelogs' ||
    entry.basis === 'Official status pages'
);
const pricingViewModel = buildToolPagePricingViewModel({
  hasPricing,
  pricingVerifiedLabel,
  officialEvidenceLinks,
  directPricingPageSource: isEligibleEvidenceUrl(directPricingPageSource)
    ? directPricingPageSource
    : null,
  hardLimitFromConstraints,
  effectiveEvidenceCons,
  hiddenCostBullets,
  canonicalHardLimitsCount: canonicalHardLimits.length,
  sectionPricingStatus: sectionStatus.pricing,
  budgetCostDrivers,
  budgetOneTimeFees,
  budgetCommitmentTerms,
  budgetRoiThreshold,
});
const {
  officialPricingSource,
  pricingSourceUrl,
  pricingSnapshotBullets: _pricingSnapshotBullets,
  pricingEvidenceLinks,
  hasPricingCheckedProof,
  pricingCheckedLabel,
  showPricingSection,
  pricingNarrativeLead,
  pricingNarrativeLabel,
} = pricingViewModel;
const toolPageSourcesViewModel = buildToolPageSourcesViewModel({
  evidenceLinksAll,
  effectiveEvidencePros,
  effectiveEvidenceCons,
  pricingSourceUrl,
  pricingEvidenceLinks,
  faqItems,
  officialDocsSourceUrl: officialDocsSource?.url || null,
  canonicalHardLimits,
});
const { collectedSourcesBySection, collectedSourcesTotal, hasCollectedSources } =
  toolPageSourcesViewModel;
const decisionProofPoints = [
  buildEvidenceBulletV2({
    text: `Pricing references reviewed from official pages (checked ${pricingVerifiedLabel || 'latest available date'}).`,
    kind: 'claim',
    sourceUrl: pricingSourceUrl,
    sourceLabel: 'Official pricing',
    retrievedAt: pricingVerifiedLabel || undefined,
    requiredSourcing: true,
  }),
  buildEvidenceBulletV2({
    text: `Documentation and product references reviewed from official docs/help sources (checked ${specsVerifiedLabel || 'latest available date'}).`,
    kind: 'claim',
    sourceUrl: officialDocsSource?.url,
    sourceLabel: 'Official docs',
    retrievedAt: specsVerifiedLabel || undefined,
    requiredSourcing: true,
  }),
  buildEvidenceBulletV2({
    text: `Plan-gating and limitations were extracted from source-linked evidence for this page (checked ${communityVerifiedLabel || 'latest available date'}).`,
    kind: 'limit',
    sourceUrl:
      topHardLimit?.sourceUrl || officialPricingSource?.url || officialDocsSource?.url || null,
    sourceLabel: 'Constraint evidence',
    retrievedAt: communityVerifiedLabel || undefined,
    requiredSourcing: true,
  }),
].filter((item): item is EvidenceBulletV2 => Boolean(item));
const avoidIfBullet = buildEvidenceBulletV2({
  text: decisionSnapshotWatchOuts[0] || 'Your workflow cannot tolerate unresolved constraints.',
  kind: 'tradeoff',
  requiredSourcing: true,
  sourceUrl: topHardLimit?.sourceUrl || null,
  sourceLabel: topHardLimit ? 'Hard limit source' : undefined,
  retrievedAt: communityVerifiedLabel || specsVerifiedLabel || pricingVerifiedLabel || undefined,
});
const decisionSnapshotDifferentiators = uniqueDecisionText([
  ...(Array.isArray(knowledgeCard?.features?.unique) ? knowledgeCard.features.unique : []),
  ...(Array.isArray(knowledgeCard?.features?.core) ? knowledgeCard.features.core : []),
]).slice(0, 2);
const lensLabelMap: Record<ReviewLens, string> = {
  general: 'General',
  personal: 'Personal',
  startup: 'Startup',
  enterprise: 'Enterprise',
};
const lensRuntime = buildToolPageLensRuntime({
  pathname: Astro.url.pathname,
  searchParams: Astro.url.searchParams,
  activeReviewLens,
  viewModelInput: {
    hasVerdict,
    showProceduralVerdict,
    showPricingSection,
    hasGettingStarted,
    hasFeatures,
    hasSpecs,
    showProceduralSpecs,
    hasPlatform,
    hasAlternatives,
  },
  lensContentInput: {
    toolName: tool.name,
    hasCollectedSources,
    hasGettingStarted,
    showPricingSection,
    hasSecurity,
    decisionSnapshotBestWhen,
    decisionSnapshotWatchOuts,
    decisionSnapshotDifferentiators,
    decisionTradeoffSummary,
    enterpriseTradeoffOverride: canonicalHardLimits[0]?.text || null,
    hardLimitCount: canonicalHardLimits.length,
  },
});
const {
  lensHrefs,
  focusSwitchOptions,
  lensDefaultFocus,
  showFocusSwitch,
  lensPriorityLinks,
  verdictLabelRationale,
  reviewDek,
  readerFocusNote,
  lensBestFitLine,
  lensWeakFitLine,
  lensTradeoffLine,
  scoreDrivers,
  workflowFitHighlights,
  workflowFitCards,
} = lensRuntime;
const tradeoffCons = uniqueDecisionText([
  ...decisionSnapshotWatchOuts,
  ...canonicalHardLimits.map((item) => item.text),
])
  .slice(0, 2)
  .map((text) =>
    buildEvidenceBulletV2({
      text,
      kind: 'tradeoff',
      requiredSourcing: true,
      sourceUrl: canonicalHardLimits.find((item) => item.text === text)?.sourceUrl || null,
      sourceLabel: canonicalHardLimits.find((item) => item.text === text) ? 'Source' : undefined,
      retrievedAt:
        communityVerifiedLabel || specsVerifiedLabel || pricingVerifiedLabel || undefined,
    })
  )
  .filter((item): item is EvidenceBulletV2 => Boolean(item));
const trustRuntime = buildToolPageTrustRuntime({
  baseEvidenceGrade,
  verificationItems: [avoidIfBullet, ...tradeoffCons, ...decisionProofPoints],
  hasCollectedSources,
  contentConfidenceLevel,
  hasPricingCheckedProof,
  pricingCheckedLabel,
  pricingSourceUrl,
  specsVerifiedLabel,
  officialDocsSourceUrl: officialDocsSource?.url || null,
  communityVerifiedLabel,
  officialPricingSourceUrl: officialPricingSource?.url || null,
});
pendingVerificationCount = trustRuntime.pendingVerificationCount;
const { trustStatus, trustConfidenceLabel, updateHistoryEntries } = trustRuntime;
const toolReviewHeading = `${tool.name} Review`;
const toolPageQaGate = evaluateToolPageQaGate({
  title: `${tool.name} Review | StackHunt`,
  h1: toolReviewHeading,
  intro: stripControlChars(decisionSnapshotSummary || ''),
  verdict: stripControlChars(renderVerdictSafe || tool.verdict || ''),
  evaluationDepth: evaluationDepth === 'Docs-only' ? 'docs_only' : 'hands_on',
  pricingSectionVisible: showPricingSection,
  hasPricingCheckedProof,
  schemaMatchesVisibleContent: Boolean(!hasFAQ || faqSchema),
  hasBestForSignal: decisionSnapshotBestWhen.length > 0,
  hasNotForSignal: decisionSnapshotWatchOuts.length > 0,
  hasTradeoffSignal: decisionTradeoffSummary !== 'Tradeoff not confirmed yet.',
  hasDecisionSummaryBlock: true,
  introLooksSpecSheet,
});
const toolMeta = generateToolMeta(tool, tool.review_count);
const indexPolicy = evaluateToolPageIndexPolicy({
  gateShouldIndex,
  isDraftPage,
  pendingVerificationCount,
  toolPageQaPass: toolPageQaGate.pass,
  showReviewInProgressBanner,
  toolCanonicalUrl: toolMeta.canonical,
  fallbackCanonicalUrl: getCanonicalUrl('/tools'),
  defaultDescription: toolMeta.description,
  draftDescription: safeDraftDescription,
});
const shouldNoindex = indexPolicy.shouldNoindex;
const meta = {
  ...toolMeta,
  description: indexPolicy.description,
  canonical: indexPolicy.canonicalUrl,
  noindex: shouldNoindex,
};
Astro.response.headers.set('X-Robots-Tag', indexPolicy.robotsTag);
const schemas = [
  generateToolSchema(tool, primaryOffer, tool.review_count),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools' },
    ...(tool.category
      ? [{ name: tool.category.name, url: `/categories/${tool.category.slug}` }]
      : []),
    { name: tool.name, url: `/tool/${tool.slug}` },
  ]),
  ...(tool.video_id
    ? [generateVideoSchema(tool, tool.video_id, tool.video_title || `${tool.name} Overview`)]
    : []),
  ...(faqSchema ? [faqSchema] : []),
];
---

<BaseLayout meta={meta} schemas={schemas}>
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={primaryOffer?.is_affiliate || false} />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/tools" class="hover:text-hunt-500">Tools</a>
      {
        tool.category && (
          <>
            <span>/</span>
            <a href={`/categories/${tool.category.slug}`} class="hover:text-hunt-500">
              {tool.category.name}
            </a>
          </>
        )
      }
      <span>/</span>
      <span aria-current="page" class="text-zinc-300">
        {tool.name}
      </span>
    </nav>

    <!-- Hero Section -->
    <header class="relative mb-12 overflow-hidden rounded-3xl border border-zinc-700 bg-zinc-900 p-6 shadow-lg sm:p-8">
      {
        showReviewInProgressBanner && (
          <div class="mb-4 rounded-lg border border-sky-500/40 bg-sky-500/10 px-4 py-2 text-sm text-sky-100">
            {hasCollectedSources
              ? 'This page is being reviewed. Claims are source-backed, but final editorial verification is still in progress.'
              : 'This page is being reviewed. Source collection is still in progress before final editorial verification.'}
          </div>
        )
      }
      <div class="pointer-events-none absolute -right-16 -top-24 h-64 w-64 rounded-full bg-hunt-500/20 blur-3xl">
      </div>
      <div class="pointer-events-none absolute -bottom-20 left-4 h-52 w-52 rounded-full bg-cyan-500/15 blur-3xl">
      </div>

      <div class="relative grid gap-8 xl:grid-cols-[1.6fr_1fr]">
        <div class="space-y-5">
          <div class="flex items-start gap-5">
          <Logo
            domain={tool.logo_url}
            name={tool.name}
            size="xl"
            priority={true}
            class="shrink-0 rounded-2xl border border-zinc-700/80 shadow-md"
          />
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-hunt-400">Review</p>
              <div class="mt-1 flex items-center gap-3">
                <h1 class="text-2xl font-bold text-zinc-100 sm:text-3xl">{toolReviewHeading}</h1>
                {
                  tool.is_verified && (
                    <span class="flex items-center gap-1 rounded-full bg-blue-500/15 px-2 py-0.5 text-xs font-medium text-blue-200 ring-1 ring-blue-400/30">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      {hasCollectedSources ? 'Verified sources' : 'Verified'}
                    </span>
                  )
                }
              </div>
              <p class="mt-1 text-sm text-zinc-400">
                {reviewDek}
              </p>
              {
                decisionSnapshotSummary && (
                  <div class="mt-2 space-y-1">
                    <p class="text-zinc-200">{decisionSnapshotSummary}</p>
                  </div>
                )
              }
            </div>
          </div>

          <div class="grid gap-2 rounded-xl border border-zinc-700/80 bg-zinc-800/40 p-3 text-sm text-zinc-300 sm:grid-cols-3">
            <div>
              <span class="text-xs uppercase tracking-wide text-zinc-500">Pricing</span>
