---
/**
 * Tool Detail Page - /tool/[slug] (singular)
 * Software tools only (type='tool')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import VideoEmbed from '@/components/VideoEmbed';
import AlternativeCard from '@/components/AlternativeCard.astro';
import AlternativesCompareGrid from '@/components/AlternativesCompareGrid.astro';
import CompanyInfo from '@/components/CompanyInfo.astro';
import SecurityCompliance from '@/components/SecurityCompliance.astro';
import SupportOptions from '@/components/SupportOptions.astro';
import PortabilityCard from '@/components/PortabilityCard.astro';
import PlatformIntegrations from '@/components/PlatformIntegrations.astro';
import FeaturesShowcase from '@/components/FeaturesShowcase.astro';
import GettingStarted from '@/components/GettingStarted.astro';
import PricingPlansGrid from '@/components/PricingPlansGrid.astro';
import PricingInsights from '@/components/PricingInsights.astro';
import ReviewFocusSwitch from '@/components/ReviewFocusSwitch.astro';
import ReviewLensSwitch from '@/components/ReviewLensSwitch.astro';
import TribalKnowledge from '@/components/TribalKnowledge.astro';
import TrustBar from '@/components/TrustBar.astro';
import PriceVerification from '@/components/PriceVerification';
import SuiteNavigation from '@/components/SuiteNavigation.astro';
import DynamicSpecs from '@/components/DynamicSpecs.astro';
import IncludedTools from '@/components/IncludedTools.astro';
import ToolHowWeEvaluateSection from '@/components/ToolHowWeEvaluateSection.astro';
import ToolWeTestedSection from '@/components/ToolWeTestedSection.astro';
import ToolDecisionConditionsSection from '@/components/ToolDecisionConditionsSection.astro';
import ToolWorkflowFitSection from '@/components/ToolWorkflowFitSection.astro';
import ToolDecisionUtilitySection from '@/components/ToolDecisionUtilitySection.astro';
import ToolPracticalOutcomesSection from '@/components/ToolPracticalOutcomesSection.astro';
import SignalReportWidget from '@/components/SignalReportWidget';
import { generateReviewSchema, generateToolMeta } from '@/lib/seo';
import { simpleMarkdown } from '@/lib/utils';
import {
  buildToolPageCategoryRef,
  buildToolPagePricingLinkText,
  getToolPageData,
  isEligibleEvidenceUrl,
  deriveToolPageReviewContextSignals,
  deriveToolPageRequestState,
  applyToolPageVersionBypassCacheHeaders,
  applyToolPageRobotsHeader,
  buildToolPageRuntimeNavigationStateFromDecisionContext,
  buildToolPageChromeContentStateFromDecisionContext,
  buildToolPagePrepReviewEvidenceStateFromDecisionContext,
  buildToolPageDecisionUtilityState,
  buildToolPagePricingScenarioState,
  buildToolPageWorkflowFitVisibility,
  buildToolPageQuickJumpLinksView,
  rankConstraintsForLens,
} from '@/lib/tool-page';

// SSR: Compute live, cache at edge (s-maxage=3600, stale-while-revalidate=604800)
export const prerender = false;

const { slug } = Astro.params;
const { activeReviewLens, hasVersionBypassParam } = deriveToolPageRequestState(
  Astro.url.searchParams
);
// Cache-bust requests like ?v=34 should always skip CDN/page cache.
applyToolPageVersionBypassCacheHeaders(Astro.response, hasVersionBypassParam);

const toolPageData = await getToolPageData(slug);
if (!toolPageData || !toolPageData.tool) {
  return Astro.redirect('/404');
}
const {
  tool,
  parentTool,
  tags,
  primaryOffer,
  reviewSelection,
  firstReview,
  reviewContentLists,
  coreState,
  orderedAlternatives,
  alternativesLabel,
  microDiffs,
  curatedVerdictEntries,
} = toolPageData;
const {
  knowledgeCard,
  globalPros,
  globalCons,
  constraints,
  canonicalFacts,
  setupTracks,
  categorySpecificData,
  displayCategorySpecificData,
  websiteHostLabel,
  vipSpecifics,
  reviewContext,
  userReportedPros,
  userReportedCons,
} = coreState;
const reviewContextSignals = deriveToolPageReviewContextSignals(reviewContext);
const { prepState, decisionSectionState, reviewArtifactsState, evidenceSignalsState } =
  buildToolPagePrepReviewEvidenceStateFromDecisionContext({
    prepDecision: {
      prep: {
        reviewSources: reviewContentLists.sources,
        isEligibleEvidenceUrl,
        tool,
        orderedAlternatives,
      },
      decision: {
        tool,
        firstReview,
        reviewSelection,
        canonicalFacts,
        knowledgeCard,
        setupTracks,
        reviewContentLists,
        audiences: tags.audiences,
        reviewContextSignals,
        globalCons,
        categorySpecificData,
        vipSpecifics,
        hasParentTool: Boolean(parentTool),
        now: new Date(),
        orderedAlternativesCount: orderedAlternatives?.length || 0,
      },
    },
    reviewEvidence: {
      reviewArtifacts: {
        canonicalFacts,
        reviewSources: reviewContentLists.sources,
        tool,
      },
      evidenceContext: {
        firstReview,
        toolLastVerifiedAt: tool.last_verified_at || null,
        toolPricingVerifiedAt: tool.pricing_verified_at || null,
        extractionDate: knowledgeCard?.meta?.extraction_date,
        constraints,
        isEligibleEvidenceUrl,
        reviewPros: reviewContentLists.pros,
        reviewCons: reviewContentLists.cons,
        globalPros: Array.isArray(globalPros) ? globalPros : [],
        globalCons: Array.isArray(globalCons) ? globalCons : [],
        knowledgeCard,
      },
      reviewContextSignals,
    },
  });
const {
  sourceEvidenceDomains: _sourceEvidenceDomains,
  toEvidenceBullet: _toEvidenceBullet,
  comparableAlternatives,
  hasComparableAlternatives,
  canCompareByAlternativeSlug,
} = prepState;
const {
  qualityState,
  faqState,
  displaySignals,
  decisionRuntime,
  sectionFlags,
  presentationGates,
  faqSchema,
} = decisionSectionState;
const {
  sectionStatus: _sectionStatus,
  gateReasons: _gateReasons,
  showReviewInProgressBanner,
} = qualityState;
const { faqItems } = faqState;
const { pricingTypeLabel } = displaySignals;
const {
  hasAbout,
  comparativeFeaturePeerCount,
  hasPricing,
  renderVerdictSafe,
  isDisallowedConClaim: _isDisallowedConClaim,
  hasVerdict,
  decisionSnapshotSummary,
} = decisionRuntime;
const {
  hasFAQRaw: _hasFAQRaw,
  hasFeatures,
  hasSpecsRaw: _hasSpecsRaw,
  hasPlatformRaw: _hasPlatformRaw,
  hasAlternatives,
  hasCommunityRaw: _hasCommunityRaw,
  hasFAQ,
  hasGettingStarted,
  hasSpecs,
  hasCommunity,
  hasPlatform: _hasPlatform,
  hasSecurity: _hasSecurity,
  hasPortability: _hasPortability,
  hasOperationalDetails,
} = sectionFlags;
const { showProceduralVerdict, showProceduralSpecs } = presentationGates;
const {
  handsOnTestEnvironment,
  handsOnTestSteps,
  handsOnTestFindings,
  handsOnTestedAtLabel,
  evaluationDepth,
  testedItems,
  notTestedItems,
  showWeTestedIt,
} = reviewArtifactsState;
const { reviewSignalsView, evidenceRuntime } = evidenceSignalsState;
const { communityVerifiedLabel } = reviewSignalsView;
const {
  effectiveEvidencePros: _effectiveEvidencePros,
  effectiveEvidenceCons: _effectiveEvidenceCons,
  hasStrengths,
  canonicalHardLimits,
  decisionTradeoffSummary: _decisionTradeoffSummaryResolved,
  officialPricingSource,
  pricingEvidenceLinks,
  showPricingSection,
  pricingNarrativeLead,
  pricingNarrativeLabel,
  collectedSourcesBySection: _collectedSourcesBySection,
  hasCollectedSources,
} = evidenceRuntime;
const lensRankedHardLimits = rankConstraintsForLens(canonicalHardLimits, activeReviewLens);
const topLensHardLimit = lensRankedHardLimits[0] || null;
const normalizeUserReportedClaim = (
  claim: Record<string, unknown>
): {
  text: string;
  source_type?: 'community' | 'editorial';
  source_domain?: string | null;
} | null => {
  const textCandidate = claim.text || claim.claim;
  if (typeof textCandidate !== 'string' || textCandidate.trim().length === 0) return null;
  const sourceType =
    claim.source_type === 'community' || claim.source_type === 'editorial'
      ? claim.source_type
      : claim.sourceType === 'community' || claim.sourceType === 'editorial'
        ? claim.sourceType
        : undefined;
  const sourceDomainCandidate = claim.source_domain || claim.sourceDomain;
  const sourceDomain =
    typeof sourceDomainCandidate === 'string' && sourceDomainCandidate.trim().length > 0
      ? sourceDomainCandidate.trim()
      : null;
  return {
    text: textCandidate.trim(),
    ...(sourceType ? { source_type: sourceType } : {}),
    ...(sourceDomain ? { source_domain: sourceDomain } : {}),
  };
};
const userSignalSummaryRecord =
  tool.specs && typeof tool.specs === 'object'
    ? (tool.specs as Record<string, unknown>).user_signal_summary
    : null;
const userSignalSummary =
  userSignalSummaryRecord && typeof userSignalSummaryRecord === 'object'
    ? (userSignalSummaryRecord as {
        community_cons?: number;
        community_pros?: number;
        editorial_cons?: number;
        editorial_pros?: number;
        corroborating_community_domains?: number;
        community_domains?: string[];
        reddit_claims?: number;
        forum_claims?: number;
        hn_claims?: number;
        top_user_reported_claims?: Array<{
          text?: string;
          source_type?: 'community' | 'editorial';
          source_domain?: string | null;
          source_channel?: 'reddit' | 'forum' | 'hn' | 'editorial' | 'other';
        }>;
      })
    : null;
const topUserReportedClaimsFromSpecs = [...userReportedPros, ...userReportedCons]
  .map(normalizeUserReportedClaim)
  .filter(
    (
      claim
    ): claim is {
      text: string;
      source_type?: 'community' | 'editorial';
      source_domain?: string | null;
    } => Boolean(claim)
  )
  .slice(0, 2);
const topUserReportedClaimsFromSummary = Array.isArray(userSignalSummary?.top_user_reported_claims)
  ? userSignalSummary.top_user_reported_claims
      .filter(
        (
          claim
        ): claim is {
          text: string;
          source_type?: 'community' | 'editorial';
          source_domain?: string | null;
        } => typeof claim?.text === 'string' && claim.text.trim().length > 0
      )
      .slice(0, 2)
  : [];
const topUserReportedClaims =
  topUserReportedClaimsFromSpecs.length > 0
    ? topUserReportedClaimsFromSpecs
    : topUserReportedClaimsFromSummary;
const communityProsCount =
  userReportedPros.filter(
    (claim) => claim.source_type === 'community' || claim.sourceType === 'community'
  ).length ||
  userSignalSummary?.community_pros ||
  0;
const communityConsCount =
  userReportedCons.filter(
    (claim) => claim.source_type === 'community' || claim.sourceType === 'community'
  ).length ||
  userSignalSummary?.community_cons ||
  0;
const pricingLensCoverageRecord =
  tool.specs && typeof tool.specs === 'object'
    ? (
        ((tool.specs as Record<string, unknown>).canonical as Record<string, unknown> | undefined)
          ?.quality as Record<string, unknown> | undefined
      )?.pricing_lens_coverage
    : null;
const constraintsLensCoverageRecord =
  tool.specs && typeof tool.specs === 'object'
    ? (
        ((tool.specs as Record<string, unknown>).canonical as Record<string, unknown> | undefined)
          ?.quality as Record<string, unknown> | undefined
      )?.constraints_lens_coverage
    : null;
const integrationsLensCoverageRecord =
  tool.specs && typeof tool.specs === 'object'
    ? (
        ((tool.specs as Record<string, unknown>).canonical as Record<string, unknown> | undefined)
          ?.quality as Record<string, unknown> | undefined
      )?.integrations_lens_coverage
    : null;
const pricingLensCoverage =
  pricingLensCoverageRecord && typeof pricingLensCoverageRecord === 'object'
    ? (pricingLensCoverageRecord as {
        personal?: number;
        startup?: number;
        enterprise?: number;
      })
    : null;
const constraintsLensCoverage =
  constraintsLensCoverageRecord && typeof constraintsLensCoverageRecord === 'object'
    ? (constraintsLensCoverageRecord as {
        personal?: number;
        startup?: number;
        enterprise?: number;
      })
    : null;
const integrationsLensCoverage =
  integrationsLensCoverageRecord && typeof integrationsLensCoverageRecord === 'object'
    ? (integrationsLensCoverageRecord as {
        personal?: number;
        startup?: number;
        enterprise?: number;
      })
    : null;
const activeLensPricingPlanCount =
  activeReviewLens === 'general' ? null : Number(pricingLensCoverage?.[activeReviewLens] || 0);
const activeLensConstraintCount =
  activeReviewLens === 'general' ? null : Number(constraintsLensCoverage?.[activeReviewLens] || 0);
const activeLensIntegrationCount =
  activeReviewLens === 'general' ? null : Number(integrationsLensCoverage?.[activeReviewLens] || 0);
const activeLensLabelMap: Record<'personal' | 'startup' | 'enterprise', string> = {
  personal: 'Solo / Freelancer',
  startup: 'Startup',
  enterprise: 'Enterprise',
};
const toolMeta = generateToolMeta(tool, tool.review_count);
const toolCategoryRef = buildToolPageCategoryRef(tool.category);
const { runtimeViewBundle, navigationState, ctaMediaState } =
  buildToolPageRuntimeNavigationStateFromDecisionContext({
    runtime: {
      pathname: Astro.url.pathname,
      searchParams: Astro.url.searchParams,
      activeReviewLens,
      tool,
      primaryOffer,
      faqSchema,
      toolMeta,
      canonicalHardLimits,
      decisionRuntime,
      sectionFlags,
      evidenceRuntime,
      qualityState,
      reviewSignalsView,
      presentationGates: {
        showProceduralVerdict,
        showProceduralSpecs,
      },
      evaluationDepth,
    },
    navigation: {
      decisionRuntime,
      sectionFlags,
      presentationGates: {
        showProceduralVerdict,
        showProceduralSpecs,
      },
      evidenceSignals: {
        showPricingSection,
      },
      faqItems,
      reviewArtifactsState,
      media: {
        tool,
        category: toolCategoryRef,
        knowledgeCard,
        renderVerdictSafe,
      },
    },
  });
const {
  schemas,
  updateHistoryLabels,
  meta,
  indexPolicy,
  updateHistoryEntries,
  toolReviewHeading,
  sourceAriaLabel,
  lensRuntime,
} = runtimeViewBundle;
const pageSchemas = firstReview
  ? [...schemas, generateReviewSchema(tool, firstReview, tool.category?.name || 'General software')]
  : schemas;
const { lensViewFields, toolChromeState, alternativesPricingState, contentSectionsState } =
  buildToolPageChromeContentStateFromDecisionContext({
    chromeLens: {
      lensRuntime,
      activeReviewLens,
      toolCategory: toolCategoryRef,
      tool,
      websiteHostLabel,
      runtimeViewBundle,
      evidenceRuntime,
      reviewSignalsView,
      evaluationDepth,
      qualityState,
    },
    contentAlternatives: {
      activeReviewLens,
      alternativesLabel: alternativesLabel as 'Alternatives' | 'Related Tools',
      toolCategoryRef,
      orderedAlternatives,
      comparableAlternatives,
      canCompareByAlternativeSlug,
      tool,
      knowledgeCard,
      parentTool,
      setupTracks,
      displayCategorySpecificData,
      vipSpecifics,
      userReportedPros,
      userReportedCons,
      decisionRuntime,
      sectionFlags,
      evidenceRuntime,
      reviewArtifactsState,
      reviewSignalsView,
      reviewContextSignals,
      qualityState,
    },
  });
const {
  lensHrefs,
  focusSwitchOptions,
  lensDefaultFocus,
  showFocusSwitch,
  lensPriorityLinks,
  verdictLabelRationale,
  reviewDek,
  readerFocusNote,
  lensBestFitLine,
  lensWeakFitLine,
  lensTradeoffLine,
  scoreDrivers,
  workflowFitHighlights,
  workflowFitCards,
} = lensViewFields;
const decisionUtilityState = buildToolPageDecisionUtilityState({
  toolName: tool.name,
  categorySlug: tool.category?.slug || null,
  activeReviewLens,
  hasApi: Boolean(knowledgeCard?.integrations?.has_api),
  hasParentTool: Boolean(parentTool),
  hasEnterpriseSignals:
    (tool.pricing_type || '').toLowerCase().includes('enterprise') ||
    tags.audiences.some((audience) => audience.slug.toLowerCase().includes('enterprise')),
  lensBestFitLine,
  lensWeakFitLine,
  lensTradeoffLine,
  hardLimitText: topLensHardLimit?.text || null,
  pricingEvidenceSourceUrl:
    pricingEvidenceLinks[0]?.sourceUrl || officialPricingSource?.url || null,
  pricingEvidenceSummary: pricingEvidenceLinks[0]?.text || null,
});
const { showWorkflowFitSection } = buildToolPageWorkflowFitVisibility({
  categorySlug: tool.category?.slug || null,
  hasWorkflowCards: workflowFitCards.length > 0,
  hasWorkflowHighlights: workflowFitHighlights.length > 0,
});
const decisionHardLimitEvidence = topLensHardLimit || null;
const pricingScenarioState = buildToolPagePricingScenarioState({
  toolName: tool.name,
  hardLimitText: topLensHardLimit?.text || null,
});
const {
  reviewInProgressBannerText,
  researchStatusView,
  categoryBreadcrumb,
  trustBarProps,
  verificationBadgeLabel,
  websiteState,
  websiteDisplayLabel,
  lensPriorityLead,
  freshnessLabels,
} = toolChromeState;
const shouldShowDecisionUtilitySection =
  decisionUtilityState.hasEvidenceAnchoredUtility &&
  (decisionUtilityState.testChecklistItems.length > 0 ||
    decisionUtilityState.commonSetups.length > 0);
const shouldShowPracticalOutcomes =
  decisionUtilityState.practicalOutcomes.length > 0 && !hasFeatures;
const showEarlySnapshotToneBanner =
  trustBarProps.confidence === 'Low' || trustBarProps.pendingCount > 0;
const {
  pricingInsightsBudgetAnalyst,
  alternativesIntroText,
  compareTeaserLinks,
  alternativesSectionState,
  alternativeCardsView,
} = alternativesPricingState;
const {
  sourceListsView,
  prosConsView,
  gettingStartedProps,
  strengthsSubtitle,
  affiliateOffersView,
  evidenceBasisChips,
  tribalKnowledgeProps,
  platformSectionState,
  specsProps,
  specsSectionState,
  aboutContent,
  pricingSectionState,
  pricingEvidenceState,
  pricingNotice,
  operationalDetailsState,
} = contentSectionsState;
const {
  sourcesSectionState,
  lowConfidenceSourcesState,
  faqItemsView,
  updateHistoryState,
  quickJumpLinks,
} = navigationState;
const quickJumpLinksView = buildToolPageQuickJumpLinksView({
  links: quickJumpLinks,
  showWorkflowFitSection,
});
const {
  compareButtonProps,
  addToStackProps,
  priceVerificationProps,
  videoState,
  videoProps,
  verdictContent,
} = ctaMediaState;
applyToolPageRobotsHeader({
  response: Astro.response,
  robotsTag: indexPolicy.robotsTag,
});
---

<BaseLayout meta={meta} schemas={pageSchemas}>
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={primaryOffer?.is_affiliate || false} />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-400" aria-label="Breadcrumb">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/tools" class="hover:text-hunt-500">Tools</a>
      {
        categoryBreadcrumb && (
          <>
            <span>/</span>
            <a href={categoryBreadcrumb.href} class="hover:text-hunt-500">
              {categoryBreadcrumb.label}
            </a>
          </>
        )
      }
      <span>/</span>
      <span aria-current="page" class="text-zinc-300">
        {tool.name}
      </span>
    </nav>

    <!-- Hero Section -->
    <header
      class="relative mb-12 overflow-hidden rounded-3xl border border-zinc-700 bg-zinc-900 p-6 shadow-lg sm:p-8"
    >
      {
        showReviewInProgressBanner && (
          <div class="mb-4 rounded-lg border border-sky-500/40 bg-sky-500/10 px-4 py-2 text-sm text-sky-100">
            {reviewInProgressBannerText}
          </div>
        )
      }
      <div
        class="pointer-events-none absolute -right-16 -top-24 h-64 w-64 rounded-full bg-hunt-500/20 blur-3xl"
      >
      </div>
      <div
        class="pointer-events-none absolute -bottom-20 left-4 h-52 w-52 rounded-full bg-cyan-500/15 blur-3xl"
      >
      </div>

      <div class="relative grid gap-8 xl:grid-cols-[1.6fr_1fr]">
        <div class="space-y-5">
          <div class="flex items-start gap-5">
            <Logo
              domain={tool.logo_url}
              name={tool.name}
              size="xl"
              priority={true}
              class="shrink-0 rounded-2xl border border-zinc-700/80 shadow-md"
            />
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-hunt-400">Review</p>
              <div class="mt-1 flex items-center gap-3">
                <h1 class="text-2xl font-bold text-zinc-100 sm:text-3xl">{toolReviewHeading}</h1>
                {
                  tool.is_verified && (
                    <span class="flex items-center gap-1 rounded-full bg-blue-500/15 px-2 py-0.5 text-xs font-medium text-blue-200 ring-1 ring-blue-400/30">
                      <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                        <path
                          fill-rule="evenodd"
                          d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                          clip-rule="evenodd"
                        />
                      </svg>
                      {verificationBadgeLabel}
                    </span>
                  )
                }
              </div>
              <p class="mt-1 text-sm text-zinc-400">
                {reviewDek}
              </p>
              {
                showEarlySnapshotToneBanner && (
                  <p class="mt-2 rounded-lg border border-amber-700/40 bg-amber-950/20 px-3 py-2 text-sm text-amber-100">
                    This is an early, docs-only snapshot. Some claims are pending confirmation. Use
                    this page to shortlist, then verify in a demo.
                  </p>
                )
              }
              {
                decisionSnapshotSummary && (
                  <div class="mt-2 space-y-1">
                    <p class="text-zinc-200">{decisionSnapshotSummary}</p>
                  </div>
                )
              }
            </div>
          </div>

          <div
            class="grid gap-2 rounded-xl border border-zinc-700/80 bg-zinc-800/40 p-3 text-sm text-zinc-300 sm:grid-cols-3"
          >
            <div>
              <span class="text-xs uppercase tracking-wide text-zinc-500">Pricing</span>
              <p class="mt-1 font-medium text-zinc-100">{pricingTypeLabel}</p>
            </div>
            {
              tool.category && (
                <div>
                  <span class="text-xs uppercase tracking-wide text-zinc-500">Category</span>
                  <a
                    href={`/categories/${tool.category.slug}`}
                    class="mt-1 block font-medium text-zinc-100 hover:text-hunt-400 transition"
                  >
                    {tool.category.name}
                  </a>
                </div>
              )
            }
            {
              websiteState.hasWebsite && (
                <a
                  href={tool.website}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-outbound="vendor"
                  data-location="hero-meta"
                  data-tool={tool.slug}
                  class="inline-flex items-end justify-between gap-2 rounded-lg border border-zinc-700/80 bg-zinc-900/40 px-3 py-2 text-zinc-100 hover:border-hunt-500 hover:text-hunt-400 transition"
                >
                  <span>
                    <span class="text-xs uppercase tracking-wide text-zinc-500">Website</span>
                    <span class="mt-1 block font-medium">{websiteDisplayLabel}</span>
                  </span>
                  <svg
                    class="h-3.5 w-3.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 17L17 7M17 7H8M17 7v9"
                    />
                  </svg>
                </a>
              )
            }
          </div>

          <div class="flex flex-wrap gap-3">
            {
              primaryOffer && (
                <AffiliateButton offer={primaryOffer} toolName={tool.name} size="lg" />
              )
            }
            <CompareButton
              client:load
              toolSlug={compareButtonProps.toolSlug}
              toolName={compareButtonProps.toolName}
              toolLogo={compareButtonProps.toolLogo}
              categorySlug={compareButtonProps.categorySlug}
              categoryName={compareButtonProps.categoryName}
            />
            <AddToStackButton
              client:load
              toolSlug={addToStackProps.toolSlug}
              toolName={addToStackProps.toolName}
              toolLogo={addToStackProps.toolLogo}
              pricing={addToStackProps.pricing}
              plans={addToStackProps.plans}
            />
          </div>
        </div>

        <aside
          class="rounded-2xl border border-zinc-700 bg-gradient-to-b from-zinc-900/95 via-zinc-900/80 to-zinc-950/95 p-5 shadow-inner"
        >
