---
/**
 * Tool Detail Page - /tool/[slug] (singular)
 * Software tools only (type='tool')
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Logo from '@/components/Logo.astro';
import ScoreBadge from '@/components/ScoreBadge.astro';
import PricingBadge from '@/components/PricingBadge.astro';
import ProsCons from '@/components/ProsCons.astro';
import AffiliateButton from '@/components/AffiliateButton.astro';
import AffiliateDisclosure from '@/components/AffiliateDisclosure.astro';
import SpiderwebGrid from '@/components/SpiderwebGrid.astro';
import SentimentTags from '@/components/SentimentTags.astro';
import VoteWidget from '@/components/VoteWidget';
import CompareButton from '@/components/CompareButton';
import AddToStackButton from '@/components/AddToStackButton';
import VideoEmbed from '@/components/VideoEmbed';
import AlternativeCard from '@/components/AlternativeCard.astro';
import CompanyInfo from '@/components/CompanyInfo.astro';
import SecurityCompliance from '@/components/SecurityCompliance.astro';
import SupportOptions from '@/components/SupportOptions.astro';
import PortabilityCard from '@/components/PortabilityCard.astro';
import PlatformIntegrations from '@/components/PlatformIntegrations.astro';
import FeaturesShowcase from '@/components/FeaturesShowcase.astro';
import PricingPlansGrid from '@/components/PricingPlansGrid.astro';
import VerifiedBadge from '@/components/VerifiedBadge.astro';
import PricingInsights from '@/components/PricingInsights.astro';
import TribalKnowledge from '@/components/TribalKnowledge.astro';
import PriceVerification from '@/components/PriceVerification';
import SuiteNavigation from '@/components/SuiteNavigation.astro';
import IncludedTools from '@/components/IncludedTools.astro';
import RelatedLinks from '@/components/RelatedLinks.astro';
import SignalReportWidget from '@/components/SignalReportWidget';
import SignalAggregatesBadge from '@/components/SignalAggregatesBadge';
import type { KnowledgeCard } from '@/lib/knowledge-card';
import { computeMicroDiffs } from '@/lib/analysis/micro-diff';
import {
  getToolBySlugAndType,
  getToolContexts,
  getToolTags,
  supabase,
} from '@/lib/supabase';
import {
  generateToolMeta,
  generateToolSchema,
  generateBreadcrumbSchema,
  generateVideoSchema,
} from '@/lib/seo';
import { simpleMarkdown } from '@/lib/utils';
import { getAlternatives } from '@/lib/analysis/alternatives';
import { evaluateContentConfidence } from '@/lib/confidence';

// SSR: Compute live, cache at edge (s-maxage=3600, stale-while-revalidate=604800)
export const prerender = false;

const { slug } = Astro.params;
const tool = await getToolBySlugAndType(slug, 'tool');

if (!tool) {
  return Astro.redirect('/404');
}

// Fetch parent tool info if this tool is part of a suite
let parentTool = null;
if (tool.parent_id) {
  const { data } = await supabase
    .from('items')
    .select('id, name, slug')
    .eq('id', tool.parent_id)
    .single();
  parentTool = data;
}

const contextLinks = await getToolContexts(tool.id);
const tags = await getToolTags(tool.id);

// Build related links for internal linking (SEO)
const relatedLinks: Array<{ href: string; title: string; description?: string; icon: 'category' | 'list' | 'tool' | 'compare' }> = [];

// Add category link
if (tool.category) {
  relatedLinks.push({
    href: `/categories/${tool.category.slug}`,
    title: tool.category.name,
    description: `Browse all ${tool.category.name.toLowerCase()} tools`,
    icon: 'category',
  });
}

// Add top 3 context links (best-of lists)
const topContexts = contextLinks?.slice(0, 3) || [];
for (const ctx of topContexts) {
  relatedLinks.push({
    href: `/best/${ctx.context.slug}`,
    title: ctx.context.title,
    description: `${ctx.context.tool_count} tools compared`,
    icon: 'list',
  });
}
const primaryOffer = tool.affiliate_offers?.find((o) => o.is_primary) || tool.affiliate_offers?.[0];
const firstReview = tool.reviews?.[0];

// Extract Knowledge Card data for new components
const knowledgeCard = tool.metadata as KnowledgeCard | null;
const toolSpecs = tool.specs as Record<string, unknown> | null;
const globalPros = Array.isArray(toolSpecs?.pros) ? toolSpecs?.pros : [];
const globalCons = Array.isArray(toolSpecs?.cons) ? toolSpecs?.cons : [];
const reviewContext = tool.review_context as Record<string, unknown> | null;
const userAdvocate = (reviewContext?.userAdvocate || reviewContext?.user_advocate) as Record<string, unknown> | null;
const budgetAnalyst = (reviewContext?.budgetAnalyst || reviewContext?.budget_analyst) as Record<string, unknown> | null;
const humanVerdict = (reviewContext?.humanVerdict || reviewContext?.human_verdict) as string | null;
const delighters = Array.isArray(userAdvocate?.delighters) ? userAdvocate?.delighters : [];
const frustrations = Array.isArray(userAdvocate?.frustrations) ? userAdvocate?.frustrations : [];
const powerTip = (userAdvocate?.powerTip || userAdvocate?.power_tip) as string | null;
const vibe = userAdvocate?.vibe as string | null;
const originStory = (userAdvocate?.originStory || userAdvocate?.origin_story) as string | null;
const idealFor = Array.isArray(userAdvocate?.idealFor || userAdvocate?.ideal_for) ? (userAdvocate?.idealFor || userAdvocate?.ideal_for) : [];
const avoidIf = Array.isArray(userAdvocate?.avoidIf || userAdvocate?.avoid_if) ? (userAdvocate?.avoidIf || userAdvocate?.avoid_if) : [];

// Fetch alternatives using hybrid search (vector similarity + category guardrails)
// Strategy: Compute live, cache at edge - no DB storage of computed relationships
const alternativesResponse = await getAlternatives(tool, { matchThreshold: 0.40, matchCount: 6 });
const alternativeIds = alternativesResponse.items.map(a => a.id);

// Fetch full data for alternatives (needed for micro-diffs and display)
const { data: alternatives } = alternativeIds.length > 0 ? await supabase
  .from('items')
  .select('id, name, slug, logo_url, short_description, avg_score, pricing_type, learning_curve, base_score, specs')
  .in('id', alternativeIds)
  .eq('type', 'tool') : { data: [] };

// Preserve similarity order from hybrid search
const orderedAlternatives = alternatives
  ? alternativeIds
      .map(id => alternatives.find(a => a.id === id))
      .filter(Boolean)
  : [];

// Track whether these are true "alternatives" or just "related tools"
const alternativesLabel = alternativesResponse.type === 'alternatives' ? 'Alternatives' : 'Related Tools';

// Compute micro-diffs for alternatives (Layer 2 - Computed)
const microDiffs = orderedAlternatives?.length
  ? computeMicroDiffs(
      { slug: tool.slug, name: tool.name, pricing_type: tool.pricing_type, learning_curve: tool.learning_curve, base_score: tool.base_score, specs: tool.specs },
      orderedAlternatives.map(alt => ({ slug: alt.slug, name: alt.name, pricing_type: alt.pricing_type, learning_curve: alt.learning_curve, base_score: alt.base_score, specs: alt.specs }))
    )
  : new Map();

// Fetch curated verdicts for alternatives (Layer 1 - Human Intelligence)
const altSlugs = orderedAlternatives?.map(a => a.slug) || [];
const curatedVerdicts = new Map<string, string>();

if (altSlugs.length > 0) {
  // Query comparison_insights where either slug is our tool
  const { data: insights } = await supabase
    .from('comparison_insights')
    .select('item_a_slug, item_b_slug, verdict')
    .or(`item_a_slug.eq.${tool.slug},item_b_slug.eq.${tool.slug}`)
    .not('verdict', 'is', null);

  for (const insight of insights || []) {
    // Determine which slug is the alternative
    const altSlug = insight.item_a_slug === tool.slug ? insight.item_b_slug : insight.item_a_slug;
    if (altSlugs.includes(altSlug) && insight.verdict) {
      curatedVerdicts.set(altSlug, insight.verdict);
    }
  }
}

const sourceDomains = firstReview?.sources
  ? [...new Set((firstReview.sources as Array<{domain: string}>).map(s => {
      const domain = s.domain.replace(/\.(com|org|net|io|co)$/, '');
      return domain.charAt(0).toUpperCase() + domain.slice(1);
    }))].slice(0, 5)
  : [];

// Fetch signal aggregates for community signals
// Note: Fetching via API to avoid TypeScript issues with complex joins
let signalAggregates: Array<{
  signal_key: string;
  signal_label: string;
  signal_category: string;
  option_key?: string;
  option_label?: string;
  count_total: number;
  count_positive: number;
  count_negative: number;
}> = [];

try {
  const signalResponse = await fetch(
    `${Astro.url.origin}/api/signals/aggregates?itemId=${tool.id}`
  );
  if (signalResponse.ok) {
    const result = await signalResponse.json();
    signalAggregates = result.aggregates || [];
  }
} catch (err) {
  console.error('Failed to fetch signal aggregates:', err);
}

// SEO: Automated confidence scoring for noindex decision
const confidence = evaluateContentConfidence(tool, firstReview);

const meta = {
  ...generateToolMeta(tool, tool.review_count),
  noindex: confidence.shouldNoindex,
};
const schemas = [
  generateToolSchema(tool, primaryOffer, tool.review_count),
  generateBreadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Tools', url: '/tools' },
    ...(tool.category ? [{ name: tool.category.name, url: `/categories/${tool.category.slug}` }] : []),
    { name: tool.name, url: `/tool/${tool.slug}` },
  ]),
  // Include VideoObject schema if video exists
  ...(tool.video_id ? [generateVideoSchema(tool, tool.video_id, tool.video_title || `${tool.name} Overview`)] : []),
];

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<BaseLayout meta={meta} schemas={schemas}>
  <AffiliateDisclosure variant="banner" hasAffiliateLinks={primaryOffer?.is_affiliate || false} />

  <div class="mx-auto max-w-5xl px-4 py-12 sm:px-6 lg:px-8">
    <!-- Breadcrumbs -->
    <nav class="mb-6 flex items-center gap-2 text-sm text-zinc-400">
      <a href="/" class="hover:text-hunt-500">Home</a>
      <span>/</span>
      <a href="/tools" class="hover:text-hunt-500">Tools</a>
      {tool.category && (
        <>
          <span>/</span>
          <a href={`/categories/${tool.category.slug}`} class="hover:text-hunt-500">
            {tool.category.name}
          </a>
        </>
      )}
      <span>/</span>
      <span class="text-zinc-300">{tool.name}</span>
    </nav>

    <!-- Verification Badge -->
    <div class="mb-6 flex flex-wrap items-start gap-4">
      <VerifiedBadge
        lastVerifiedAt={tool.last_verified_at}
        sourceCount={firstReview?.sources?.length || 0}
        size="md"
      />

      {/* Content Confidence Indicator (shown when noindexed or low confidence) */}
      {(confidence.shouldNoindex || confidence.score < 7) && (
        <div class:list={[
          'inline-flex items-center gap-2 rounded-lg border px-3 py-1.5 text-sm font-medium',
          confidence.shouldNoindex
            ? 'border-red-500/30 bg-red-500/10 text-red-400'
            : 'border-amber-500/30 bg-amber-500/10 text-amber-400'
        ]}>
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            {confidence.shouldNoindex ? (
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
            ) : (
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            )}
          </svg>
          <span>
            {confidence.shouldNoindex ? 'Noindexed' : 'Low Quality'}: {confidence.score.toFixed(1)}/10
          </span>
          {confidence.shouldNoindex && (
            <span class="text-xs opacity-75">
              ({confidence.reasons[0]})
            </span>
          )}
        </div>
      )}
    </div>

    <!-- Hero Section -->
    <header class="mb-12 rounded-2xl border-2 border-zinc-600 bg-gradient-to-br from-zinc-800 to-zinc-900 p-6 sm:p-8 shadow-lg">
      <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div class="flex items-start gap-5">
          <Logo domain={tool.logo_url} name={tool.name} size="xl" class="shrink-0 rounded-2xl border border-zinc-700 shadow-sm" />
          <div>
            <div class="flex items-center gap-3">
              <h1 class="text-2xl font-bold text-zinc-100 sm:text-3xl">{tool.name}</h1>
              {tool.is_verified && (
                <span class="flex items-center gap-1 rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-700">
                  <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                  Verified
                </span>
              )}
            </div>
            {(tool.short_description || knowledgeCard?.tagline) && (
              <div class="mt-2 space-y-1">
                {tool.short_description && <p class="text-zinc-300">{tool.short_description}</p>}
                {knowledgeCard?.tagline && knowledgeCard.tagline !== tool.short_description && (
                  <p class="text-sm text-zinc-400 italic">{knowledgeCard.tagline}</p>
                )}
              </div>
            )}
            <div class="mt-3 flex flex-wrap items-center gap-3">
              <PricingBadge type={tool.pricing_type} />
              {tool.category && (
                <a href={`/categories/${tool.category.slug}`} class="text-sm text-zinc-400 hover:text-hunt-500">
                  {tool.category.name}
                </a>
              )}
              {tool.website && (
                <a href={tool.website} target="_blank" rel="noopener" class="flex items-center gap-1 text-sm text-zinc-400 hover:text-hunt-500">
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
                  </svg>
                  Website
                </a>
              )}
            </div>
            {(tags.functions.length > 0 || tags.audiences.length > 0 || tags.platforms.length > 0) && (
              <div class="mt-4 flex flex-wrap gap-2">
                {tags.functions.map((tag) => (
                  <a
                    href={`/categories/${tag.slug}`}
                    class="inline-flex items-center rounded-full bg-blue-100 px-2.5 py-0.5 text-xs font-medium text-blue-800 hover:bg-blue-200 transition"
                  >
                    {tag.name}
                  </a>
                ))}
                {tags.audiences.map((tag) => (
                  <a
                    href={`/categories/${tag.slug}`}
                    class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800 hover:bg-green-200 transition"
                  >
                    {tag.name}
                  </a>
                ))}
                {tags.platforms.map((tag) => (
                  <a
                    href={`/categories/${tag.slug}`}
                    class="inline-flex items-center rounded-full bg-purple-100 px-2.5 py-0.5 text-xs font-medium text-purple-800 hover:bg-purple-200 transition"
                  >
                    {tag.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        </div>
        <div class="flex flex-col items-center gap-4 sm:items-end">
          {tool.avg_score > 0 && <ScoreBadge score={Math.round(tool.avg_score)} size="lg" showLabel />}
          {primaryOffer && <AffiliateButton offer={primaryOffer} toolName={tool.name} size="lg" />}
          <div class="flex flex-wrap gap-3 justify-center sm:justify-end">
            <CompareButton client:load toolSlug={tool.slug} toolName={tool.name} toolLogo={tool.logo_url} categorySlug={tool.category?.slug} categoryName={tool.category?.name} />
            <AddToStackButton client:load toolSlug={tool.slug} toolName={tool.name} toolLogo={tool.logo_url} pricing={{ starting_price: (tool.metadata as Record<string, unknown>)?.pricing?.starting_price ?? null, model: (tool.metadata as Record<string, unknown>)?.pricing?.model ?? tool.pricing_type }} />
          </div>
        </div>
      </div>
    </header>

    <!-- Main Content Grid -->
    <div class="grid gap-12 lg:grid-cols-3">
      <div class="space-y-12 lg:col-span-2">
        {/* Technical Highlights (Global, factual pros/cons) */}
        {(globalPros.length > 0 || globalCons.length > 0) && (
          <section class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="mb-2 text-lg font-semibold text-zinc-100">Technical Highlights</h2>
            <p class="mb-4 text-sm text-zinc-400">Objective capabilities and limitations (universally true).</p>
            <ProsCons pros={globalPros} cons={globalCons} sourceDisplay="toggle" />
          </section>
        )}

        {/* Community Signals - Aggregates (Read-only) */}
        {signalAggregates.length > 0 && (
          <SignalAggregatesBadge client:visible aggregates={signalAggregates} />
        )}

        {/* Community Signals - Report Widget (Phase 1) */}
        <SignalReportWidget client:visible itemId={tool.id} itemName={tool.name} phase={1} />

        {/* Review Summary */}
        {firstReview?.summary_markdown && (
          <section class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="mb-4 text-lg font-semibold text-zinc-100">Our Analysis</h2>
            <div class="prose prose-slate prose-sm max-w-none" set:html={simpleMarkdown(firstReview.summary_markdown)} />

            {/* Standout Features */}
            {firstReview.standout_features?.length > 0 && (
              <div class="mt-6 border-t border-zinc-800 pt-4">
                <h3 class="text-sm font-medium text-zinc-300 mb-2">Standout Features</h3>
                <div class="flex flex-wrap gap-2">
                  {firstReview.standout_features.map((feature: string) => (
                    <span class="inline-flex items-center rounded-full bg-green-100 px-2.5 py-0.5 text-xs font-medium text-green-800">
                      <svg class="h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                      </svg>
                      {feature}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {/* Dealbreakers */}
            {firstReview.dealbreakers?.length > 0 && (
              <div class="mt-4 border-t border-zinc-800 pt-4">
                <h3 class="text-sm font-medium text-zinc-300 mb-2">Potential Dealbreakers</h3>
                <div class="flex flex-wrap gap-2">
                  {firstReview.dealbreakers.map((dealbreaker: string) => (
                    <span class="inline-flex items-center rounded-full bg-red-100 px-2.5 py-0.5 text-xs font-medium text-red-800">
                      <svg class="h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                      </svg>
                      {dealbreaker}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {/* Value Rating and Fit Score */}
            {(firstReview.value_rating || firstReview.fit_score) && (
              <div class="mt-4 border-t border-zinc-800 pt-4 flex flex-wrap gap-4">
                {firstReview.value_rating && (
                  <div class="flex items-center gap-2">
                    <span class="text-sm text-zinc-400">Value:</span>
                    <div class="flex">
                      {[1, 2, 3, 4, 5].map((star) => (
                        <svg class={`h-4 w-4 ${star <= firstReview.value_rating ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                        </svg>
                      ))}
                    </div>
                  </div>
                )}
                {firstReview.fit_score && (
                  <div class="flex items-center gap-2">
                    <span class="text-sm text-zinc-400">Context Fit:</span>
                    <span class="text-sm font-medium text-zinc-300">{firstReview.fit_score}%</span>
                  </div>
                )}
              </div>
            )}

            {/* Switching From */}
            {firstReview.switching_from?.length > 0 && (
              <div class="mt-4 border-t border-zinc-800 pt-4">
                <span class="text-xs text-zinc-400">Users often switch from: </span>
                <span class="text-xs text-zinc-300">{firstReview.switching_from.join(', ')}</span>
              </div>
            )}

            {firstReview.sentiment_tags?.length > 0 && (
              <div class="mt-6 border-t border-zinc-800 pt-4">
                <SentimentTags tags={firstReview.sentiment_tags} />
              </div>
            )}
            <div class="mt-6 flex items-center justify-between border-t border-zinc-800 pt-4">
              <span class="text-sm text-zinc-400">Was this helpful?</span>
              <VoteWidget client:visible reviewId={firstReview.id} initialUpvotes={firstReview.upvotes} initialDownvotes={firstReview.downvotes} turnstileSiteKey={turnstileSiteKey} />
            </div>
            <div class="mt-4 flex items-center justify-between border-t border-zinc-800 pt-4">
              {sourceDomains.length > 0 && (
                <div class="flex items-center gap-2 text-xs text-zinc-500">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                  <span>Sources: {sourceDomains.join(', ')}</span>
                </div>
              )}
              <button type="button" data-suggest-edit data-tool-id={tool.id} data-tool-name={tool.name} class="text-xs text-zinc-500 hover:text-hunt-600 transition">
                See something wrong? Suggest an edit
              </button>
            </div>
          </section>
        )}

        {/* About */}
        {tool.long_description && (
          <section class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow">
            <h2 class="mb-4 text-lg font-semibold text-zinc-100">About {tool.name}</h2>
            <div class="prose prose-slate max-w-none text-zinc-300 leading-relaxed" set:html={simpleMarkdown(tool.long_description)} />
          </section>
        )}

        {/* Tribal Knowledge (V3.1: Split-Brain Intelligence) */}
        <TribalKnowledge
          userAdvocate={userAdvocate ? {
            vibe,
            originStory,
            idealFor,
            avoidIf,
            powerTip,
            delighters,
            frustrations,
          } : undefined}
          humanVerdict={humanVerdict}
        />

        {/* Contextual Pros & Cons (for SEO + audience-specific signal) */}
        {firstReview && (firstReview.pros?.length > 0 || firstReview.cons?.length > 0) && (
          <ProsCons
            pros={firstReview.pros || []}
            cons={firstReview.cons || []}
            title="Contextual Pros & Cons"
            sourceDisplay="toggle"
          />
        )}

        {/* Features Showcase */}
        {(knowledgeCard?.features?.core?.length > 0 || knowledgeCard?.features?.unique?.length > 0) && (
          <FeaturesShowcase
            features={knowledgeCard.features}
            toolName={tool.name}
          />
        )}

        {/* Pricing Plans */}
        {(knowledgeCard?.smp_pricing || knowledgeCard?.pricing?.tiers?.length > 0) && (
          <div id="pricing-plans">
            <PricingPlansGrid
              smp_pricing={knowledgeCard?.smp_pricing}
              legacy_pricing={knowledgeCard?.pricing}
              toolName={tool.name}
            >
              <PriceVerification
                slot="verification"
                client:visible
                toolId={tool.id}
                toolName={tool.name}
                currentPrice={knowledgeCard?.pricing?.starting_price}
                pricingType={tool.pricing_type}
                verificationCount={tool.user_verifications_this_week || 0}
                variant="inline"
              />
            </PricingPlansGrid>
          </div>
        )}

        {/* Platform Support & Integrations */}
        {(knowledgeCard?.platforms?.length > 0 || knowledgeCard?.integrations) && (
          <PlatformIntegrations
            platforms={knowledgeCard.platforms || []}
            integrations={knowledgeCard.integrations}
            toolName={tool.name}
          />
        )}

        {/* Video Embed - Bottom of content for better UX */}
        {tool.video_id && (
          <section>
            <h2 class="mb-4 text-lg font-semibold text-zinc-100">Watch {tool.name} in Action</h2>
            <VideoEmbed client:visible id={tool.video_id} title={tool.video_title || `${tool.name} Overview`} />
          </section>
        )}

        {/* Included Tools (if this is a parent suite) */}
        <IncludedTools toolId={tool.id} toolName={tool.name} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-6 lg:sticky lg:top-8 lg:self-start">
        {/* Quick Stats - Moved to top for quick scanning */}
        <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
          <h3 class="mb-4 font-semibold text-zinc-100">Quick Stats</h3>
          <dl class="space-y-3">
            <div class="flex justify-between">
              <dt class="text-sm text-zinc-400">Overall Score</dt>
              <dd class="text-sm font-medium text-zinc-100">{tool.avg_score > 0 ? `${Math.round(tool.avg_score)}/100` : 'N/A'}</dd>
            </div>
            <div class="flex justify-between">
              <dt class="text-sm text-zinc-400">Reviews</dt>
              <dd class="text-sm font-medium text-zinc-100">{tool.review_count}</dd>
            </div>
            {tool.category && (
              <div class="flex justify-between">
                <dt class="text-sm text-zinc-400">Category</dt>
                <dd class="text-sm font-medium text-zinc-100">{tool.category.name}</dd>
              </div>
            )}
          </dl>
          {tool.data_confidence && tool.data_confidence < 0.8 && (
            <div class="mt-4 rounded-lg border border-amber-700 bg-amber-900/30 px-3 py-2 text-xs text-amber-400">
              <svg class="inline-block h-3 w-3 mr-1" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
              Some data may be approximate
            </div>
          )}
        </div>

        {/* Company Info */}
        {knowledgeCard && (
          <CompanyInfo
            company={knowledgeCard.company}
            audience={knowledgeCard.audience}
            learningCurve={tool.learning_curve}
          />
        )}

        {/* Pricing Insights (Budget Analyst) */}
        <PricingInsights budgetAnalyst={budgetAnalyst ? {
          costDrivers: Array.isArray(budgetAnalyst.costDrivers || budgetAnalyst.cost_drivers) ? (budgetAnalyst.costDrivers || budgetAnalyst.cost_drivers) : [],
          oneTimeFees: Array.isArray(budgetAnalyst.oneTimeFees || budgetAnalyst.one_time_fees) ? (budgetAnalyst.oneTimeFees || budgetAnalyst.one_time_fees) : [],
          commitmentTerms: (budgetAnalyst.commitmentTerms || budgetAnalyst.commitment_terms) as string | null | undefined,
          roiThreshold: (budgetAnalyst.roiThreshold || budgetAnalyst.roi_threshold) as string | null | undefined,
        } : undefined} />

        {/* Suite Navigation (if part of a bundle) */}
        {parentTool && (
          <SuiteNavigation
            currentToolId={tool.id}
            parentId={parentTool.id}
            parentName={parentTool.name}
          />
        )}

        {/* Related Links (SEO internal linking) */}
        {relatedLinks.length > 0 && (
          <RelatedLinks
            title="Related Pages"
            links={relatedLinks}
            variant="compact"
          />
        )}

        {/* Security & Compliance */}
        {knowledgeCard?.security && (
          <SecurityCompliance security={knowledgeCard.security} />
        )}

        {/* Support Options */}
        {knowledgeCard?.support && (
          <SupportOptions support={knowledgeCard.support} />
        )}

        {/* Portability */}
        {knowledgeCard?.smp_portability && (
          <PortabilityCard
            portability={knowledgeCard.smp_portability}
            toolName={tool.name}
          />
        )}

        {tool.affiliate_offers && tool.affiliate_offers.length > 1 && (
          <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
            <h3 class="mb-4 font-semibold text-zinc-100">Get {tool.name}</h3>
            <div class="space-y-3">
              {tool.affiliate_offers.map((offer) => (
                <a href={offer.url} target="_blank" rel={offer.is_affiliate ? 'nofollow sponsored noopener' : 'noopener'} class="flex items-center justify-between rounded-lg border border-zinc-800 p-3 transition hover:border-hunt-200 hover:bg-hunt-50">
                  <span class="text-sm font-medium text-zinc-300">{offer.cta_text}</span>
                  <svg class="h-4 w-4 text-zinc-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>

    {/* Alternatives Section - Hybrid Search Strategy */}
    {orderedAlternatives && orderedAlternatives.length > 0 && (
      <section class="mt-16">
        <header class="mb-6">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
            <div>
              <h2 class="text-2xl font-semibold text-zinc-100">{alternativesLabel} to {tool.name}</h2>
              <p class="mt-1 text-sm text-zinc-400">
                {alternativesResponse.type === 'alternatives'
                  ? `Other ${tool.specs?.taxonomy?.primary_function?.toLowerCase() || tool.category?.name?.toLowerCase() || ''} tools to consider`
                  : 'Similar tools you might find useful'}
              </p>
            </div>
            {tool.category && (
              <a href={`/categories/${tool.category.slug}`} class="text-sm text-hunt-500 hover:text-hunt-400 transition shrink-0">
                View all →
              </a>
            )}
          </div>
        </header>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {orderedAlternatives.map((alt) => (
            <AlternativeCard
              main={{ slug: tool.slug, name: tool.name, pricing_type: tool.pricing_type, learning_curve: tool.learning_curve, base_score: tool.base_score }}
              alt={alt}
              curatedVerdict={curatedVerdicts.get(alt.slug)}
              computedDiff={microDiffs.get(alt.slug)}
            />
          ))}
        </div>
      </section>
    )}

    {/* Spiderweb */}
    {contextLinks && contextLinks.length > 0 && (
      <div class="mt-16">
        <SpiderwebGrid contexts={contextLinks.map((cl) => ({ id: cl.context.id, title: cl.context.title, slug: cl.context.slug, score: cl.score, tool_count: cl.context.tool_count }))} currentToolName={tool.name} limit={9} />
      </div>
    )}

    {/* Content Update Request */}
    <div class="mt-16 rounded-xl border border-amber-700/50 bg-amber-900/20 p-6">
      <div class="flex items-start gap-4">
        <div class="flex-1">
          <h3 class="text-lg font-semibold text-zinc-100 mb-2">Notice outdated information?</h3>
          <p class="text-sm text-zinc-400 mb-4">
            Help us keep {tool.name} up to date. Report outdated pricing, features, or other inaccuracies and we'll re-verify the data.
          </p>
          <button
            type="button"
            data-feedback-toggle
            class="inline-flex items-center gap-2 rounded-lg bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700 transition"
          >
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            Report Outdated Info
          </button>
        </div>
        <svg class="h-12 w-12 text-amber-700/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>
  </div>

  <!-- Content Update Modal -->
  <div id="feedback-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 p-4 backdrop-blur-sm">
    <div class="w-full max-w-lg rounded-xl bg-zinc-900 border border-amber-700/50 p-6 shadow-2xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-zinc-100">Report Outdated Information</h3>
        <button type="button" data-feedback-close class="text-zinc-500 hover:text-zinc-300 transition">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="feedback-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={tool.id} />
        <input type="hidden" name="tool_name" value={tool.name} />
        <input type="hidden" name="page_url" value={`/tool/${tool.slug}`} />

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-2">What's outdated?</label>
          <select
            name="feedback_type"
            required
            class="w-full rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-2 text-sm text-zinc-100 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20"
          >
            <option value="">Select what needs updating...</option>
            <option value="incorrect_pricing">Pricing changed</option>
            <option value="incorrect_features">Features changed</option>
            <option value="outdated_info">General info is outdated</option>
            <option value="missing_info">Missing important details</option>
            <option value="broken_link">Broken link</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-2">
            What's the current/correct information? <span class="text-zinc-500">(required)</span>
          </label>
          <textarea
            name="feedback_text"
            rows="4"
            required
            maxlength="1000"
            placeholder="e.g., 'Pricing is now $29/month, not $19/month' or 'They added SSO support in the Pro plan'"
            class="w-full rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20"
          ></textarea>
          <p class="mt-1 text-xs text-zinc-500">Be specific so we can verify and update quickly</p>
        </div>

        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-2">
            Your email <span class="text-zinc-500">(optional)</span>
          </label>
          <input
            type="email"
            name="reporter_email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-2 text-sm text-zinc-100 placeholder-zinc-500 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/20"
          />
          <p class="mt-1 text-xs text-zinc-500">We'll notify you when we've updated the information</p>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 rounded-lg bg-amber-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-amber-700 transition disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Submit Report
          </button>
          <button
            type="button"
            data-feedback-close
            class="rounded-lg border border-zinc-700 px-4 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-800 transition"
          >
            Cancel
          </button>
        </div>
      </form>

      <div id="feedback-success" class="hidden text-center py-6">
        <svg class="mx-auto h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-4 text-sm text-zinc-300">Thanks for the report!</p>
        <p class="mt-1 text-xs text-zinc-500">We'll re-verify this information within 24-48 hours.</p>
        <button
          type="button"
          data-feedback-close
          class="mt-4 text-sm text-amber-500 hover:text-amber-400 transition"
        >
          Close
        </button>
      </div>
    </div>
  </div>

  <!-- Suggest Edit Modal -->
  <div id="suggest-edit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-xl bg-zinc-900 p-6 shadow-xl">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-lg font-semibold text-zinc-100">Suggest an Edit</h3>
        <button type="button" data-close-modal class="text-zinc-500 hover:text-zinc-300">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
      <form id="suggest-edit-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={tool.id} />
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">What needs correcting?</label>
          <select name="field_name" class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20">
            <option value="pricing">Pricing information</option>
            <option value="pros">Pros</option>
            <option value="cons">Cons</option>
            <option value="summary">Summary/description</option>
            <option value="score">Score seems off</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">What's the correct information?</label>
          <textarea name="correction_text" rows="3" required placeholder="e.g., The pricing has changed to $15/month..." class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">Your email (optional)</label>
          <input type="email" name="reporter_email" placeholder="you@example.com" class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20" />
          <p class="mt-1 text-xs text-zinc-500">We'll notify you when the correction is reviewed</p>
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button type="submit" class="flex-1 rounded-lg bg-hunt-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-hunt-700 transition">Submit Suggestion</button>
          <button type="button" data-close-modal class="rounded-lg border border-zinc-700 px-4 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-900 transition">Cancel</button>
        </div>
      </form>
      <div id="suggest-edit-success" class="hidden text-center py-4">
        <svg class="mx-auto h-12 w-12 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <p class="mt-3 text-sm text-zinc-300">Thanks! We'll review your suggestion.</p>
        <button type="button" data-close-modal class="mt-4 text-sm text-hunt-600 hover:text-hunt-700">Close</button>
      </div>
    </div>
  </div>

  <script is:inline>
    // Suggest Edit Modal
    const modal = document.getElementById('suggest-edit-modal');
    const form = document.getElementById('suggest-edit-form');
    const success = document.getElementById('suggest-edit-success');
    document.querySelectorAll('[data-suggest-edit]').forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.remove('hidden');
        modal?.classList.add('flex');
        form?.classList.remove('hidden');
        success?.classList.add('hidden');
      });
    });
    document.querySelectorAll('[data-close-modal]').forEach(btn => {
      btn.addEventListener('click', () => {
        modal?.classList.add('hidden');
        modal?.classList.remove('flex');
      });
    });
    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }
    });
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      try {
        const res = await fetch('/api/corrections', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        if (res.ok) {
          form.classList.add('hidden');
          success?.classList.remove('hidden');
          form.reset();
        } else {
          alert('Failed to submit. Please try again.');
        }
      } catch (err) {
        alert('Network error. Please try again.');
      }
    });

    // Feedback Modal
    const feedbackModal = document.getElementById('feedback-modal');
    const feedbackForm = document.getElementById('feedback-form');
    const feedbackSuccess = document.getElementById('feedback-success');

    document.querySelectorAll('[data-feedback-toggle]').forEach(btn => {
      btn.addEventListener('click', () => {
        feedbackModal?.classList.remove('hidden');
        feedbackModal?.classList.add('flex');
        feedbackForm?.classList.remove('hidden');
        feedbackSuccess?.classList.add('hidden');
      });
    });

    document.querySelectorAll('[data-feedback-close]').forEach(btn => {
      btn.addEventListener('click', () => {
        feedbackModal?.classList.add('hidden');
        feedbackModal?.classList.remove('flex');
      });
    });

    feedbackModal?.addEventListener('click', (e) => {
      if (e.target === feedbackModal) {
        feedbackModal.classList.add('hidden');
        feedbackModal.classList.remove('flex');
      }
    });

    feedbackForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = e.target.querySelector('button[type="submit"]');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Sending...';
      }

      const formData = new FormData(feedbackForm);
      const data = Object.fromEntries(formData);

      try {
        const res = await fetch('/api/feedback', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          feedbackForm?.classList.add('hidden');
          feedbackSuccess?.classList.remove('hidden');
          feedbackForm?.reset();
        } else {
          alert('Failed to submit feedback. Please try again.');
        }
      } catch (err) {
        alert('Network error. Please try again.');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.textContent = 'Submit Feedback';
        }
      }
    });
  </script>
</BaseLayout>
