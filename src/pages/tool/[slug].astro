                <p class="mb-3 text-xs text-zinc-500">{specsSectionState.checkedLead}</p>
              )}
              <DynamicSpecs
                categorySpecificData={specsProps.categorySpecificData}
                specifics={specsProps.specifics}
                toolName={specsProps.toolName}
                categoryName={specsProps.categoryName}
              />
            </section>
          )
        }
        {
          showProceduralSpecs && (
            <section
              id="specs"
              class="rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm"
              data-focus-target
              data-focus-groups="all capabilities"
            >
              <h2 class="text-lg font-semibold text-zinc-100">Technical Validation Steps</h2>
              <ul class="mt-4 space-y-2 text-sm text-zinc-300">
                <li>- Confirm API limits and throttling behavior using your expected peak load.</li>
                <li>
                  - Verify export formats and data portability before onboarding large datasets.
                </li>
                <li>
                  - Check release cadence and changelog quality for operational predictability.
                </li>
                <li>- Validate admin controls needed by your security/compliance process.</li>
              </ul>
            </section>
          )
        }
        {/* Field Notes (source-backed user signal summary) */}
        {
          tribalKnowledgeProps.shouldShow && (
            <div data-focus-target data-focus-groups="all verdict capabilities">
              <TribalKnowledge
                userAdvocate={tribalKnowledgeProps.userAdvocate}
                humanVerdict={tribalKnowledgeProps.humanVerdict}
              />
            </div>
          )
        }

        {/* Platform Support & Integrations */}
        {
          platformSectionState.shouldShow && (
            <div data-focus-target data-focus-groups="all integrations capabilities">
              {activeReviewLens !== 'general' && activeLensIntegrationCount !== null && (
                <p class="mb-2 text-xs text-zinc-500">
                  Lens coverage, {activeLensLabelMap[activeReviewLens]}:{' '}
                  {activeLensIntegrationCount} integration
                  {activeLensIntegrationCount === 1 ? '' : 's'} tagged.
                </p>
              )}
              <PlatformIntegrations
                platforms={platformSectionState.platforms}
                integrations={platformSectionState.integrations}
                toolName={tool.name}
                sectionId="platform-integrations"
                activeReviewLens={activeReviewLens}
              />
            </div>
          )
        }

        {/* About - Deep context after decision, pricing, and rollout guidance */}
        {
          hasAbout && (
            <details
              id="about"
              class="group rounded-xl border border-zinc-700 bg-zinc-900 p-6 shadow-sm hover:shadow-md transition-shadow"
              data-focus-target
              data-focus-groups="all capabilities"
            >
              <summary class="flex items-center justify-between cursor-pointer">
                <h2 class="text-lg font-semibold text-zinc-100">About {tool.name}</h2>
                <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
                  <span class="group-open:hidden">Expand</span>
                  <span class="hidden group-open:inline">Collapse</span>
                  <svg
                    class="h-4 w-4 transition-transform group-open:rotate-90"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </span>
              </summary>
              <div
                class="mt-4 prose prose-slate max-w-none text-zinc-300 leading-relaxed"
                set:html={simpleMarkdown(aboutContent.body)}
              />
            </details>
          )
        }

        {/* Video Embed - Bottom of content for better UX */}
        {
          videoState.hasVideo && (
            <section id="video" data-focus-target data-focus-groups="all capabilities">
              <h2 class="mb-4 text-lg font-semibold text-zinc-100">Watch {tool.name} in Action</h2>
              <VideoEmbed client:visible id={tool.video_id} title={videoProps.title} />
            </section>
          )
        }

        {/* Included Tools (if this is a parent suite) */}
        <IncludedTools toolId={tool.id} toolName={tool.name} />
      </div>

      <!-- Sidebar -->
      <div class="space-y-6 lg:sticky lg:top-8 lg:self-start">
        {
          hasOperationalDetails && (
            <details
              class="group rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm"
              data-focus-target
              data-focus-groups="all capabilities integrations trust"
            >
              <summary class="flex cursor-pointer list-none items-center justify-between">
                <h3 class="font-semibold text-zinc-100">Operational details</h3>
                <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
                  <span class="group-open:hidden">Expand</span>
                  <span class="hidden group-open:inline">Collapse</span>
                </span>
              </summary>
              <div class="mt-4 space-y-6">
                {/* Company Info */}
                {operationalDetailsState.showCompanyInfo && (
                  <CompanyInfo
                    company={knowledgeCard.company}
                    audience={knowledgeCard.audience}
                    learningCurve={tool.learning_curve}
                  />
                )}

                {/* Suite Navigation (if part of a bundle) */}
                {operationalDetailsState.showSuiteNavigation && (
                  <SuiteNavigation
                    currentToolId={tool.id}
                    parentId={parentTool.id}
                    parentName={parentTool.name}
                  />
                )}

                {/* Security & Compliance */}
                {operationalDetailsState.showSecurity && (
                  <SecurityCompliance security={knowledgeCard.security} />
                )}

                {/* Support Options */}
                {operationalDetailsState.showSupport && (
                  <SupportOptions support={knowledgeCard.support} />
                )}

                {/* Portability */}
                {operationalDetailsState.showPortability && (
                  <PortabilityCard
                    portability={knowledgeCard.smp_portability}
                    toolName={tool.name}
                  />
                )}
              </div>
            </details>
          )
        }

        {
          affiliateOffersView.shouldShow && (
            <div class="rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm">
              <h3 class="mb-4 font-semibold text-zinc-100">Get {tool.name}</h3>
              <div class="space-y-3">
                {affiliateOffersView.offers.map((offer) => (
                  <a
                    href={offer.url}
                    target="_blank"
                    rel={offer.rel}
                    data-outbound="vendor"
                    data-location="sidebar-offers"
                    data-tool={tool.slug}
                    class="flex items-center justify-between rounded-lg border border-zinc-800 p-3 transition hover:border-hunt-200 hover:bg-hunt-50"
                  >
                    <span class="text-sm font-medium text-zinc-300">{offer.ctaText}</span>
                    <svg
                      class="h-4 w-4 text-zinc-500"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </div>

    {/* FAQ - Visible content to match FAQ schema */}
    {
      hasFAQ && (
        <section
          id="faq"
          class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 p-5"
          data-focus-target
          data-focus-groups="all capabilities trust"
        >
          <h2 class="mb-4 text-lg font-semibold text-zinc-100">FAQ</h2>
          <div class="space-y-4">
            {faqItemsView.map((item) => (
              <details class="group rounded-lg border border-zinc-800 bg-zinc-900 p-4">
                <summary class="flex items-center justify-between cursor-pointer">
                  <h3 class="text-sm font-semibold text-zinc-100">{item.question}</h3>
                  <svg
                    class="h-4 w-4 text-zinc-400 transition-transform group-open:rotate-90 md:hidden"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 5l7 7-7 7"
                    />
                  </svg>
                </summary>
                <div class="mt-2 space-y-2">
                  <p class="text-sm text-zinc-300">{item.answer}</p>
                  {item.hasSourceLink && (
                    <a
                      href={item.answer_source_url}
                      target="_blank"
                      rel="noopener"
                      aria-label={sourceAriaLabel(item.question)}
                      data-outbound="source"
                      data-location="faq"
                      data-tool={tool.slug}
                      class="inline-flex items-center gap-1 text-xs text-zinc-300 underline underline-offset-2 hover:text-hunt-500"
                    >
                      Answer source
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                        />
                      </svg>
                    </a>
                  )}
                </div>
              </details>
            ))}
          </div>
        </section>
      )
    }

    {/* Alternatives Section - Hybrid Search Strategy */}
    {
      hasAlternatives && (
        <section id="alternatives" class="mt-16" data-focus-target data-focus-groups="all verdict">
          <header class="mb-6">
            <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
              <div>
                <h2 class="text-2xl font-semibold text-zinc-100">
                  {alternativesLabel} to {tool.name}
                </h2>
                <p class="mt-1 text-sm text-zinc-400">{alternativesIntroText}</p>
                {activeReviewLens !== 'general' && (
                  <p class="mt-1 text-xs text-zinc-500">
                    Alternatives are prioritized for the current review lens.
                  </p>
                )}
                {qualityState.communityCorroborationCount > 0 && (
                  <p class="mt-1 text-xs text-zinc-500">
                    Includes signals corroborated across {qualityState.communityCorroborationCount}{' '}
                    community domains.
                  </p>
                )}
              </div>
              {alternativesSectionState.viewAllHref && (
                <a
                  href={alternativesSectionState.viewAllHref}
                  class="text-sm text-hunt-500 hover:text-hunt-400 transition shrink-0"
                >
                  View all →
                </a>
              )}
            </div>
          </header>

          <AlternativesCompareGrid
            main={{
              name: tool.name,
              slug: tool.slug,
              pricing_type: tool.pricing_type,
              learning_curve: tool.learning_curve,
            }}
            alternatives={alternativeCardsView.map((entry) => ({
              name: entry.alt.name,
              slug: entry.alt.slug,
              pricing_type: entry.alt.pricing_type,
              learning_curve: entry.alt.learning_curve,
              curatedVerdict: curatedVerdictEntries.get(entry.alt.slug)?.verdict || null,
              computedDiff: microDiffs.get(entry.alt.slug) || null,
            }))}
            asOfLabel={freshnessLabels.verdictAsOfLabel}
            activeReviewLens={activeReviewLens}
          />
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {alternativeCardsView.map((entry) => (
              <AlternativeCard
                main={{
                  slug: tool.slug,
                  name: tool.name,
                  pricing_type: tool.pricing_type,
                  learning_curve: tool.learning_curve,
                  base_score: tool.base_score,
                }}
                alt={entry.alt}
                curatedVerdict={curatedVerdictEntries.get(entry.alt.slug)?.verdict || null}
                curatedVerdictUpdatedAt={
                  curatedVerdictEntries.get(entry.alt.slug)?.updatedAt || null
                }
                computedDiff={microDiffs.get(entry.alt.slug)}
                showCompareLink={entry.showCompareLink}
              />
            ))}
          </div>
        </section>
      )
    }

    <ToolHowWeEvaluateSection
      evaluationDepth={evaluationDepth}
      hasCollectedSources={hasCollectedSources}
      testedItems={testedItems}
      notTestedItems={notTestedItems}
    />

    {
      showWeTestedIt && (
        <ToolWeTestedSection
          testedAtLabel={handsOnTestedAtLabel}
          testEnvironment={handsOnTestEnvironment}
          testSteps={handsOnTestSteps}
          testFindings={handsOnTestFindings}
        />
      )
    }

    {
      sourcesSectionState.hasSources && (
        <section
          id="sources"
          class="mt-12 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm"
          data-focus-target
          data-focus-groups="all trust"
        >
          <details class="group mb-4 rounded-lg border border-zinc-800 bg-zinc-950/50 p-3">
            <summary class="flex cursor-pointer list-none items-center justify-between">
              <span class="text-sm font-medium text-zinc-300">Trust details</span>
              <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
                <span class="group-open:hidden">Expand</span>
                <span class="hidden group-open:inline">Collapse</span>
              </span>
            </summary>
            <div class="mt-3">
              <TrustBar
                status={trustBarProps.status}
                pendingCount={trustBarProps.pendingCount}
                evaluationDepth={trustBarProps.evaluationDepth}
                lastChecked={trustBarProps.lastChecked}
                confidence={trustBarProps.confidence}
                sourcesCount={trustBarProps.sourcesCount}
              />
            </div>
          </details>
          <h2 class="text-lg font-semibold text-zinc-100">Methodology & Sources</h2>
          <div class="mt-3 flex flex-wrap gap-2">
            {evidenceBasisChips.map((chip) => (
              <span class="rounded-full border border-zinc-700 bg-zinc-800 px-2.5 py-1 text-xs text-zinc-300">
                {chip.text}
              </span>
            ))}
          </div>
          <details class="mt-4 rounded-lg border border-zinc-800 bg-zinc-950/60 p-3">
            <summary class="cursor-pointer text-sm text-zinc-300">View sources</summary>
            <ul class="mt-3 space-y-2 text-sm">
              {sourceListsView.methodologyLinks.map((source) => (
                <li>
                  <a
                    href={source.url}
                    target="_blank"
                    rel="noopener"
                    data-outbound="source"
                    data-location="methodology-sources"
                    data-tool={tool.slug}
                    class="text-zinc-300 hover:text-hunt-500"
                  >
                    {source.title}
                  </a>
                  <span class="ml-2 text-xs text-zinc-500">
                    {source.domain} · {source.basis} · {source.quality} confidence ·{' '}
                    {source.inclusionReason}
                  </span>
                </li>
              ))}
            </ul>
            {lowConfidenceSourcesState.show && (
              <div class="mt-4 rounded-lg border border-amber-700/30 bg-amber-950/20 p-3">
                <p class="text-xs font-semibold uppercase tracking-wide text-amber-300">
                  {lowConfidenceSourcesState.title}
                </p>
                <ul class="mt-2 space-y-1 text-xs text-zinc-400">
                  {sourceListsView.lowConfidenceLinks.map((source) => (
                    <li>
                      {source.domain} · {source.inclusionReason}
                    </li>
                  ))}
                </ul>
              </div>
            )}
          </details>
        </section>
      )
    }

    {
      updateHistoryState.hasUpdates && (
        <details
          id="update-history"
          class="group mt-12 rounded-xl border border-zinc-700 bg-zinc-900 p-5 shadow-sm"
          data-focus-target
          data-focus-groups="all trust"
        >
          <summary class="flex cursor-pointer list-none items-center justify-between">
            <div>
              <h2 class="text-lg font-semibold text-zinc-100">Update History</h2>
              <p class="mt-1 text-sm text-zinc-400">
                Last update {updateHistoryLabels.lastUpdateLabel} • Last check{' '}
                {updateHistoryLabels.lastCheckLabel}
              </p>
            </div>
            <span class="inline-flex items-center gap-2 text-xs text-zinc-400">
              <span class="group-open:hidden">Expand</span>
              <span class="hidden group-open:inline">Collapse</span>
            </span>
          </summary>
          <ul class="mt-4 space-y-3 text-sm text-zinc-300">
            {updateHistoryEntries.map((entry) => (
              <li class="rounded-lg border border-zinc-800 bg-zinc-950/40 p-3">
                <p class="font-medium text-zinc-100">{entry.date}</p>
                <p class="mt-1">{entry.what}</p>
                <p class="mt-1 text-xs text-zinc-500">Why: {entry.why}</p>
                {entry.source && (
                  <a
                    href={entry.source}
                    target="_blank"
                    rel="noopener"
                    class="mt-1 inline-flex text-xs text-zinc-300 underline underline-offset-2 hover:text-hunt-500"
                  >
                    Source
                  </a>
                )}
              </li>
            ))}
          </ul>
        </details>
      )
    }
  </div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    {/* Community Feedback - Compact consolidated section */}
    {
      hasCommunity && (
        <section
          id="community"
          class="mt-12 rounded-xl border border-zinc-800 bg-zinc-900/50 p-5"
          data-focus-target
          data-focus-groups="all trust verdict"
        >
          {communityVerifiedLabel && (
            <p class="mb-3 text-xs text-zinc-500">
              Community signals checked {communityVerifiedLabel}
            </p>
          )}
          <SignalReportWidget client:visible itemId={tool.id} itemName={tool.name} phase={1} />
          <div class="sm:text-right shrink-0">
            <button
              type="button"
              data-suggest-edit
              data-tool-id={tool.id}
              data-tool-name={tool.name}
              class="inline-flex items-center gap-2 rounded-lg border border-zinc-700 bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:bg-zinc-700 hover:text-zinc-300 hover:border-zinc-600 transition"
            >
              <svg
                class="h-3.5 w-3.5"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                />
              </svg>
              Report correction
            </button>
          </div>
        </section>
      )
    }
  </div>

  <!-- Suggest Edit Modal -->
  <div
    id="suggest-edit-modal"
    class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4"
    role="dialog"
    aria-modal="true"
    aria-labelledby="suggest-edit-title"
    aria-hidden="true"
  >
    <div
      class="w-full max-w-md rounded-xl bg-zinc-900 p-6 shadow-xl"
      tabindex="-1"
      data-modal-panel
    >
      <div class="flex items-center justify-between mb-4">
        <h3 id="suggest-edit-title" class="text-lg font-semibold text-zinc-100">Suggest an Edit</h3>
        <button
          type="button"
          data-close-modal
          aria-label="Close suggest edit dialog"
          class="text-zinc-500 hover:text-zinc-300"
        >
          <svg
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <form id="suggest-edit-form" class="space-y-4">
        <input type="hidden" name="tool_id" value={tool.id} />
        <input type="text" name="company_name" tabindex="-1" autocomplete="off" class="hidden" />
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">What needs correcting?</label>
          <select
            name="field_name"
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          >
            <option value="pricing">Pricing information</option>
            <option value="pros">Pros</option>
            <option value="cons">Cons</option>
            <option value="summary">Summary/description</option>
            <option value="score">Score seems off</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1"
            >What's the correct information?</label
          >
          <textarea
            name="correction_text"
            rows="3"
            required
            placeholder="e.g., The pricing has changed to $15/month..."
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          ></textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-zinc-300 mb-1">Your email (optional)</label>
          <input
            type="email"
            name="reporter_email"
            placeholder="you@example.com"
            class="w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-hunt-500 focus:outline-none focus:ring-2 focus:ring-hunt-500/20"
          />
          <p class="mt-1 text-xs text-zinc-500">We'll notify you when the correction is reviewed</p>
        </div>
        <div class="flex items-center gap-3 pt-2">
          <button
            type="submit"
            class="flex-1 rounded-lg bg-hunt-600 px-4 py-2.5 text-sm font-medium text-white hover:bg-hunt-700 transition"
            >Submit Suggestion</button
          >
          <button
            type="button"
            data-close-modal
            class="rounded-lg border border-zinc-700 px-4 py-2.5 text-sm font-medium text-zinc-300 hover:bg-zinc-900 transition"
            >Cancel</button
          >
        </div>
      </form>
      <div id="suggest-edit-success" class="hidden text-center py-4">
        <svg
          class="mx-auto h-12 w-12 text-green-500"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="mt-3 text-sm text-zinc-300">Thanks! We'll review your suggestion.</p>
        <button
          type="button"
          data-close-modal
          class="mt-4 text-sm text-hunt-600 hover:text-hunt-700">Close</button
        >
      </div>
    </div>
  </div>

  <script type="module">
    import { initToolPageInteractions } from '@/lib/client/tool-page-interactions';

    initToolPageInteractions();
  </script>
</BaseLayout>
