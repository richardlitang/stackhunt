{
  "name": "stackhunt",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "codex:check": "npm run typecheck && npm run lint && npm run test",
    "codex:format": "npm run format",
    "codex:format:check": "npm run format:check",
    "codex:build": "npm run build",
    "codex:e2e": "node scripts/run-e2e.mjs tests/e2e/homepage.spec.ts tests/e2e/pricing.spec.ts tests/e2e/seo.spec.ts tests/e2e/visual.spec.ts tests/e2e/tool-pages.spec.ts",
    "codex:verify:content": "npm run qa:gates && npm run qa:rendered-tool-pages -- --sample=15",
    "codex:verify:links": "npm run verify-affiliates && npm run verify-corrections",
    "codex:preview:serve": "npm run preview -- --port 4321 --host 127.0.0.1",
    "codex:lhci": "node scripts/codex-lhci.mjs",
    "design:pass": "node scripts/design-pass.mjs",
    "mcp:stackhunt": "node tools/mcp-stackhunt/server.mjs",
    "hunt": "npx tsx scripts/hunter.ts",
    "hunt:batch": "npx tsx scripts/hunter.ts --queue batch --priority 5",
    "eval:capture": "npx tsx scripts/capture-eval-fixtures.ts",
    "eval:hunter": "npx tsx scripts/eval-hunter.ts",
    "constraints": "npx tsx scripts/extract-constraints.ts",
    "queue:worker": "npx tsx scripts/queue-worker.ts",
    "queue:defunct": "npx tsx scripts/defunct-worker.ts",
    "verify-corrections": "npx tsx scripts/verify-corrections.ts",
    "verify-affiliates": "npx tsx scripts/verify-affiliate-links.ts",
    "discover-topics": "npx tsx scripts/discover-topics.ts",
    "qa:gates": "node --import tsx scripts/report-draft-gate-reasons.ts",
    "qa:gates:published-drift": "node --import tsx scripts/report-draft-gate-reasons.ts --include-published --max-stale-draft-review=0",
    "qa:rendered-tool-pages": "node scripts/qa-rendered-tool-pages.mjs",
    "qa:smoke:live": "node scripts/smoke-live-tool-page.mjs",
    "qa:seo:sitemaps": "node scripts/check-sitemaps.mjs",
    "qa:tool-page-imports": "node scripts/check-tool-page-helper-imports.mjs",
    "qa:tool-page-call-shapes": "node scripts/check-tool-page-route-call-shapes.mjs",
    "qa:tool-page-tdz": "node scripts/check-tool-page-tdz-guards.mjs",
    "docs:tool-page-map": "node scripts/generate-tool-page-orchestration-map.mjs",
    "qa:tool-page-map": "node scripts/check-tool-page-orchestration-map.mjs",
    "qa:tool-page-barrel": "node scripts/check-tool-page-barrel-exports.mjs",
    "qa:rpc": "node scripts/check-rpc-signatures.mjs",
    "qa:prepush": "npm run qa:rpc && npm run qa:tool-page-imports && npm run qa:tool-page-call-shapes && npm run qa:tool-page-tdz && npm run qa:tool-page-map && npm run qa:tool-page-barrel && npm run format:check:changed && npm run lint:strict && npm run typecheck && npm run build && npm run qa:rendered-tool-pages -- --template-only --sample=15",
    "hooks:install": "node scripts/install-git-hooks.mjs",
    "prepare": "npm run hooks:install",
    "qa:content-policy": "node scripts/ci-content-policy-gates.mjs",
    "qa:autopilot": "npx tsx scripts/qa-autopilot.ts",
    "qa:autopilot:cron": "npm run qa:autopilot -- --recompute-limit=400 --gates-limit=80 --max-publish=10 --ideas-limit=12 --blocked-limit=8 --refresh-limit=12 --refresh-priority=90 --worker-batch=3",
    "qa:reconcile-votes": "npx tsx scripts/reconcile-vote-counts.ts",
    "qa:pricing-fallback": "npx tsx scripts/report-pricing-fallback.ts",
    "qa:taxonomy-drift": "npx tsx scripts/check-taxonomy-drift.ts",
    "qa:negative-signals": "node --import tsx scripts/report-negative-signal-coverage.ts",
    "qa:queue-pricing-fallback-rehunt": "npx tsx scripts/queue-pricing-fallback-rehunt.ts",
    "qa:queue-pricing-fallback-rehunt:apply": "npx tsx scripts/queue-pricing-fallback-rehunt.ts --apply",
    "qa:queue-blocked-rehunt": "npx tsx scripts/queue-blocked-rehunt.ts",
    "qa:backfill-source-types": "npx tsx scripts/backfill-review-source-types.ts",
    "qa:backfill-claim-metadata": "node scripts/backfill-claim-metadata.mjs",
    "qa:backfill-decision-intro": "node --import tsx scripts/backfill-decision-intro.ts",
    "qa:queue-volatile-refresh": "npx tsx scripts/queue-volatile-refresh.ts",
    "qa:recompute-quality": "node --import tsx scripts/recompute-quality-snapshots.ts",
    "qa:backfill-generation-quality-scores": "node --import tsx scripts/backfill-generation-quality-scores.ts",
    "qa:backfill-item-fact-packs": "npx tsx scripts/backfill-item-fact-packs.ts",
    "qa:diff-runtime-snapshot": "npx tsx scripts/diff-runtime-vs-snapshot.ts",
    "qa:diff-compare-snapshot": "npx tsx scripts/diff-compare-runtime-vs-snapshot.ts",
    "qa:compile-shadow-snapshots": "npx tsx scripts/compile-shadow-snapshots.ts",
    "qa:publish-shadow-snapshots": "npx tsx scripts/publish-shadow-snapshots.ts",
    "import-ideas": "npx tsx scripts/import-content-ideas.ts",
    "queue-ideas": "npx tsx scripts/queue-content-ideas.ts",
    "regenerate-embeddings": "npx tsx scripts/regenerate-embeddings.ts",
    "pricing:backfill": "npx tsx scripts/pricing-backfill.ts",
    "subcategory:backfill": "npx tsx scripts/backfill-subcategory.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "types:db": "supabase gen types typescript --project-id vhelpqzbtzwiddoebnyy > src/types/supabase.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:strict": "eslint src --max-warnings=0",
    "lint:changed": "node scripts/check-lint-changed.mjs",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json}\"",
    "format:check:changed": "node scripts/check-format-changed.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^6.0.0",
    "@astrojs/vercel": "^8.0.0",
    "@google/genai": "^1.39.0",
    "@iconify-json/lucide": "^1.2.87",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@supabase/supabase-js": "^2.45.0",
    "astro": "^5.0.0",
    "astro-icon": "^1.1.5",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-lite-youtube-embed": "^3.3.3",
    "recharts": "^3.7.0",
    "replicate": "^1.4.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@lhci/cli": "^0.15.1",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "lighthouse": "^13.0.3",
    "postcss": "^8.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "supabase": "^1.200.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16",
    "wait-on": "^9.0.4"
  }
}
