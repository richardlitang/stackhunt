{
  "name": "stackhunt",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "hunt": "npx tsx scripts/hunter.ts",
    "hunt:batch": "npx tsx scripts/hunter.ts --queue batch --priority 5",
    "constraints": "npx tsx scripts/extract-constraints.ts",
    "queue:worker": "npx tsx scripts/queue-worker.ts",
    "verify-corrections": "npx tsx scripts/verify-corrections.ts",
    "verify-affiliates": "npx tsx scripts/verify-affiliate-links.ts",
    "discover-topics": "npx tsx scripts/discover-topics.ts",
    "import-ideas": "npx tsx scripts/import-content-ideas.ts",
    "queue-ideas": "npx tsx scripts/queue-content-ideas.ts",
    "regenerate-embeddings": "npx tsx scripts/regenerate-embeddings.ts",
    "pricing:backfill": "npx tsx scripts/pricing-backfill.ts",
    "subcategory:backfill": "npx tsx scripts/backfill-subcategory.ts",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,astro,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,astro,css,json}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^6.0.0",
    "@astrojs/vercel": "^8.0.0",
    "@google/generative-ai": "^0.21.0",
    "@iconify-json/lucide": "^1.2.87",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@supabase/supabase-js": "^2.45.0",
    "astro": "^5.0.0",
    "astro-icon": "^1.1.5",
    "axios": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.2.3",
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-lite-youtube-embed": "^3.3.3",
    "recharts": "^3.7.0",
    "replicate": "^1.4.0",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.1",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "@vitest/coverage-v8": "^4.0.16",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.5.0",
    "postcss": "^8.4.0",
    "prettier": "^3.7.4",
    "prettier-plugin-astro": "^0.14.1",
    "supabase": "^1.200.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.16"
  }
}
