# ============================================================================
# STACKHUNT ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================================================

# ----------------------------------------------------------------------------
# SUPABASE (Required)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# ----------------------------------------------------------------------------
SUPABASE_URL=
PUBLIC_SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------------------------------
# AI / SEARCH (Required for Hunter Agent)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=
SERPER_API_KEY=

# ----------------------------------------------------------------------------
# CLOUDFLARE TURNSTILE (Required for voting)
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# ----------------------------------------------------------------------------
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ----------------------------------------------------------------------------
# ADMIN / SECURITY
# ----------------------------------------------------------------------------
ADMIN_PASSWORD=change-me-to-something-secure
SESSION_SECRET=
IP_HASH_SALT=

# ----------------------------------------------------------------------------
# OG IMAGES (Optional)
# Get from: https://replicate.com/account/api-tokens
# ----------------------------------------------------------------------------
REPLICATE_API_TOKEN=

# ----------------------------------------------------------------------------
# CRON (Optional - for Editorial Brain)
# ----------------------------------------------------------------------------
CRON_SECRET=

# ----------------------------------------------------------------------------
# LOGOS (Optional - for high-quality logo fetching)
# Get from: https://brandfetch.com/api (Free tier, no attribution required)
# ----------------------------------------------------------------------------
PUBLIC_BRANDFETCH_CLIENT_ID=

# ----------------------------------------------------------------------------
# SITE
# ----------------------------------------------------------------------------
PUBLIC_SITE_URL=https://stackhunt.com
